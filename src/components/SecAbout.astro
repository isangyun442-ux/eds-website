---
// src/components/SecAbout.astro
---
<section class="sec s2" id="sec2">

  <!-- 모바일 전용 언어 버튼 -->
  <div class="ab-lang-bar">
    <button class="ab-lang-btn" data-lang="ko" onclick="__applyLang('ko')">KO</button>
    <button class="ab-lang-btn" data-lang="en" onclick="__applyLang('en')">EN</button>
    <button class="ab-lang-btn" data-lang="zh" onclick="__applyLang('zh')">ZH</button>
    <button class="ab-lang-btn" data-lang="ja" onclick="__applyLang('ja')">JA</button>
  </div>

  <div class="ab-wrap">

    <!-- 왼쪽: 브랜드 컬러 -->
    <div class="ab-left fade-up">
      <!-- 장식 SVG -->
      <div class="ab-left-content">
        <p class="ab-label" data-i18n="about.eyebrow1">ABOUT US</p>
        <h2 class="ab-title" data-i18n-html="about.title1">"1만 시간의<br>법칙"</h2>
        <p class="ab-body" data-i18n-html="about.body1">
          어떤 분야에서 전문성을 갖기 위해 투자해야 하는 시간을 의미합니다. 1993년 앤더스 에릭슨이 연구한 내용을 바탕으로 베스트셀러 작가 말콤 글래드웰이 <em>《아웃라이어, 성공의 기회를 발견한 사람들, 2009》</em>에서 이 에릭슨의 주장을 간단하게 <strong>"1만 시간을 연습하면 전문가가 된다"</strong>는 이론으로 설명했습니다.
        </p>
        <p class="ab-body">
          아웃라이어에서는 빌 게이츠와 비틀즈를 예로 제시했지만, 비단 그들만이 아니라 각자의 분야에서 명성을 떨치는 사람들은 대부분 이 법칙에 따라 자신의 능력을 증진시키고 한계를 극복하며 스스로 발전시키고 있는 것입니다.
        </p>
      </div>
    </div>

    <!-- 오른쪽: 다크 배경 -->
    <div class="ab-right fade-up fade-up-d2">
      <!-- 장식 SVG -->
      <div class="ab-right-content">
        <p class="ab-label" data-i18n="about.eyebrow2">PROFESSIONAL GROUP</p>
        <h2 class="ab-title" data-i18n-html="about.title2">전문가 집단<br><em class="ab-em">이담에스티</em></h2>
        <p class="ab-body" data-i18n-html="about.body2a">
          이담에스티는 방송기술, 컴퓨터그래픽, 오디오, IT 분야의 <strong>20년 이상의 외길</strong>을 다져온 전문가들로 구성된 회사입니다. 미디어 기술은 컴퓨터와 IT분야의 빠른 성장을 바탕으로 HDTV, 3DTV, AR/VR을 거쳐 Metaverse와 홀로그램으로 빠르게 변화하고 있습니다.
        </p>
        <p class="ab-body" data-i18n-html="about.body2b">
          우리 회사는 <strong>모두 엔지니어로 구성</strong>되어 있으며 매월 자체 사내 세미나 개최와 기술습득에 필요한 요소들을 지원함으로써 트렌드에 뒤쳐지지 않습니다.
        </p>
        <p class="ab-body" data-i18n-html="about.body3">
          이러한 준비된 기술 서비스를 바탕으로 중앙정부, 지자체, 공기업을 포함한 <strong>91개 관공서·공공기관</strong>, <strong>115개 교육기관</strong>, 방송국, 종교단체, 병원, 기업 등 <strong>516개</strong> 수많은 국내고객과 해외의 미디어 시스템 고객은 상호 소개와 재구매를 통하여 이담에스티의 서비스를 검증받았습니다.
        </p>
        <p class="ab-body" data-i18n-html="about.msg">
          이담에스티는 다양한 미디어 시스템 구축 노하우와 끊임없는 사내 연구와 대외 기술 습득 활동을 통해 트렌디한 구축 서비스를 제공하겠습니다.
        </p>
        <p class="ab-sig" data-i18n="about.sign">임직원 일동</p>
      </div>
    </div>

  </div>
</section>

<style>
  .s2 { background: url('/images/about-bg.png') center center / cover no-repeat; }

  /* ── 전체 레이아웃 ── */
  .ab-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 700px;
  }

  /* ── 장식 SVG ── */

  /* ── 왼쪽 (브랜드 블루) ── */
  .ab-left {
    position: relative;
    background: linear-gradient(135deg, #2a45c8 0%, #1a2f8a 60%, #0f1f6a 100%);
    overflow: hidden;
  }
  .ab-left-content {
    position: relative; z-index: 2;
    padding: 100px 72px;
    display: flex; flex-direction: column; justify-content: center;
    height: 100%;
  }

  /* ── 오른쪽 (다크 차콜) ── */
  .ab-right {
    position: relative;
    background: linear-gradient(135deg, #1a1f2e 0%, #141828 60%, #0e1220 100%);
    overflow: hidden;
  }
  .ab-right-content {
    position: relative; z-index: 2;
    padding: 100px 72px;
    display: flex; flex-direction: column; justify-content: center;
    height: 100%;
  }

  /* ── 라벨 ── */
  .ab-label {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.22em; color: rgba(255,255,255,0.45);
    margin-bottom: 20px;
  }

  /* ── 제목 ── */
  .ab-title {
    font-size: clamp(30px, 3vw, 48px); font-weight: 900;
    letter-spacing: -0.03em; line-height: 1.15;
    color: #fff; margin-bottom: 40px;
  }
  .ab-em { font-style: normal; color: rgba(255,255,255,0.65); }

  /* ── 본문 ── */
  .ab-body {
    font-size: 15px; line-height: 2.0;
    color: rgba(255,255,255,0.65);
    margin-bottom: 20px;
  }
  .ab-body em { font-style: italic; color: rgba(255,255,255,0.5); }
  .ab-body strong { color: #fff; font-weight: 700; }

  /* ── 임직원 일동 ── */
  .ab-sig {
    font-size: 13px; color: rgba(255,255,255,0.3);
    margin-top: 12px;
  }

  /* ── 반응형 ── */
  @media (max-width: 960px) {
    .ab-wrap { grid-template-columns: 1fr; }
    .ab-left-content, .ab-right-content { padding: 72px 48px; }
  }
  @media (max-width: 480px) {
    .ab-left-content, .ab-right-content { padding: 56px 28px; }
    .ab-title { margin-bottom: 28px; }
  }

  /* 모바일 언어 버튼 */
  .ab-lang-bar { display: none; }
  @media (max-width: 768px) {
    .ab-lang-bar {
      display: flex; gap: 6px; padding: 14px 24px;
      justify-content: flex-end; border-bottom: 1px solid rgba(255,255,255,0.1);
      background: #1a2f8a;
    }
    .ab-lang-btn {
      font-size: 11px; font-weight: 700; padding: 5px 10px;
      background: transparent; border: 1px solid rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.5); cursor: pointer; letter-spacing: 0.06em;
      font-family: inherit; transition: all 0.2s;
    }
    .ab-lang-btn:hover { border-color: #fff; color: #fff; }
    .ab-lang-btn.active { border-color: #fff; color: #fff; background: rgba(255,255,255,0.1); }
  }
</style>

<script is:inline>
(function() {
  const btns = document.querySelectorAll('.ab-lang-btn');
  const curLang = localStorage.getItem('eds-lang') || 'ko';
  btns.forEach(function(btn) {
    btn.classList.toggle('active', btn.getAttribute('data-lang') === curLang);
    btn.addEventListener('click', function() {
      btns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
    });
  });
})();
</script>

<!-- KV 스타일 & 텍스트 로더 -->
<script is:inline>
(function(){
  fetch('/api/admin/design-styles?section=about')
    .then(function(r){return r.ok?r.json():null;})
    .then(function(data){
      if(!data) return;
      var s = data.styles || {};
      var t = data.texts || {};
      var sec = document.getElementById('sec2');
      if(!sec) return;

      // 스타일 주입
      var st = document.getElementById('__about_dynamic_styles__');
      if(!st){st=document.createElement('style');st.id='__about_dynamic_styles__';document.head.appendChild(st);}
      st.textContent = [
        s.leftBg1&&s.leftBg2 ? '#sec2 .ab-left{background:linear-gradient(135deg,'+s.leftBg1+' 0%,'+s.leftBg2+' 100%)!important;}' : '',
        s.rightBg1&&s.rightBg2 ? '#sec2 .ab-right{background:linear-gradient(135deg,'+s.rightBg1+' 0%,'+s.rightBg2+' 100%)!important;}' : '',
        s.titleColor ? '#sec2 .ab-title{color:'+s.titleColor+';}' : '',
        s.titleSize ? '#sec2 .ab-title{font-size:'+s.titleSize+'px;}' : '',
        s.letterSpacing ? '#sec2 .ab-title{letter-spacing:'+s.letterSpacing+'em;}' : '',
        s.bodyColor ? '#sec2 .ab-body{color:'+s.bodyColor+';}' : '',
        s.bodySize ? '#sec2 .ab-body{font-size:'+s.bodySize+'px;}' : '',
        s.lineHeight ? '#sec2 .ab-body{line-height:'+s.lineHeight+';}' : '',
        s.accentColor ? '#sec2 .ab-body strong{color:'+s.accentColor+';}' : '',
        s.padding ? '#sec2 .ab-left-content,#sec2 .ab-right-content{padding:'+s.padding+'px!important;}' : '',
        s.minHeight ? '#sec2 .ab-wrap{min-height:'+s.minHeight+'px!important;}' : '',
        s.fontFamily ? '#sec2 .ab-title,#sec2 .ab-body,#sec2 .ab-label{font-family:'+s.fontFamily+';}' : '',
      ].join('');

      // 텍스트 복원 - 에디터 잔재 제거 후 적용
      function cleanHtml(html){
        var tmp=document.createElement('div');
        tmp.innerHTML=html;
        // contentEditable, eds-e 클래스, outline 스타일 제거
        tmp.querySelectorAll('[contenteditable]').forEach(function(el){
          el.removeAttribute('contenteditable');
          el.classList.remove('eds-e');
          if(!el.getAttribute('class'))el.removeAttribute('class');
        });
        tmp.querySelectorAll('[style*="outline"]').forEach(function(el){
          el.style.outline='';
          if(!el.getAttribute('style'))el.removeAttribute('style');
        });
        // 툴바 제거
        var tb=tmp.querySelector('#__tb__');
        if(tb)tb.remove();
        return tmp.innerHTML;
      }
      if(t.leftContent){
        var lc=sec.querySelector('.ab-left-content');
        if(lc) lc.innerHTML=cleanHtml(t.leftContent);
      }
      if(t.rightContent){
        var rc=sec.querySelector('.ab-right-content');
        if(rc) rc.innerHTML=cleanHtml(t.rightContent);
      }

      // KV 로드 완료 후 원본 저장 (다국어 복원용)
      if(window.saveOriginals) window.saveOriginals();

    }).catch(function(){});
})();
</script>
