---
// src/components/SecServices.astro
---
<section class="sec s3" id="sec3">
  <div class="svc-inner">

    <!-- 헤더 -->
    <div class="svc-header">
      <span class="svc-eyebrow fade-up" data-i18n="svc.eyebrow">Business Field</span>
      <h2 class="svc-title fade-up fade-up-d1">사업 분야</h2>
      <p class="svc-subtitle fade-up fade-up-d2" data-i18n="svc.subtitle">19년의 현장 경험으로 완성된 솔루션 — 설계부터 구축, 유지보수까지 책임집니다</p>
    </div>

    <!-- 탭 버튼 -->
    <div class="svc-tabs fade-up fade-up-d3">
      <button class="svc-tab active" data-idx="0">
        <span class="svc-tab-num">01</span>
        <span class="svc-tab-name">공공기관</span>
      </button>
      <button class="svc-tab" data-idx="1">
        <span class="svc-tab-num">02</span>
        <span class="svc-tab-name">교육기관</span>
      </button>
      <button class="svc-tab" data-idx="2">
        <span class="svc-tab-num">03</span>
        <span class="svc-tab-name">기업</span>
      </button>
      <button class="svc-tab" data-idx="3">
        <span class="svc-tab-num">04</span>
        <span class="svc-tab-name">미디어센터</span>
      </button>
      <button class="svc-tab" data-idx="4">
        <span class="svc-tab-num">05</span>
        <span class="svc-tab-name">종교시설</span>
      </button>
    </div>

    <!-- 패널 -->
    <div class="svc-panels-wrap fade-up fade-up-d3">
      <button class="svc-arrow svc-arrow--l" id="svcPrev" aria-label="이전">&#8249;</button>
      <div class="svc-panels">

      <div class="svc-panel active" data-idx="0">
        <div class="svc-panel-img" style="background-image:url('/images/services/public.jpg')">
          <div class="svc-panel-ov"></div>
        </div>
        <div class="svc-panel-text">
          <span class="svc-tag">Public Institution</span>
          <h3 class="svc-name">공공기관</h3>
          <p class="svc-desc">방송제작, 디지털미디어, 아카이브, 장애인방송 시스템 구축 경험을 바탕으로 공공기관에 최적화된 솔루션을 제공합니다. 안정적인 콘텐츠 제작 기반 마련을 위한 미디어 스토리지, 비디오 서버, 미디어관리시스템을 구축합니다.</p>
          <div class="svc-chips">
            <span class="svc-chip">방송 SI</span>
            <span class="svc-chip">아카이브 시스템</span>
            <span class="svc-chip">장애인방송</span>
            <span class="svc-chip">MAM 자산관리</span>
            <span class="svc-chip">화상회의 시스템</span>
          </div>
        </div>
      </div>

      <div class="svc-panel" data-idx="1">
        <div class="svc-panel-img" style="background-image:url('/images/services/education.jpg')">
          <div class="svc-panel-ov"></div>
        </div>
        <div class="svc-panel-text">
          <span class="svc-tag">Education</span>
          <h3 class="svc-name">교육기관</h3>
          <p class="svc-desc">사이버대학교부터 초·중·고등학교까지 목적에 맞는 최적의 교육 환경을 설계합니다. 이러닝 스튜디오, 스마트 강의실, LED 디스플레이를 통해 온·오프라인 교육 모두를 아우릅니다.</p>
          <div class="svc-chips">
            <span class="svc-chip">이러닝 스튜디오</span>
            <span class="svc-chip">스마트 강의실</span>
            <span class="svc-chip">하이브리드 수업</span>
            <span class="svc-chip">인터랙티브 디스플레이</span>
            <span class="svc-chip">LED 디스플레이</span>
          </div>
        </div>
      </div>

      <div class="svc-panel" data-idx="2">
        <div class="svc-panel-img" style="background-image:url('/images/services/enterprise.jpg')">
          <div class="svc-panel-ov"></div>
        </div>
        <div class="svc-panel-text">
          <span class="svc-tag">Enterprise</span>
          <h3 class="svc-name">기업</h3>
          <p class="svc-desc">기업 유튜브 채널, 사내 방송, 화상회의 시스템 구축까지 다양한 기업 미디어 환경을 지원합니다. Zoom, Teams, Webex 등 주요 플랫폼과 완벽 호환되는 스마트 오피스 환경을 완성합니다.</p>
          <div class="svc-chips">
            <span class="svc-chip">유튜브 스튜디오</span>
            <span class="svc-chip">화상회의 시스템</span>
            <span class="svc-chip">사내방송</span>
            <span class="svc-chip">Zoom·Teams 통합</span>
            <span class="svc-chip">스마트 오피스</span>
          </div>
        </div>
      </div>

      <div class="svc-panel" data-idx="3">
        <div class="svc-panel-img" style="background-image:url('/images/services/media.jpg')">
          <div class="svc-panel-ov"></div>
        </div>
        <div class="svc-panel-text">
          <span class="svc-tag">Media Center</span>
          <h3 class="svc-name">미디어센터</h3>
          <p class="svc-desc">P1.5 초고해상도 LED Wall부터 실내외 대형 전광판, XR 가상 스튜디오까지 전문 미디어센터에 필요한 모든 솔루션을 구축합니다. 미디어 서버 연동으로 최고의 영상 환경을 완성합니다.</p>
          <div class="svc-chips">
            <span class="svc-chip">LED Wall</span>
            <span class="svc-chip">XR 가상 스튜디오</span>
            <span class="svc-chip">미디어서버</span>
            <span class="svc-chip">전광판</span>
            <span class="svc-chip">미디어 아카이브</span>
          </div>
        </div>
      </div>

      <div class="svc-panel" data-idx="4">
        <div class="svc-panel-img" style="background-image:url('/images/services/religion.jpg')">
          <div class="svc-panel-ov"></div>
        </div>
        <div class="svc-panel-text">
          <span class="svc-tag">Religious Facility</span>
          <h3 class="svc-name">종교시설</h3>
          <p class="svc-desc">교회, 성당, 사찰 등 종교 시설에 특화된 음향·영상·조명 통합 시스템을 구축합니다. 예배·법회 영상 송출, LED 전광판, 온라인 스트리밍까지 종교 공간에 최적화된 솔루션을 제공합니다.</p>
          <div class="svc-chips">
            <span class="svc-chip">음향·영상 통합</span>
            <span class="svc-chip">예배 영상 송출</span>
            <span class="svc-chip">온라인 스트리밍</span>
            <span class="svc-chip">LED 전광판</span>
            <span class="svc-chip">조명 시스템</span>
          </div>
        </div>
      </div>

      </div>
      <button class="svc-arrow svc-arrow--r" id="svcNext" aria-label="다음">&#8250;</button>
    </div>
  </div>
</section>

<style>
  /* 섹션 배경 — 더 깊은 그라디언트 */
  .s3 {
    background:
      linear-gradient(180deg, #c8d8f4 0%, #dce8fb 30%, #eef3fc 65%, #f8faff 100%);
  }
  .svc-inner { max-width: 1300px; margin: 0 auto; padding: 100px 60px; }

  /* 헤더 */
  .svc-header { text-align: center; margin-bottom: 48px; }
  .svc-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.24em;
    text-transform: uppercase; color: #1a2f8a; margin-bottom: 20px;
  }
  .svc-eyebrow::before, .svc-eyebrow::after { content: ''; display: block; width: 20px; height: 2px; background: #1a2f8a; }
  .svc-title { font-size: clamp(28px, 3.5vw, 48px); font-weight: 900; letter-spacing: -0.04em; color: #0d1a3a; margin-bottom: 14px; }
  .svc-title em { font-style: normal; color: #1a2f8a; }
  .svc-subtitle { font-size: 15px; color: #6b7a8d; line-height: 1.8; }

  /* 탭 — 입체감 강화 */
  .svc-tabs {
    display: flex; gap: 0;
    border-bottom: 2px solid rgba(26,47,138,0.15);
    margin-bottom: 0;
    overflow-x: auto;
    scrollbar-width: none;
    background: rgba(255,255,255,0.5);
    border-radius: 12px 12px 0 0;
    padding: 0 4px;
    backdrop-filter: blur(8px);
  }
  .svc-tabs::-webkit-scrollbar { display: none; }
  .svc-tab {
    display: flex; align-items: center; gap: 8px;
    padding: 18px 28px; background: none; border: none;
    cursor: pointer; font-family: inherit;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: color 0.25s, border-color 0.25s, background 0.25s, transform 0.2s, box-shadow 0.2s;
    white-space: nowrap; flex-shrink: 0;
    border-radius: 10px 10px 0 0;
    position: relative;
  }
  .svc-tab:hover {
    background: rgba(255,255,255,0.85);
    transform: translateY(-2px);
  }
  .svc-tab.active {
    border-bottom-color: #1a2f8a;
    background: rgba(255,255,255,0.98);
    transform: translateY(-3px);
    box-shadow: 0 -4px 16px rgba(26,47,138,0.10), 0 -1px 0 rgba(26,47,138,0.06);
  }
  .svc-tab-num { font-size: 10px; font-weight: 700; color: #ccc; letter-spacing: 0.1em; transition: color 0.2s; }
  .svc-tab:hover .svc-tab-num { color: #8898cc; }
  .svc-tab.active .svc-tab-num { color: #1a2f8a; }
  .svc-tab-name { font-size: 15px; font-weight: 700; color: #aaa; transition: color 0.2s; }
  .svc-tab:hover .svc-tab-name { color: #334; }
  .svc-tab.active .svc-tab-name { color: #0d1a3a; }

  /* 패널 래퍼 — 입체 카드 */
  .svc-panels-wrap { position: relative; }
  .svc-panels {
    width: 100%;
    border: 1px solid rgba(26,47,138,0.13);
    border-top: none;
    border-radius: 0 0 20px 20px;
    overflow: hidden;
    /* 다층 그림자로 깊이감 */
    box-shadow:
      0 2px 0 rgba(255,255,255,0.9) inset,
      0 4px 24px rgba(26,47,138,0.08),
      0 16px 60px rgba(26,47,138,0.10),
      0 40px 100px rgba(26,47,138,0.07);
  }
  .svc-panel { display: none; grid-template-columns: 1.15fr 1fr; align-items: stretch; }
  .svc-panel.active { display: grid; }

  /* 패널 이미지 — 더 강한 오버레이 + 엣지 */
  .svc-panel-img {
    background-size: cover; background-position: center;
    width: 100%; height: 100%; min-height: 480px; position: relative;
    transition: transform 0.6s cubic-bezier(.22,.61,.36,1);
  }
  .svc-panel.active .svc-panel-img { transform: scale(1); }
  .svc-panel-ov {
    position: absolute; inset: 0;
    background:
      linear-gradient(135deg, rgba(10,20,60,0.35) 0%, transparent 55%),
      linear-gradient(to right, rgba(10,20,50,0.15) 0%, transparent 40%);
  }
  /* 이미지 우측 엣지 하이라이트 (빛 반사) */
  .svc-panel-img::after {
    content: '';
    position: absolute; top: 0; right: 0; bottom: 0; width: 3px;
    background: linear-gradient(180deg, rgba(255,255,255,0.35) 0%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.25) 100%);
  }

  /* 패널 텍스트 — 유리 느낌 */
  .svc-panel-text {
    padding: 52px 52px;
    display: flex; flex-direction: column; justify-content: center;
    background:
      linear-gradient(160deg, rgba(255,255,255,0.99) 0%, rgba(245,249,255,0.97) 100%);
    border-left: 1px solid rgba(255,255,255,0.9);
    position: relative;
  }
  /* 텍스트 패널 상단 엣지 하이라이트 */
  .svc-panel-text::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, rgba(26,47,138,0.0) 0%, rgba(26,47,138,0.12) 40%, rgba(255,255,255,0.0) 100%);
  }
  /* 우측 상단 장식 */
  .svc-panel-text::after {
    content: '';
    position: absolute; top: 24px; right: 24px;
    width: 48px; height: 48px;
    border-top: 2px solid rgba(26,47,138,0.12);
    border-right: 2px solid rgba(26,47,138,0.12);
  }

  .svc-tag {
    font-size: 10px; font-weight: 700; letter-spacing: 0.22em;
    text-transform: uppercase; color: #1a2f8a; margin-bottom: 14px;
    display: flex; align-items: center; gap: 8px;
  }
  .svc-tag::before { content: ''; width: 24px; height: 2px; background: linear-gradient(90deg,#1a2f8a,#4a6fd8); display: block; }

  .svc-name {
    font-size: clamp(26px, 2.8vw, 42px); font-weight: 900;
    letter-spacing: -0.04em; color: #0d1a3a;
    margin-bottom: 20px; line-height: 1.15;
    text-shadow: 0 2px 12px rgba(26,47,138,0.07);
  }
  .svc-desc { font-size: 14px; color: #556; line-height: 2.05; margin-bottom: 32px; }

  /* 칩 태그 — 입체감 */
  .svc-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  :global(.svc-chip) {
    font-size: 11px; font-weight: 600; padding: 6px 16px;
    border: 1px solid rgba(26,47,138,0.18);
    color: #445;
    background: linear-gradient(145deg, #ffffff 0%, #f0f4fc 100%);
    border-radius: 6px;
    box-shadow: 0 2px 6px rgba(26,47,138,0.07), 0 1px 0 rgba(255,255,255,0.9) inset;
    transition: all 0.22s cubic-bezier(.22,.61,.36,1);
    cursor: default;
  }
  :global(.svc-chip:hover) {
    border-color: #1a2f8a;
    color: #1a2f8a;
    background: linear-gradient(145deg, #eef3ff 0%, #dce8ff 100%);
    box-shadow: 0 4px 12px rgba(26,47,138,0.14), 0 1px 0 rgba(255,255,255,0.9) inset;
    transform: translateY(-2px);
  }

  /* 화살표 */
  .svc-inner { position: relative; }
  .svc-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 44px; height: 96px;
    background: rgba(255,255,255,0.75);
    border: 1px solid rgba(26,47,138,0.12);
    cursor: pointer; z-index: 10;
    font-size: 32px; color: #1a2f8a;
    display: flex; align-items: center; justify-content: center;
    backdrop-filter: blur(10px);
    transition: background 0.2s, opacity 0.2s, transform 0.2s, box-shadow 0.2s;
    border-radius: 8px;
    opacity: 0.7;
    box-shadow: 0 4px 16px rgba(26,47,138,0.10);
  }
  .svc-arrow:hover {
    background: rgba(255,255,255,0.97);
    opacity: 1;
    box-shadow: 0 8px 28px rgba(26,47,138,0.16);
    transform: translateY(calc(-50% - 2px));
  }
  .svc-arrow:disabled { opacity: 0.15; cursor: default; }
  .svc-arrow--l { left: -60px; }
  .svc-arrow--r { right: -60px; }

  /* 반응형 */
  @media (max-width: 900px) {
    .svc-inner { padding: 72px 32px; }
    .svc-panel { grid-template-columns: 1fr; }
    .svc-panel-img { min-height: 240px; aspect-ratio: 16/9; height: auto; }
    .svc-panel-text { padding: 36px 28px; }
    .svc-tab { padding: 12px 18px; }
    .svc-tab-num { display: none; }
  }
  @media (max-width: 480px) {
    .svc-inner { padding: 60px 20px; }
    .svc-tab-name { font-size: 13px; }
  }
</style>

<script is:inline>
(function () {
  const tabs   = document.querySelectorAll('.svc-tab');
  const panels = document.querySelectorAll('.svc-panel');
  let cur = 0;

  function go(idx) {
    cur = idx;
    tabs.forEach(function (el) { el.classList.remove('active'); });
    panels.forEach(function (el) { el.classList.remove('active'); });
    tabs[cur].classList.add('active');
    panels[cur].classList.add('active');
  }

  tabs.forEach(function (el) {
    el.addEventListener('click', function () { go(parseInt(el.dataset.idx)); });
  });

  const btnPrev = document.getElementById('svcPrev');
  const btnNext = document.getElementById('svcNext');
  if (btnPrev) btnPrev.addEventListener('click', function () { go((cur - 1 + tabs.length) % tabs.length); });
  if (btnNext) btnNext.addEventListener('click', function () { go((cur + 1) % tabs.length); });

  const targets = document.querySelectorAll('#sec3 .fade-up');
  const obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  targets.forEach(function (el) { obs.observe(el); });

  // KV 데이터로 텍스트/이미지만 교체 (HTML 구조 유지)
  fetch('/api/admin/design-styles?section=services')
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) {
      if (!data || !Array.isArray(data.tabs)) return;
      data.tabs.forEach(function (t, i) {
        // 탭 버튼 이름
        const tabNameEl = document.querySelector('.svc-tab[data-idx="' + i + '"] .svc-tab-name');
        if (tabNameEl) tabNameEl.textContent = t.name || '';

        // 패널 내용
        const panel = document.querySelector('.svc-panel[data-idx="' + i + '"]');
        if (!panel) return;

        const imgEl = panel.querySelector('.svc-panel-img');
        if (imgEl && t.img) imgEl.style.backgroundImage = "url('" + t.img + "')";

        const tagEl = panel.querySelector('.svc-tag');
        if (tagEl) tagEl.textContent = t.tag || '';

        const nameEl = panel.querySelector('.svc-name');
        if (nameEl) nameEl.textContent = t.title || '';

        const descEl = panel.querySelector('.svc-desc');
        if (descEl) descEl.textContent = t.desc || '';

        const chipsEl = panel.querySelector('.svc-chips');
        if (chipsEl && t.chips && t.chips.length > 0) {
          chipsEl.innerHTML = '';
          t.chips.forEach(function (c) {
            const span = document.createElement('span');
            span.className = 'svc-chip';
            span.textContent = c;
            chipsEl.appendChild(span);
          });
        }
      });
    })
    .catch(function () {});
})();
</script>
