---
// src/components/SecServices.astro
---
<section class="sec s3" id="sec3">
  <div class="svc-header">
    <div class="svc-header-left">
      <span class="sec-tag" data-i18n="svc.eyebrow">Services</span>
      <h2 class="sec-title" data-i18n="svc.title">서비스</h2>
    </div>
    <div class="svc-nav">
      <button class="svc-btn" id="svc-prev" aria-label="이전">←</button>
      <span class="svc-count"><span id="svc-cur">1</span> / <span id="svc-total">6</span></span>
      <button class="svc-btn" id="svc-next" aria-label="다음">→</button>
    </div>
  </div>

  <div class="svc-track-wrap">
    <div class="svc-track" id="svc-track">
      <div class="svc-card" onclick="openSvc(0)">
        <div class="svc-img" style="background-image:url('/images/KTV_BS_01.jpg')"></div>
        <div class="svc-body">
          <span class="svc-n">01</span>
          <h3 class="svc-title" data-i18n="svc.1.title">방송제작 스튜디오</h3>
          <p class="svc-desc" data-i18n="svc.1.desc">4K UHD 촬영부터 실시간 스트리밍까지</p>
          <span class="svc-link">자세히 보기 →</span>
        </div>
      </div>
      <div class="svc-card" onclick="openSvc(1)">
        <div class="svc-img" style="background-image:url('/images/SC_ST_09.jpg')"></div>
        <div class="svc-body">
          <span class="svc-n">02</span>
          <h3 class="svc-title" data-i18n="svc.2.title">이러닝 스튜디오</h3>
          <p class="svc-desc" data-i18n="svc.2.desc">자동 추적 카메라와 크로마키 환경</p>
          <span class="svc-link">자세히 보기 →</span>
        </div>
      </div>
      <div class="svc-card" onclick="openSvc(2)">
        <div class="svc-img" style="background-image:url('/images/GKDE_S_08.jpg')"></div>
        <div class="svc-body">
          <span class="svc-n">03</span>
          <h3 class="svc-title" data-i18n="svc.3.title">LED 디스플레이</h3>
          <p class="svc-desc" data-i18n="svc.3.desc">P1.5 피치 LED Wall XR 스튜디오</p>
          <span class="svc-link">자세히 보기 →</span>
        </div>
      </div>
      <div class="svc-card" onclick="openSvc(3)">
        <div class="svc-img" style="background-image:url('/images/GMC_S_01.jpg')"></div>
        <div class="svc-body">
          <span class="svc-n">04</span>
          <h3 class="svc-title" data-i18n="svc.4.title">스마트 강의실</h3>
          <p class="svc-desc" data-i18n="svc.4.desc">온·오프라인 동시 수업 환경 구현</p>
          <span class="svc-link">자세히 보기 →</span>
        </div>
      </div>
      <div class="svc-card" onclick="openSvc(4)">
        <div class="svc-img" style="background-image:url('/images/MG_DAS_02.jpg')"></div>
        <div class="svc-body">
          <span class="svc-n">05</span>
          <h3 class="svc-title" data-i18n="svc.5.title">아카이브 시스템</h3>
          <p class="svc-desc" data-i18n="svc.5.desc">영상 자산 디지털화 및 장기 보존</p>
          <span class="svc-link">자세히 보기 →</span>
        </div>
      </div>
      <div class="svc-card" onclick="openSvc(5)">
        <div class="svc-img" style="background-image:url('/images/HUFS_ST_04.jpg')"></div>
        <div class="svc-body">
          <span class="svc-n">06</span>
          <h3 class="svc-title" data-i18n="svc.6.title">화상회의 시스템</h3>
          <p class="svc-desc" data-i18n="svc.6.desc">Zoom·Teams 통합 원격 회의 환경</p>
          <span class="svc-link">자세히 보기 →</span>
        </div>
      </div>
    </div>
  </div>

  <!-- 진행 바 -->
  <div class="svc-progress-wrap">
    <div class="svc-progress-bar" id="svc-progress-bar"></div>
  </div>
</section>

<!-- 서비스 모달 -->
<div class="svc-modal-bg" id="svc-modal-bg">
  <div class="svc-modal">
    <div class="svc-modal-img" id="svc-modal-img"></div>
    <div class="svc-modal-body">
      <button class="svc-modal-close" onclick="closeSvc()">✕</button>
      <span class="svc-modal-n" id="svc-modal-n"></span>
      <h3 class="svc-modal-title" id="svc-modal-title"></h3>
      <p class="svc-modal-desc" id="svc-modal-desc"></p>
      <ul class="svc-modal-list" id="svc-modal-list"></ul>
      <button class="svc-modal-cta" data-i18n="svc.cta" onclick="goTo(7)">도입 문의하기 →</button>
    </div>
  </div>
</div>

<style>
  /* ── Section ── */
  .s3 {
    background: #F8F8F6;
    display: flex;
    flex-direction: column;
    padding: 80px 0 60px;
    overflow: hidden;
  }

  /* ── Header ── */
  .svc-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 0 56px 36px;
  }
  .sec-tag {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #00B8D9;
    display: block;
    margin-bottom: 8px;
  }
  .sec-title {
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #0A0A0A;
    line-height: 1;
  }

  /* ── Nav ── */
  .svc-nav {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-bottom: 4px;
  }
  .svc-btn {
    width: 40px;
    height: 40px;
    background: none;
    border: 1px solid #D0D0D0;
    cursor: pointer;
    font-size: 16px;
    color: #0A0A0A;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    font-family: inherit;
  }
  .svc-btn:hover { background: #0A0A0A; border-color: #0A0A0A; color: #fff; }
  .svc-btn:disabled { opacity: 0.25; cursor: default; }
  .svc-btn:disabled:hover { background: none; border-color: #D0D0D0; color: #0A0A0A; }
  .svc-count {
    font-size: 12px;
    font-weight: 500;
    color: #999;
    letter-spacing: 0.04em;
    min-width: 36px;
    text-align: center;
  }

  /* ── Track ── */
  .svc-track-wrap {
    overflow: hidden;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }
  .svc-track-wrap:active { cursor: grabbing; }
  .svc-track {
    display: flex;
    gap: 0;
    transition: transform 0.55s cubic-bezier(0.77, 0, 0.175, 1);
    will-change: transform;
  }

  /* ── Card ── */
  .svc-card {
    flex: 0 0 calc(100% / 3.2);
    min-width: 0;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    padding-left: 56px;
  }
  .svc-card:first-child { padding-left: 56px; }
  .svc-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
    overflow: hidden;
    position: relative;
    transition: opacity 0.3s;
  }
  .svc-card:hover .svc-img { opacity: 0.88; }
  .svc-body {
    padding: 22px 24px 22px 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .svc-n {
    font-size: 10px;
    font-weight: 700;
    color: #00B8D9;
    letter-spacing: 0.14em;
  }
  .svc-card .svc-title {
    font-size: 16px;
    font-weight: 700;
    color: #0A0A0A;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }
  .svc-desc {
    font-size: 12px;
    color: #888;
    line-height: 1.7;
  }
  .svc-link {
    font-size: 11px;
    font-weight: 600;
    color: #0A0A0A;
    letter-spacing: 0.04em;
    margin-top: 4px;
    transition: color 0.2s;
  }
  .svc-card:hover .svc-link { color: #00B8D9; }

  /* ── Progress ── */
  .svc-progress-wrap {
    margin: 32px 56px 0;
    height: 1px;
    background: #E0E0E0;
    position: relative;
  }
  .svc-progress-bar {
    position: absolute;
    left: 0;
    top: 0;
    height: 1px;
    background: #0A0A0A;
    transition: width 0.55s cubic-bezier(0.77, 0, 0.175, 1);
  }

  /* ── Modal ── */
  .svc-modal-bg {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 500;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }
  .svc-modal-bg.on { display: flex; }
  .svc-modal {
    background: #fff;
    width: 90%;
    max-width: 720px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-height: 90vh;
    overflow: hidden;
  }
  .svc-modal-img { background-size: cover; background-position: center; min-height: 340px; }
  .svc-modal-body {
    padding: 40px 32px 36px;
    position: relative;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .svc-modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 30px;
    height: 30px;
    background: none;
    border: 1px solid #E0E0E0;
    cursor: pointer;
    font-size: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: inherit;
    transition: background 0.2s, color 0.2s;
  }
  .svc-modal-close:hover { background: #0A0A0A; color: #fff; border-color: #0A0A0A; }
  .svc-modal-n { font-size: 10px; font-weight: 700; color: #00B8D9; letter-spacing: 0.16em; }
  .svc-modal-title {
    font-size: 22px;
    font-weight: 800;
    color: #0A0A0A;
    letter-spacing: -0.03em;
    padding-bottom: 14px;
    border-bottom: 1px solid #F0F0F0;
  }
  .svc-modal-desc { font-size: 13px; color: #666; line-height: 1.9; }
  .svc-modal-list { display: flex; flex-direction: column; gap: 8px; list-style: none; }
  .svc-modal-list li {
    font-size: 12px;
    color: #444;
    padding-left: 16px;
    position: relative;
    line-height: 1.65;
  }
  .svc-modal-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 4px;
    height: 4px;
    background: #00B8D9;
  }
  .svc-modal-cta {
    margin-top: auto;
    background: #0A0A0A;
    color: #fff;
    border: none;
    font-size: 12px;
    font-weight: 700;
    padding: 13px 24px;
    cursor: pointer;
    font-family: inherit;
    align-self: flex-start;
    letter-spacing: 0.04em;
    transition: background 0.2s;
  }
  .svc-modal-cta:hover { background: #00B8D9; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .svc-card { flex: 0 0 calc(100% / 2.2); }
  }
  @media (max-width: 768px) {
    .s3 { padding: 64px 0 48px; }
    .svc-header { padding: 0 28px 28px; }
    .svc-card { flex: 0 0 calc(100% / 1.15); padding-left: 28px; }
    .svc-progress-wrap { margin: 24px 28px 0; }
    .svc-modal { grid-template-columns: 1fr; }
    .svc-modal-img { min-height: 220px; }
  }
  @media (max-width: 480px) {
    .svc-card { flex: 0 0 85%; }
  }
</style>

<script is:inline>
const svcData = [
  { n:'01', title:'방송제작 스튜디오', img:'/images/KTV_BS_01.jpg',
    desc:'4K UHD 카메라, 스위처, 조명 시스템을 통합하여 전문 방송 제작 환경을 구축합니다. 실시간 스트리밍과 녹화를 동시에 지원합니다.',
    list:['4K UHD 다카메라 시스템','실시간 스트리밍 지원','자동화 조명 및 크로마키','프롬프터·부조정실 통합','OB차량 야외 촬영 지원'] },
  { n:'02', title:'이러닝 스튜디오', img:'/images/SC_ST_09.jpg',
    desc:'온라인 교육 콘텐츠 제작에 최적화된 이러닝 스튜디오를 구축합니다. 자동 추적 카메라와 전자칠판으로 고품질 강의를 제작합니다.',
    list:['자동 추적 PTZ 카메라','전자칠판·태블릿 연동','크로마키 배경 시스템','1인 셀프 스튜디오','LMS 자동 업로드'] },
  { n:'03', title:'LED 디스플레이', img:'/images/GKDE_S_08.jpg',
    desc:'P1.5~P4 피치 LED Wall을 활용한 XR 가상 스튜디오, 전시 공간, 강당 등 다양한 공간에 맞춤형 LED 디스플레이를 설치합니다.',
    list:['P1.5 초고해상도 LED Wall','XR 가상 스튜디오 배경','실내외 대형 전광판','미디어 서버 연동','공연장·전시관 맞춤 설계'] },
  { n:'04', title:'스마트 강의실', img:'/images/GMC_S_01.jpg',
    desc:'원터치로 온·오프라인 동시 수업이 가능한 스마트 강의실을 구축합니다. 하이브리드 교육 환경을 실현합니다.',
    list:['원터치 통합 제어 시스템','온·오프라인 동시 수업','전자칠판·인터랙티브 디스플레이','자동 추적 카메라','다중 강의실 연동'] },
  { n:'05', title:'아카이브 시스템', img:'/images/MG_DAS_02.jpg',
    desc:'방송 영상, 교육 콘텐츠, 기관 기록물 등을 장기 보존하고 효율적으로 관리할 수 있는 미디어 아카이브 시스템을 구축합니다.',
    list:['MAM 미디어 자산 관리','대용량 SAN·NAS 스토리지','자동 인제스트·메타데이터','검색·공유·스트리밍 통합','LTO 테이프 아카이브'] },
  { n:'06', title:'화상회의 시스템', img:'/images/HUFS_ST_04.jpg',
    desc:'Zoom, Teams, Webex 등 주요 플랫폼과 완벽 호환되는 화상회의 시스템을 구축합니다.',
    list:['Zoom·Teams·Webex 통합','자동 추적 카메라','에코 제거 마이크 어레이','대형 디스플레이 연동','다자간 화상회의실 구성'] }
];

/* ── Slider ── */
(function() {
  const track = document.getElementById('svc-track');
  const cards = track.querySelectorAll('.svc-card');
  const total = cards.length;
  const btnPrev = document.getElementById('svc-prev');
  const btnNext = document.getElementById('svc-next');
  const curEl = document.getElementById('svc-cur');
  const totalEl = document.getElementById('svc-total');
  const progressBar = document.getElementById('svc-progress-bar');
  totalEl.textContent = total;

  let cur = 0;
  let visibleCount = window.innerWidth <= 768 ? 1 : window.innerWidth <= 1024 ? 2 : 3;

  function getCardWidth() {
    return cards[0].getBoundingClientRect().width;
  }

  function update() {
    const w = getCardWidth();
    track.style.transform = 'translateX(-' + (cur * w) + 'px)';
    curEl.textContent = cur + 1;
    btnPrev.disabled = cur === 0;
    btnNext.disabled = cur >= total - visibleCount;
    progressBar.style.width = ((cur + visibleCount) / total * 100) + '%';
  }

  btnPrev.addEventListener('click', function() { if (cur > 0) { cur--; update(); } });
  btnNext.addEventListener('click', function() { if (cur < total - visibleCount) { cur++; update(); } });

  /* drag */
  let startX = 0, isDragging = false, prevented = false;
  track.addEventListener('mousedown', function(e) { startX = e.clientX; isDragging = true; prevented = false; });
  track.addEventListener('mousemove', function(e) {
    if (!isDragging) return;
    if (!prevented && Math.abs(e.clientX - startX) > 5) { prevented = true; }
  });
  track.addEventListener('mouseup', function(e) {
    if (!isDragging) return;
    isDragging = false;
    const dx = e.clientX - startX;
    if (dx < -40 && cur < total - visibleCount) { cur++; update(); }
    else if (dx > 40 && cur > 0) { cur--; update(); }
  });
  track.addEventListener('mouseleave', function() { isDragging = false; });

  /* touch */
  let tx = 0;
  track.addEventListener('touchstart', function(e) { tx = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', function(e) {
    const dx = e.changedTouches[0].clientX - tx;
    if (dx < -40 && cur < total - visibleCount) { cur++; update(); }
    else if (dx > 40 && cur > 0) { cur--; update(); }
  });

  window.addEventListener('resize', function() {
    visibleCount = window.innerWidth <= 768 ? 1 : window.innerWidth <= 1024 ? 2 : 3;
    if (cur > total - visibleCount) cur = total - visibleCount;
    update();
  });

  /* prevent card click on drag */
  track.querySelectorAll('.svc-card').forEach(function(card) {
    card.addEventListener('click', function(e) { if (prevented) { e.stopImmediatePropagation(); prevented = false; } });
  });

  update();
})();

/* ── Modal ── */
function openSvc(i) {
  const d = svcData[i];
  document.getElementById('svc-modal-n').textContent = d.n;
  document.getElementById('svc-modal-title').textContent = d.title;
  document.getElementById('svc-modal-desc').textContent = d.desc;
  document.getElementById('svc-modal-img').style.backgroundImage = "url('" + d.img + "')";
  document.getElementById('svc-modal-list').innerHTML = d.list.map(function(l) { return '<li>' + l + '</li>'; }).join('');
  document.getElementById('svc-modal-bg').classList.add('on');
  document.body.style.overflow = 'hidden';
}
function closeSvc() {
  document.getElementById('svc-modal-bg').classList.remove('on');
  document.body.style.overflow = '';
}
document.getElementById('svc-modal-bg').addEventListener('click', function(e) {
  if (e.target === this) closeSvc();
});
</script>
