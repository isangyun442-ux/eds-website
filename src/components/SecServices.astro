document.querySelectorAll('.svc-tabs').forEach(function(tabGroup) {
  const bi = parseInt(tabGroup.getAttribute('data-block'));
  const descEl = document.getElementById('svc-desc-' + bi);
  tabGroup.querySelectorAll('.svc-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      const ti = parseInt(tab.getAttribute('data-idx'));
      tabGroup.querySelectorAll('.svc-tab').forEach(function(t) { t.classList.remove('on'); });
      tab.classList.add('on');
      descEl.classList.add('fade');
      setTimeout(function() {
        descEl.textContent = svcTabData[bi][ti];
        descEl.classList.remove('fade');
      }, 220);
    });
  });
});
</script>
