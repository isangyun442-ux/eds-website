      <div class="brand fade-up fade-up-d3"><div class="bb" style="background:#00B8D9">AMX</div><p class="bl">AMX</p><p class="bc">Control</p></div>
      <div class="brand fade-up fade-up-d4"><div class="bb" style="background:#0D3A4A">Bos</div><p class="bl">Bose Pro</p><p class="bc">Speaker</p></div>
      <div class="brand fade-up fade-up-d1"><div class="bb" style="background:#1428A0">Sam</div><p class="bl">Samsung B2B</p><p class="bc">LED</p></div>
      <div class="brand fade-up fade-up-d2"><div class="bb" style="background:#A50034">LG</div><p class="bl">LG Business</p><p class="bc">OLED</p></div>
      <div class="brand fade-up fade-up-d3"><div class="bb" style="background:#007DC3">Ext</div><p class="bl">Extron</p><p class="bc">Signal</p></div>
      <div class="brand fade-up fade-up-d4"><div class="bb" style="background:#5C2D91">Mic</div><p class="bl">Microsoft</p><p class="bc">Teams</p></div>
    </div>
