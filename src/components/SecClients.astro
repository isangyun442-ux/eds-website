<style>
  .s6 { background: #fff; }
  .s6-inner { padding: 120px 80px 100px; max-width: 1200px; margin: 0 auto; }

  .sec-header { text-align: center; margin-bottom: 72px; }
  .sec-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.24em;
    text-transform: uppercase; color: #00B8D9; margin-bottom: 16px;
  }
  .sec-eyebrow::before, .sec-eyebrow::after {
    content: ''; display: block; width: 20px; height: 2px; background: #00B8D9;
  }
  .sec-title {
    font-size: clamp(28px, 3.2vw, 48px);
    font-weight: 800; letter-spacing: -0.04em;
    color: #0a0a0a; margin-bottom: 14px;
  }
  .sec-sub { font-size: 15px; color: #aaa; }
  .sec-sub strong { color: #D42B2B; font-weight: 700; }

  .stats-row {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 2px; background: #f0f0f0; margin-bottom: 0;
  }
  .stat { background: #fff; padding: 40px 36px 32px; }
  .stat-n {
    font-size: 52px; font-weight: 900;
    letter-spacing: -0.05em; color: #0a0a0a; line-height: 1;
  }
  .stat-n span { color: #00B8D9; font-size: 32px; }
  .stat-l { font-size: 12px; color: #bbb; margin-top: 10px; letter-spacing: 0.02em; }

  .mq-wrap {
    position: relative; overflow: hidden;
    border-top: 1px solid #f5f5f5; border-bottom: 1px solid #f5f5f5;
  }
  .mq-wrap::before, .mq-wrap::after {
    content: ''; position: absolute; top: 0; bottom: 0; width: 60px; z-index: 2; pointer-events: none;
  }
  .mq-wrap::before { left: 0; background: linear-gradient(90deg, #fff, transparent); }
  .mq-wrap::after  { right: 0; background: linear-gradient(-90deg, #fff, transparent); }
  .mq-track { display: flex; width: max-content; animation: mq 26s linear infinite; }
  @keyframes mq { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  .cli {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; width: 140px; height: 72px;
    border-right: 1px solid #f5f5f5; gap: 6px; padding: 0 18px; flex-shrink: 0;
  }
  .cli-bar { height: 3px; border-radius: 2px; }
  .cli span {
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
    color: #0D3A4A; opacity: 0.35; text-transform: uppercase;
  }

  .brands-div {
    display: flex; align-items: center; gap: 16px;
    padding: 28px 0 20px;
  }
  .brands-div::before, .brands-div::after { content: ''; flex: 1; height: 1px; background: #f0f0f0; }
  .brands-div span {
    font-size: 9px; font-weight: 700; letter-spacing: 0.2em;
    text-transform: uppercase; color: #bbb; white-space: nowrap;
  }

  .brands-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 1px; background: #f0f0f0; }
  .brand {
    background: #fff; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 24px 12px; gap: 8px; transition: background 0.2s;
  }
  .brand:hover { background: #FAFAFA; }
  .bb {
    width: 40px; height: 40px; display: flex; align-items: center;
    justify-content: center; font-size: 9px; font-weight: 800; color: #fff;
    clip-path: polygon(7px 0, 100% 0, calc(100% - 7px) 100%, 0 100%);
  }
  .bl {
    font-size: 9px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: #0D3A4A; opacity: 0.5; text-align: center;
  }
  .bc { font-size: 8px; letter-spacing: 0.06em; text-transform: uppercase; color: #bbb; text-align: center; }
  .brand:hover .bl { opacity: 1; }

  @media (max-width: 900px) {
    .s6-inner { padding: 80px 32px 80px; }
    .stats-row { grid-template-columns: 1fr 1fr; }
    .stat-n { font-size: 40px; }
    .brands-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 480px) {
    .s6-inner { padding: 60px 20px 60px; }
    .brands-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
