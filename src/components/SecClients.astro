---
<section class="sec s6" id="sec6">
  <div class="s6-scroll" id="s6scroll">
    <div class="s6-inner">
      <div class="sec-header" style="text-align:center;">
        <span class="sec-tag" style="text-align:center;">Clients & Partners</span>
        <h2 class="sec-title">신뢰받는 파트너십</h2>
      </div>
      <p class="s6-sub">국내 <strong>200+</strong> 기관·기업과 함께합니다</p>
      <div class="stats-row">
        <div class="stat"><p class="stat-n">200<span>+</span></p><p class="stat-l">구축 완료 공간</p></div>
        <div class="stat"><p class="stat-n">17<span>년</span></p><p class="stat-l">업력 및 전문성</p></div>
        <div class="stat"><p class="stat-n">98<span>%</span></p><p class="stat-l">고객 만족도</p></div>
        <div class="stat"><p class="stat-n">24<span>/7</span></p><p class="stat-l">기술 지원</p></div>
      </div>
      <div class="mq-wrap">
        <div class="mq-track">
          <div class="cli"><div class="cli-bar" style="background:#E11E3C;width:32px"></div><span>LG</span></div>
          <div class="cli"><div class="cli-bar" style="background:#006EFF;width:48px"></div><span>Hyundai</span></div>
          <div class="cli"><div class="cli-bar" style="background:#003087;width:36px"></div><span>KDB</span></div>
          <div class="cli"><div class="cli-bar" style="background:#E60012;width:32px"></div><span>KT</span></div>
          <div class="cli"><div class="cli-bar" style="background:#FF6600;width:28px"></div><span>SK</span></div>
          <div class="cli"><div class="cli-bar" style="background:#003DA5;width:44px"></div><span>Posco</span></div>
          <div class="cli"><div class="cli-bar" style="background:#D4002A;width:40px"></div><span>Lotte</span></div>
          <div class="cli"><div class="cli-bar" style="background:#0055A4;width:48px"></div><span>Hanwha</span></div>
          <div class="cli"><div class="cli-bar" style="background:#00854A;width:44px"></div><span>Naver</span></div>
          <div class="cli"><div class="cli-bar" style="background:#1428A0;width:48px"></div><span>Samsung</span></div>
          <div class="cli"><div class="cli-bar" style="background:#E11E3C;width:32px"></div><span>LG</span></div>
          <div class="cli"><div class="cli-bar" style="background:#006EFF;width:48px"></div><span>Hyundai</span></div>
          <div class="cli"><div class="cli-bar" style="background:#003087;width:36px"></div><span>KDB</span></div>
          <div class="cli"><div class="cli-bar" style="background:#E60012;width:32px"></div><span>KT</span></div>
          <div class="cli"><div class="cli-bar" style="background:#FF6600;width:28px"></div><span>SK</span></div>
          <div class="cli"><div class="cli-bar" style="background:#003DA5;width:44px"></div><span>Posco</span></div>
          <div class="cli"><div class="cli-bar" style="background:#D4002A;width:40px"></div><span>Lotte</span></div>
          <div class="cli"><div class="cli-bar" style="background:#0055A4;width:48px"></div><span>Hanwha</span></div>
          <div class="cli"><div class="cli-bar" style="background:#00854A;width:44px"></div><span>Naver</span></div>
          <div class="cli"><div class="cli-bar" style="background:#1428A0;width:48px"></div><span>Samsung</span></div>
        </div>
      </div>
      <div class="brands-div"><span>취급 브랜드 · Technology Partners</span></div>
      <div class="brands-grid">
        <div class="brand"><div class="bb" style="background:#E60012">Pan</div><p class="bl">Panasonic</p><p class="bc">Display · AV</p></div>
        <div class="brand"><div class="bb" style="background:#003087">Sony</div><p class="bl">Sony Pro</p><p class="bc">Camera</p></div>
        <div class="brand"><div class="bb" style="background:#0066CC">Cre</div><p class="bl">Crestron</p><p class="bc">Control</p></div>
        <div class="brand"><div class="bb" style="background:#FF6600">Poly</div><p class="bl">Poly</p><p class="bc">Video Conf.</p></div>
        <div class="brand"><div class="bb" style="background:#1A1A1A">Shu</div><p class="bl">Shure</p><p class="bc">Audio · Mic</p></div>
        <div class="brand"><div class="bb" style="background:#D42B2B">NEC</div><p class="bl">NEC Display</p><p class="bc">Large Format</p></div>
        <div class="brand"><div class="bb" style="background:#00B8D9">AMX</div><p class="bl">AMX</p><p class="bc">Control</p></div>
        <div class="brand"><div class="bb" style="background:#0D3A4A">Bos</div><p class="bl">Bose Pro</p><p class="bc">Speaker</p></div>
        <div class="brand"><div class="bb" style="background:#1428A0">Sam</div><p class="bl">Samsung B2B</p><p class="bc">LED</p></div>
        <div class="brand"><div class="bb" style="background:#A50034">LG</div><p class="bl">LG Business</p><p class="bc">OLED</p></div>
        <div class="brand"><div class="bb" style="background:#007DC3">Ext</div><p class="bl">Extron</p><p class="bc">Signal</p></div>
        <div class="brand"><div class="bb" style="background:#5C2D91">Mic</div><p class="bl">Microsoft</p><p class="bc">Teams</p></div>
      </div>
    </div>
  </div>
</section>

<style>
  .s6 { background: #fff; display: flex; flex-direction: column; }
  .s6-scroll { flex: 1; overflow-y: auto; overflow-x: hidden; scrollbar-width: none; min-height: 0; }
  .s6-scroll::-webkit-scrollbar { display: none; }
  .s6-inner { padding: 72px 48px 48px; }
  .s6-sub { font-size: 13px; color: #aaa; text-align: center; margin-bottom: 32px; }
  .s6-sub strong { color: #D42B2B; }
  .sec-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #bbb; display: block; margin-bottom: 5px; }
  .sec-title { font-size: clamp(24px,3.5vw,40px); font-weight: 800; letter-spacing: -0.03em; color: #0A0A0A; margin-bottom: 20px; }
  .stats-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 2px; background: #f0f0f0; margin-bottom: 0; }
  .stat { background: #fff; padding: 28px 28px 22px; }
  .stat-n { font-size: 44px; font-weight: 800; letter-spacing: -0.04em; color: #0A0A0A; line-height: 1; }
  .stat-n span { color: #00B8D9; font-size: 28px; }
  .stat-l { font-size: 11px; color: #aaa; margin-top: 6px; }
  .mq-wrap { position: relative; overflow: hidden; border-top: 1px solid #f5f5f5; border-bottom: 1px solid #f5f5f5; }
  .mq-wrap::before,.mq-wrap::after { content:''; position:absolute; top:0; bottom:0; width:52px; z-index:2; pointer-events:none; }
  .mq-wrap::before { left:0; background: linear-gradient(90deg,#fff,transparent); }
  .mq-wrap::after  { right:0; background: linear-gradient(-90deg,#fff,transparent); }
  .mq-track { display: flex; width: max-content; animation: mq 26s linear infinite; }
  @keyframes mq { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
  .cli { display:flex; flex-direction:column; align-items:center; justify-content:center; width:130px; height:68px; border-right:1px solid #f5f5f5; gap:5px; padding:0 16px; flex-shrink:0; }
  .cli-bar { height: 3px; border-radius: 2px; }
  .cli span { font-size:11px; font-weight:700; letter-spacing:0.06em; color:#0D3A4A; opacity:0.4; text-transform:uppercase; }
  .brands-div { display:flex; align-items:center; gap:14px; padding:18px 0 14px; }
  .brands-div::before,.brands-div::after { content:''; flex:1; height:1px; background:#f0f0f0; }
  .brands-div span { font-size:9px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#bbb; white-space:nowrap; }
  .brands-grid { display:grid; grid-template-columns:repeat(6,1fr); gap:1px; background:#f0f0f0; }
  .brand { background:#fff; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:18px 10px; gap:6px; transition:background 0.2s; }
  .brand:hover { background:#FAFAFA; }
  .bb { width:38px; height:38px; display:flex; align-items:center; justify-content:center; font-size:9px; font-weight:800; color:#fff; clip-path:polygon(7px 0,100% 0,calc(100% - 7px) 100%,0 100%); }
  .bl { font-size:9px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#0D3A4A; opacity:0.5; text-align:center; }
  .bc { font-size:8px; letter-spacing:0.06em; text-transform:uppercase; color:#bbb; text-align:center; }
  .brand:hover .bl { opacity:1; }

  @media (max-width: 768px) {
    .s6-inner { padding: 64px 20px 40px; }
    .stats-row { grid-template-columns: 1fr 1fr; }
    .stat-n { font-size: 34px; }
    .brands-grid { grid-template-columns: repeat(3,1fr); }
  }
  @media (max-width: 480px) { .brands-grid { grid-template-columns: repeat(2,1fr); } }
</style>
