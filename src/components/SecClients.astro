    <div class="brands-div fade-up"><span>취급 브랜드 · Technology Partners</span></div>
    <div class="brands-grid">
      <div class="brand fade-up fade-up-d1"><div class="bb" style="background:#E60012">Pan</div><p class="bl">Panasonic</p><p class="bc">Display · AV</p></div>
      <div class="brand fade-up fade-up-d2"><div class="bb" style="background:#003087">Sony</div><p class="bl">Sony Pro</p><p class="bc">Camera</p></div>
      <div class="brand fade-up fade-up-d3"><div class="bb" style="background:#0066CC">Cre</div><p class="bl">Crestron</p><p class="bc">Control</p></div>
