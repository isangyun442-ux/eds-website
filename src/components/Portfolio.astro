---
// 구축사례 섹션
// 수정할 것: projects 배열의 내용과 image 경로
// image: '/images/파일명.jpg' 형태로 public/images/ 폴더에 사진 넣으면 돼요

const projects = [
  { cat: 'LED Studio',    name: 'K-콘텐츠 XR 스튜디오',    meta: '서울 강남 · 2024', image: '/images/studio-1.jpg', big: true },
  { cat: 'Smart Meeting', name: '대기업 임원회의실',         meta: '서울 여의도 · 2024', image: '/images/studio-2.jpg', big: true },
  { cat: 'Lecture Room',  name: '대학교 스마트 강의동',      meta: '경기 수원 · 2024', image: '' },
  { cat: 'LED Studio',    name: '방송사 뉴스 스튜디오',      meta: '서울 마포 · 2023', image: '' },
  { cat: 'Smart Meeting', name: '스타트업 허브 회의시설',    meta: '서울 성수 · 2023', image: '' },
  { cat: 'Education',     name: '기업 교육센터 구축',        meta: '인천 송도 · 2023', image: '' },
];
---

<section id="portfolio">
  <div class="reveal">
    <div class="s-eyebrow">Portfolio</div>
    <h2 class="s-title">구축 사례</h2>
    <p class="s-sub">실제 완성된 공간들을 확인해보세요</p>
  </div>

  <div class="port-grid">
    {projects.map((p, i) => (
      <div class={`port-card reveal ${p.big ? 'big' : ''}`}>
        <div class="port-bg" style={p.image ? `background-image:url('${p.image}')` : ''}></div>
        {/* 사진 없을 때 LED 픽셀 애니메이션 표시 */}
        {!p.image && (
          <div class="port-pixels">
            {Array.from({length: 80}).map(() => <div class="pp"></div>)}
          </div>
        )}
        <div class="port-overlay"></div>
        <div class="port-info">
          <div class="pi-cat">{p.cat}</div>
          <div class="pi-name">{p.name}</div>
          <div class="pi-meta">{p.meta}</div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  #portfolio { padding: 100px 60px; background: var(--navy3); }
  #portfolio .s-eyebrow { color: var(--cyan); }
  #portfolio .s-eyebrow::before { background: var(--cyan); }
  #portfolio .s-title { color: #fff; }
  #portfolio .s-sub   { color: rgba(255,255,255,0.4); }

  .port-grid {
    display: grid; grid-template-columns: repeat(3,1fr);
    grid-template-rows: 260px 200px;
    gap: 3px; margin-top: 56px;
  }
  .port-card { position: relative; overflow: hidden; background: var(--navy2); cursor: pointer; }
  .port-card.big { grid-row: 1/3; }

  .port-bg {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #061828 0%, #0D2E45 50%, #0A4060 100%);
    background-size: cover; background-position: center;
    transition: transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .port-card:hover .port-bg { transform: scale(1.04); }

  .port-pixels {
    position: absolute; inset: 0;
    display: grid; grid-template-columns: repeat(10,1fr); grid-template-rows: repeat(8,1fr);
    gap: 3px; padding: 16px; opacity: 0.45;
  }
  .pp { border-radius: 1px; background: var(--cyan); animation: ppa 3s ease-in-out infinite; }
  .pp:nth-child(3n) { animation-delay:.4s; background: var(--red); }
  .pp:nth-child(5n) { animation-delay:.8s; background: #fff; opacity:.2; }
  .pp:nth-child(7n) { animation-delay:1.2s; opacity:.1; }
  @keyframes ppa { 0%,100%{opacity:.6} 50%{opacity:.15} }

  .port-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(transparent 40%, rgba(6,18,28,0.9) 100%);
  }
  .port-card::after {
    content: ''; position: absolute; top: 0; right: 0;
    border-top: 28px solid var(--cyan); border-left: 28px solid transparent; opacity: 0.6;
  }
  .port-card:nth-child(even)::after { border-top-color: var(--red); }

  .port-info { position: absolute; bottom: 0; left: 0; right: 0; padding: 20px 22px; }
  .pi-cat  { font-size: 10px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: var(--cyan); margin-bottom: 6px; }
  .pi-name { font-family: var(--sans); font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .pi-meta { font-size: 11px; color: rgba(255,255,255,0.35); }

  @media (max-width: 768px) {
    #portfolio { padding: 72px 24px; }
    .port-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
    .port-card.big { grid-row: auto; }
    .port-card { height: 200px; }
  }
  @media (max-width: 480px) {
    .port-grid { grid-template-columns: 1fr; }
  }
</style>
