---
// 네비게이션 컴포넌트
// 수정할 것: 로고 이미지 경로, 메뉴 항목
---

<nav id="nav">
  <a class="nav-logo" href="#">
    <!-- 로고 이미지: public/images/logo.png 에 파일 넣으면 자동 적용 -->
    <img src="/images/logo.png" alt="EDS — Beyond The Future" />
  </a>
  <ul class="nav-links">
    <li><a href="#services">서비스</a></li>
    <li><a href="#portfolio">구축사례</a></li>
    <li><a href="#process">진행절차</a></li>
    <li><a href="#clients">파트너스</a></li>
    <li><a href="#contact" class="nav-cta">도입 문의</a></li>
  </ul>
  <!-- 모바일 햄버거 버튼 -->
  <button class="nav-hamburger" id="hamburger" aria-label="메뉴 열기">
    <span></span><span></span><span></span>
  </button>
</nav>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    height: 64px;
    background: var(--navy3);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 60px;
    border-bottom: 2px solid var(--cyan);
    transition: box-shadow 0.3s;
  }
  nav.scrolled { box-shadow: 0 4px 24px rgba(0,184,217,0.15); }

  .nav-logo img {
    height: 38px; width: auto; object-fit: contain;
  }
  /* 로고 이미지 없을 때 텍스트 대체 */
  .nav-logo img[src="/images/logo.png"]:not([complete]),
  .nav-logo img[src="/images/logo.png"][naturalWidth="0"] {
    visibility: hidden;
  }

  .nav-links {
    display: flex; align-items: center; gap: 32px; list-style: none;
  }
  .nav-links a {
    font-size: 13px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--cyan); }
  .nav-cta {
    background: var(--red) !important;
    color: #fff !important;
    padding: 9px 22px;
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    font-weight: 700 !important;
    transition: background 0.2s !important;
  }
  .nav-cta:hover { background: var(--red2) !important; }

  /* 모바일 햄버거 */
  .nav-hamburger {
    display: none;
    flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: 4px;
  }
  .nav-hamburger span {
    display: block; width: 22px; height: 2px;
    background: rgba(255,255,255,0.7);
    transition: transform 0.2s, opacity 0.2s;
  }

  @media (max-width: 768px) {
    nav { padding: 0 20px; }
    .nav-hamburger { display: flex; }
    .nav-links {
      display: none;
      position: absolute; top: 64px; left: 0; right: 0;
      background: var(--navy3);
      flex-direction: column; gap: 0;
      border-bottom: 2px solid var(--cyan);
      padding: 12px 0;
    }
    .nav-links.open { display: flex; }
    .nav-links li { width: 100%; }
    .nav-links a {
      display: block; padding: 14px 24px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .nav-cta { clip-path: none !important; margin: 8px 24px; display: block; text-align: center; }
  }
</style>

<script>
  // 스크롤 시 nav 그림자
  window.addEventListener('scroll', () => {
    document.getElementById('nav')?.classList.toggle('scrolled', window.scrollY > 60);
  });
  // 모바일 햄버거 토글
  document.getElementById('hamburger')?.addEventListener('click', () => {
    document.querySelector('.nav-links')?.classList.toggle('open');
  });
</script>
