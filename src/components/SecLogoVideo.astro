---
// src/components/SecLogoVideo.astro
---
<section class="sec s1" id="sec1">
  <div class="logo-video-wrap">
    <video id="logoVideo" src="/videos/logo.mp4" muted playsinline preload="auto"></video>
  </div>
</section>

<style>
  .s1 { background: #000 !important; overflow: hidden; }
  .s1.active { background: #000 !important; }
  .logo-video-wrap { position: absolute; inset: 0; background: #000; }
  .logo-video-wrap video { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>
