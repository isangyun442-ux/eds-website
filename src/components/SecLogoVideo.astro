---
// src/components/SecLogoVideo.astro
---
<section class="sec s1" id="sec1">
  <!-- 모바일 터치 대기 화면 -->
  <div class="logo-touch-screen" id="logoTouchScreen">
    <img src="/images/logo.png" alt="EDS 이담에스티" class="logo-touch-img" />
    <p class="logo-touch-text">화면을 터치하여 시작하세요</p>
    <div class="logo-touch-dot">
      <span></span><span></span><span></span>
    </div>
  </div>
  <!-- 영상 -->
  <div class="logo-video-wrap" id="logoVideoWrap">
    <video id="logoVideo" src="https://res.cloudinary.com/dlaty4qsq/video/upload/v1776229066/logo_slzbmr.mp4" muted playsinline preload="auto"></video>
  </div>
</section>

<style>
  .s1 { background: #fff; overflow: hidden; }

  .logo-touch-screen {
    position: absolute; inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #fff;
    z-index: 2;
    gap: 28px;
  }
  .logo-touch-img {
    width: 200px; height: auto;
    animation: logoFloat 2.5s ease-in-out infinite;
  }
  @keyframes logoFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .logo-touch-text {
    font-family: 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif;
    font-size: 14px; font-weight: 600;
    color: #0D3A4A; letter-spacing: 0.08em;
    animation: fadePulse 1.8s ease-in-out infinite;
  }
  @keyframes fadePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .logo-touch-dot { display: flex; gap: 8px; }
  .logo-touch-dot span {
    width: 6px; height: 6px; border-radius: 50%;
    background: #00B8D9;
    animation: dotBounce 1.2s ease-in-out infinite;
  }
  .logo-touch-dot span:nth-child(2) { animation-delay: 0.2s; }
  .logo-touch-dot span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes dotBounce {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50% { transform: translateY(-8px); opacity: 1; }
  }

  .logo-video-wrap {
    position: absolute; inset: 0;
    background: #000;
    display: none;
  }
  .logo-video-wrap video {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }

  @media (min-width: 769px) {
    .s1 { background: #000; }
    .logo-touch-screen { display: none !important; }
    .logo-video-wrap { display: block !important; }
  }
  @media (max-width: 768px) {
    .logo-touch-screen { display: flex; }
    .logo-video-wrap { display: none; }
  }
</style>

<script is:inline>
(function() {
  const isMobile = window.innerWidth <= 768;
  if (!isMobile) return;

  const touchScreen = document.getElementById('logoTouchScreen');
  const videoWrap = document.getElementById('logoVideoWrap');
  const video = document.getElementById('logoVideo');
  if (!touchScreen || !video) return;

  // 대기화면 보여주는 동안 미리 영상 로드
  video.load();

  function startVideo() {
    touchScreen.style.display = 'none';
    videoWrap.style.cssText = 'display:block; position:absolute; inset:0; background:#000;';
    video.currentTime = 0;
    video.play();
  }

  touchScreen.addEventListener('click', startVideo, { once: true });
  touchScreen.addEventListener('touchstart', startVideo, { once: true });
})();
</script>
