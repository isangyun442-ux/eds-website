---
// 히어로 섹션
// 수정할 것: 메인 타이틀, 설명 문구
---

<section id="hero">
  <div class="hero-left reveal">
    <div class="hero-eyebrow">Beyond The Future</div>
    <h1 class="hero-title">
      <span class="t-red">스마트</span><br />
      공간을<br />
      <span class="t-cyan">설계</span>합니다
    </h1>
    <p class="hero-sub-title">Smart Space Solution</p>
    <p class="hero-desc">
      EDS는 스마트 회의실, LED 스튜디오, 강의실 통합 시스템을 전문으로 설계·구축합니다.
      미래의 공간을 지금 경험하세요.
    </p>
    <div class="hero-btns">
      <a class="btn-red" href="#contact">무료 상담 신청 →</a>
      <a class="btn-outline" href="#portfolio">구축 사례 보기</a>
    </div>
  </div>

  <div class="hero-right reveal">
    <div class="mockup-card">
      <div class="mc-header">
        <span class="mc-title">LED Studio — Live Monitor</span>
        <span class="mc-status"><span class="mc-dot"></span>Operating</span>
      </div>
      <div class="led-grid">
        {Array.from({length: 32}).map(() => <div class="lpx"></div>)}
      </div>
      <div class="mc-specs">
        <div class="mc-spec"><div class="mc-spec-v">4K</div><div class="mc-spec-l">해상도</div></div>
        <div class="mc-spec"><div class="mc-spec-v">P1.2</div><div class="mc-spec-l">픽셀피치</div></div>
        <div class="mc-spec"><div class="mc-spec-v">600</div><div class="mc-spec-l">nit</div></div>
        <div class="mc-spec"><div class="mc-spec-v">16:9</div><div class="mc-spec-l">비율</div></div>
      </div>
    </div>
    <div class="mockup-row">
      <div class="mockup-mini">
        <span class="mm-icon">📡</span>
        <div><div class="mm-label">원격 제어</div><div class="mm-val">앱·태블릿 연동</div></div>
      </div>
      <div class="mockup-mini">
        <span class="mm-icon">🎙</span>
        <div><div class="mm-label">음향 통합</div><div class="mm-val">DSP 자동 조절</div></div>
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    min-height: 100vh;
    background: var(--navy3);
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 100px 60px 60px;
    position: relative; overflow: hidden; gap: 60px;
  }
  #hero::before {
    content: '';
    position: absolute; top: 0; right: -60px; bottom: 0; width: 55%;
    background: var(--navy2);
    clip-path: polygon(80px 0, 100% 0, 100% 100%, 0 100%);
    pointer-events: none;
  }
  #hero::after {
    content: '';
    position: absolute; top: 0; bottom: 0;
    left: calc(45% - 3px); width: 3px;
    background: linear-gradient(180deg, transparent, var(--cyan) 30%, var(--cyan) 70%, transparent);
    pointer-events: none;
  }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--cyan); margin-bottom: 24px;
  }
  .hero-eyebrow::before { content: ''; display: block; width: 32px; height: 2px; background: var(--cyan); }
  .hero-title {
    font-family: var(--sans);
    font-size: clamp(44px, 5.5vw, 76px); font-weight: 800; font-style: italic;
    line-height: 1.0; letter-spacing: -0.02em; color: #fff; margin-bottom: 6px;
  }
  .t-red  { color: var(--red); }
  .t-cyan { color: var(--cyan); }
  .hero-sub-title {
    font-size: clamp(16px, 2vw, 22px); font-weight: 600;
    color: rgba(255,255,255,0.45); letter-spacing: 0.06em;
    text-transform: uppercase; margin-bottom: 32px;
  }
  .hero-desc {
    font-family: var(--kr); font-size: 15px; line-height: 1.9;
    color: rgba(255,255,255,0.55); max-width: 420px; margin-bottom: 44px;
  }
  .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-red {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--red); color: #fff;
    padding: 14px 36px; font-size: 13px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
    transition: background 0.2s, transform 0.15s;
  }
  .btn-red:hover { background: var(--red2); transform: translateY(-2px); }
  .btn-outline {
    display: inline-flex; align-items: center;
    background: transparent; color: rgba(255,255,255,0.7);
    padding: 13px 32px; font-size: 13px; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    border: 1.5px solid rgba(255,255,255,0.2);
    clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover { border-color: var(--cyan); color: var(--cyan); }

  /* mockup */
  .hero-right { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 14px; }
  .mockup-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(0,184,217,0.18); border-left: 3px solid var(--cyan);
    padding: 18px 20px; position: relative;
  }
  .mockup-card::before {
    content: ''; position: absolute; top: 0; right: 0;
    border-top: 12px solid var(--cyan); border-left: 12px solid transparent; opacity: 0.4;
  }
  .mc-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .mc-title  { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--cyan); }
  .mc-status { display: flex; align-items: center; gap: 5px; font-size: 10px; color: #00D68F; background: rgba(0,214,143,0.1); padding: 3px 9px; }
  .mc-dot    { width: 5px; height: 5px; border-radius: 50%; background: #00D68F; animation: blink 2s ease-in-out infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.4} }

  .led-grid { display: grid; grid-template-columns: repeat(16, 1fr); gap: 2px; margin-bottom: 12px; }
  .lpx { aspect-ratio: 1; border-radius: 1px; background: var(--cyan); animation: lpxa 2.5s ease-in-out infinite; }
  .lpx:nth-child(3n)  { animation-delay:.3s; background: var(--red); }
  .lpx:nth-child(5n)  { animation-delay:.7s; background: var(--navy); opacity:.6; }
  .lpx:nth-child(7n)  { animation-delay:1.1s; opacity:.3; }
  @keyframes lpxa { 0%,100%{opacity:1} 50%{opacity:0.35} }

  .mc-specs { display: grid; grid-template-columns: repeat(4,1fr); gap: 6px; }
  .mc-spec   { background: rgba(0,184,217,0.06); padding: 8px 6px; text-align: center; }
  .mc-spec-v { font-size: 16px; font-weight: 700; color: var(--cyan); line-height: 1; margin-bottom: 3px; }
  .mc-spec-l { font-size: 9px; letter-spacing: .08em; color: var(--gray); text-transform: uppercase; }

  .mockup-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .mockup-mini {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07); border-top: 2px solid var(--red);
    padding: 14px 16px; display: flex; align-items: center; gap: 10px;
  }
  .mm-icon  { font-size: 20px; }
  .mm-label { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.7); margin-bottom: 2px; }
  .mm-val   { font-size: 11px; color: var(--gray); }

  @media (max-width: 768px) {
    #hero { grid-template-columns: 1fr; padding: 100px 24px 60px; gap: 40px; min-height: auto; }
    #hero::before, #hero::after { display: none; }
    .hero-title { font-size: 40px; }
  }
</style>
