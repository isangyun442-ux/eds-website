---
// src/components/SecContact.astro
---

<!-- 도입문의 모달 -->
<div class="iq-modal" id="inquiryModal">
  <div class="iq-overlay" id="iqOverlay"></div>
  <div class="iq-box">
    <button class="iq-close" id="iqClose">✕</button>

    <div class="iq-head">
      <span class="iq-eyebrow">INQUIRY</span>
      <h3 class="iq-title">도입 문의</h3>
      <p class="iq-sub">담당자가 확인 후 빠르게 연락드리겠습니다</p>
    </div>

    <div id="iqForm">
      <div class="iq-row">
        <div class="iq-field">
          <label class="iq-label">회사명 <span class="iq-req">*</span></label>
          <input class="iq-input" id="iq-company" type="text" placeholder="(주)이담에스티" />
        </div>
        <div class="iq-field">
          <label class="iq-label">담당자명 <span class="iq-req">*</span></label>
          <input class="iq-input" id="iq-name" type="text" placeholder="홍길동" />
        </div>
      </div>
      <div class="iq-row">
        <div class="iq-field">
          <label class="iq-label">연락처 <span class="iq-req">*</span></label>
          <input class="iq-input" id="iq-phone" type="tel" placeholder="010-1234-5678" />
        </div>
        <div class="iq-field">
          <label class="iq-label">이메일</label>
          <input class="iq-input" id="iq-email" type="email" placeholder="example@company.com" />
        </div>
      </div>
      <div class="iq-field">
        <label class="iq-label">문의 유형</label>
        <div class="iq-chips" id="iq-type-chips">
          <button class="iq-chip on" data-v="방송·미디어 시스템">방송·미디어 시스템</button>
          <button class="iq-chip" data-v="LED 디스플레이">LED 디스플레이</button>
          <button class="iq-chip" data-v="화상회의 시스템">화상회의 시스템</button>
          <button class="iq-chip" data-v="아카이브·스토리지">아카이브·스토리지</button>
          <button class="iq-chip" data-v="기타">기타</button>
        </div>
      </div>
      <div class="iq-field">
        <label class="iq-label">문의 내용</label>
        <textarea class="iq-input iq-ta" id="iq-message" placeholder="도입을 검토 중인 시스템이나 궁금한 사항을 자유롭게 작성해주세요." rows="4"></textarea>
      </div>

      <p class="iq-privacy">수집된 정보는 문의 응대 목적으로만 사용되며, 응대 완료 후 즉시 파기됩니다.</p>

      <button class="iq-submit" id="iqSubmit" onclick="iqSend()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        문의 보내기
      </button>
    </div>

    <!-- 완료 화면 -->
    <div class="iq-done" id="iqDone" style="display:none">
      <div class="iq-done-icon">✓</div>
      <h3 class="iq-done-title">문의가 접수됐습니다</h3>
      <p class="iq-done-sub">담당자가 확인 후 빠른 시간 내에 연락드리겠습니다.<br>평일 09:00 – 18:00 운영</p>
      <button class="iq-done-btn" onclick="iqClose()">닫기</button>
    </div>

  </div>
</div>
<section class="sec s7" id="sec7">

  <!-- 물결 배경 SVG -->
  <div class="ct-bg-waves" aria-hidden="true">
    <svg class="wave-svg" viewBox="0 0 1440 560" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <path d="M-100 280 Q200 100 500 280 Q800 460 1100 280 Q1300 160 1540 280" stroke="#1a2f8a" stroke-width="1" fill="none" opacity="0.06"/>
      <path d="M-100 320 Q200 140 500 320 Q800 500 1100 320 Q1300 200 1540 320" stroke="#1a2f8a" stroke-width="1" fill="none" opacity="0.05"/>
      <path d="M-100 360 Q200 180 500 360 Q800 540 1100 360 Q1300 240 1540 360" stroke="#1a2f8a" stroke-width="0.8" fill="none" opacity="0.04"/>
      <path d="M0 280 Q360 80 720 280 Q1080 480 1440 280" stroke="#1a2f8a" stroke-width="1.5" fill="none" opacity="0.08"/>
      <path d="M0 320 Q360 520 720 320 Q1080 120 1440 320" stroke="#1a2f8a" stroke-width="1.5" fill="none" opacity="0.08"/>
      <ellipse cx="1200" cy="200" rx="300" ry="200" stroke="#1a2f8a" stroke-width="0.8" fill="none" opacity="0.04"/>
      <ellipse cx="200" cy="400" rx="250" ry="180" stroke="#1a2f8a" stroke-width="0.8" fill="none" opacity="0.04"/>
    </svg>
  </div>

  <!-- 콘텐츠 2컬럼 -->
  <div class="ct-content">

    <!-- 왼쪽: 포스터 -->
    <div class="ct-left fade-up">
      <div class="ct-poster">

        <!-- 배경 그래픽 -->
        <div class="ct-poster-bg" aria-hidden="true">
          <svg class="ct-poster-svg" viewBox="0 0 600 520" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
            <circle cx="480" cy="80"  r="220" fill="rgba(255,255,255,0.04)"/>
            <circle cx="480" cy="80"  r="160" fill="rgba(255,255,255,0.04)"/>
            <circle cx="480" cy="80"  r="100" fill="rgba(255,255,255,0.05)"/>
            <circle cx="60"  cy="460" r="180" fill="rgba(255,255,255,0.03)"/>
            <path d="M0 340 Q150 260 300 340 Q450 420 600 340" stroke="rgba(255,255,255,0.08)" stroke-width="1" fill="none"/>
            <path d="M0 380 Q150 300 300 380 Q450 460 600 380" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none"/>
          </svg>
        </div>

        <!-- 포스터 콘텐츠 -->
        <div class="ct-poster-inner">
          <div class="ct-poster-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2l2.2 3.2 3.8-.8 1 3.8 3.8 1-.8 3.8L25 16l-3 2.4.6 3.9-3.8.6L16 26l-3.8-1.2L9 26l-2.8-2.8-3.8-.6.6-3.9L0 16l3-2.8-.8-3.8 3.8-1 1-3.8 3.8.8Z"/></svg>
            19년 전문 기업
          </div>

          <h2 class="ct-poster-title">설계부터 구축,<br>유지보수까지<br><em>책임집니다</em></h2>

          <p class="ct-poster-desc">방송·미디어·LED·화상회의 시스템<br>공공기관 · 교육기관 · 기업 전문</p>

          <!-- 배지 -->
          <div class="ct-poster-badges">
            <div class="ct-poster-tag">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              당일 견적 가능
            </div>
            <div class="ct-poster-tag">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              전국 출고
            </div>
            <div class="ct-poster-tag">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              ISO 9001 인증
            </div>
            <div class="ct-poster-tag">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              특허 보유 기업
            </div>
          </div>

          <!-- 문의 버튼 -->
          <button class="ct-poster-btn" onclick="document.getElementById('inquiryModal').classList.add('open')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            도입 문의하기
          </button>

          <!-- 연락처 -->
          <div class="ct-poster-contact">
            <span>02-857-7744</span>
            <span class="ct-poster-div">|</span>
            <span>pub@edamst.com</span>
            <span class="ct-poster-div">|</span>
            <span>평일 09:00 – 18:00</span>
          </div>
        </div>

      </div>
    </div>

    <!-- 오른쪽: 구글맵 -->
    <div class="ct-right fade-up fade-up-d2">
      <div class="ct-map-wrap">
        <iframe
          src="https://maps.google.com/maps?q=서울시+구로구+디지털로31길+19+에이스테크노타워2차&t=&z=16&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="이담에스티 위치"
        ></iframe>
      </div>
      <p class="ct-map-caption">서울시 구로구 디지털로31길 19, 에이스테크노타워2차 406호</p>
    </div>

  </div>

  <!-- Footer -->
  <footer class="eds-footer">
    <div class="eds-footer-inner">
      <div class="eds-footer-left">
        <img class="eds-footer-logo" src="/images/logo.png" alt="EDS 이담에스티" />
        <div class="eds-footer-info">
          <div class="eds-footer-company">(주)이담에스티</div>
          <div class="eds-footer-details">
            <span>주소 서울시 구로구 디지털로31길 19, 406호</span>
            <span class="div">|</span>
            <span>TEL 02-857-7744</span>
            <span class="div">|</span>
            <span>FAX 02-857-7321</span>
            <span class="div">|</span>
            <span>E-mail pub@edamst.com</span>
          </div>
        </div>
      </div>
      <span class="eds-footer-copy">Copyright 2022. EDAMST. All rights reserved.</span>
    </div>
  </footer>

</section>

<style>
  .s7 { position: relative; background: #fff; overflow: hidden; }

  .ct-bg-waves { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
  .wave-svg { width: 100%; height: 100%; }

  /* 2컬럼 레이아웃 */
  .ct-content {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0;
    max-width: 1400px; margin: 0 auto;
    padding: 80px 60px 60px;
    min-height: 520px;
    align-items: center;
  }

  /* 왼쪽: 포스터 */
  .ct-left { padding-right: 40px; }
  .ct-poster {
    position: relative;
    background: linear-gradient(135deg, #1a2f8a 0%, #0d1a4a 55%, #060e28 100%);
    border-radius: 20px;
    overflow: hidden;
    min-height: 480px;
    display: flex; align-items: stretch;
  }
  .ct-poster-bg { position: absolute; inset: 0; pointer-events: none; }
  .ct-poster-svg { width: 100%; height: 100%; }

  .ct-poster-inner {
    position: relative; z-index: 1;
    padding: 48px 44px;
    display: flex; flex-direction: column; justify-content: center;
    gap: 0;
  }

  .ct-poster-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.9); font-size: 11px; font-weight: 700;
    letter-spacing: 0.08em; padding: 5px 13px; border-radius: 50px;
    margin-bottom: 24px; width: fit-content;
  }

  .ct-poster-title {
    font-size: clamp(28px, 3.2vw, 42px); font-weight: 900;
    color: #fff; letter-spacing: -0.04em; line-height: 1.2;
    margin-bottom: 16px;
  }
  .ct-poster-title em { font-style: normal; color: #7dd3fc; }

  .ct-poster-desc {
    font-size: 14px; color: rgba(255,255,255,0.55);
    line-height: 1.8; margin-bottom: 28px;
  }

  .ct-poster-badges {
    display: flex; flex-wrap: wrap; gap: 8px;
    margin-bottom: 36px;
  }
  .ct-poster-tag {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.75); font-size: 12px; font-weight: 600;
    padding: 6px 14px; border-radius: 6px;
  }

  .ct-poster-btn {
    display: inline-flex; align-items: center; gap: 9px;
    background: #fff; color: #1a2f8a;
    border: none; cursor: pointer; font-family: inherit;
    font-size: 15px; font-weight: 800;
    padding: 15px 36px; border-radius: 50px;
    margin-bottom: 24px; width: fit-content;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
  }
  .ct-poster-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,0,0,0.35); }

  .ct-poster-contact {
    display: flex; align-items: center; flex-wrap: wrap; gap: 6px 10px;
    font-size: 12px; color: rgba(255,255,255,0.35);
  }
  .ct-poster-div { color: rgba(255,255,255,0.15); }

  /* 오른쪽: 지도 */
  .ct-right { display: flex; flex-direction: column; gap: 12px; }
  .ct-map-wrap {
    width: 100%; height: 420px;
    border-radius: 14px; overflow: hidden;
    box-shadow: 0 12px 48px rgba(26,47,138,0.12);
    border: 1px solid #e8edf4;
  }
  .ct-map-wrap iframe { width: 100%; height: 100%; display: block; }
  .ct-map-caption { font-size: 12px; color: #aaa; text-align: center; }

  /* Footer */
  .eds-footer { position: relative; z-index: 1; background: #1a2f8a; }
  .eds-footer-inner { padding: 32px 60px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
  .eds-footer-left { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
  .eds-footer-logo { height: 28px; width: auto; filter: brightness(0) invert(1); opacity: 0.8; }
  .eds-footer-info { display: flex; flex-direction: column; gap: 4px; }
  .eds-footer-company { font-size: 13px; font-weight: 700; color: #fff; }
  .eds-footer-details { display: flex; align-items: center; flex-wrap: wrap; gap: 4px 8px; font-size: 12px; color: rgba(255,255,255,0.5); }
  .eds-footer-details .div { color: rgba(255,255,255,0.2); }
  .eds-footer-copy { font-size: 11px; color: rgba(255,255,255,0.3); letter-spacing: 0.04em; }

  @media (max-width: 960px) {
    .ct-content { grid-template-columns: 1fr; padding: 60px 32px 48px; }
    .ct-left { padding-right: 0; margin-bottom: 32px; }
    .ct-poster { min-height: 360px; }
    .ct-poster-inner { padding: 36px 28px; }
    .ct-map-wrap { height: 300px; }
    .eds-footer-inner { padding: 24px 32px; flex-direction: column; align-items: flex-start; }
    .eds-footer-details .div { display: none; }
    .eds-footer-details { flex-direction: column; gap: 4px; }
  }
  @media (max-width: 480px) {
    .ct-content { padding: 48px 20px 40px; }
    .ct-poster-inner { padding: 28px 22px; }
  }

  /* ── 도입문의 모달 ── */
  .iq-modal { display:none; position:fixed; inset:0; z-index:9000; align-items:center; justify-content:center; padding:20px; }
  .iq-modal.open { display:flex; }
  .iq-overlay { position:fixed; inset:0; background:rgba(8,12,32,0.72); backdrop-filter:blur(4px); cursor:pointer; }
  .iq-box {
    position:relative; z-index:1;
    background:#fff; border-radius:18px;
    width:100%; max-width:560px;
    max-height:90vh; overflow-y:auto;
    padding:40px 40px 36px;
    box-shadow:0 32px 80px rgba(0,0,0,0.22);
    scrollbar-width:thin; scrollbar-color:#e0e7f4 transparent;
    animation: iqIn .28s cubic-bezier(0.16,1,0.3,1);
  }
  @keyframes iqIn { from { opacity:0; transform:translateY(24px) scale(0.97); } to { opacity:1; transform:none; } }
  .iq-close {
    position:absolute; top:16px; right:16px;
    width:32px; height:32px; border-radius:50%;
    background:#f4f6fb; border:none; cursor:pointer;
    font-size:14px; color:#666; display:flex; align-items:center; justify-content:center;
    transition:background .15s;
  }
  .iq-close:hover { background:#e8edf4; }
  .iq-head { margin-bottom:28px; }
  .iq-eyebrow { font-size:10px; font-weight:700; letter-spacing:.18em; color:#1a2f8a; text-transform:uppercase; }
  .iq-title { font-size:26px; font-weight:900; color:#0d1a3a; letter-spacing:-.03em; margin:6px 0 6px; }
  .iq-sub { font-size:13px; color:#8896a4; line-height:1.6; }

  .iq-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .iq-field { display:flex; flex-direction:column; gap:6px; margin-bottom:14px; }
  .iq-label { font-size:12px; font-weight:700; color:#4a5568; }
  .iq-req { color:#e53e3e; }
  .iq-input {
    padding:11px 14px; border:1.5px solid #e2e8f0; border-radius:8px;
    font-size:14px; font-family:inherit; color:#0d1a3a;
    outline:none; transition:border-color .15s, box-shadow .15s;
    background:#fafbfe;
  }
  .iq-input:focus { border-color:#1a2f8a; box-shadow:0 0 0 3px rgba(26,47,138,.08); background:#fff; }
  .iq-ta { resize:vertical; min-height:96px; line-height:1.6; }

  .iq-chips { display:flex; flex-wrap:wrap; gap:7px; }
  .iq-chip {
    padding:6px 14px; border-radius:50px;
    border:1.5px solid #e2e8f0; background:#fafbfe;
    font-size:12px; font-weight:600; color:#6b7a8d;
    cursor:pointer; font-family:inherit; transition:all .15s;
  }
  .iq-chip.on { border-color:#1a2f8a; background:rgba(26,47,138,.07); color:#1a2f8a; }
  .iq-chip:hover { border-color:#1a2f8a; color:#1a2f8a; }

  .iq-privacy { font-size:11px; color:#aaa; line-height:1.6; margin:4px 0 20px; }
  .iq-submit {
    width:100%; padding:15px; border-radius:10px;
    background:#1a2f8a; color:#fff; border:none;
    font-size:15px; font-weight:700; font-family:inherit;
    cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px;
    transition:background .2s, transform .15s;
  }
  .iq-submit:hover { background:#152570; transform:translateY(-1px); }
  .iq-submit:disabled { background:#a0aec0; cursor:not-allowed; transform:none; }

  /* 완료 화면 */
  .iq-done { text-align:center; padding:20px 0; }
  .iq-done-icon { width:60px; height:60px; border-radius:50%; background:rgba(26,47,138,.1); color:#1a2f8a; font-size:26px; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; }
  .iq-done-title { font-size:22px; font-weight:900; color:#0d1a3a; margin-bottom:10px; }
  .iq-done-sub { font-size:14px; color:#6b7a8d; line-height:1.8; margin-bottom:28px; }
  .iq-done-btn { padding:12px 36px; border-radius:50px; border:2px solid #1a2f8a; background:transparent; color:#1a2f8a; font-size:14px; font-weight:700; font-family:inherit; cursor:pointer; transition:all .2s; }
  .iq-done-btn:hover { background:#1a2f8a; color:#fff; }

  @media (max-width:560px) {
    .iq-box { padding:28px 20px 24px; }
    .iq-row { grid-template-columns:1fr; }
  }
</style>

<script is:inline>
// ── 모달 열기/닫기 ──
function iqClose(){
  document.getElementById('inquiryModal').classList.remove('open');
  document.getElementById('iqDone').style.display = 'none';
  document.getElementById('iqForm').style.display = 'block';
}
document.getElementById('iqClose').addEventListener('click', iqClose);
document.getElementById('iqOverlay').addEventListener('click', iqClose);

// ── 유형 칩 토글 ──
document.getElementById('iq-type-chips').addEventListener('click', function(e){
  const chip = e.target.closest('.iq-chip');
  if(!chip) return;
  document.querySelectorAll('.iq-chip').forEach(c => c.classList.remove('on'));
  chip.classList.add('on');
});

// ── 제출 ──
window.iqSend = async function(){
  const company = document.getElementById('iq-company').value.trim();
  const name    = document.getElementById('iq-name').value.trim();
  const phone   = document.getElementById('iq-phone').value.trim();
  const email   = document.getElementById('iq-email').value.trim();
  const type    = document.querySelector('.iq-chip.on')?.dataset.v || '';
  const message = document.getElementById('iq-message').value.trim();

  if(!company){ alert('회사명을 입력해주세요.'); return; }
  if(!name)   { alert('담당자명을 입력해주세요.'); return; }
  if(!phone)  { alert('연락처를 입력해주세요.'); return; }

  const btn = document.getElementById('iqSubmit');
  btn.disabled = true;
  btn.textContent = '전송 중...';

  try {
    const res = await fetch('https://formspree.io/f/xredrdpl', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ company, name, phone, email, type, message })
    });
    if(res.ok){
      document.getElementById('iqForm').style.display = 'none';
      document.getElementById('iqDone').style.display = 'block';
    } else {
      alert('전송에 실패했습니다. 잠시 후 다시 시도해주세요.');
      btn.disabled = false;
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg> 문의 보내기';
    }
  } catch(e) {
    alert('네트워크 오류가 발생했습니다.');
    btn.disabled = false;
    btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg> 문의 보내기';
  }
};
</script>
