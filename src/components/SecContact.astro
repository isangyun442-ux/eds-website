---
// src/components/SecContact.astro
---
<section class="sec s7" id="sec7">

  <!-- Contact 메인 영역 -->
  <div class="ct-main">
    <div class="ct-top fade-up">
      <div class="ct-top-left">
        <div class="ct-side-line"></div>
        <div class="ct-side-num">07<br>↓</div>
      </div>
      <div class="ct-top-content">
        <h2 class="ct-title">Contact Us</h2>
        <p class="ct-sub">스마트 공간 구축에 관하여 문의 바랍니다.</p>
        <div class="ct-info">
          <div class="ct-info-row">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 .01h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/></svg>
            <span>02-857-7744</span>
          </div>
          <div class="ct-info-row">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 8l10 6 10-6"/></svg>
            <span>pub@edamst.com</span>
          </div>
        </div>
      </div>
      <div class="ct-arrow" aria-hidden="true">
        <svg viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="10" y1="150" x2="150" y2="10" stroke="white" stroke-width="10" stroke-linecap="round" opacity="0.2"/>
          <polyline points="70,10 150,10 150,90" stroke="white" stroke-width="10" stroke-linecap="round" stroke-linejoin="round" opacity="0.2"/>
        </svg>
      </div>
    </div>

    <div class="ct-divider"></div>

    <!-- 하단: 폼 영역 -->
    <div class="ct-bottom fade-up fade-up-d2">
      <div class="ct-address">
        <div class="ct-addr-row">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>서울시 구로구 디지털로31길 19, 406호</span>
        </div>
        <div class="ct-addr-row">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <span>평일 09:00 – 18:00</span>
        </div>
      </div>
      <div class="ct-form">
        <div class="ct-field"><label>이름</label><input type="text" placeholder="담당자 이름" /></div>
        <div class="ct-field"><label>연락처</label><input type="tel" placeholder="010-0000-0000" /></div>
        <div class="ct-field"><label>이메일</label><input type="email" placeholder="example@company.com" /></div>
        <div class="ct-field"><label>문의 내용</label><input type="text" placeholder="방송제작 스튜디오, LED 디스플레이..." /></div>
        <button class="ct-btn">문의 보내기 →</button>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="eds-footer">
    <div class="eds-footer-inner">
      <div class="eds-footer-left">
        <img class="eds-footer-logo" src="/images/logo.png" alt="EDS 이담에스티" />
        <div class="eds-footer-info-wrap">
          <span>대표 최명순</span><span class="div">|</span>
          <span>서울시 구로구 디지털로31길 19, 406호</span><span class="div">|</span>
          <span>Tel 02-857-7744</span><span class="div">|</span>
          <span>Fax 02-857-7321</span><span class="div">|</span>
          <a href="mailto:pub@edamst.com">pub@edamst.com</a>
        </div>
      </div>
      <span class="eds-footer-copy">Copyright 2022. EDAMST. All rights reserved.</span>
    </div>
  </footer>

</section>

<style>
  .s7 { background: #1a2f8a; position: relative; overflow: hidden; }

  /* ── 메인 ── */
  .ct-main {
    max-width: 1200px; margin: 0 auto;
    padding: 80px 80px 80px;
  }

  /* ── 상단 타이틀 영역 ── */
  .ct-top {
    display: flex; align-items: flex-start;
    gap: 0; position: relative; padding-bottom: 48px;
  }
  .ct-top-left {
    display: flex; flex-direction: column;
    align-items: center; margin-right: 32px;
    padding-top: 8px;
  }
  .ct-side-line {
    width: 1px; height: 48px; background: rgba(255,255,255,0.25);
    margin-bottom: 8px;
  }
  .ct-side-num {
    font-size: 10px; font-weight: 700; color: rgba(255,255,255,0.4);
    letter-spacing: 0.1em; text-align: center; line-height: 1.6;
  }
  .ct-top-content { flex: 1; }
  .ct-title {
    font-size: clamp(48px, 8vw, 100px);
    font-weight: 900; letter-spacing: -0.04em;
    color: #fff; line-height: 1.0; margin-bottom: 20px;
  }
  .ct-sub {
    font-size: 15px; font-weight: 600;
    color: rgba(255,255,255,0.85); margin-bottom: 28px;
  }
  .ct-info { display: flex; flex-direction: column; gap: 12px; }
  .ct-info-row {
    display: flex; align-items: center; gap: 12px;
    font-size: 14px; color: rgba(255,255,255,0.75);
  }
  .ct-info-row svg { color: rgba(255,255,255,0.5); flex-shrink: 0; }

  /* 화살표: 오른쪽 상단에만 */
  .ct-arrow {
    width: 160px; height: 160px;
    flex-shrink: 0; align-self: flex-start;
  }

  /* ── 구분선 ── */
  .ct-divider { height: 1px; background: rgba(255,255,255,0.15); margin-bottom: 48px; }

  /* ── 하단 폼 영역 ── */
  .ct-bottom {
    display: grid; grid-template-columns: 1fr 2fr; gap: 60px; align-items: start;
  }
  .ct-address { display: flex; flex-direction: column; gap: 14px; padding-top: 8px; }
  .ct-addr-row {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.6;
  }
  .ct-addr-row svg { color: rgba(255,255,255,0.35); flex-shrink: 0; margin-top: 2px; }

  /* 폼 */
  .ct-form { display: flex; flex-direction: column; border-top: 1px solid rgba(255,255,255,0.15); }
  .ct-field { border-bottom: 1px solid rgba(255,255,255,0.1); padding: 16px 0; }
  .ct-field label {
    display: block; font-size: 9px; font-weight: 800;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.35); margin-bottom: 8px;
  }
  .ct-field input {
    background: none; border: none; outline: none;
    font-size: 14px; color: #fff; width: 100%; font-family: inherit;
  }
  .ct-field input::placeholder { color: rgba(255,255,255,0.2); }
  .ct-btn {
    margin-top: 24px; background: #fff; color: #1a2f8a; border: none;
    font-size: 12px; font-weight: 800; padding: 16px 40px;
    cursor: pointer; letter-spacing: 0.12em; text-transform: uppercase;
    font-family: inherit; transition: background 0.2s, color 0.2s, transform 0.2s;
    align-self: flex-start;
  }
  .ct-btn:hover { background: #00B8D9; color: #fff; transform: translateY(-2px); }

  /* ── Footer ── */
  .eds-footer { background: rgba(0,0,0,0.25); border-top: 1px solid rgba(255,255,255,0.08); }
  .eds-footer-inner {
    max-width: 1200px; margin: 0 auto; padding: 24px 80px;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
  }
  .eds-footer-left { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .eds-footer-logo { height: 20px; width: auto; filter: brightness(0) invert(1); opacity: 0.5; }
  .eds-footer-info-wrap {
    display: flex; align-items: center; flex-wrap: wrap; gap: 4px 8px;
    font-size: 11px; color: rgba(255,255,255,0.3);
  }
  .eds-footer-info-wrap .div { color: rgba(255,255,255,0.12); }
  .eds-footer-info-wrap a { color: rgba(255,255,255,0.35); text-decoration: none; transition: color 0.2s; }
  .eds-footer-info-wrap a:hover { color: #fff; }
  .eds-footer-copy { font-size: 10px; color: rgba(255,255,255,0.2); letter-spacing: 0.06em; }

  /* ── 반응형 ── */
  @media (max-width: 900px) {
    .ct-main { padding: 60px 40px; }
    .ct-bottom { grid-template-columns: 1fr; gap: 36px; }
    .ct-arrow { width: 100px; height: 100px; }
    .eds-footer-inner { padding: 20px 40px; }
  }
  @media (max-width: 480px) {
    .ct-main { padding: 48px 24px; }
    .ct-top-left { display: none; }
    .ct-title { font-size: clamp(40px, 12vw, 64px); }
    .ct-arrow { display: none; }
    .eds-footer-inner { padding: 18px 24px; flex-direction: column; align-items: flex-start; }
    .eds-footer-info-wrap .div { display: none; }
  }
</style>
