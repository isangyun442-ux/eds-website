---
// src/components/SecContact.astro
---
<section class="sec s7" id="sec7">

  <div class="ct-wrap">
    <!-- 왼쪽: Contact Us 타이틀 + 정보 -->
    <div class="ct-left fade-up">
      <p class="ct-eyebrow">Contact Us</p>
      <h2 class="ct-title" data-i18n="ct.title">도입 문의</h2>
      <p class="ct-sub">스마트 공간 구축에 관하여 문의 바랍니다.</p>

      <div class="ct-info">
        <div class="ct-info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 .01h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/></svg>
          <span>02-857-7744</span>
        </div>
        <div class="ct-info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 8l10 6 10-6"/></svg>
          <span>pub@edamst.com</span>
        </div>
        <div class="ct-info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>서울시 구로구 디지털로31길 19, 406호</span>
        </div>
        <div class="ct-info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <span>평일 09:00 – 18:00</span>
        </div>
      </div>
    </div>

    <!-- 오른쪽: 폼 -->
    <div class="ct-right fade-up fade-up-d2">
      <div class="ct-form">
        <div class="ct-field">
          <label>이름</label>
          <input type="text" placeholder="담당자 이름" />
        </div>
        <div class="ct-field">
          <label>연락처</label>
          <input type="tel" placeholder="010-0000-0000" />
        </div>
        <div class="ct-field">
          <label>이메일</label>
          <input type="email" placeholder="example@company.com" />
        </div>
        <div class="ct-field">
          <label>문의 내용</label>
          <input type="text" placeholder="방송제작 스튜디오, LED 디스플레이..." />
        </div>
      </div>
      <button class="ct-btn">문의 보내기 →</button>
    </div>

    <!-- 화살표 장식 -->
    <div class="ct-arrow" aria-hidden="true">
      <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="20" y1="180" x2="180" y2="20" stroke="white" stroke-width="8" stroke-linecap="round" opacity="0.12"/>
        <polyline points="90,20 180,20 180,110" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" opacity="0.12"/>
      </svg>
    </div>
  </div>

  <!-- Footer -->
  <footer class="eds-footer">
    <div class="eds-footer-inner">
      <div class="eds-footer-left">
        <img class="eds-footer-logo" src="/images/logo.png" alt="EDS 이담에스티" />
        <div class="eds-footer-info-wrap">
          <span>대표 최명순</span>
          <span class="div">|</span>
          <span>서울시 구로구 디지털로31길 19, 406호</span>
          <span class="div">|</span>
          <span>Tel 02-857-7744</span>
          <span class="div">|</span>
          <span>Fax 02-857-7321</span>
          <span class="div">|</span>
          <a href="mailto:pub@edamst.com">pub@edamst.com</a>
        </div>
      </div>
      <span class="eds-footer-copy">Copyright 2022. EDAMST. All rights reserved.</span>
    </div>
  </footer>

</section>

<style>
  .s7 {
    background: #0D1F2D;
    position: relative;
    overflow: hidden;
  }

  /* ── 메인 영역 ── */
  .ct-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
    max-width: 1200px; margin: 0 auto;
    padding: 120px 80px 100px;
    position: relative;
  }

  /* ── 왼쪽 ── */
  .ct-eyebrow {
    font-size: 11px; font-weight: 800; letter-spacing: 0.24em;
    text-transform: uppercase; color: rgba(255,255,255,0.35);
    margin-bottom: 16px; display: block;
  }
  .ct-title {
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 900; letter-spacing: -0.04em;
    color: #fff; line-height: 1.0; margin-bottom: 16px;
  }
  .ct-sub {
    font-size: 15px; color: rgba(255,255,255,0.45);
    line-height: 1.7; margin-bottom: 48px;
  }
  .ct-info { display: flex; flex-direction: column; gap: 16px; }
  .ct-info-row {
    display: flex; align-items: center; gap: 14px;
    font-size: 14px; color: rgba(255,255,255,0.65);
  }
  .ct-info-row svg { color: rgba(255,255,255,0.35); flex-shrink: 0; }

  /* ── 구분선 ── */
  .ct-divider {
    width: 1px; background: rgba(255,255,255,0.1);
    align-self: stretch;
  }

  /* ── 오른쪽 폼 ── */
  .ct-form { display: flex; flex-direction: column; border-top: 1px solid rgba(255,255,255,0.1); }
  .ct-field { border-bottom: 1px solid rgba(255,255,255,0.08); padding: 18px 0; }
  .ct-field label {
    display: block; font-size: 9px; font-weight: 800;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.3); margin-bottom: 8px;
  }
  .ct-field input {
    background: none; border: none; outline: none;
    font-size: 14px; color: #fff; width: 100%; font-family: inherit;
  }
  .ct-field input::placeholder { color: rgba(255,255,255,0.15); }
  .ct-btn {
    margin-top: 28px; background: #fff; color: #0D1F2D; border: none;
    font-size: 12px; font-weight: 800; padding: 18px 48px;
    cursor: pointer; letter-spacing: 0.12em; text-transform: uppercase;
    font-family: inherit; transition: background 0.25s, color 0.2s, transform 0.2s;
    align-self: flex-start;
  }
  .ct-btn:hover { background: #00B8D9; color: #fff; transform: translateY(-2px); }

  /* ── 화살표 장식 ── */
  .ct-arrow {
    position: absolute; right: 60px; top: 50%;
    transform: translateY(-50%);
    width: 180px; height: 180px;
    pointer-events: none;
  }

  /* ── Footer ── */
  .eds-footer {
    background: rgba(0,0,0,0.3);
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .eds-footer-inner {
    max-width: 1200px; margin: 0 auto;
    padding: 28px 80px;
    display: flex; align-items: center;
    justify-content: space-between; flex-wrap: wrap; gap: 12px;
  }
  .eds-footer-left {
    display: flex; align-items: center; gap: 24px; flex-wrap: wrap;
  }
  .eds-footer-logo {
    height: 22px; width: auto;
    filter: brightness(0) invert(1); opacity: 0.5;
  }
  .eds-footer-info-wrap {
    display: flex; align-items: center; flex-wrap: wrap; gap: 4px 10px;
    font-size: 11px; color: rgba(255,255,255,0.3);
  }
  .eds-footer-info-wrap .div { color: rgba(255,255,255,0.12); }
  .eds-footer-info-wrap a {
    color: rgba(255,255,255,0.4); text-decoration: none;
    transition: color 0.2s;
  }
  .eds-footer-info-wrap a:hover { color: #fff; }
  .eds-footer-copy { font-size: 10px; color: rgba(255,255,255,0.2); letter-spacing: 0.06em; }

  /* ── 반응형 ── */
  @media (max-width: 900px) {
    .ct-wrap { grid-template-columns: 1fr; padding: 80px 40px 60px; gap: 48px; }
    .ct-arrow { display: none; }
    .eds-footer-inner { padding: 24px 40px; }
  }
  @media (max-width: 480px) {
    .ct-wrap { padding: 60px 24px 48px; }
    .ct-title { font-size: clamp(40px, 12vw, 72px); }
    .eds-footer-inner { padding: 20px 24px; flex-direction: column; align-items: flex-start; }
    .eds-footer-info-wrap .div { display: none; }
  }
</style>
