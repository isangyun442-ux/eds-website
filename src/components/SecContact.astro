---
// src/components/SecContact.astro
---
<section class="sec s7" id="sec7">
  <div class="ct-inner">
    <div class="ct-left fade-up">
      <span class="ct-eyebrow">Contact</span>
      <h2 class="ct-title" data-i18n="ct.title">지금 바로<br>상담을 시작하세요</h2>
      <img class="ct-logo" src="/images/logo.png" alt="EDS 이담에스티" />
      <div class="ct-info">
        <div class="ct-row"><span class="ct-label">주소</span><span class="ct-val">서울시 구로구 디지털로31길 19, 406호</span></div>
        <div class="ct-row"><span class="ct-label">전화</span><span class="ct-val">02-857-7744</span></div>
        <div class="ct-row"><span class="ct-label">팩스</span><span class="ct-val">02-857-7321</span></div>
        <div class="ct-row"><span class="ct-label">이메일</span><span class="ct-val">pub@edamst.com</span></div>
        <div class="ct-row"><span class="ct-label">운영</span><span class="ct-val">평일 09:00 – 18:00</span></div>
      </div>
    </div>
    <div class="ct-right fade-up fade-up-d2">
      <div class="ct-form">
        <div class="ct-field"><label>이름</label><input type="text" data-i18n="ct.form.ph.name" placeholder="담당자 이름" /></div>
        <div class="ct-field"><label>연락처</label><input type="tel" data-i18n="ct.form.ph.phone" placeholder="010-0000-0000" /></div>
        <div class="ct-field"><label>이메일</label><input type="email" data-i18n="ct.form.ph.email" placeholder="example@company.com" /></div>
        <div class="ct-field"><label>문의 유형</label><input type="text" data-i18n="ct.form.ph.msg" placeholder="방송제작 스튜디오, LED 디스플레이..." /></div>
      </div>
      <button class="ct-btn" data-i18n="ct.form.submit">문의 보내기 →</button>
    </div>
  </div>

  <footer class="eds-footer">
    <div class="eds-footer-inner">
      <div class="eds-footer-top">
        <img class="eds-footer-logo" src="/images/logo.png" alt="EDS 이담에스티" />
        <span class="eds-footer-copy">Copyright 2022. EDAMST. All rights reserved.</span>
      </div>
      <div class="eds-footer-bottom">
        <span class="eds-footer-info">대표 최명순</span>
        <span class="eds-footer-div">|</span>
        <span class="eds-footer-info">서울시 구로구 디지털로31길 19, 406호 (에이스테크노타워Ⅱ)</span>
        <span class="eds-footer-div">|</span>
        <span class="eds-footer-info">Tel 02-857-7744</span>
        <span class="eds-footer-div">|</span>
        <span class="eds-footer-info">Fax 02-857-7321</span>
        <span class="eds-footer-div">|</span>
        <a class="eds-footer-mail" href="mailto:pub@edamst.com">pub@edamst.com</a>
      </div>
    </div>
  </footer>
</section>

<style>
  .s7 { background: #0D3A4A; }

  .ct-inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
    padding: 120px 80px 100px;
    max-width: 1200px; margin: 0 auto;
  }

  .ct-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.24em;
    text-transform: uppercase; color: #00B8D9;
    margin-bottom: 20px;
  }
  .ct-eyebrow::before { content: ''; display: block; width: 20px; height: 2px; background: #00B8D9; }

  .ct-title {
    font-size: clamp(28px, 3.2vw, 48px);
    font-weight: 800; letter-spacing: -0.04em;
    color: #fff; line-height: 1.15; margin-bottom: 32px;
  }
  .ct-logo {
    height: 30px; width: auto; max-width: 180px;
    filter: brightness(0) invert(1); opacity: 0.5;
    display: block; margin-bottom: 28px;
  }
  .ct-info { display: flex; flex-direction: column; gap: 10px; }
  .ct-row { display: flex; gap: 16px; }
  .ct-label {
    font-size: 9px; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: rgba(255,255,255,0.3); min-width: 48px; padding-top: 1px;
  }
  .ct-val { font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.6; }

  .ct-form { display: flex; flex-direction: column; border-top: 1px solid rgba(255,255,255,0.08); }
  .ct-field { border-bottom: 1px solid rgba(255,255,255,0.08); padding: 16px 0; }
  .ct-field label {
    display: block; font-size: 9px; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(255,255,255,0.3); margin-bottom: 6px;
  }
  .ct-field input {
    background: none; border: none; outline: none;
    font-size: 14px; color: #fff; width: 100%; font-family: inherit;
  }
  .ct-field input::placeholder { color: rgba(255,255,255,0.15); }
  .ct-btn {
    margin-top: 24px; background: #00B8D9; color: #fff; border: none;
    font-size: 12px; font-weight: 700; padding: 16px 36px;
    cursor: pointer; letter-spacing: 0.12em; text-transform: uppercase;
    font-family: inherit; transition: background 0.25s, transform 0.2s;
    align-self: flex-start;
  }
  .ct-btn:hover { background: #009bb8; transform: translateY(-1px); }

  /* Footer */
  .eds-footer { background: rgba(0,0,0,0.4); border-top: 1px solid rgba(255,255,255,0.06); }
  .eds-footer-inner { max-width: 1200px; margin: 0 auto; padding: 28px 80px; }
  .eds-footer-top {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px; padding-bottom: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .eds-footer-logo {
    height: 22px; width: auto; object-fit: contain;
    filter: brightness(0) invert(1); opacity: 0.6;
  }
  .eds-footer-copy { font-size: 10px; color: rgba(255,255,255,0.2); letter-spacing: 0.06em; }
  .eds-footer-bottom {
    display: flex; align-items: center; flex-wrap: wrap; gap: 5px 12px;
  }
  .eds-footer-info { font-size: 11px; color: rgba(255,255,255,0.3); letter-spacing: 0.02em; }
  .eds-footer-div { font-size: 10px; color: rgba(255,255,255,0.12); }
  .eds-footer-mail {
    font-size: 11px; color: #00B8D9; text-decoration: none; transition: color 0.2s;
  }
  .eds-footer-mail:hover { color: #fff; }

  @media (max-width: 900px) {
    .ct-inner { grid-template-columns: 1fr; padding: 80px 40px 60px; gap: 48px; }
    .eds-footer-inner { padding: 24px 40px; }
  }
  @media (max-width: 480px) {
    .ct-inner { padding: 60px 24px 48px; }
    .eds-footer-inner { padding: 20px 24px; }
    .eds-footer-div { display: none; }
    .eds-footer-info, .eds-footer-mail { font-size: 10px; }
  }
</style>
