---
// src/components/SecContact.astro
---
<section class="sec s7" id="sec7">

  <!-- 물결 배경 SVG -->
  <div class="ct-bg-waves" aria-hidden="true">
    <svg class="wave-svg" viewBox="0 0 1440 560" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <path d="M-100 280 Q200 100 500 280 Q800 460 1100 280 Q1300 160 1540 280" stroke="#1a2f8a" stroke-width="1" fill="none" opacity="0.06"/>
      <path d="M-100 320 Q200 140 500 320 Q800 500 1100 320 Q1300 200 1540 320" stroke="#1a2f8a" stroke-width="1" fill="none" opacity="0.05"/>
      <path d="M-100 360 Q200 180 500 360 Q800 540 1100 360 Q1300 240 1540 360" stroke="#1a2f8a" stroke-width="0.8" fill="none" opacity="0.04"/>
      <path d="M0 280 Q360 80 720 280 Q1080 480 1440 280" stroke="#1a2f8a" stroke-width="1.5" fill="none" opacity="0.08"/>
      <path d="M0 320 Q360 520 720 320 Q1080 120 1440 320" stroke="#1a2f8a" stroke-width="1.5" fill="none" opacity="0.08"/>
      <ellipse cx="1200" cy="200" rx="300" ry="200" stroke="#1a2f8a" stroke-width="0.8" fill="none" opacity="0.04"/>
      <ellipse cx="200" cy="400" rx="250" ry="180" stroke="#1a2f8a" stroke-width="0.8" fill="none" opacity="0.04"/>
    </svg>
  </div>

  <!-- 콘텐츠 2컬럼 -->
  <div class="ct-content">

    <!-- 왼쪽: Contact 정보 -->
    <div class="ct-left fade-up">
      <div class="ct-logo">
        <img src="/images/logo.png" alt="EDS 이담에스티" />
      </div>
      <div class="ct-header">
        <h2 class="ct-title">Contact Us</h2>
        <p class="ct-sub">제품 문의 · 기술문의</p>
      </div>

      <!-- 연락처 정보 -->
      <div class="ct-info-list fade-up fade-up-d1">
        <div class="ct-info-item">
          <div class="ct-info-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p class="ct-info-label">주소</p>
            <p class="ct-info-value">서울시 구로구 디지털로31길 19, 406호<br>(구로동, 에이스테크노타워2차)</p>
          </div>
        </div>
        <div class="ct-info-item">
          <div class="ct-info-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
          </div>
          <div>
            <p class="ct-info-label">전화</p>
            <p class="ct-info-value">02-857-7744</p>
          </div>
        </div>
        <div class="ct-info-item">
          <div class="ct-info-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div>
            <p class="ct-info-label">이메일</p>
            <p class="ct-info-value">pub@edamst.com</p>
          </div>
        </div>
        <div class="ct-info-item">
          <div class="ct-info-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <p class="ct-info-label">운영시간</p>
            <p class="ct-info-value">평일 09:00 – 18:00</p>
          </div>
        </div>
      </div>

      <div class="ct-btn-wrap fade-up fade-up-d2">
        <button class="ct-btn" onclick="document.getElementById('inquiryModal').classList.add('open')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
          문의하기
        </button>
      </div>
    </div>

    <!-- 오른쪽: 구글맵 -->
    <div class="ct-right fade-up fade-up-d2">
      <div class="ct-map-wrap">
        <iframe
          src="https://maps.google.com/maps?q=서울시+구로구+디지털로31길+19+에이스테크노타워2차&t=&z=16&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="이담에스티 위치"
        ></iframe>
      </div>
      <p class="ct-map-caption">서울시 구로구 디지털로31길 19, 에이스테크노타워2차 406호</p>
    </div>

  </div>

  <!-- Footer -->
  <footer class="eds-footer">
    <div class="eds-footer-inner">
      <div class="eds-footer-left">
        <img class="eds-footer-logo" src="/images/logo.png" alt="EDS 이담에스티" />
        <div class="eds-footer-info">
          <div class="eds-footer-company">(주)이담에스티</div>
          <div class="eds-footer-details">
            <span>주소 서울시 구로구 디지털로31길 19, 406호</span>
            <span class="div">|</span>
            <span>TEL 02-857-7744</span>
            <span class="div">|</span>
            <span>FAX 02-857-7321</span>
            <span class="div">|</span>
            <span>E-mail pub@edamst.com</span>
          </div>
        </div>
      </div>
      <span class="eds-footer-copy">Copyright 2022. EDAMST. All rights reserved.</span>
    </div>
  </footer>

</section>

<style>
  .s7 { position: relative; background: #fff; overflow: hidden; }

  .ct-bg-waves { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
  .wave-svg { width: 100%; height: 100%; }

  /* 2컬럼 레이아웃 */
  .ct-content {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0;
    max-width: 1400px; margin: 0 auto;
    padding: 80px 60px 60px;
    min-height: 520px;
    align-items: center;
  }

  /* 왼쪽 */
  .ct-left { display: flex; flex-direction: column; gap: 0; padding-right: 60px; }
  .ct-logo { margin-bottom: 28px; }
  .ct-logo img { height: 40px; width: auto; }
  .ct-title { font-size: clamp(40px, 5vw, 72px); font-weight: 900; letter-spacing: -0.04em; color: #1a2f8a; line-height: 1.0; margin-bottom: 8px; }
  .ct-sub { font-size: 16px; color: #6b7a8d; letter-spacing: 0.02em; margin-bottom: 36px; }

  /* 연락처 정보 */
  .ct-info-list { display: flex; flex-direction: column; gap: 20px; margin-bottom: 36px; }
  .ct-info-item { display: flex; align-items: flex-start; gap: 14px; }
  .ct-info-icon {
    width: 36px; height: 36px; flex-shrink: 0;
    background: rgba(26,47,138,0.08); border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #1a2f8a;
  }
  .ct-info-label { font-size: 11px; font-weight: 700; color: #aaa; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 3px; }
  .ct-info-value { font-size: 14px; color: #333; line-height: 1.6; font-weight: 500; }

  /* 버튼 */
  .ct-btn-wrap { }
  .ct-btn {
    display: inline-flex; align-items: center; gap: 10px;
    background: transparent; color: #1a2f8a;
    border: 2px solid #1a2f8a;
    font-size: 15px; font-weight: 700;
    padding: 16px 44px; cursor: pointer;
    letter-spacing: 0.06em; font-family: inherit;
    border-radius: 50px;
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .ct-btn:hover { background: #1a2f8a; color: #fff; transform: translateY(-2px); }

  /* 오른쪽: 지도 */
  .ct-right { display: flex; flex-direction: column; gap: 12px; }
  .ct-map-wrap {
    width: 100%; height: 420px;
    border-radius: 14px; overflow: hidden;
    box-shadow: 0 12px 48px rgba(26,47,138,0.12);
    border: 1px solid #e8edf4;
  }
  .ct-map-wrap iframe { width: 100%; height: 100%; display: block; }
  .ct-map-caption { font-size: 12px; color: #aaa; text-align: center; }

  /* Footer */
  .eds-footer { position: relative; z-index: 1; background: #1a2f8a; }
  .eds-footer-inner { padding: 32px 60px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
  .eds-footer-left { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
  .eds-footer-logo { height: 28px; width: auto; filter: brightness(0) invert(1); opacity: 0.8; }
  .eds-footer-info { display: flex; flex-direction: column; gap: 4px; }
  .eds-footer-company { font-size: 13px; font-weight: 700; color: #fff; }
  .eds-footer-details { display: flex; align-items: center; flex-wrap: wrap; gap: 4px 8px; font-size: 12px; color: rgba(255,255,255,0.5); }
  .eds-footer-details .div { color: rgba(255,255,255,0.2); }
  .eds-footer-copy { font-size: 11px; color: rgba(255,255,255,0.3); letter-spacing: 0.04em; }

  @media (max-width: 960px) {
    .ct-content { grid-template-columns: 1fr; padding: 60px 32px 48px; }
    .ct-left { padding-right: 0; margin-bottom: 40px; }
    .ct-map-wrap { height: 300px; }
    .eds-footer-inner { padding: 24px 32px; flex-direction: column; align-items: flex-start; }
    .eds-footer-details .div { display: none; }
    .eds-footer-details { flex-direction: column; gap: 4px; }
  }
  @media (max-width: 480px) {
    .ct-content { padding: 48px 20px 40px; }
  }
</style>
