---

<section id="history">
  <div class="history-inner">

    <div class="h-header fade-up">
      <span class="h-eyebrow">Company History</span>
      <h2 class="h-title">EDS의 걸어온 길</h2>
      <p class="h-sub">2007년 창립 이래 끊임없이 성장해온 이담에스티의 연혁입니다</p>
    </div>

    <div class="timeline">
      <div class="tl-line"></div>

      {history.map((h) => (
        <div class="tl-row fade-up">
          <div class="tl-year-col">
            <div class="tl-year">{h.year}</div>
          </div>
          <div class="tl-dot-col">
            <div class="tl-dot"></div>
          </div>
          <div class="tl-content-col">
            <div class="tl-card">
              {h.items.map((item) => (
                <div class="tl-item">
                  <span class="tl-month">{item.month}</span>
                  <span class="tl-desc">{item.desc}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}

      <div class="tl-end fade-up">
        <div class="tl-end-dot"></div>
        <span class="tl-end-label">FOUNDED 2007</span>
      </div>
    </div>

  </div>
</section>

<style>
  #history {
    background: #fff;
    padding: 100px 60px;
  }

  .history-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  /* 헤더 */
  .h-header {
    text-align: center;
    margin-bottom: 72px;
  }
  .h-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.22em;
    text-transform: uppercase; color: #00B8D9;
    margin-bottom: 14px;
  }
  .h-eyebrow::before,
  .h-eyebrow::after {
    content: ''; display: block;
    width: 28px; height: 1px; background: #00B8D9; opacity: 0.5;
  }
  .h-title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800; letter-spacing: -0.03em;
    color: #0A0A0A; margin-bottom: 12px;
  }
  .h-sub {
    font-size: 14px; color: #999; line-height: 1.7;
  }

  /* 타임라인 레이아웃 */
  .timeline {
    position: relative;
    padding-bottom: 48px;
  }

  /* 세로 중앙선 */
  .tl-line {
    position: absolute;
    top: 0; bottom: 0;
    left: 96px;
    width: 1px;
    background: #e8e8e8;
  }

  /* 각 행 */
  .tl-row {
    display: grid;
    grid-template-columns: 96px 0 1fr;
    gap: 0 32px;
    margin-bottom: 0;
    align-items: flex-start;
    position: relative;
  }

  /* 연도 */
  .tl-year-col {
    display: flex;
    justify-content: flex-end;
    padding-right: 28px;
    padding-top: 16px;
  }
  .tl-year {
    font-size: 15px; font-weight: 800;
    letter-spacing: -0.02em;
    color: #0D3A4A;
  }

  /* 점 */
  .tl-dot-col {
    display: flex;
    justify-content: center;
    padding-top: 20px;
    position: relative;
    z-index: 2;
  }
  .tl-dot {
    width: 9px; height: 9px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid #00B8D9;
    flex-shrink: 0;
    margin-left: -4px;
  }

  /* 카드 */
  .tl-content-col {
    padding: 12px 0 28px 0;
  }
  .tl-card {
    display: flex; flex-direction: column; gap: 0;
  }
  .tl-item {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 9px 0;
    border-bottom: 1px solid #f4f4f4;
  }
  .tl-item:last-child { border-bottom: none; }
  .tl-item:first-child { padding-top: 0; }

  .tl-month {
    font-size: 11px; font-weight: 700;
    color: #00B8D9; letter-spacing: 0.04em;
    flex-shrink: 0; min-width: 32px;
    padding-top: 2px;
  }
  .tl-desc {
    font-size: 13px; line-height: 1.75;
    color: #555;
  }

  /* 끝 점 */
  .tl-end {
    display: flex; flex-direction: column;
    align-items: flex-start;
    padding-left: 84px;
    margin-top: 4px;
    gap: 6px;
  }
  .tl-end-dot {
    width: 13px; height: 13px;
    border-radius: 50%;
    background: #0D3A4A;
    margin-left: 7px;
  }
  .tl-end-label {
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.18em; color: #aaa;
    text-transform: uppercase;
    padding-left: 2px;
  }

  /* 페이드업 애니메이션 초기 상태 */
  .fade-up {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* 반응형 */
  @media (max-width: 768px) {
    #history { padding: 72px 24px; }
    .tl-line { left: 64px; }
    .tl-row { grid-template-columns: 64px 0 1fr; gap: 0 20px; }
    .tl-year-col { padding-right: 18px; padding-top: 14px; }
    .tl-year { font-size: 13px; }
    .tl-dot-col { padding-top: 18px; }
    .tl-end { padding-left: 54px; }
    .tl-desc { font-size: 12px; }
  }

  @media (max-width: 480px) {
    #history { padding: 60px 16px; }
    .tl-line { left: 52px; }
    .tl-row { grid-template-columns: 52px 0 1fr; gap: 0 14px; }
    .tl-year-col { padding-right: 12px; }
    .tl-year { font-size: 12px; }
    .tl-end { padding-left: 42px; }
  }
</style>

<script>
  const targets = document.querySelectorAll('#history .fade-up');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.15,
      rootMargin: '0px 0px -40px 0px',
    }
  );

  targets.forEach((el) => observer.observe(el));
</script>
