---
// 서비스 섹션
// 수정할 것: services 배열의 내용만 바꾸면 카드가 자동으로 생성돼요!

const services = [
  {
    num: '01',
    icon: '🏢',
    name: '스마트 회의실',
    desc: '버튼 하나로 조명이 조절되고 화면이 켜지고 카메라가 참석자를 자동 추적합니다. Zoom·Teams·Webex 어떤 플랫폼과도 연동되며, 별도 조작 없이 바로 회의를 시작할 수 있는 환경을 구성합니다.',
    tags: ['영상회의 통합', '자동 조명·블라인드', 'UHD 터치 디스플레이', '무선 프레젠테이션'],
  },
  {
    num: '02',
    icon: '💡',
    name: 'LED 스튜디오',
    desc: 'P1.2~P2.5 피치의 고해상도 LED Wall로 실제 배경을 완벽 대체합니다. 방송·유튜브·기업 홍보영상·XR 콘텐츠 제작에 최적화된 색온도와 밝기를 실시간 제어합니다.',
    tags: ['LED Wall 설계·시공', 'XR / 버추얼 프로덕션', '컬러 캘리브레이션', '카메라 연동'],
  },
  {
    num: '03',
    icon: '🎓',
    name: '스마트 강의실',
    desc: '강사가 칠판 앞에 서면 카메라가 자동으로 따라가고 판서 내용이 실시간으로 온라인 수강생에게 전달됩니다. 현장·원격 학습자를 동시에 연결하는 하이브리드 강의 환경을 구현합니다.',
    tags: ['자동 추적 카메라', '하이브리드 강의', '실시간 스트리밍', '강의 녹화·아카이빙'],
  },
  {
    num: '04',
    icon: '🔧',
    name: '시스템 통합(SI)',
    desc: 'AV 장비, IT 네트워크, 보안, 조명, 공조까지 모두 하나의 컨트롤 패널에서 관리합니다. Crestron·AMX 기반 중앙 제어 시스템으로 운영 복잡성을 줄이고 에너지 효율을 높입니다.',
    tags: ['Crestron / AMX', '중앙 통합 제어', '네트워크 설계', 'IoT 연동'],
  },
  {
    num: '05',
    icon: '📊',
    name: '컨설팅 & 설계',
    desc: '장비를 팔기 전에 공간을 먼저 이해합니다. 현장 실사 → 3D 시뮬레이션 → 예산별 최적 안 제안 순서로 진행하며, 불필요한 장비 없이 꼭 필요한 것만 구성해드립니다.',
    tags: ['현장 실사 무료', '3D 시뮬레이션', '예산별 옵션 제안', 'ROI 분석'],
  },
  {
    num: '06',
    icon: '🛠',
    name: '유지보수 & AS',
    desc: '구축 후가 진짜 시작입니다. 원격 모니터링으로 이상 징후를 미리 감지하고 긴급 출동팀이 4시간 이내 현장에 도착합니다. 연간 계약으로 예산을 예측 가능하게 관리하세요.',
    tags: ['24/7 원격 모니터링', '4시간 내 긴급출동', '연간 정기점검', '소모품 교체 포함'],
  },
];
---

<section id="services">
  <div class="reveal">
    <div class="s-eyebrow">Services</div>
    <h2 class="s-title">EDS가 구축하는<br />스마트 공간</h2>
    <p class="s-sub">기획·설계·시공·유지보수까지 원스톱으로 제공합니다</p>
  </div>

  <div class="svc-grid">
    {services.map((s) => (
      <div class="svc-card reveal">
        <div class="svc-num">{s.num} /</div>
        <span class="svc-icon">{s.icon}</span>
        <div class="svc-name">{s.name}</div>
        <p class="svc-desc">{s.desc}</p>
        <div class="svc-tags">
          {s.tags.map((t) => <span class="stag">{t}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  #services { padding: 100px 60px; background: var(--bg); }
  .s-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--red); margin-bottom: 16px;
  }
  .s-eyebrow::before { content: ''; display: block; width: 24px; height: 2px; background: var(--red); }
  .s-title {
    font-family: var(--sans);
    font-size: clamp(28px, 4vw, 44px); font-weight: 800; font-style: italic;
    line-height: 1.1; letter-spacing: -0.02em; color: var(--navy3); margin-bottom: 16px;
  }
  .s-sub { font-family: var(--kr); font-size: 15px; line-height: 1.85; color: var(--gray); max-width: 520px; }

  .svc-grid {
    display: grid; grid-template-columns: repeat(3,1fr);
    gap: 2px; margin-top: 56px; background: var(--line);
  }
  .svc-card {
    background: var(--white); padding: 36px 28px;
    position: relative; overflow: hidden;
    transition: transform 0.25s;
  }
  .svc-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: var(--navy); transition: background 0.25s;
  }
  .svc-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(13,58,74,0.12); z-index: 1; }
  .svc-card:hover::before { background: var(--red); }
  .svc-card::after {
    content: '/'; position: absolute; bottom: -20px; right: 16px;
    font-size: 120px; font-weight: 900; font-style: italic;
    color: rgba(13,58,74,0.04); line-height: 1; pointer-events: none;
  }
  .svc-num  { font-size: 11px; font-weight: 700; letter-spacing: .15em; color: var(--red); margin-bottom: 16px; }
  .svc-icon { font-size: 28px; margin-bottom: 16px; display: block; }
  .svc-name { font-family: var(--sans); font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: 12px; }
  .svc-desc { font-family: var(--kr); font-size: 13px; line-height: 1.9; color: #607080; margin-bottom: 20px; }
  .svc-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .stag { font-size: 10px; font-weight: 600; letter-spacing: .06em; background: var(--light); color: var(--navy); padding: 4px 10px; }

  @media (max-width: 768px) {
    #services { padding: 72px 24px; }
    .svc-grid { grid-template-columns: 1fr; }
  }
</style>
