---
// src/components/SecCert.astro
---

<!-- 라이트박스 -->
<div class="cert-lb" id="certLb">
  <div class="cert-lb-overlay" id="certLbOverlay"></div>
  <div class="cert-lb-box">
    <button class="cert-lb-close" id="certLbClose">✕</button>
    <img class="cert-lb-img" id="certLbImg" src="" alt="" />
    <div class="cert-lb-caption" id="certLbCaption"></div>
  </div>
</div>

<section class="sec s-cert" id="sec-cert">
  <div class="cert-inner">
    <div class="cert-label fade-up" data-i18n="cert.eyebrow">CERTIFICATION</div>
    <h2 class="cert-title fade-up fade-up-d1">
      <svg class="cert-title-icon" width="38" height="44" viewBox="0 0 38 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M19 2l2.2 3.2 3.8-.8 1 3.8 3.8 1-.8 3.8L32 16l-3 2.4.6 3.9-3.8.6L24 26l-3.8-1.2L17 26l-2.8-2.8-3.8-.6.6-3.9L8 16l3-2.8-.8-3.8 3.8-1 1-3.8 3.8.8Z" stroke="#1a2f8a" stroke-width="1.8" stroke-linejoin="round" fill="rgba(26,47,138,0.06)"/>
        <circle cx="19" cy="16" r="7" stroke="#1a2f8a" stroke-width="1.8" fill="none"/>
        <path d="M15.5 16l2.5 2.5 4-4" stroke="#1a2f8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M14 25l-3 8 4-2 2 4 3-8" stroke="#1a2f8a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <path d="M24 25l3 8-4-2-2 4-3-8" stroke="#1a2f8a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
      <span data-i18n="cert.title">인증현황</span>
    </h2>
    <p class="cert-sub fade-up fade-up-d2" data-i18n="cert.sub">이담에스티가 보유한 공인 인증 및 등록 현황입니다</p>

    <!-- ISO 3개 → 특허증 3개 → 나머지 4개 -->
    <div class="cert-grid cert-grid-all fade-up fade-up-d3">
      <!-- ISO 3개 -->
      <div class="cert-card" data-img="/images/cert/cert_06.jpg" data-name="품질경영시스템인증서">
        <div class="cert-img-wrap"><img src="/images/cert/cert_06.jpg" alt="품질경영시스템인증서" loading="lazy" /></div>
        <div class="cert-info"><p class="cert-name">품질경영시스템인증서</p><p class="cert-desc">ISO 9001</p></div>
      </div>
      <div class="cert-card" data-img="/images/cert/cert_07.jpg" data-name="환경경영시스템인증서">
        <div class="cert-img-wrap"><img src="/images/cert/cert_07.jpg" alt="환경경영시스템인증서" loading="lazy" /></div>
        <div class="cert-info"><p class="cert-name">환경경영시스템인증서</p><p class="cert-desc">ISO 14001</p></div>
      </div>
      <div class="cert-card" data-img="/images/cert/cert_08.jpg" data-name="안전보건경영시스템인증서">
        <div class="cert-img-wrap"><img src="/images/cert/cert_08.jpg" alt="안전보건경영시스템인증서" loading="lazy" /></div>
        <div class="cert-info"><p class="cert-name">안전보건경영시스템인증서</p><p class="cert-desc">ISO 45001</p></div>
      </div>
      <!-- 특허증 3개 -->
      <div class="cert-card" data-img="/images/cert/cert_09.jpg" data-name="특허증 · 다중 영상 스트림 녹화 방법 및 그 장치">
        <div class="cert-img-wrap"><img src="/images/cert/cert_09.jpg" alt="특허증 다중 영상 스트림 녹화" loading="lazy" /></div>
        <div class="cert-info"><p class="cert-name">특허증</p><p class="cert-desc">다중 영상 스트림 녹화 방법 및 그 장치</p></div>
      </div>
      <div class="cert-card" data-img="/images/cert/cert_10.jpg" data-name="특허증 · 내용기반 영상검색 장치 및 방법">
        <div class="cert-img-wrap"><img src="/images/cert/cert_10.jpg" alt="특허증 내용기반 영상검색" loading="lazy" /></div>
        <div class="cert-info"><p class="cert-name">특허증</p><p class="cert-desc">내용기반 영상검색 장치 및 방법</p></div>
      </div>
      <div class="cert-card" data-img="/images/cert/cert_11.jpg" data-name="특허증 · 디지털 방송 모니터링 시스템">
        <div class="cert-img-wrap"><img src="/images/cert/cert_11.jpg" alt="특허증 디지털 방송 모니터링" loading="lazy" /></div>
        <div class="cert-info"><p class="cert-name">특허증</p><p class="cert-desc">디지털 방송 모니터링 시스템</p></div>
      </div>
      <!-- 나머지 4개 -->
      <div class="cert-card" data-img="/images/cert/cert_02.jpg" data-name="정보통신공사등록증">
        <div class="cert-img-wrap"><img src="/images/cert/cert_02.jpg" alt="정보통신공사등록증" loading="lazy" /></div>
        <div class="cert-info"><p class="cert-name">정보통신공사등록증</p><p class="cert-desc">공사업 면허 보유</p></div>
      </div>
      <div class="cert-card" data-img="/images/cert/cert_03.jpg" data-name="이노비즈 인증">
        <div class="cert-img-wrap"><img src="/images/cert/cert_03.jpg" alt="이노비즈 인증" loading="lazy" /></div>
        <div class="cert-info"><p class="cert-name">이노비즈 인증</p><p class="cert-desc">기술혁신형 중소기업</p></div>
      </div>
      <div class="cert-card" data-img="/images/cert/cert_04.jpg" data-name="경영혁신형중소기업확인서">
        <div class="cert-img-wrap"><img src="/images/cert/cert_04.jpg" alt="경영혁신형중소기업확인서" loading="lazy" /></div>
        <div class="cert-info"><p class="cert-name">경영혁신형중소기업확인서</p><p class="cert-desc">메인비즈 공식 인증</p></div>
      </div>
      <div class="cert-card" data-img="/images/cert/cert_05.jpg" data-name="소프트웨어사업자">
        <div class="cert-img-wrap"><img src="/images/cert/cert_05.jpg" alt="소프트웨어사업자" loading="lazy" /></div>
        <div class="cert-info"><p class="cert-name">소프트웨어사업자</p><p class="cert-desc">SW 사업자 확인서</p></div>
      </div>
    </div>
  </div>
</section>

<style>
  /* 라이트박스 - 사용 안함 */
  .cert-lb { display:none !important; }

  /* 섹션 */
  .s-cert { background:linear-gradient(180deg,#ffffff 0%,#eef2fb 60%,#dce6f8 100%); padding:100px 0 90px; }
  .cert-inner { max-width:1400px; margin:0 auto; padding:0 40px; text-align:center; }

  .cert-label { font-size:11px; font-weight:700; letter-spacing:0.22em; text-transform:uppercase; color:#1a2f8a; margin-bottom:14px; display:flex; align-items:center; justify-content:center; gap:10px; }
  .cert-label::before, .cert-label::after { content:''; width:28px; height:1px; background:#1a2f8a; display:block; opacity:0.5; }
  .cert-title { font-size:clamp(28px,3.5vw,44px); font-weight:800; color:#0d1a3a; letter-spacing:-0.03em; margin-bottom:14px; display:flex; align-items:center; justify-content:center; gap:12px; }
  .cert-title-icon { flex-shrink:0; }
  .cert-sub { font-size:14px; color:#8896a4; line-height:1.7; margin-bottom:48px; }

  /* 한 줄 11열 그리드 */
  .cert-grid { display:grid; gap:12px; margin-bottom:0; }
  .cert-grid-all { grid-template-columns:repeat(10,1fr); }

  /* 카드 - 클릭 효과 없음 */
  .cert-card { background:rgba(255,255,255,0.88); border:1px solid rgba(26,47,138,0.1); border-radius:10px; overflow:hidden; cursor:default; }
  .cert-card:hover { box-shadow:0 4px 16px rgba(26,47,138,0.08); border-color:#c5d0ed; }

  /* 이미지 */
  .cert-img-wrap { width:100%; aspect-ratio:3/4; background:#f5f7fb; display:flex; align-items:center; justify-content:center; overflow:hidden; padding:6px; box-sizing:border-box; }
  .cert-img-wrap img { width:100%; height:100%; object-fit:contain; }

  /* 카드 하단 */
  .cert-info { padding:6px 5px 8px; text-align:left; border-top:1px solid #f0f4fb; }
  .cert-name { font-size:8.5px; font-weight:700; color:#0d1a3a; margin:0 0 2px; line-height:1.35; letter-spacing:-0.03em; word-break:keep-all; }
  .cert-desc { font-size:9px; color:#9aa4b8; margin:0; }

  /* fade-up */
  .fade-up { opacity:0; transform:translateY(28px); transition:opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1); transition-delay:0.15s; will-change:transform,opacity; }
  .fade-up.visible { opacity:1; transform:translateY(0); }
  .fade-up-d1 { transition-delay:0.25s; }
  .fade-up-d2 { transition-delay:0.35s; }
  .fade-up-d3 { transition-delay:0.45s; }

  @media (max-width:1200px) { .cert-grid-all { grid-template-columns:repeat(6,1fr); } }
  @media (max-width:768px) { .cert-grid-all { grid-template-columns:repeat(4,1fr); gap:10px; } .s-cert { padding:70px 0 60px; } .cert-inner { padding:0 20px; } }
  @media (max-width:480px) { .cert-grid-all { grid-template-columns:repeat(3,1fr); } }
</style>

<script is:inline>
(function () {
  const targets = document.querySelectorAll('#sec-cert .fade-up');
  const obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        obs.unobserve(e.target); // 한 번 실행 후 감시 해제 → 스크롤 끊김 방지
      }
    });
  }, { threshold: 0.08 });
  targets.forEach(function (el) { obs.observe(el); });
})();
</script>
