---
// src/components/SecCert.astro
---

  <div class="cert-lb-box">
    <button class="cert-lb-close" id="certLbClose">✕</button>
    <img class="cert-lb-img" id="certLbImg" src="" alt="" />
    <div class="cert-lb-caption" id="certLbCaption"></div>
  </div>
</div>

<section class="sec s-cert" id="sec-cert">
  <div class="cert-inner">
    <div class="cert-label fade-up" data-i18n="cert.eyebrow">CERTIFICATION</div>
    <h2 class="cert-title fade-up fade-up-d1">
      <span data-i18n="cert.title">인증 현황</span>
    </h2>
    <p class="cert-sub fade-up fade-up-d2" data-i18n="cert.sub">이담에스티가 보유한 공인 인증 및 등록 현황입니다</p>

    <!-- ISO 3개 → 특허증 3개 → 나머지 4개 -->
    <div class="cert-grid cert-grid-all">
      <!-- ISO 3개 -->
      <div class="cert-card cert-card-anim" data-img="/images/cert/cert_06.webp" data-name="품질경영시스템인증서" style="transition-delay:0.0s">
        <div class="cert-img-wrap"><img src="/images/cert/cert_06.webp" alt="품질경영시스템인증서" loading="eager" /></div>
        <div class="cert-info"><p class="cert-name">품질경영시스템인증서</p><p class="cert-desc">ISO 9001</p></div>
      </div>
      <div class="cert-card cert-card-anim" data-img="/images/cert/cert_07.webp" data-name="환경경영시스템인증서" style="transition-delay:0.06s">
        <div class="cert-img-wrap"><img src="/images/cert/cert_07.webp" alt="환경경영시스템인증서" loading="eager" /></div>
        <div class="cert-info"><p class="cert-name">환경경영시스템인증서</p><p class="cert-desc">ISO 14001</p></div>
      </div>
      <div class="cert-card cert-card-anim" data-img="/images/cert/cert_08.webp" data-name="안전보건경영시스템인증서" style="transition-delay:0.12s">
        <div class="cert-img-wrap"><img src="/images/cert/cert_08.webp" alt="안전보건경영시스템인증서" loading="eager" /></div>
        <div class="cert-info"><p class="cert-name">안전보건경영시스템인증서</p><p class="cert-desc">ISO 45001</p></div>
      </div>
      <!-- 특허증 3개 -->
      <div class="cert-card" data-img="/images/cert/cert_09.webp" data-name="특허증 · 다중 영상 스트림 녹화 방법 및 그 장치">
        <div class="cert-img-wrap"><img src="/images/cert/cert_09.webp" alt="특허증 다중 영상 스트림 녹화" loading="eager" /></div>
        <div class="cert-info"><p class="cert-name">특허증</p><p class="cert-desc">다중 영상 스트림 녹화 방법 및 그 장치</p></div>
      </div>
      <div class="cert-card" data-img="/images/cert/cert_10.webp" data-name="특허증 · 내용기반 영상검색 장치 및 방법">
        <div class="cert-img-wrap"><img src="/images/cert/cert_10.webp" alt="특허증 내용기반 영상검색" loading="eager" /></div>
        <div class="cert-info"><p class="cert-name">특허증</p><p class="cert-desc">내용기반 영상검색 장치 및 방법</p></div>
      </div>
      <div class="cert-card" data-img="/images/cert/cert_11.webp" data-name="특허증 · 디지털 방송 모니터링 시스템">
        <div class="cert-img-wrap"><img src="/images/cert/cert_11.webp" alt="특허증 디지털 방송 모니터링" loading="eager" /></div>
        <div class="cert-info"><p class="cert-name">특허증</p><p class="cert-desc">디지털 방송 모니터링 시스템</p></div>
      </div>
      <!-- 나머지 4개 -->
      <div class="cert-card cert-card-anim" data-img="/images/cert/cert_02.webp" data-name="정보통신공사등록증" style="transition-delay:0.36s">
        <div class="cert-img-wrap"><img src="/images/cert/cert_02.webp" alt="정보통신공사등록증" loading="eager" /></div>
        <div class="cert-info"><p class="cert-name">정보통신공사등록증</p><p class="cert-desc">공사업 면허 보유</p></div>
      </div>
      <div class="cert-card cert-card-anim" data-img="/images/cert/cert_03.webp" data-name="이노비즈 인증" style="transition-delay:0.42s">
        <div class="cert-img-wrap"><img src="/images/cert/cert_03.webp" alt="이노비즈 인증" loading="eager" /></div>
        <div class="cert-info"><p class="cert-name">이노비즈 인증</p><p class="cert-desc">기술혁신형 중소기업</p></div>
      </div>
      <div class="cert-card cert-card-anim" data-img="/images/cert/cert_04.webp" data-name="경영혁신형중소기업확인서" style="transition-delay:0.48s">
        <div class="cert-img-wrap"><img src="/images/cert/cert_04.webp" alt="경영혁신형중소기업확인서" loading="eager" /></div>
        <div class="cert-info"><p class="cert-name">경영혁신형중소기업확인서</p><p class="cert-desc">메인비즈 공식 인증</p></div>
      </div>
      <div class="cert-card cert-card-anim" data-img="/images/cert/cert_05.webp" data-name="소프트웨어사업자" style="transition-delay:0.54s">
        <div class="cert-img-wrap"><img src="/images/cert/cert_05.webp" alt="소프트웨어사업자" loading="eager" /></div>
        <div class="cert-info"><p class="cert-name">소프트웨어사업자</p><p class="cert-desc">SW 사업자 확인서</p></div>
      </div>
    </div>
  </div>
</section>

<style>
  /* 라이트박스 - 사용 안함 */
  .cert-lb { display:none !important; }

  /* 섹션 */
  .s-cert { background:linear-gradient(180deg,#ffffff 0%,#eef2fb 60%,#dce6f8 100%); padding:100px 0 90px; }
  .cert-inner { max-width:1680px; margin:0 auto; padding:0 40px; text-align:center; }

  .cert-label { font-size:11px; font-weight:700; letter-spacing:0.22em; text-transform:uppercase; color:#1a2f8a; margin-bottom:14px; display:flex; align-items:center; justify-content:center; gap:10px; }
  .cert-label::before, .cert-label::after { content:''; width:28px; height:1px; background:#1a2f8a; display:block; opacity:0.5; }
  .cert-title { font-size:clamp(28px,3.5vw,44px); font-weight:800; color:#0d1a3a; letter-spacing:-0.03em; margin-bottom:14px; display:flex; align-items:center; justify-content:center; gap:12px; }
  .cert-title-icon { flex-shrink:0; }
  .cert-sub { font-size:14px; color:#8896a4; line-height:1.7; margin-bottom:48px; }

  /* 한 줄 11열 그리드 */
  .cert-grid { display:grid; gap:16px; margin-bottom:0; opacity:1; transform:none; }
  .cert-grid-all { grid-template-columns:repeat(10,1fr); }

  /* 카드 */
  .cert-card {
    background:rgba(255,255,255,0.88); border:1px solid rgba(26,47,138,0.1);
    border-radius:10px; overflow:hidden; cursor:default;
    transition:box-shadow 0.25s, border-color 0.25s, transform 0.25s;
  }
  .cert-card:hover {
    box-shadow:0 8px 28px rgba(26,47,138,0.15);
    border-color:#1a2f8a;
  }

  /* 이미지 */
  .cert-img-wrap {
    width:100%; aspect-ratio:3/4; background:#f5f7fb;
    display:flex; align-items:center; justify-content:center;
    overflow:hidden; padding:6px; box-sizing:border-box;
  }
  .cert-img-wrap img {
    width:100%; height:100%; object-fit:contain;
    transition:transform 0.35s cubic-bezier(0.16,1,0.3,1);
  }
  .cert-card:hover .cert-img-wrap img { transform:scale(1.06); }

  /* 카드 하단 */
  .cert-info { padding:8px 5px 10px; text-align:center; border-top:1px solid #f0f4fb; }
  .cert-name { font-size:12px; font-weight:700; color:#0d1a3a; margin:0 0 2px; line-height:1.35; letter-spacing:-0.03em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .cert-desc { font-size:12px; color:#9aa4b8; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

  /* 카드 등장 애니메이션 */
  .cert-card-anim {
    opacity:0;
    transform:translateY(20px);
    transition:opacity 0.5s cubic-bezier(0.16,1,0.3,1),
               transform 0.5s cubic-bezier(0.16,1,0.3,1),
               box-shadow 0.25s, border-color 0.25s, transform 0.25s;
  }
  .cert-card-anim.visible {
    opacity:1;
    transform:translateY(0);
  }
  .cert-card-anim.visible:hover {
    transform:translateY(-3px);
  }

  /* fade-up */
  .fade-up { opacity:0; transform:translateY(28px); transition:opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1); transition-delay:0.15s; will-change:transform,opacity; }
  .fade-up.visible { opacity:1; transform:translateY(0); }
  .fade-up-d1 { transition-delay:0.25s; }
  .fade-up-d2 { transition-delay:0.35s; }
  .fade-up-d3 { transition-delay:0.45s; }

  @media (max-width:1200px) { .cert-grid-all { grid-template-columns:repeat(6,1fr); } }
  @media (max-width:768px) { .cert-grid-all { grid-template-columns:repeat(4,1fr); gap:10px; } .s-cert { padding:70px 0 60px; } .cert-inner { padding:0 20px; } }
  @media (max-width:480px) { .cert-grid-all { grid-template-columns:repeat(3,1fr); } }
</style>

<script is:inline>
(function () {
  // fade-up 옵저버 (헤더)
  const targets = document.querySelectorAll('#sec-cert .fade-up');
  const obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  targets.forEach(function (el) { obs.observe(el); });

  // 카드 등장 옵저버
  const cardObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        cardObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.05, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('#sec-cert .cert-card-anim').forEach(function (el) {
    cardObs.observe(el);
  });


})();
</script>
