---
// src/components/SecCert.astro
---
<section class="sec s-cert" id="sec-cert">
  <div class="cert-inner">
    <div class="cert-label fade-up">CERTIFICATION</div>
    <h2 class="cert-title fade-up fade-up-d1">인증현황</h2>
    <p class="cert-sub fade-up fade-up-d2">이담에스티가 보유한 공인 인증 및 특허 현황입니다</p>

    <div class="cert-grid fade-up fade-up-d3">

      <div class="cert-card">
        <div class="cert-img-wrap">
          <div class="cert-img-placeholder">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
            <span>인증서 이미지</span>
          </div>
        </div>
        <div class="cert-info">
          <div class="cert-name">이노비즈 인증</div>
          <div class="cert-desc">기술혁신형 중소기업 인증</div>
        </div>
      </div>

      <div class="cert-card">
        <div class="cert-img-wrap">
          <div class="cert-img-placeholder">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
            <span>인증서 이미지</span>
          </div>
        </div>
        <div class="cert-info">
          <div class="cert-name">ISO 9001</div>
          <div class="cert-desc">품질경영시스템 국제인증</div>
        </div>
      </div>

      <div class="cert-card">
        <div class="cert-img-wrap">
          <div class="cert-img-placeholder">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
            <span>인증서 이미지</span>
          </div>
        </div>
        <div class="cert-info">
          <div class="cert-name">벤처기업 확인</div>
          <div class="cert-desc">벤처기업 공식 인증</div>
        </div>
      </div>

      <div class="cert-card">
        <div class="cert-img-wrap">
          <div class="cert-img-placeholder">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
            <span>인증서 이미지</span>
          </div>
        </div>
        <div class="cert-info">
          <div class="cert-name">정보통신공사업</div>
          <div class="cert-desc">정보통신공사업 면허 보유</div>
        </div>
      </div>

      <div class="cert-card">
        <div class="cert-img-wrap">
          <div class="cert-img-placeholder">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
            <span>인증서 이미지</span>
          </div>
        </div>
        <div class="cert-info">
          <div class="cert-name">특허 제1호</div>
          <div class="cert-desc">특허 등록증</div>
        </div>
      </div>

      <div class="cert-card">
        <div class="cert-img-wrap">
          <div class="cert-img-placeholder">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
            <span>인증서 이미지</span>
          </div>
        </div>
        <div class="cert-info">
          <div class="cert-name">직접생산증명</div>
          <div class="cert-desc">조달청 직접생산 확인증</div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .s-cert {
    background: #f7f9fb;
    padding: 100px 0 80px;
  }
  .cert-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
    text-align: center;
  }
  .cert-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.22em;
    text-transform: uppercase; color: #1a2f8a;
    margin-bottom: 14px;
    display: flex; align-items: center; justify-content: center; gap: 10px;
  }
  .cert-label::before,
  .cert-label::after { content: ''; width: 28px; height: 2px; background: #1a2f8a; display: block; }
  .cert-title {
    font-size: clamp(28px, 3.5vw, 44px); font-weight: 800;
    color: #0D1F2D; letter-spacing: -0.03em; margin-bottom: 14px;
  }
  .cert-sub {
    font-size: 15px; color: #6b7a8d; line-height: 1.7;
    margin-bottom: 56px;
  }
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .cert-card {
    background: #fff;
    border: 1px solid #e8edf2;
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.25s, transform 0.25s;
  }
  .cert-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    transform: translateY(-3px);
  }
  .cert-img-wrap {
    width: 100%;
    aspect-ratio: 3/2;
    overflow: hidden;
    background: #f0f3f7;
  }
  .cert-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .cert-img-placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 8px; color: #b0bcc9;
    font-size: 11px;
  }
  .cert-info {
    padding: 16px 18px;
    text-align: left;
  }
  .cert-name {
    font-size: 14px; font-weight: 700; color: #0D1F2D;
    margin-bottom: 4px;
  }
  .cert-desc {
    font-size: 12px; color: #8896a4;
  }

  @media (max-width: 768px) {
    .cert-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .s-cert { padding: 70px 0 60px; }
  }
  @media (max-width: 480px) {
    .cert-grid { grid-template-columns: 1fr; }
  }
</style>
