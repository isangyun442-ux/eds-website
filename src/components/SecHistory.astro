---
<section class="sec s5" id="sec6">

  <!-- 웨이브 SVG 배경 -->
  <div class="hist-waves" aria-hidden="true">
    <svg class="waves-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 1800" preserveAspectRatio="xMidYMid slice">
