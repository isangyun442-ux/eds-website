<style>
  .s5 {
    background: linear-gradient(170deg, #060e18 0%, #0a1628 35%, #0d1c38 65%, #070f1e 100%);
    position: relative;
    overflow: hidden;
  }
  /* 웨이브 배경 */
  .hist-waves {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .waves-svg {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0; left: 0;
  }

  .hist-inner {
    position: relative;
    z-index: 1;
    max-width: 900px; margin: 0 auto;
    padding: 60px 80px 60px;
  }

  .h-header { text-align: center; margin-bottom: 48px; }
  .h-eyebrow {
    display: inline-flex; align-items: center; gap: 12px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.24em;
    text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 18px;
  }
  .h-eyebrow::before, .h-eyebrow::after {
    content: ''; display: block; width: 32px; height: 1px;
    background: rgba(255,255,255,0.4); opacity: 1;
  }
  .h-title {
    font-size: clamp(28px, 3.5vw, 48px);
    font-weight: 900; letter-spacing: -0.05em;
    color: #fff; margin-bottom: 14px;
  }
  .h-sub { font-size: 15px; color: rgba(255,255,255,0.55); line-height: 1.7; }

  .timeline { position: relative; padding-bottom: 32px; }
  .tl-line {
    position: absolute; top: 0; bottom: 0; left: 92px;
    width: 1px; background: rgba(255,255,255,0.12);
  }

  .tl-row {
    display: grid; grid-template-columns: 92px 0 1fr;
    gap: 0 32px; align-items: flex-start; position: relative;
  }

  .tl-year-col { display: flex; justify-content: flex-end; padding-right: 24px; padding-top: 14px; }
  .tl-year { font-size: 14px; font-weight: 900; letter-spacing: -0.02em; color: #fff; font-weight: 900; }

  .tl-dot-col { display: flex; justify-content: center; padding-top: 19px; position: relative; z-index: 2; }
  .tl-dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: #0a1628; border: 2px solid rgba(255,255,255,0.5); flex-shrink: 0; margin-left: -4px;
  }

  .tl-content-col { padding: 8px 0 18px 0; }
  .tl-card { display: flex; flex-direction: column; }
  .tl-item {
    display: flex; gap: 16px; align-items: flex-start;
    padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .tl-item:last-child { border-bottom: none; }
  .tl-item:first-child { padding-top: 0; }
  .tl-month {
    font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.55);
    letter-spacing: 0.04em; flex-shrink: 0; min-width: 34px; padding-top: 2px;
  }
  .tl-desc { font-size: 14px; line-height: 1.9; color: rgba(255,255,255,0.80); letter-spacing: 0.01em; }

  .tl-end {
    display: flex; flex-direction: column;
    align-items: flex-start; padding-left: 80px;
    margin-top: 8px; gap: 8px;
  }
  .tl-end-dot { width: 14px; height: 14px; border-radius: 50%; background: rgba(255,255,255,0.4); margin-left: 5px; }
  .tl-end-label {
    font-size: 10px; font-weight: 700; letter-spacing: 0.22em;
    color: rgba(255,255,255,0.35); text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .hist-inner { padding: 48px 32px 48px; }
    .tl-line { left: 64px; }
    .tl-row { grid-template-columns: 64px 0 1fr; gap: 0 20px; }
    .tl-year-col { padding-right: 18px; }
    .tl-year { font-size: 12px; }
    .tl-end { padding-left: 52px; }
  }
  @media (max-width: 480px) {
    .hist-inner { padding: 40px 20px 40px; }
    .tl-line { left: 54px; }
    .tl-row { grid-template-columns: 54px 0 1fr; gap: 0 14px; }
  }
</style>

<script is:inline>
  (function() {
    const targets = document.querySelectorAll('#sec5 .tl-row, #sec5 .h-header .fade-up');
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.08, rootMargin: '0px 0px -20px 0px' });
    targets.forEach(el => obs.observe(el));
  })();
</script>
