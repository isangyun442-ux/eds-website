      <path d="M-40,1480 C260,1424 600,1500 940,1448 C1160,1412 1340,1472 1480,1452" stroke="url(#wg2)" stroke-width="0.8" fill="none" opacity="0.3"/>
      <!-- 묶음 12 -->
