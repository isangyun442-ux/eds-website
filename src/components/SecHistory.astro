---
<section class="sec s5" id="sec6">

  <!-- 리본 웨이브 배경 -->
  <div class="hist-waves" aria-hidden="true">
    <canvas class="waves-canvas" id="histWaveCanvas"></canvas>
  </div>

  <div class="hist-inner">
    <div class="h-header">
      <span class="h-eyebrow fade-up" data-i18n="hist.eyebrow">Company History</span>
      <h2 class="h-title fade-up fade-up-d1" data-i18n="hist.title">EDS의 걸어온 길</h2>
      <p class="h-sub fade-up fade-up-d2" data-i18n="hist.sub">2007년 창립 이래 끊임없이 성장해온 이담에스티의 연혁입니다</p>
    </div>
    <div class="timeline">
      <div class="tl-line"></div>
      {history.map((h) => (
        <div class="tl-row fade-up">
          <div class="tl-year-col"><div class="tl-year">{h.year}</div></div>
          <div class="tl-dot-col"><div class="tl-dot"></div></div>
          <div class="tl-content-col">
            <div class="tl-card">
              {h.items.map((item) => (
                <div class="tl-item">
                  <span class="tl-month">{item.month}</span>
                  <span class="tl-desc">{item.desc}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
      <div class="tl-end">
        <div class="tl-end-dot"></div>
        <span class="tl-end-label" data-i18n="hist.founded">FOUNDED 2007</span>
      </div>
    </div>
  </div>
</section>

<!-- 클라이언트 사이드 스타일 로더 -->
<script is:inline>
(function(){
  fetch('/api/admin/design-styles?section=history')
    .then(r=>r.ok?r.json():null)
    .then(function(data){
      if(!data||!data.styles)return;
      var s=data.styles;
      var st=document.getElementById('__hist_dynamic_styles__');
      if(!st){st=document.createElement('style');st.id='__hist_dynamic_styles__';document.head.appendChild(st);}
      st.textContent=[
        s.hBg1&&s.hBg2?'#sec6 .s5{background:linear-gradient(170deg,'+s.hBg1+' 0%,'+s.hBg2+' 100%)!important;}':'',
        s.hTitleColor?'#sec6 .h-title{color:'+s.hTitleColor+'!important;}':'',
        s.hTitleSize?'#sec6 .h-title{font-size:'+s.hTitleSize+'px!important;}':'',
        s.hSubColor?'#sec6 .h-sub,#sec6 .h-eyebrow,#sec6 .tl-month{color:'+s.hSubColor+'!important;}':'',
        s.hYearColor?'#sec6 .tl-year{color:'+s.hYearColor+'!important;}':'',
        s.hDescColor?'#sec6 .tl-desc{color:'+s.hDescColor+'!important;}':'',
        s.hDescSize?'#sec6 .tl-desc{font-size:'+s.hDescSize+'px!important;}':'',
        s.hLineHeight?'#sec6 .tl-desc{line-height:'+s.hLineHeight+'!important;}':'',
        s.hLineColor?'#sec6 .tl-line{background:'+s.hLineColor+'!important;}':'',
        s.hDotColor?'#sec6 .tl-dot{border-color:'+s.hDotColor+'!important;}#sec6 .tl-end-dot{background:'+s.hDotColor+'!important;}':'',
      ].join('');
      // 제목/서브타이틀만 복원 (연혁 항목 건드리지 않음)
      if(data.texts){
        var t=data.texts;
        var sec6=document.getElementById('sec6');
        if(sec6){
          if(t.histTitle){var ht=sec6.querySelector('.h-title');if(ht)ht.textContent=t.histTitle;}
          if(t.histSub){var hs=sec6.querySelector('.h-sub');if(hs)hs.textContent=t.histSub;}
        }
      }
    }).catch(function(){});
})();
</script>

<style>
  .s5 {
    background: linear-gradient(180deg, #ffffff 0%, #eef2fb 50%, #dce6f8 100%);
    position: relative;
    overflow: hidden;
  }
  /* 웨이브 배경 */
  .hist-waves {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    will-change: transform;
  }
  .waves-canvas {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0; left: 0;
  }

  .hist-inner {
    position: relative;
    z-index: 1;
    max-width: 900px; margin: 0 auto;
    padding: 60px 80px 60px;
  }

  .h-header { text-align: center; margin-bottom: 48px; }
  .h-eyebrow {
    display: inline-flex; align-items: center; gap: 12px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.24em;
    text-transform: uppercase; color: #1a2f8a; margin-bottom: 18px;
  }
  .h-eyebrow::before, .h-eyebrow::after {
    content: ''; display: block; width: 32px; height: 1px;
    background: #1a2f8a; opacity: 0.4;
  }
  .h-title {
    font-size: clamp(28px, 3.5vw, 48px);
    font-weight: 900; letter-spacing: -0.05em;
    color: #0d1a3a; margin-bottom: 14px;
  }
  .h-sub { font-size: 15px; color: #6b7a99; line-height: 1.7; }

  .timeline { position: relative; padding-bottom: 32px; }
  .tl-line {
    position: absolute; top: 0; bottom: 0; left: 92px;
    width: 1px; background: rgba(26,47,138,0.15);
  }

  .tl-row {
    display: grid; grid-template-columns: 92px 0 1fr;
    gap: 0 32px; align-items: flex-start; position: relative;
  }

  .tl-year-col { display: flex; justify-content: flex-end; padding-right: 24px; padding-top: 14px; }
  .tl-year { font-size: 14px; font-weight: 900; letter-spacing: -0.02em; color: #0d1a3a; font-weight: 900; }

  .tl-dot-col { display: flex; justify-content: center; padding-top: 19px; position: relative; z-index: 2; }
  .tl-dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: #ffffff; border: 2px solid #1a2f8a; flex-shrink: 0; margin-left: -4px;
  }

  .tl-content-col { padding: 8px 0 18px 0; }
  .tl-card { display: flex; flex-direction: column; }
  .tl-item {
    display: flex; gap: 16px; align-items: flex-start;
    padding: 6px 0;
  }
  .tl-item:last-child { border-bottom: none; }
  .tl-item:first-child { padding-top: 0; }
  .tl-month {
    font-size: 11px; font-weight: 700; color: #1a2f8a;
    letter-spacing: 0.04em; flex-shrink: 0; min-width: 34px; padding-top: 2px;
  }
  .tl-desc { font-size: 14px; line-height: 1.9; color: #444e6a; letter-spacing: 0.01em; }

  .tl-end {
    display: flex; flex-direction: column;
    align-items: flex-start; padding-left: 80px;
    margin-top: 8px; gap: 8px;
  }
  .tl-end-dot { width: 14px; height: 14px; border-radius: 50%; background: #1a2f8a; margin-left: 5px; }
  .tl-end-label {
    font-size: 10px; font-weight: 700; letter-spacing: 0.22em;
    color: #9aa4b8; text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .hist-inner { padding: 48px 32px 48px; }
    .tl-line { left: 64px; }
    .tl-row { grid-template-columns: 64px 0 1fr; gap: 0 20px; }
    .tl-year-col { padding-right: 18px; }
    .tl-year { font-size: 12px; }
    .tl-end { padding-left: 52px; }
  }
  @media (max-width: 480px) {
    .hist-inner { padding: 40px 20px 40px; }
    .tl-line { left: 54px; }
    .tl-row { grid-template-columns: 54px 0 1fr; gap: 0 14px; }
  }
</style>

<script is:inline>
(function() {
  /* 타임라인 fade-up */
  /* 스크롤 재실행 fade-up */
  const targets = document.querySelectorAll('#sec6 .tl-row, #sec6 .h-header .fade-up');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
      } else {
        e.target.classList.remove('visible');
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -20px 0px' });
  targets.forEach(el => obs.observe(el));

  /* 패럴렉스 */
  function onScroll() {
    const section = document.getElementById('sec6');
    const waves = section ? section.querySelector('.hist-waves') : null;
    if (!section || !waves) return;
    const rect = section.getBoundingClientRect();
    const scrolled = -rect.top;
    waves.style.transform = 'translateY(' + (scrolled * 0.25) + 'px)';
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  /* 리본 웨이브 캔버스 */
  function drawWaves() {
    const canvas = document.getElementById('histWaveCanvas');
    if (!canvas) return;
    const section = canvas.closest('section');
    const W = section.offsetWidth || 1440;
    const H = section.offsetHeight || 2000;
    canvas.width = W;
    canvas.height = H;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, W, H);

    function waveY(x, cy, amp, freq, phase) {
      return cy + amp * Math.sin(freq * x + phase);
    }

    function drawRibbon(cy, amp, freq, phase, lineCount, spread, colorA, colorB) {
      for (let i = 0; i < lineCount; i++) {
        const t = i / (lineCount - 1);
        const offset = (i - lineCount / 2) * spread;
        const edgeFade = Math.sin(Math.PI * t);
        const lw = 0.3 + edgeFade * 0.8;
        const op = 0.06 + edgeFade * 0.55;
        const r = Math.round(colorA[0] + (colorB[0] - colorA[0]) * t);
        const g = Math.round(colorA[1] + (colorB[1] - colorA[1]) * t);
        const b = Math.round(colorA[2] + (colorB[2] - colorA[2]) * t);
        ctx.beginPath();
        ctx.strokeStyle = `rgba(${r},${g},${b},${op})`;
        ctx.lineWidth = lw;
        for (let x = 0; x <= W; x += 3) {
          const y = waveY(x, cy + offset, amp + offset * 0.12, freq, phase);
          x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.stroke();
      }
    }

    const navy  = [26,  47, 138];
    const white = [200, 215, 255];

    /* 리본 1 */
    drawRibbon(H * 0.18, H * 0.06, 6.28 / W * 1.2, 0,             60, 3.0, navy, white);
    /* 리본 2 — 중간 강조 */
    drawRibbon(H * 0.46, H * 0.07, 6.28 / W * 1.0, Math.PI * 0.6, 75, 2.8, white, navy);
    /* 리본 3 */
    drawRibbon(H * 0.75, H * 0.055, 6.28 / W * 1.3, Math.PI * 1.3, 55, 2.6, navy, white);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', drawWaves);
  } else {
    drawWaves();
  }
  window.addEventListener('resize', drawWaves);
})();
</script>
