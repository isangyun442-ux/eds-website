  <div class="hist-inner">
    <div class="h-header">
      <span class="h-eyebrow fade-up" data-i18n="hist.eyebrow">Company History</span>
      <h2 class="h-title fade-up fade-up-d1" data-i18n="hist.title">EDS의 걸어온 길</h2>
      <p class="h-sub fade-up fade-up-d2" data-i18n="hist.sub">2007년 창립 이래 끊임없이 성장해온 이담에스티의 연혁입니다</p>
    </div>
    <div class="timeline">
      <div class="tl-line"></div>
      {history.map((h) => (
        <div class="tl-row fade-up">
          <div class="tl-year-col"><div class="tl-year">{h.year}</div></div>
          <div class="tl-dot-col"><div class="tl-dot"></div></div>
          <div class="tl-content-col">
            <div class="tl-card">
              {h.items.map((item) => (
                <div class="tl-item">
                  <span class="tl-month">{item.month}</span>
                  <span class="tl-desc">{item.desc}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
      <div class="tl-end">
        <div class="tl-end-dot"></div>
        <span class="tl-end-label" data-i18n="hist.founded">FOUNDED 2007</span>
      </div>
    </div>
