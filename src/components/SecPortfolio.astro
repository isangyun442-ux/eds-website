---
// src/components/SecPortfolio.astro
---
<section class="sec s4" id="sec4">

  <!-- 배경 이미지들 -->
  <div class="port-bg" id="port-bg">
    <div class="port-bg-slide active" style="background-image:url('/images/HUFS_ST_04.jpg')"></div>
    <div class="port-bg-slide" style="background-image:url('/images/SC_ST_09.jpg')"></div>
    <div class="port-bg-slide" style="background-image:url('/images/GMC_S_01.jpg')"></div>
    <div class="port-bg-slide" style="background-image:url('/images/GKDE_S_08.jpg')"></div>
    <div class="port-bg-slide" style="background-image:url('/images/KTV_BS_01.jpg')"></div>
  </div>

  <!-- 오버레이 -->
  <div class="port-overlay"></div>

  <!-- 콘텐츠 -->
  <div class="port-content">

    <!-- 상단 라벨 -->
    <div class="port-eyebrow">
      <span class="port-tag">Portfolio</span>
      <h2 class="port-heading">구축 사례</h2>
    </div>

    <!-- 중앙 텍스트 -->
    <div class="port-center">
      <div class="port-slides" id="port-slides">

        <div class="port-slide active">
          <span class="port-n">01 / 05</span>
          <h3 class="port-title">한국외국어대학교<br>스튜디오 첨단화</h3>
          <p class="port-desc">LED 디스플레이 &nbsp;·&nbsp; 2025.02 &nbsp;·&nbsp; 교육기관</p>
        </div>

        <div class="port-slide">
          <span class="port-n">02 / 05</span>
          <h3 class="port-title">서울사이버대학교<br>스마트 강의실 고도화</h3>
          <p class="port-desc">스마트 강의실 &nbsp;·&nbsp; 2024.11 &nbsp;·&nbsp; 교육기관</p>
        </div>

        <div class="port-slide">
          <span class="port-n">03 / 05</span>
          <h3 class="port-title">공주대학교<br>이러닝 스튜디오</h3>
          <p class="port-desc">이러닝 스튜디오 &nbsp;·&nbsp; 2024.09 &nbsp;·&nbsp; 교육기관</p>
        </div>

        <div class="port-slide">
          <span class="port-n">04 / 05</span>
          <h3 class="port-title">경기도교육청<br>UHD 방송제작</h3>
          <p class="port-desc">방송제작 &nbsp;·&nbsp; 2024.06 &nbsp;·&nbsp; 공공기관</p>
        </div>

        <div class="port-slide">
          <span class="port-n">05 / 05</span>
          <h3 class="port-title">KTV<br>방송 인프라 시스템</h3>
          <p class="port-desc">방송 인프라 &nbsp;·&nbsp; 2024.03 &nbsp;·&nbsp; 방송국</p>
        </div>

      </div>
    </div>

    <!-- 하단: 화살표 + 도트 + 전체보기 -->
    <div class="port-bottom">
      <div class="port-dots" id="port-dots">
        <span class="port-dot active"></span>
        <span class="port-dot"></span>
        <span class="port-dot"></span>
        <span class="port-dot"></span>
        <span class="port-dot"></span>
      </div>
      <div class="port-arrows">
        <button class="port-btn" id="port-prev">←</button>
        <button class="port-btn" id="port-next">→</button>
      </div>
      <a href="/works" class="port-all">전체 구축사례 보기 →</a>
    </div>

  </div>

</section>

<style>
  .s4 {
    position: relative;
    height: 100vh;
    overflow: hidden;
    display: flex; align-items: stretch;
  }

  /* ── 배경 ── */
  .port-bg { position: absolute; inset: 0; }
  .port-bg-slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.4,0,0.2,1);
  }
  .port-bg-slide.active { opacity: 1; }

  /* ── 오버레이 ── */
  .port-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to right,
      rgba(10,20,60,0.75) 0%,
      rgba(10,20,60,0.4) 60%,
      rgba(10,20,60,0.2) 100%
    );
    z-index: 1;
  }

  /* ── 콘텐츠 ── */
  .port-content {
    position: relative; z-index: 2;
    width: 100%; display: flex; flex-direction: column;
    justify-content: space-between;
    padding: 80px 80px 60px;
    max-width: 900px;
  }

  /* ── 상단 라벨 ── */
  .port-tag {
    font-size: 11px; font-weight: 800; letter-spacing: 0.24em;
    text-transform: uppercase; color: rgba(255,255,255,0.5);
    display: flex; align-items: center; gap: 10px; margin-bottom: 10px;
  }
  .port-heading {
    font-size: clamp(14px, 1.4vw, 20px); font-weight: 700;
    color: rgba(255,255,255,0.7); letter-spacing: -0.02em;
  }

  /* ── 중앙 슬라이드 텍스트 ── */
  .port-slides { position: relative; min-height: 160px; }
  .port-slide {
    position: absolute; top: 0; left: 0;
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.6s, transform 0.6s;
    pointer-events: none;
  }
  .port-slide.active {
    opacity: 1; transform: translateY(0);
    position: relative; pointer-events: auto;
  }
  .port-n {
    font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
    color: rgba(255,255,255,0.45); display: block; margin-bottom: 16px;
  }
  .port-title {
    font-size: clamp(32px, 5vw, 72px);
    font-weight: 900; letter-spacing: -0.04em;
    color: #fff; line-height: 1.1; margin-bottom: 20px;
  }
  .port-desc {
    font-size: 14px; color: rgba(255,255,255,0.6); letter-spacing: 0.02em;
  }

  /* ── 하단 ── */
  .port-bottom {
    display: flex; align-items: center; gap: 32px; flex-wrap: wrap;
  }
  .port-dots { display: flex; gap: 8px; }
  .port-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(255,255,255,0.3); cursor: pointer;
    transition: background 0.3s, transform 0.3s;
  }
  .port-dot.active { background: #fff; transform: scale(1.4); }

  .port-arrows { display: flex; gap: 10px; }
  .port-btn {
    width: 48px; height: 48px;
    background: rgba(255,255,255,0.1);
    border: 1.5px solid rgba(255,255,255,0.35);
    color: #fff; font-size: 16px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, border-color 0.2s;
    font-family: inherit;
  }
  .port-btn:hover { background: rgba(255,255,255,0.2); border-color: #fff; }
  .port-btn:disabled { opacity: 0.2; cursor: default; }

  .port-all {
    margin-left: auto;
    font-size: 12px; font-weight: 800; color: #fff;
    text-decoration: none; letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 32px;
    border: 1.5px solid rgba(255,255,255,0.5);
    transition: background 0.2s, border-color 0.2s;
  }
  .port-all:hover { background: rgba(255,255,255,0.1); border-color: #fff; }

  @media (max-width: 768px) {
    .port-content { padding: 60px 32px 40px; }
    .port-all { margin-left: 0; }
  }
</style>

<script is:inline>
(function () {
  const bgs    = document.querySelectorAll('.port-bg-slide');
  const slides = document.querySelectorAll('.port-slide');
  const dots   = document.querySelectorAll('.port-dot');
  const btnPrev = document.getElementById('port-prev');
  const btnNext = document.getElementById('port-next');
  const total  = slides.length;
  let cur = 0;

  function go(n) {
    bgs[cur].classList.remove('active');
    slides[cur].classList.remove('active');
    dots[cur].classList.remove('active');
    cur = (n + total) % total;
    bgs[cur].classList.add('active');
    slides[cur].classList.add('active');
    dots[cur].classList.add('active');
    btnPrev.disabled = cur === 0;
    btnNext.disabled = cur === total - 1;
  }

  btnPrev.addEventListener('click', function () { go(cur - 1); });
  btnNext.addEventListener('click', function () { go(cur + 1); });
  dots.forEach(function (dot, i) { dot.addEventListener('click', function () { go(i); }); });

  // 키보드
  document.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft') go(cur - 1);
    if (e.key === 'ArrowRight') go(cur + 1);
  });

  go(0);
})();
</script>
