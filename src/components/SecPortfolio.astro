<style is:global>
  .s4 {
    position: relative;
    height: 100vh; min-height: 600px;
    overflow: hidden;
    display: flex; align-items: center;
  }

  /* ?�?� 배경 ?�?� */
  .port-bg { position: absolute; inset: 0; }
  .port-bg-slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0; filter: blur(12px);
    transform: scale(1.08);
    transition: opacity 0.8s;
  }
  .port-bg-slide.active { opacity: 1; }
  .port-overlay {
    position: absolute; inset: 0;
    background: rgba(8, 16, 48, 0.72);
    z-index: 1;
  }

  /* ?�?� 콘텐�??�?� */
  .port-content {
    position: relative; z-index: 2;
    width: 100%; display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  /* ?�?� ?�쪽 ?��?지 ?�널 ?�?� */
  .port-left {
    flex: 0 0 680px;
    padding: 20px 20px 20px 0;
    display: flex; align-items: center;
  }
  .port-img-wrap {
    position: relative;
    width: 100%; height: 560px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5);
    cursor: pointer;
    overflow: hidden;
  }
  /* ?�버 ??"?�세??보기" ?�버?�이 */
  .port-img-hover {
    position: absolute; inset: 0; z-index: 10;
    background: rgba(8,16,48,0.45);
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }
  .port-img-wrap:hover .port-img-hover { opacity: 1; }
  .port-img-hover span {
    font-size: 13px; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: #fff;
    border: 1.5px solid rgba(255,255,255,0.7);
    padding: 10px 24px;
  }
  .port-img-slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.4,0,0.2,1);
  }
  .port-img-slide.active { opacity: 1; }

  /* ?�?� ?�네??3???�?� */
  .port-thumbs {
    display: flex; gap: 10px;
    margin-bottom: 28px;
  }
  .port-thumb {
    width: 90px; height: 60px;
    background-size: cover; background-position: center;
    border-radius: 4px;
    cursor: pointer;
    opacity: 0.4;
    border: 2px solid transparent;
    transition: opacity 0.3s, border-color 0.3s, transform 0.3s;
    flex-shrink: 0;
  }
  .port-thumb:hover { opacity: 0.75; transform: translateY(-2px); }
  .port-thumb.active {
    opacity: 1;
    border-color: #fff;
    transform: translateY(-2px);
  }
  .port-thumb.hidden { opacity: 0; pointer-events: none; }

  /* ?�?� ?�른�??�스???�?� */
  .port-right {
    flex: 0 0 480px;
    padding: 80px 40px 60px 60px;
    display: flex; flex-direction: column;
    justify-content: center; gap: 0;
    /* ?�체 ?�이 고정 ???��? ?�소 ?�직임 방�? */
    height: 100vh;
    min-height: 600px;
    box-sizing: border-box;
  }
  .port-eyebrow {
    font-size: 20px; font-weight: 900; letter-spacing: 0.28em;
    text-transform: uppercase; color: #fff;
    margin-bottom: 28px;
    display: flex; align-items: center; gap: 12px;
  }
  .port-eyebrow::before { content: ''; width: 28px; height: 2px; background: #fff; display: block; }

  /* ?�라?�드 ?�스????고정 ?�이�??�이?�웃 ?�동 방�? */
  .port-slides {
    position: relative;
    height: 200px;
    margin-bottom: 40px;
    flex-shrink: 0;
  }
  .port-slide {
    position: absolute; top: 0; left: 0; width: 100%;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.6s, transform 0.6s;
    pointer-events: none;
  }
  .port-slide.active {
    opacity: 1; transform: translateY(0);
    pointer-events: auto;
  }
  .port-title {
    font-size: clamp(20px, 2.4vw, 38px);
    font-weight: 900; letter-spacing: -0.04em;
    color: #fff; line-height: 1.2; margin-bottom: 16px;
  }
  .port-sub {
    font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.5); letter-spacing: 0.04em;
    margin-bottom: 20px;
  }
  .port-desc {
    font-size: 13px; color: rgba(255,255,255,0.6);
    line-height: 1.9; max-width: 400px;
    display: -webkit-box; -webkit-line-clamp: 3;
    -webkit-box-orient: vertical; overflow: hidden;
  }

  /* ?�?� ?�단 컨트�??�?� */
  .port-bottom {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  .port-arrows { display: flex; gap: 10px; }
  .port-btn {
    width: 48px; height: 48px;
    background: rgba(255,255,255,0.08);
    border: 1.5px solid rgba(255,255,255,0.3);
    color: #fff; font-size: 16px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, border-color 0.2s;
    font-family: inherit;
  }
  .port-btn:hover { background: rgba(255,255,255,0.18); border-color: #fff; }
  .port-btn:disabled { opacity: 0.2; cursor: default; }

  /* 카운??*/
  .port-counter {
    font-size: 13px; color: rgba(255,255,255,0.5);
    font-weight: 600; letter-spacing: 0.05em;
  }
  .port-cur-num { color: #fff; font-size: 18px; font-weight: 900; }

  .port-all {
    display: inline-flex; align-items: center;
    margin-top: 16px;
    font-size: 12px; font-weight: 800; color: #fff;
    text-decoration: none; letter-spacing: 0.1em; text-transform: uppercase;
    height: 48px; padding: 0 28px;
    border: 1.5px solid rgba(255,255,255,0.4);
    transition: background 0.2s, border-color 0.2s;
    white-space: nowrap;
    align-self: flex-start;
  }
  .port-all:hover { background: rgba(255,255,255,0.1); border-color: #fff; }

  @media (max-width: 900px) {
    .port-content { flex-direction: column; }
    .port-left { flex: 0 0 auto; width: 100%; height: 40vh; padding: 20px; }
    .port-img-wrap { height: 100%; }
    .port-right { padding: 40px 32px; }
    .port-all { margin-left: 0; }
  }
</style>

<!-- ?�적 ?�로?�트 ?�이???�라?�언?�에 ?�달 -->
<script is:inline define:vars={{ staticProjectsJSON: JSON.stringify(projects) }}>
  window.__staticProjects = JSON.parse(staticProjectsJSON);
</script>

<script is:inline>
(function () {
  function initSlider(allProjects) {
    if (!allProjects || allProjects.length === 0) return;

    const bg      = document.getElementById('port-bg');
    const imgWrap = document.getElementById('port-img-wrap');
    const slidesEl = document.getElementById('port-slides');
    const totalEl = document.querySelector('.port-total-num');

    // DOM ?�구??    bg.innerHTML = allProjects.map((p, i) =>
      `<div class="port-bg-slide${i===0?' active':''}" style="background-image:url('${p.images&&p.images[0]?p.images[0]:''}')"></div>`
    ).join('');

    imgWrap.innerHTML = allProjects.map((p, i) =>
      `<div class="port-img-slide${i===0?' active':''}"></div>`
    ).join('');

    // background-image�?JS�?직접 ?�정 (inline style ?�싱 문제 방�?)
    const imgDivs = imgWrap.querySelectorAll('.port-img-slide');
    allProjects.forEach((p, i) => {
      if (p.images && p.images[0]) {
        imgDivs[i].style.backgroundImage = `url('${p.images[0]}')`;
        imgDivs[i].style.backgroundSize = 'cover';
        imgDivs[i].style.backgroundPosition = 'center';
      }
    });

    slidesEl.innerHTML = allProjects.map((p, i) =>
      `<div class="port-slide${i===0?' active':''}">
        <h3 class="port-title">${p.title||''}</h3>
        <p class="port-sub">${p.service||''}&nbsp;·&nbsp;${p.date||''}</p>
        <p class="port-desc">${p.overview||''}</p>
      </div>`
    ).join('');

    if (totalEl) totalEl.textContent = allProjects.length;

    // ?�라?�더 초기??    const bgs   = document.querySelectorAll('.port-bg-slide');
    const imgs  = document.querySelectorAll('.port-img-slide');
    const slds  = document.querySelectorAll('.port-slide');
    const total = slds.length;
    let cur = 0;

    const btnPrev = document.getElementById('port-prev');
    const btnNext = document.getElementById('port-next');
    const curNum  = document.getElementById('port-cur-num');
    const tPrev   = document.getElementById('port-thumb-prev');
    const tCur    = document.getElementById('port-thumb-cur');
    const tNext   = document.getElementById('port-thumb-next');

    function setThumb(el, idx) {
      if (idx < 0 || idx >= total) {
        el.classList.add('hidden');
        el.style.backgroundImage = '';
      } else {
        el.classList.remove('hidden');
        const url = allProjects[idx].images && allProjects[idx].images[0] ? allProjects[idx].images[0] : '';
        el.style.backgroundImage = url ? `url('${url}')` : '';
      }
    }

    function go(n) {
      bgs[cur].classList.remove('active');
      imgs[cur].classList.remove('active');
      slds[cur].classList.remove('active');
      cur = Math.max(0, Math.min(n, total - 1));
      bgs[cur].classList.add('active');
      imgs[cur].classList.add('active');
      slds[cur].classList.add('active');
      curNum.textContent = String(cur + 1).padStart(2, '0');
      setThumb(tPrev, cur - 1);
      setThumb(tCur,  cur);
      setThumb(tNext, cur + 1);
      btnPrev.disabled = cur === 0;
      btnNext.disabled = cur === total - 1;
    }

    tPrev.addEventListener('click', function () { go(cur - 1); });
    tCur.addEventListener('click',  function () { go(cur); });
    tNext.addEventListener('click', function () { go(cur + 1); });
    btnPrev.addEventListener('click', function () { go(cur - 1); });
    btnNext.addEventListener('click', function () { go(cur + 1); });

    // 메인 ?��?지 ?�릭 ??/works?open=ID ?�동
    imgWrap.addEventListener('click', function () {
      const p = allProjects[cur];
      if (p && p.id) {
        window.location.href = '/works?open=' + p.id;
      }
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft')  go(cur - 1);
      if (e.key === 'ArrowRight') go(cur + 1);
    });

    go(0);
  }

  // KV ?�이??+ ?�적 ?�이???�치�?  const staticProjects = window.__staticProjects || [];

  fetch('/api/admin/projects', { cache: 'no-store' })
    .then(r => r.json())
    .then(kvProjects => {
      if (Array.isArray(kvProjects) && kvProjects.length > 0) {
        // KV 내 중복 ID 제거 (Map으로 유일값만 유지)
        const kvMap = new Map(kvProjects.map(p => [p.id, p]));
        // 정적 데이터에서 KV에 없는 항목만 보완
        staticProjects.forEach(p => { if (!kvMap.has(p.id)) kvMap.set(p.id, p); });
        initSlider(Array.from(kvMap.values()));
      } else {
        initSlider(staticProjects);
      }
    })
    .catch(() => {
      initSlider(staticProjects);
    });
})();
</script>

