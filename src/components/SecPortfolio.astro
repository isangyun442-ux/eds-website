---
// src/components/SecPortfolio.astro
import { projects } from '../data/projects.js';
---
<section class="sec s4" id="sec4">

  <!-- 배경 (블러 + 어둡게) -->
  <div class="port-bg" id="port-bg">
    {projects.map((p, i) => (
      <div class={`port-bg-slide${i === 0 ? ' active' : ''}`} style={`background-image:url('${p.images && p.images[0] ? p.images[0] : ''}')`}></div>
    ))}
  </div>
  <div class="port-overlay"></div>

  <!-- 콘텐츠 -->
  <div class="port-content">

    <!-- 왼쪽: 메인 이미지 -->
    <div class="port-left">
      <div class="port-img-wrap" id="port-img-wrap">
        {projects.map((p, i) => (
          <div class={`port-img-slide${i === 0 ? ' active' : ''}`} style={`background-image:url('${p.images && p.images[0] ? p.images[0] : ''}')`}></div>
        ))}
      </div>
    </div>

    <!-- 오른쪽: 텍스트 -->
    <div class="port-right">

      <!-- 썸네일 3장 (이전/현재/다음) -->
      <div class="port-thumbs" id="port-thumbs">
        <div class="port-thumb" id="port-thumb-prev"></div>
        <div class="port-thumb active" id="port-thumb-cur"></div>
        <div class="port-thumb" id="port-thumb-next"></div>
      </div>

      <div class="port-eyebrow">Portfolio</div>

      <div class="port-slides" id="port-slides">
        {projects.map((p, i) => (
          <div class={`port-slide${i === 0 ? ' active' : ''}`}>
            <h3 class="port-title">{p.title}</h3>
            <p class="port-sub">{p.service}&nbsp;·&nbsp;{p.date}</p>
            <p class="port-desc">{p.overview || ''}</p>
          </div>
        ))}
      </div>

      <!-- 하단 컨트롤 -->
      <div class="port-bottom">
        <div class="port-arrows">
          <button class="port-btn" id="port-prev">←</button>
          <button class="port-btn" id="port-next">→</button>
        </div>
        <div class="port-counter">
          <span class="port-cur-num" id="port-cur-num">01</span>
          <span class="port-sep"> / </span>
          <span class="port-total-num">170</span>
        </div>
        <a href="/works" class="port-all">전체 구축사례 보기 →</a>
      </div>
    </div>

  </div>

</section>

<style>
  .s4 {
    position: relative;
    height: 100vh; min-height: 600px;
    overflow: hidden;
    display: flex; align-items: center;
  }

  /* ── 배경 ── */
  .port-bg { position: absolute; inset: 0; }
  .port-bg-slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0; filter: blur(12px);
    transform: scale(1.08);
    transition: opacity 0.8s;
  }
  .port-bg-slide.active { opacity: 1; }
  .port-overlay {
    position: absolute; inset: 0;
    background: rgba(8, 16, 48, 0.72);
    z-index: 1;
  }

  /* ── 콘텐츠 ── */
  .port-content {
    position: relative; z-index: 2;
    width: 100%; display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  /* ── 왼쪽 이미지 패널 ── */
  .port-left {
    flex: 0 0 680px;
    padding: 20px 20px 20px 0;
    display: flex; align-items: center;
  }
  .port-img-wrap {
    position: relative;
    width: 100%; height: 560px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5);
  }
  .port-img-slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.4,0,0.2,1);
  }
  .port-img-slide.active { opacity: 1; }

  /* ── 썸네일 3장 ── */
  .port-thumbs {
    display: flex; gap: 10px;
    margin-bottom: 28px;
  }
  .port-thumb {
    width: 90px; height: 60px;
    background-size: cover; background-position: center;
    border-radius: 4px;
    cursor: pointer;
    opacity: 0.4;
    border: 2px solid transparent;
    transition: opacity 0.3s, border-color 0.3s, transform 0.3s;
    flex-shrink: 0;
  }
  .port-thumb:hover { opacity: 0.75; transform: translateY(-2px); }
  .port-thumb.active {
    opacity: 1;
    border-color: #fff;
    transform: translateY(-2px);
  }
  .port-thumb.hidden { opacity: 0; pointer-events: none; }

  /* ── 오른쪽 텍스트 ── */
  .port-right {
    flex: 0 0 480px;
    padding: 80px 40px 60px 60px;
    display: flex; flex-direction: column;
    justify-content: center; gap: 0;
  }
  .port-eyebrow {
    font-size: 20px; font-weight: 900; letter-spacing: 0.28em;
    text-transform: uppercase; color: #fff;
    margin-bottom: 28px;
    display: flex; align-items: center; gap: 12px;
  }
  .port-eyebrow::before { content: ''; width: 28px; height: 2px; background: #fff; display: block; }

  /* 슬라이드 텍스트 */
  .port-slides { position: relative; min-height: 220px; margin-bottom: 40px; }
  .port-slide {
    position: absolute; top: 0; left: 0; width: 100%;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.6s, transform 0.6s;
    pointer-events: none;
  }
  .port-slide.active {
    opacity: 1; transform: translateY(0);
    position: relative; pointer-events: auto;
  }
  .port-title {
    font-size: clamp(20px, 2.4vw, 38px);
    font-weight: 900; letter-spacing: -0.04em;
    color: #fff; line-height: 1.2; margin-bottom: 16px;
  }
  .port-sub {
    font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.5); letter-spacing: 0.04em;
    margin-bottom: 20px;
  }
  .port-desc {
    font-size: 13px; color: rgba(255,255,255,0.6);
    line-height: 1.9; max-width: 400px;
    display: -webkit-box; -webkit-line-clamp: 3;
    -webkit-box-orient: vertical; overflow: hidden;
  }

  /* ── 하단 컨트롤 ── */
  .port-bottom {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  .port-arrows { display: flex; gap: 10px; }
  .port-btn {
    width: 48px; height: 48px;
    background: rgba(255,255,255,0.08);
    border: 1.5px solid rgba(255,255,255,0.3);
    color: #fff; font-size: 16px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, border-color 0.2s;
    font-family: inherit;
  }
  .port-btn:hover { background: rgba(255,255,255,0.18); border-color: #fff; }
  .port-btn:disabled { opacity: 0.2; cursor: default; }

  /* 카운터 */
  .port-counter {
    font-size: 13px; color: rgba(255,255,255,0.5);
    font-weight: 600; letter-spacing: 0.05em;
  }
  .port-cur-num { color: #fff; font-size: 18px; font-weight: 900; }

  .port-all {
    margin-left: auto;
    font-size: 12px; font-weight: 800; color: #fff;
    text-decoration: none; letter-spacing: 0.1em; text-transform: uppercase;
    height: 48px; padding: 0 28px;
    display: inline-flex; align-items: center;
    border: 1.5px solid rgba(255,255,255,0.4);
    transition: background 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .port-all:hover { background: rgba(255,255,255,0.1); border-color: #fff; }

  @media (max-width: 900px) {
    .port-content { flex-direction: column; }
    .port-left { flex: 0 0 auto; width: 100%; height: 40vh; padding: 20px; }
    .port-img-wrap { height: 100%; }
    .port-right { padding: 40px 32px; }
    .port-all { margin-left: 0; }
  }
</style>

<script is:inline>
(function () {
  const bgs    = document.querySelectorAll('.port-bg-slide');
  const imgs   = document.querySelectorAll('.port-img-slide');
  const slides = document.querySelectorAll('.port-slide');
  const total  = slides.length;
  let cur = 0;

  const btnPrev  = document.getElementById('port-prev');
  const btnNext  = document.getElementById('port-next');
  const curNum   = document.getElementById('port-cur-num');
  const tPrev    = document.getElementById('port-thumb-prev');
  const tCur     = document.getElementById('port-thumb-cur');
  const tNext    = document.getElementById('port-thumb-next');

  // 전체 프로젝트 이미지 목록 (bg/img 슬라이드에서 추출)
  const imgUrls = Array.from(imgs).map(el => el.style.backgroundImage);

  function setThumb(el, idx) {
    if (idx < 0 || idx >= total) {
      el.classList.add('hidden');
      el.style.backgroundImage = '';
    } else {
      el.classList.remove('hidden');
      el.style.backgroundImage = imgUrls[idx];
    }
  }

  function go(n) {
    bgs[cur].classList.remove('active');
    imgs[cur].classList.remove('active');
    slides[cur].classList.remove('active');
    cur = Math.max(0, Math.min(n, total - 1));
    bgs[cur].classList.add('active');
    imgs[cur].classList.add('active');
    slides[cur].classList.add('active');

    // 카운터 업데이트
    curNum.textContent = String(cur + 1).padStart(2, '0');

    // 썸네일 3장 업데이트
    setThumb(tPrev, cur - 1);
    setThumb(tCur,  cur);
    setThumb(tNext, cur + 1);

    btnPrev.disabled = cur === 0;
    btnNext.disabled = cur === total - 1;
  }

  // 썸네일 클릭
  tPrev.addEventListener('click', function () { go(cur - 1); });
  tCur.addEventListener('click',  function () { go(cur); });
  tNext.addEventListener('click', function () { go(cur + 1); });

  btnPrev.addEventListener('click', function () { go(cur - 1); });
  btnNext.addEventListener('click', function () { go(cur + 1); });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  go(cur - 1);
    if (e.key === 'ArrowRight') go(cur + 1);
  });

  go(0);
})();
</script>
