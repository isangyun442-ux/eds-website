<style>
  /* ── Section ── */
  .s4 {
    background: #F8F8F6;
    display: flex;
    flex-direction: column;
    padding: 80px 0 0;
  }

  /* ── Header ── */
  .port-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 0 56px 36px;
    flex-shrink: 0;
  }
  .sec-tag {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #00B8D9;
    display: block;
    margin-bottom: 8px;
  }
  .sec-title {
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #0A0A0A;
    line-height: 1;
  }

  /* ── Nav ── */
  .port-nav {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-bottom: 4px;
  }
  .port-btn {
    width: 40px;
    height: 40px;
    background: none;
    border: 1px solid #D0D0D0;
    cursor: pointer;
    font-size: 16px;
    color: #0A0A0A;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    font-family: inherit;
  }
  .port-btn:hover { background: #0A0A0A; border-color: #0A0A0A; color: #fff; }
  .port-btn:disabled { opacity: 0.25; cursor: default; }
  .port-btn:disabled:hover { background: none; border-color: #D0D0D0; color: #0A0A0A; }
  .port-count {
    font-size: 12px;
    font-weight: 500;
    color: #999;
    letter-spacing: 0.04em;
    min-width: 36px;
    text-align: center;
  }

  /* ── Track ── */
  .port-track-wrap {
    overflow: hidden;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    flex: 1;
    min-height: 0;
  }
  .port-track-wrap:active { cursor: grabbing; }
  .port-track {
    display: flex;
    height: 100%;
    transition: transform 0.55s cubic-bezier(0.77, 0, 0.175, 1);
    will-change: transform;
  }

  /* ── Card ── */
  .port-card {
    flex: 0 0 calc(100% / 3.2);
    min-width: 0;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    padding-left: 56px;
    height: 100%;
  }
  .port-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
    transition: opacity 0.3s;
    flex-shrink: 0;
  }
  .port-card:hover .port-img { opacity: 0.85; }
  .port-body {
    padding: 22px 24px 22px 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .port-n {
    font-size: 10px;
    font-weight: 700;
    color: #00B8D9;
    letter-spacing: 0.14em;
  }
  .port-title {
    font-size: 16px;
    font-weight: 700;
    color: #0A0A0A;
    letter-spacing: -0.02em;
    line-height: 1.4;
  }
  .port-desc {
    font-size: 11px;
    color: #999;
    line-height: 1.6;
  }
  .port-link {
    font-size: 11px;
    font-weight: 600;
    color: #0A0A0A;
    letter-spacing: 0.04em;
    margin-top: 4px;
    transition: color 0.2s;
  }
  .port-card:hover .port-link { color: #00B8D9; }


  /* ── CTA 카드 ── */
  .port-cta-card {
    background: #0A0A0A;
    cursor: pointer;
    display: flex !important;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding-left: 56px;
  }
  .port-cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 0 24px 0 0;
  }
  .port-cta-num {
    font-size: 52px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .port-cta-plus {
    font-size: 36px;
    color: #00B8D9;
  }
  .port-cta-label {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .port-cta-arr {
    font-size: 12px;
    font-weight: 700;
    color: #00B8D9;
    letter-spacing: 0.06em;
    margin-top: 4px;
    transition: transform 0.2s;
  }
  .port-cta-card:hover .port-cta-arr { transform: translateX(4px); }
  .port-cta-card:hover { background: #0D2030; }

  /* ── Progress ── */
  .port-progress-wrap {
    margin: 24px 56px 0;
    height: 1px;
    background: #E0E0E0;
    position: relative;
    flex-shrink: 0;
  }
  .port-progress-bar {
    position: absolute;
    left: 0; top: 0;
    height: 1px;
    background: #0A0A0A;
    transition: width 0.55s cubic-bezier(0.77, 0, 0.175, 1);
  }

  /* ── Footer ── */
  .port-footer {
    padding: 20px 56px 0;
    flex-shrink: 0;
  }
  .port-all {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 700;
    color: #0A0A0A;
    text-decoration: none;
    letter-spacing: 0.04em;
    padding: 14px 28px;
    border: 1.5px solid #0A0A0A;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .port-all:hover { background: #0A0A0A; color: #fff; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .port-card { flex: 0 0 calc(100% / 2.2); }
  }
  @media (max-width: 768px) {
    .s4 { padding: 64px 0 40px; }
    .port-header { padding: 0 28px 28px; }
    .port-card { flex: 0 0 calc(100% / 1.15); padding-left: 28px; }
    .port-progress-wrap { margin: 20px 28px 0; }
    .port-footer { padding: 16px 28px 0; }
    .port-all { font-size: 13px; padding: 12px 22px; }
  }
  @media (max-width: 480px) {
    .port-card { flex: 0 0 85%; }
  }
  /* ── EDS Footer ── */
  .eds-footer {
    background: #0A0A0A;
    padding: 24px 56px 28px;
    margin-top: auto;
    border-top: 1px solid rgba(255,255,255,0.07);
  }
  .eds-footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .eds-footer-logo {
    height: 24px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.75;
  }
  .eds-footer-copy {
    font-size: 10px;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.06em;
  }
  .eds-footer-bottom {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 5px 10px;
  }
  .eds-footer-info {
    font-size: 11px;
    color: rgba(255,255,255,0.38);
    letter-spacing: 0.02em;
  }
  .eds-footer-div {
    font-size: 10px;
    color: rgba(255,255,255,0.15);
  }
  .eds-footer-mail {
    font-size: 11px;
    color: #00B8D9;
    text-decoration: none;
    transition: color 0.2s;
  }
  .eds-footer-mail:hover { color: #fff; }
  @media (max-width: 768px) {
    .eds-footer { padding: 20px 28px 24px; }
    .eds-footer-div { display: none; }
    .eds-footer-bottom { gap: 3px 8px; }
    .eds-footer-info, .eds-footer-mail { font-size: 10px; }
    .eds-footer-copy { font-size: 9px; }
  }
  /* ── 스크롤 힌트 ── */
  .scroll-hint-sec {
    position: absolute;
    bottom: 110px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    pointer-events: none;
  }
  .scroll-hint-sec .sh-mouse {
    width: 20px; height: 30px;
    border-radius: 10px;
    display: flex; align-items: flex-start;
    justify-content: center; padding-top: 4px;
  }
  .scroll-hint-sec .sh-wheel {
    width: 2px; height: 5px;
    border-radius: 1px;
    animation: shw-sec 1.8s ease infinite;
  }
  @keyframes shw-sec {
    0%  { opacity: 1; transform: translateY(0); }
    100%{ opacity: 0; transform: translateY(9px); }
  }
  .scroll-hint-sec .sh-text {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .s4 .scroll-hint-sec .sh-mouse,
  .s5 .scroll-hint-sec .sh-mouse,
  .s6 .scroll-hint-sec .sh-mouse { border: 1.5px solid rgba(0,0,0,0.2); }
  .s4 .scroll-hint-sec .sh-wheel,
  .s5 .scroll-hint-sec .sh-wheel,
  .s6 .scroll-hint-sec .sh-wheel { background: rgba(0,0,0,0.3); }
  .s4 .scroll-hint-sec .sh-text,
  .s5 .scroll-hint-sec .sh-text,
  .s6 .scroll-hint-sec .sh-text  { color: rgba(0,0,0,0.25); }
</style>

<script is:inline>
(function () {
  const track   = document.getElementById('port-track');
  const cards   = track.querySelectorAll('.port-card');
  const total   = cards.length;
  const btnPrev = document.getElementById('port-prev');
  const btnNext = document.getElementById('port-next');
  const curEl   = document.getElementById('port-cur');
  const totalEl = document.getElementById('port-total');
  const progBar = document.getElementById('port-progress-bar');

  totalEl.textContent = total;

  let cur = 0;
  let vis = window.innerWidth <= 768 ? 1 : window.innerWidth <= 1024 ? 2 : 3;

  function getW() { return cards[0].getBoundingClientRect().width; }

  function update() {
    track.style.transform = 'translateX(-' + (cur * getW()) + 'px)';
    curEl.textContent = cur + 1;
    btnPrev.disabled = cur === 0;
    btnNext.disabled = cur >= total - vis;
    progBar.style.width = ((cur + vis) / total * 100) + '%';
  }

  btnPrev.addEventListener('click', function () { if (cur > 0) { cur--; update(); } });
  btnNext.addEventListener('click', function () { if (cur < total - vis) { cur++; update(); } });

  /* 드래그 */
  let startX = 0, isDragging = false, prevented = false;
  track.addEventListener('mousedown', function (e) { startX = e.clientX; isDragging = true; prevented = false; });
  track.addEventListener('mousemove', function (e) {
    if (!isDragging) return;
    if (!prevented && Math.abs(e.clientX - startX) > 5) prevented = true;
  });
  track.addEventListener('mouseup', function (e) {
    if (!isDragging) return;
    isDragging = false;
    const dx = e.clientX - startX;
    if (dx < -40 && cur < total - vis) { cur++; update(); }
    else if (dx > 40 && cur > 0) { cur--; update(); }
  });
  track.addEventListener('mouseleave', function () { isDragging = false; });

  /* 터치 */
  let tx = 0;
  track.addEventListener('touchstart', function (e) { tx = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', function (e) {
    const dx = e.changedTouches[0].clientX - tx;
    if (dx < -40 && cur < total - vis) { cur++; update(); }
    else if (dx > 40 && cur > 0) { cur--; update(); }
  });

  /* 리사이즈 */
  window.addEventListener('resize', function () {
    vis = window.innerWidth <= 768 ? 1 : window.innerWidth <= 1024 ? 2 : 3;
    if (cur > total - vis) cur = total - vis;
    update();
  });

  /* 드래그 중 클릭 방지 */
  cards.forEach(function (card) {
    card.addEventListener('click', function (e) {
      if (prevented) { e.stopImmediatePropagation(); prevented = false; }
    });
  });

  update();
})();
</script>
