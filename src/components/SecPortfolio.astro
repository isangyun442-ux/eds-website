  <div class="port-track-wrap">
    <div class="port-track" id="port-track">

      <div class="port-card" onclick="location.href='/works'">
        <div class="port-img" style="background-image:url('/images/HUFS_ST_04.jpg')"></div>
        <div class="port-body">
          <span class="port-n">01</span>
          <h3 class="port-title">한국외국어대학교<br>스튜디오 첨단화</h3>
          <p class="port-desc">LED 디스플레이 · 2025.02 · 교육기관</p>
          <span class="port-link">사례 보기 →</span>
        </div>
      </div>

      <div class="port-card" onclick="location.href='/works'">
        <div class="port-img" style="background-image:url('/images/SC_ST_09.jpg')"></div>
        <div class="port-body">
          <span class="port-n">02</span>
          <h3 class="port-title">서울사이버대학교<br>스마트 강의실 고도화</h3>
          <p class="port-desc">스마트 강의실 · 2024.11 · 교육기관</p>
          <span class="port-link">사례 보기 →</span>
        </div>
      </div>

      <div class="port-card" onclick="location.href='/works'">
        <div class="port-img" style="background-image:url('/images/GMC_S_01.jpg')"></div>
        <div class="port-body">
          <span class="port-n">03</span>
          <h3 class="port-title">공주대학교<br>이러닝 스튜디오</h3>
          <p class="port-desc">이러닝 스튜디오 · 2024.09 · 교육기관</p>
          <span class="port-link">사례 보기 →</span>
        </div>
      </div>

      <div class="port-card" onclick="location.href='/works'">
        <div class="port-img" style="background-image:url('/images/GKDE_S_08.jpg')"></div>
        <div class="port-body">
          <span class="port-n">04</span>
          <h3 class="port-title">경기도교육청<br>UHD 방송제작</h3>
          <p class="port-desc">방송제작 · 2024.06 · 공공기관</p>
          <span class="port-link">사례 보기 →</span>
        </div>
      </div>

      <div class="port-card" onclick="location.href='/works'">
        <div class="port-img" style="background-image:url('/images/KTV_BS_01.jpg')"></div>
