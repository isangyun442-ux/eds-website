---
// src/components/SecPortfolio.astro
---
<section class="sec s4" id="sec4">

  <!-- 배경 (블러 + 어둡게) -->
  <div class="port-bg" id="port-bg">
    <div class="port-bg-slide active" style="background-image:url('/images/HUFS_ST_04.jpg')"></div>
    <div class="port-bg-slide" style="background-image:url('/images/SC_ST_09.jpg')"></div>
    <div class="port-bg-slide" style="background-image:url('/images/GMC_S_01.jpg')"></div>
    <div class="port-bg-slide" style="background-image:url('/images/GKDE_S_08.jpg')"></div>
    <div class="port-bg-slide" style="background-image:url('/images/KTV_BS_01.jpg')"></div>
  </div>
  <div class="port-overlay"></div>

  <!-- 콘텐츠 -->
  <div class="port-content">

    <!-- 왼쪽: 선명한 이미지 패널 -->
    <div class="port-left">
      <div class="port-img-wrap" id="port-img-wrap">
        <div class="port-img-slide active" style="background-image:url('/images/HUFS_ST_04.jpg')"></div>
        <div class="port-img-slide" style="background-image:url('/images/SC_ST_09.jpg')"></div>
        <div class="port-img-slide" style="background-image:url('/images/GMC_S_01.jpg')"></div>
        <div class="port-img-slide" style="background-image:url('/images/GKDE_S_08.jpg')"></div>
        <div class="port-img-slide" style="background-image:url('/images/KTV_BS_01.jpg')"></div>
      </div>
    </div>

    <!-- 오른쪽: 텍스트 -->
    <div class="port-right">
      <div class="port-eyebrow">Portfolio</div>
      <div class="port-slides" id="port-slides">

        <div class="port-slide active">
          <h3 class="port-title">한국외국어대학교<br>스튜디오 첨단화</h3>
          <p class="port-sub">LED 디스플레이 &nbsp;·&nbsp; 2025.02</p>
          <p class="port-desc">최신 LED 디스플레이 시스템으로 방송 스튜디오를 첨단화하여 고품질 교육 콘텐츠 제작 환경을 구축하였습니다.</p>
        </div>

        <div class="port-slide">
          <h3 class="port-title">서울사이버대학교<br>스마트 강의실 고도화</h3>
          <p class="port-sub">스마트 강의실 &nbsp;·&nbsp; 2024.11</p>
          <p class="port-desc">원터치 하이브리드 수업이 가능한 스마트 강의실로 고도화하여 온·오프라인 동시 수업 환경을 완성하였습니다.</p>
        </div>

        <div class="port-slide">
          <h3 class="port-title">공주대학교<br>이러닝 스튜디오</h3>
          <p class="port-sub">이러닝 스튜디오 &nbsp;·&nbsp; 2024.09</p>
          <p class="port-desc">전문 이러닝 콘텐츠 제작을 위한 최적화된 스튜디오 환경을 구축하여 교육 품질 향상에 기여하였습니다.</p>
        </div>

        <div class="port-slide">
          <h3 class="port-title">경기도교육청<br>UHD 방송제작</h3>
          <p class="port-sub">방송제작 &nbsp;·&nbsp; 2024.06</p>
          <p class="port-desc">UHD 급 방송제작 시스템을 구축하여 공공 교육 방송의 품질을 한 단계 향상시켰습니다.</p>
        </div>

        <div class="port-slide">
          <h3 class="port-title">KTV<br>방송 인프라 시스템</h3>
          <p class="port-sub">방송 인프라 &nbsp;·&nbsp; 2024.03</p>
          <p class="port-desc">국가 공식 방송 채널의 안정적인 방송 인프라 시스템 구축으로 24시간 무중단 방송을 지원합니다.</p>
        </div>

      </div>

      <!-- 하단 컨트롤 -->
      <div class="port-bottom">
        <div class="port-arrows">
          <button class="port-btn" id="port-prev">←</button>
          <button class="port-btn" id="port-next">→</button>
        </div>
        <div class="port-dots" id="port-dots">
          <span class="port-dot active"></span>
          <span class="port-dot"></span>
          <span class="port-dot"></span>
          <span class="port-dot"></span>
          <span class="port-dot"></span>
        </div>
        <a href="/works" class="port-all">전체 구축사례 보기 →</a>
      </div>
    </div>

  </div>

</section>

<style>
  .s4 {
    position: relative;
    height: 100vh; min-height: 600px;
    overflow: hidden;
    display: flex; align-items: center;
  }

  /* ── 배경: 블러 + 어둡게 ── */
  .port-bg { position: absolute; inset: 0; }
  .port-bg-slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0; filter: blur(12px);
    transform: scale(1.08);
    transition: opacity 0.8s;
  }
  .port-bg-slide.active { opacity: 1; }
  .port-overlay {
    position: absolute; inset: 0;
    background: rgba(8, 16, 48, 0.72);
    z-index: 1;
  }

  /* ── 콘텐츠 ── */
  .port-content {
    position: relative; z-index: 2;
    width: 100%; display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  /* ── 왼쪽 이미지 패널 ── */
  .port-left {
    flex: 0 0 520px;
    height: 100%;
    padding: 60px 20px 60px 0;
    display: flex; align-items: center;
  }
  .port-img-wrap {
    position: relative;
    width: 100%; height: 520px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5);
  }
  .port-img-slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.4,0,0.2,1);
  }
  .port-img-slide.active { opacity: 1; }

  /* ── 오른쪽 텍스트 ── */
  .port-right {
    flex: 0 0 480px;
    padding: 80px 40px 60px 60px;
    display: flex; flex-direction: column;
    justify-content: center; gap: 0;
  }
  .port-eyebrow {
    font-size: 20px; font-weight: 900; letter-spacing: 0.28em;
    text-transform: uppercase; color: #fff;
    margin-bottom: 28px;
    display: flex; align-items: center; gap: 12px;
  }
  .port-eyebrow::before { content: ''; width: 28px; height: 2px; background: #fff; display: block; }

  /* 슬라이드 텍스트 */
  .port-slides { position: relative; min-height: 220px; margin-bottom: 40px; }
  .port-slide {
    position: absolute; top: 0; left: 0; width: 100%;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.6s, transform 0.6s;
    pointer-events: none;
  }
  .port-slide.active {
    opacity: 1; transform: translateY(0);
    position: relative; pointer-events: auto;
  }
  .port-title {
    font-size: clamp(28px, 3.5vw, 56px);
    font-weight: 900; letter-spacing: -0.04em;
    color: #fff; line-height: 1.1; margin-bottom: 16px;
  }
  .port-sub {
    font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.5); letter-spacing: 0.04em;
    margin-bottom: 20px;
  }
  .port-desc {
    font-size: 14px; color: rgba(255,255,255,0.6);
    line-height: 1.9; max-width: 400px;
  }

  /* ── 하단 컨트롤 ── */
  .port-bottom {
    display: flex; align-items: center; gap: 24px; flex-wrap: wrap;
  }
  .port-arrows { display: flex; gap: 10px; }
  .port-btn {
    width: 48px; height: 48px;
    background: rgba(255,255,255,0.08);
    border: 1.5px solid rgba(255,255,255,0.3);
    color: #fff; font-size: 16px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, border-color 0.2s;
    font-family: inherit;
  }
  .port-btn:hover { background: rgba(255,255,255,0.18); border-color: #fff; }
  .port-btn:disabled { opacity: 0.2; cursor: default; }

  .port-dots { display: flex; gap: 8px; }
  .port-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(255,255,255,0.3); cursor: pointer;
    transition: background 0.3s, transform 0.3s;
  }
  .port-dot.active { background: #fff; transform: scale(1.4); }

  .port-all {
    margin-left: 0;
    font-size: 12px; font-weight: 800; color: #fff;
    text-decoration: none; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 14px 32px;
    border: 1.5px solid rgba(255,255,255,0.4);
    transition: background 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .port-all:hover { background: rgba(255,255,255,0.1); border-color: #fff; }

  @media (max-width: 900px) {
    .port-content { flex-direction: column; }
    .port-left { flex: 0 0 auto; width: 100%; height: 40vh; padding: 20px; }
    .port-img-wrap { height: 100%; }
    .port-right { padding: 40px 32px; }
    .port-all { margin-left: 0; }
  }
</style>

<script is:inline>
(function () {
  const bgs    = document.querySelectorAll('.port-bg-slide');
  const imgs   = document.querySelectorAll('.port-img-slide');
  const slides = document.querySelectorAll('.port-slide');
  const dots   = document.querySelectorAll('.port-dot');
  const btnPrev = document.getElementById('port-prev');
  const btnNext = document.getElementById('port-next');
  const total  = slides.length;
  let cur = 0;

  function go(n) {
    bgs[cur].classList.remove('active');
    imgs[cur].classList.remove('active');
    slides[cur].classList.remove('active');
    dots[cur].classList.remove('active');
    cur = Math.max(0, Math.min(n, total - 1));
    bgs[cur].classList.add('active');
    imgs[cur].classList.add('active');
    slides[cur].classList.add('active');
    dots[cur].classList.add('active');
    btnPrev.disabled = cur === 0;
    btnNext.disabled = cur === total - 1;
  }

  btnPrev.addEventListener('click', function () { go(cur - 1); });
  btnNext.addEventListener('click', function () { go(cur + 1); });
  dots.forEach(function (dot, i) { dot.addEventListener('click', function () { go(i); }); });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft') go(cur - 1);
    if (e.key === 'ArrowRight') go(cur + 1);
  });

  go(0);
})();
</script>
