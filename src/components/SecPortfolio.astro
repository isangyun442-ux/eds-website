---
// src/components/SecPortfolio.astro
---
<section class="sec s4" id="sec4">
  <div class="port-header">
    <div>
      <span class="sec-tag">Portfolio</span>
      <h2 class="sec-title">구축 사례</h2>
    </div>
    <a href="/works" class="port-all">전체 보기 →</a>
  </div>

  <div class="port-grid">

    <!-- 메인 카드 (크게) -->
    <a class="pc pc-main" href="/works/hufs">
      <div class="pc-img" style="background-image:url('/images/HUFS_ST_04.jpg')"></div>
      <div class="pc-over"></div>
      <div class="pc-info">
        <span class="pc-cat">LED 디스플레이</span>
        <h3 class="pc-name">한국외국어대학교<br>스튜디오 첨단화</h3>
        <p class="pc-meta">2025.02 · 교육기관</p>
      </div>
    </a>

    <!-- 오른쪽 서브 카드 4장 -->
    <div class="pc-sub-grid">

      <a class="pc pc-sub" href="/works/sc">
        <div class="pc-img" style="background-image:url('/images/SC_ST_09.jpg')"></div>
        <div class="pc-over"></div>
        <div class="pc-info">
          <span class="pc-cat">스마트 강의실</span>
          <h3 class="pc-name">서울사이버대학교 고도화</h3>
          <p class="pc-meta">2024.11 · 교육기관</p>
        </div>
      </a>

      <a class="pc pc-sub" href="/works/gmc">
        <div class="pc-img" style="background-image:url('/images/GMC_S_01.jpg')"></div>
        <div class="pc-over"></div>
        <div class="pc-info">
          <span class="pc-cat">이러닝 스튜디오</span>
          <h3 class="pc-name">공주대학교 스튜디오</h3>
          <p class="pc-meta">2024.09 · 교육기관</p>
        </div>
      </a>

      <a class="pc pc-sub" href="/works/gkde">
        <div class="pc-img" style="background-image:url('/images/GKDE_S_08.jpg')"></div>
        <div class="pc-over"></div>
        <div class="pc-info">
          <span class="pc-cat">방송제작</span>
          <h3 class="pc-name">경기도교육청 UHD</h3>
          <p class="pc-meta">2024.06 · 공공기관</p>
        </div>
      </a>

      <a class="pc pc-sub" href="/works/ktv">
        <div class="pc-img" style="background-image:url('/images/KTV_BS_01.jpg')"></div>
        <div class="pc-over"></div>
        <div class="pc-info">
          <span class="pc-cat">방송 인프라</span>
          <h3 class="pc-name">KTV 방송시스템</h3>
          <p class="pc-meta">2024.03 · 방송국</p>
        </div>
      </a>

    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .s4 {
    background: #fff;
    padding: 72px 48px 60px;
  }

  /* ── Header ── */
  .port-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 28px;
  }
  .sec-tag {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #00B8D9;
    display: block;
    margin-bottom: 8px;
  }
  .sec-title {
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #0A0A0A;
    line-height: 1;
  }
  .port-all {
    font-size: 12px;
    font-weight: 600;
    color: #0A0A0A;
    text-decoration: none;
    letter-spacing: 0.04em;
    padding-bottom: 3px;
    border-bottom: 1px solid #0A0A0A;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .port-all:hover { color: #00B8D9; border-color: #00B8D9; }

  /* ── 매거진 그리드 ── */
  .port-grid {
    display: grid;
    grid-template-columns: 1.65fr 1fr;
    gap: 4px;
    height: 560px;
  }

  /* ── 공통 카드 ── */
  .pc {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    display: block;
    text-decoration: none;
    background: #0D1F2D;
  }

  /* 이미지 */
  .pc-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 0.55s ease;
    filter: brightness(0.75);
  }
  .pc:hover .pc-img {
    transform: scale(1.05);
    filter: brightness(0.45);
  }

  /* 그라디언트 오버레이 */
  .pc-over {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.72) 0%,
      rgba(0,0,0,0.12) 45%,
      transparent 100%
    );
    transition: background 0.55s ease;
  }
  .pc:hover .pc-over {
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.88) 0%,
      rgba(0,0,0,0.32) 55%,
      rgba(0,0,0,0.08) 100%
    );
  }

  /* 텍스트 정보 */
  .pc-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 22px 24px 26px;
    z-index: 1;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .pc:hover .pc-info { transform: translateY(-4px); }

  .pc-cat {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #00B8D9;
    display: block;
    margin-bottom: 7px;
  }
  .pc-name {
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .pc-meta {
    font-size: 10px;
    color: rgba(255,255,255,0.4);
    margin-top: 5px;
    margin-bottom: 0;
  }

  /* ── 메인 카드 ── */
  .pc-main .pc-name { font-size: 22px; }
  .pc-main .pc-info { padding: 28px 32px 36px; }
  .pc-main .pc-cat { font-size: 10px; margin-bottom: 10px; }

  /* ── 서브 그리드 ── */
  .pc-sub-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 4px;
  }
  .pc-sub .pc-name { font-size: 13px; }
  .pc-sub .pc-info { padding: 16px 18px 20px; }

  /* ── 반응형 ── */
  @media (max-width: 900px) {
    .s4 { padding: 64px 28px 48px; }
    .port-grid {
      grid-template-columns: 1fr;
      height: auto;
      gap: 4px;
    }
    .pc-main { height: 340px; }
    .pc-sub-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 180px 180px;
    }
  }
  @media (max-width: 480px) {
    .s4 { padding: 56px 16px 40px; }
    .pc-sub-grid { grid-template-rows: 150px 150px; }
    .pc-main { height: 280px; }
    .pc-main .pc-name { font-size: 18px; }
  }
</style>
