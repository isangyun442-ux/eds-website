---
// 고객사 & 파트너스 섹션
// 수정할 것: clients 배열과 brands 배열 내용
---

<section id="clients">
  <div class="clients-header reveal">
    <div class="clients-eyebrow">Clients & Partners</div>
    <div class="clients-title">신뢰받는 파트너십</div>
    <div class="clients-count">국내 <span>200+</span> 기관·기업과 함께합니다</div>
  </div>

  <!-- 고객사 로고 자동 슬라이더 -->
  <div class="clients-track-wrap reveal">
    <div class="clients-track">
      <!-- SET 1 -->
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:52px;background:#1428A0"></div><div class="cli-name">Samsung</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:40px;background:#E11E3C"></div><div class="cli-name">LG</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:56px;background:#006EFF"></div><div class="cli-name">Hyundai</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:44px;background:#003087"></div><div class="cli-name">KDB</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:60px;background:#E60012"></div><div class="cli-name">KT</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:48px;background:#FF6600"></div><div class="cli-name">SK</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:52px;background:#003DA5"></div><div class="cli-name">Posco</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:44px;background:#D4002A"></div><div class="cli-name">Lotte</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:50px;background:#0055A4"></div><div class="cli-name">Hanwha</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:58px;background:#00854A"></div><div class="cli-name">Naver</div></div></div>
      <!-- SET 2 (무한 루프용 복사) -->
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:52px;background:#1428A0"></div><div class="cli-name">Samsung</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:40px;background:#E11E3C"></div><div class="cli-name">LG</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:56px;background:#006EFF"></div><div class="cli-name">Hyundai</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:44px;background:#003087"></div><div class="cli-name">KDB</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:60px;background:#E60012"></div><div class="cli-name">KT</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:48px;background:#FF6600"></div><div class="cli-name">SK</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:52px;background:#003DA5"></div><div class="cli-name">Posco</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:44px;background:#D4002A"></div><div class="cli-name">Lotte</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:50px;background:#0055A4"></div><div class="cli-name">Hanwha</div></div></div>
      <div class="client-logo-item"><div class="cli-pill"><div class="cli-bar" style="width:58px;background:#00854A"></div><div class="cli-name">Naver</div></div></div>
    </div>
  </div>

  <!-- 취급 브랜드 구분선 -->
  <div class="clients-divider reveal">
    <div class="clients-div-label">취급 브랜드 · Technology Partners</div>
  </div>

  <!-- 취급 브랜드 그리드 -->
  <div class="brands-grid reveal">
    <div class="brand-item"><div class="brand-badge" style="background:#E60012">Pan</div><div class="brand-label">Panasonic</div><div class="brand-cat">Display · AV</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#003087">Sony</div><div class="brand-label">Sony Pro</div><div class="brand-cat">Camera · Display</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#0066CC">Cre</div><div class="brand-label">Crestron</div><div class="brand-cat">Control System</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#FF6600">Poly</div><div class="brand-label">Poly</div><div class="brand-cat">Video Conf.</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#1A1A1A">Shu</div><div class="brand-label">Shure</div><div class="brand-cat">Audio · Mic</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#D42B2B">NEC</div><div class="brand-label">NEC Display</div><div class="brand-cat">Large Format</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#00B8D9">AMX</div><div class="brand-label">AMX</div><div class="brand-cat">Control System</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#0D3A4A">Bos</div><div class="brand-label">Bose Pro</div><div class="brand-cat">Speaker · DSP</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#2D7DD2">Sam</div><div class="brand-label">Samsung B2B</div><div class="brand-cat">LED · Display</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#A50034">LG</div><div class="brand-label">LG Business</div><div class="brand-cat">LED · OLED</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#007DC3">Ext</div><div class="brand-label">Extron</div><div class="brand-cat">Signal Dist.</div></div>
    <div class="brand-item"><div class="brand-badge" style="background:#5C2D91">Mic</div><div class="brand-label">Microsoft</div><div class="brand-cat">Teams Room</div></div>
  </div>
</section>

<style>
  #clients {
    background: var(--white);
    padding: 72px 60px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }
  .clients-header { text-align: center; margin-bottom: 48px; }
  .clients-eyebrow {
    display: inline-flex; align-items: center; gap: 16px;
    font-size: 11px; font-weight: 700; letter-spacing: .22em;
    text-transform: uppercase; color: var(--gray); margin-bottom: 12px;
  }
  .clients-eyebrow::before,
  .clients-eyebrow::after { content: ''; display: block; width: 40px; height: 1px; background: var(--light); }
  .clients-title { font-family: var(--sans); font-size: 22px; font-weight: 700; font-style: italic; color: var(--navy); letter-spacing: -0.01em; }
  .clients-count { font-size: 13px; color: var(--gray); margin-top: 6px; font-family: var(--kr); }
  .clients-count span { color: var(--red); font-weight: 700; }

  /* 슬라이더 */
  .clients-track-wrap { position: relative; overflow: hidden; }
  .clients-track-wrap::before,
  .clients-track-wrap::after {
    content: ''; position: absolute; top: 0; bottom: 0; width: 80px; z-index: 2; pointer-events: none;
  }
  .clients-track-wrap::before { left: 0; background: linear-gradient(90deg, var(--white), transparent); }
  .clients-track-wrap::after  { right: 0; background: linear-gradient(-90deg, var(--white), transparent); }
  .clients-track {
    display: flex; gap: 0; width: max-content;
    animation: clientsScroll 30s linear infinite;
  }
  .clients-track:hover { animation-play-state: paused; }
  @keyframes clientsScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  .client-logo-item {
    display: inline-flex; align-items: center; justify-content: center;
    width: 180px; height: 80px; flex-shrink: 0;
    border-right: 1px solid var(--line); padding: 0 28px;
    transition: background 0.2s;
  }
  .client-logo-item:hover { background: var(--bg); }
  .cli-pill { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .cli-bar  { height: 4px; border-radius: 2px; }
  .cli-name { font-family: var(--sans); font-size: 13px; font-weight: 700; letter-spacing: .06em; color: var(--navy); opacity: .55; text-transform: uppercase; }
  .client-logo-item:hover .cli-name { opacity: .9; }

  /* 구분선 */
  .clients-divider {
    display: flex; align-items: center; gap: 20px;
    margin: 40px 0 32px;
  }
  .clients-divider::before,
  .clients-divider::after { content: ''; flex: 1; height: 1px; background: var(--line); }
  .clients-div-label { font-size: 10px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--gray); white-space: nowrap; }

  /* 브랜드 그리드 */
  .brands-grid {
    display: grid; grid-template-columns: repeat(6, 1fr);
    gap: 2px; background: var(--line);
  }
  .brand-item {
    background: var(--white);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 22px 16px; gap: 8px; transition: background 0.2s;
  }
  .brand-item:hover { background: var(--bg); }
  .brand-badge {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800; letter-spacing: .04em; color: #fff;
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
  }
  .brand-label { font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: .08em; color: var(--navy); opacity: .6; text-transform: uppercase; text-align: center; }
  .brand-cat   { font-size: 9px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--gray); text-align: center; }
  .brand-item:hover .brand-label { opacity: 1; }

  @media (max-width: 768px) {
    #clients { padding: 56px 24px; }
    .brands-grid { grid-template-columns: repeat(3, 1fr); }
    .client-logo-item { width: 140px; }
  }
  @media (max-width: 480px) {
    .brands-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
