---
// 모든 페이지가 공유하는 HTML 틀
// props로 title을 받아서 <title> 태그에 넣어요
const { title = 'EDS (주)이담에스티' } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="EDS 이담에스티 — 스마트 회의실, LED 스튜디오, 강의실 구축 전문" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <!-- 각 페이지 내용이 여기에 들어와요 -->
    <slot />

    <!-- 스크롤 애니메이션 스크립트 (모든 페이지 공통) -->
    <script>
      const ANIM_CLASSES = ['.reveal', '.fade-up', '.fade-left', '.fade-right', '.fade-scale'];

      const obs = new IntersectionObserver((entries) => {
        // 같은 타이밍에 들어온 요소들끼리만 스태거 적용
        const intersecting = entries.filter(e => e.isIntersecting);
        intersecting.forEach((e, i) => {
          // data-delay 속성이 있으면 그 값 우선 사용
          const extra = parseInt(e.target.dataset.delay || '0', 10);
          const stagger = i * 80; // 같은 배치에서 80ms 간격
          setTimeout(() => {
            e.target.classList.add('visible');
          }, stagger + extra);
          obs.unobserve(e.target);
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -40px 0px' // 뷰포트 하단 40px 전에 미리 트리거
      });

      // 모든 애니메이션 대상 관찰 시작
      document.querySelectorAll(ANIM_CLASSES.join(',')).forEach(el => obs.observe(el));
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
