---
// 모든 페이지가 공유하는 HTML 틀
// props로 title을 받아서 <title> 태그에 넣어요
const { title = 'EDS (주)이담에스티' } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="EDS 이담에스티 — 스마트 회의실, LED 스튜디오, 강의실 구축 전문" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Lenis 관성 스크롤 -->
    <script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
  </head>
  <body>
    <!-- 각 페이지 내용이 여기에 들어와요 -->
    <slot />

    <!-- Lenis 관성 스크롤 + 스크롤 등장 애니메이션 -->
    <script>
      // ── Lenis 초기화 ──
      const lenis = new (window as any).Lenis({
        duration: 1.3,          // 스크롤 지속 시간 (클수록 느리고 부드럽게)
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // expo easing
        smoothWheel: true,      // 마우스 휠 부드럽게
        touchMultiplier: 1.8,   // 터치 감도
      });

      // RAF 루프 (Lenis 필수)
      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // anchor 링크 클릭 시 Lenis로 부드럽게 이동
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          e.preventDefault();
          const target = document.querySelector((anchor as HTMLAnchorElement).getAttribute('href')!);
          if (target) lenis.scrollTo(target, { offset: -80, duration: 1.6 });
        });
      });

      // ── 스크롤 등장 애니메이션 ──
      const ANIM_CLASSES = ['.reveal', '.fade-up', '.fade-left', '.fade-right', '.fade-scale'];

      const obs = new IntersectionObserver((entries) => {
        const intersecting = entries.filter(e => e.isIntersecting);
        intersecting.forEach((e, i) => {
          const extra = parseInt((e.target as HTMLElement).dataset.delay || '0', 10);
          const stagger = i * 80;
          setTimeout(() => e.target.classList.add('visible'), stagger + extra);
          obs.unobserve(e.target);
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -40px 0px'
      });

      document.querySelectorAll(ANIM_CLASSES.join(',')).forEach(el => obs.observe(el));
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
