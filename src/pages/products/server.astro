---
// src/pages/products/server.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Nanum+Square:wght@400;700;800&display=swap" rel="stylesheet" />
  <title>컴퓨터 서버 — EDS 이담에스티</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Inter','Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:#fff;color:#0a0a0a;-webkit-font-smoothing:antialiased;}

    .nav {
      position:fixed; top:0; left:0; right:0; z-index:300;
      display:flex; align-items:center; justify-content:space-between;
      padding:18px 80px;
      background:rgba(255,255,255,0.97);
      box-shadow:0 1px 0 rgba(0,0,0,0.07);
      backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
    }
    .nav-logo{height:28px;display:flex;align-items:center;text-decoration:none;}
    .nav-logo img{height:28px;width:auto;object-fit:contain;}
    .nav-menu{display:flex;align-items:center;gap:48px;}
    .nav-item{position:relative;}
    .nav-link{
      display:block;
      font-family:'Nanum Square','Apple SD Gothic Neo',sans-serif;
      font-size:20px;font-weight:400;letter-spacing:0.05em;
      text-decoration:none;cursor:pointer;color:#1a1a1a;
      padding:8px 4px;border-radius:6px;transition:all 0.2s;white-space:nowrap;
    }
    .nav-link:hover{color:#1a2f8a;}
    .nav-link.active{color:#1a2f8a;}
    .nav-item.has-drop:hover .nav-link{color:#1a2f8a;}
    .nav-drop{
      position:absolute;top:calc(100% + 6px);left:0;min-width:160px;
      background:#fff;border-radius:10px;
      border:1px solid rgba(0,0,0,0.08);box-shadow:0 8px 40px rgba(0,0,0,0.12);
      padding:8px 0;opacity:0;visibility:hidden;transform:translateY(-6px);
      transition:opacity 0.2s,transform 0.2s,visibility 0.2s;
    }
    .nav-item.has-drop:hover .nav-drop{opacity:1;visibility:visible;transform:translateY(0);}
    .drop-link{
      display:block;font-size:14px;font-weight:500;color:#444;
      text-decoration:none;padding:10px 20px;
      transition:background 0.15s,color 0.15s;white-space:nowrap;
    }
    .drop-link:hover{background:rgba(26,47,138,0.05);color:#1a2f8a;}
    .nav-cta{
      font-size:13px;font-weight:700;padding:9px 20px;
      background:#1a2f8a;color:#fff;border:none;cursor:pointer;
      border-radius:6px;font-family:inherit;transition:background 0.2s;text-decoration:none;
    }
    .nav-cta:hover{background:#142580;}
    @media(max-width:768px){.nav{padding:12px 20px;}.nav-menu{display:none;}}

    /* HERO */
    .hero{padding:120px 60px 80px;background:linear-gradient(170deg,#f7f9ff 0%,#edf1fb 100%);}
    .hero-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
    .hero-badge{display:inline-flex;align-items:center;gap:8px;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#1a2f8a;margin-bottom:20px;}
    .hero-badge::before{content:'';width:20px;height:1.5px;background:#1a2f8a;}
    .hero-title{font-size:clamp(28px,3.5vw,48px);font-weight:900;letter-spacing:-0.04em;color:#0d1a3a;line-height:1.15;margin-bottom:12px;}
    .hero-title em{color:#1a2f8a;font-style:normal;}
    .hero-sub{font-size:15px;color:#6b7a8d;line-height:1.8;margin-bottom:32px;}
    .hero-models{display:flex;flex-wrap:wrap;gap:8px;}
    .hero-model{display:inline-block;font-size:11px;font-weight:700;background:#1a2f8a;color:#fff;padding:4px 12px;border-radius:4px;letter-spacing:0.06em;}
    .hero-img{width:100%;}
    .hero-img img{width:100%;height:auto;display:block;}
    @media(max-width:900px){.hero{padding:100px 24px 60px;}.hero-inner{grid-template-columns:1fr;gap:40px;}.hero-img{order:-1;}}

    /* SECTION 공통 */
    .sec{padding:80px 60px;}
    .sec-inner{max-width:1200px;margin:0 auto;}
    .sec-label{font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#1a2f8a;margin-bottom:12px;}
    .sec-title{font-size:clamp(22px,2.8vw,36px);font-weight:800;letter-spacing:-0.03em;color:#0d1a3a;margin-bottom:16px;}
    .sec-desc{font-size:14px;color:#6b7a8d;line-height:1.9;max-width:760px;}
    @media(max-width:768px){.sec{padding:60px 24px;}}

    /* OVERVIEW */
    .overview{background:#fff;}
    .overview-box{background:#f7f9ff;border-left:4px solid #1a2f8a;border-radius:0 10px 10px 0;padding:28px 32px;margin-top:24px;}
    .overview-box p{font-size:14px;color:#444;line-height:2;font-weight:500;}

    /* FEATURES */
    .features{background:#f7f9ff;}
    .feat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:48px;}
    .feat-card{background:#fff;border:1px solid #e8edf4;border-radius:12px;padding:28px 28px 24px;transition:box-shadow 0.25s,transform 0.25s;}
    .feat-card:hover{box-shadow:0 10px 36px rgba(26,47,138,0.1);transform:translateY(-3px);}
    .feat-tag{display:inline-block;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#1a2f8a;background:rgba(26,47,138,0.08);padding:3px 10px;border-radius:4px;margin-bottom:12px;}
    .feat-title{font-size:15px;font-weight:800;color:#0d1a3a;margin-bottom:12px;}
    .feat-list{display:flex;flex-direction:column;gap:7px;}
    .feat-item{font-size:13px;color:#555;line-height:1.75;padding-left:14px;position:relative;}
    .feat-item::before{content:'·';position:absolute;left:0;color:#1a2f8a;font-weight:700;}
    @media(max-width:768px){.feat-grid{grid-template-columns:1fr;}}

    /* SPECS */
    .specs{background:#fff;}
    .specs-wrap{overflow-x:auto;margin-top:40px;}
    .specs-table{width:100%;border-collapse:collapse;min-width:700px;}
    .specs-table thead{background:#0d1a3a;}
    .specs-table thead th{padding:14px 16px;font-size:11px;font-weight:700;color:#fff;text-align:center;letter-spacing:0.06em;text-transform:uppercase;white-space:nowrap;}
    .specs-table thead th:first-child{text-align:left;}
    .specs-table tbody tr{border-bottom:1px solid #f0f4fb;}
    .specs-table tbody tr:last-child{border-bottom:none;}
    .specs-table tbody tr:hover{background:#f7f9ff;}
    .specs-table td{padding:14px 16px;font-size:13px;color:#333;text-align:center;vertical-align:middle;}
    .specs-table td:first-child{font-weight:700;color:#1a2f8a;text-align:left;white-space:nowrap;}
    .specs-note{font-size:12px;color:#aaa;margin-top:14px;text-align:right;}

    /* CTA */
    .cta-sec{background:linear-gradient(135deg,#0d1a3a 0%,#1a2f8a 100%);padding:80px 60px;}
    .cta-inner{max-width:700px;margin:0 auto;text-align:center;}
    .cta-title{font-size:clamp(22px,3vw,36px);font-weight:900;color:#fff;letter-spacing:-0.03em;margin-bottom:16px;}
    .cta-sub{font-size:14px;color:rgba(255,255,255,0.65);line-height:1.8;margin-bottom:36px;}
    .cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
    .cta-btn{font-size:14px;font-weight:700;padding:14px 36px;border-radius:6px;cursor:pointer;font-family:inherit;text-decoration:none;transition:all 0.2s;}
    .cta-btn--primary{background:#fff;color:#1a2f8a;}
    .cta-btn--primary:hover{background:#e8edf8;}
    .cta-btn--outline{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,0.4);}
    .cta-btn--outline:hover{background:rgba(255,255,255,0.1);border-color:#fff;}
    @media(max-width:768px){.cta-sec{padding:60px 24px;}}

    /* FOOTER */
    .footer{background:#0d1a3a;padding:28px 60px;display:flex;justify-content:space-between;align-items:center;gap:16px;}
    .footer-logo img{height:20px;filter:brightness(0) invert(1);opacity:0.6;}
    .footer-info{display:flex;flex-direction:column;gap:4px;text-align:right;}
    .footer-copy{font-size:11px;color:rgba(255,255,255,0.3);}
    .footer-contact{font-size:12px;color:rgba(255,255,255,0.45);}
    @media(max-width:768px){.footer{padding:20px 24px;flex-direction:column;text-align:center;}.footer-info{text-align:center;}}
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <a href="/" class="nav-logo"><img src="/images/logo.png" alt="EDS 이담에스티" /></a>
    <div class="nav-menu">
      <div class="nav-item has-drop">
        <span class="nav-link">회사소개</span>
        <div class="nav-drop">
          <a href="/#sec2" class="drop-link">인사말</a>
          <a href="/#sec6" class="drop-link">연혁</a>
          <a href="/#sec-cert" class="drop-link">인증현황</a>
          <a href="/#sec7" class="drop-link">오시는 길</a>
        </div>
      </div>
      <div class="nav-item">
        <a href="/#sec3" class="nav-link">사업분야</a>
      </div>
      <div class="nav-item has-drop">
        <span class="nav-link">조달청 등록제품</span>
        <div class="nav-drop">
          <a href="/products/mediabox" class="drop-link">미디어박스</a>
          <a href="/products/server" class="drop-link">컴퓨터 서버</a>
          <a href="/products/disk-array" class="drop-link">디스크 어레이</a>
          <a href="/products/led" class="drop-link">LED 전광판</a>
        </div>
      </div>
      <div class="nav-item">
        <a href="/works" class="nav-link">구축사례</a>
      </div>
      <div class="nav-item">
        <a href="/#sec7" class="nav-link">문의</a>
      </div>
    </div>
    <a href="/#sec7" class="nav-cta">도입 문의</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div>
        <div class="hero-badge">조달청 등록제품</div>
        <h1 class="hero-title">컴퓨터 <em>서버</em></h1>
        <p class="hero-sub">고성능과 확장성을 바탕으로 개발된<br>2U 2WAY 8BAY 컴퓨터 서버시스템</p>
        <div class="hero-models">
          <span class="hero-model">MSV-2000N</span>
          <span class="hero-model">MSV-2000</span>
          <span class="hero-model">MB-HD8000</span>
          <span class="hero-model">MB-HW3208</span>
          <span class="hero-model">MB-HW6408</span>
        </div>
      </div>
      <div class="hero-img">
        <img src="/images/products/server.png" alt="컴퓨터 서버" />
      </div>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="sec overview">
    <div class="sec-inner">
      <div class="sec-label">Overview</div>
      <h2 class="sec-title">미디어밴스 컴퓨터서버란?</h2>
      <p class="sec-desc">미디어밴스 컴퓨터서버는 안정적인 서버 구축을 위한 최적의 솔루션을 제시합니다. 최신 인텔 제온 스케일러블 프로세서와 DDR5 메모리를 기반으로 압도적인 컴퓨팅 성능을 제공하며, PCIe 5.0 기반의 초고속 인터페이스를 통해 데이터 병목 현상을 최소화합니다.</p>
      <div class="overview-box">
        <p>미디어밴스는 그래픽 옵션이 있어 기본적인 그래픽 및 디스플레이를 작업용 고객, 고성능의 성능과 메모리를 탐재하여 3D 렌더링, 고급 그래픽 작업이 필요한 고객 모두 원하는 옵션을 선택할 수 있습니다. 서버내 하드웨어 컨트롤러는 RAID 0, 1, 5, 6, 50, 60 등 다양한 RAID 레벨을 지원하여 데이터 안정성과 성능을 동시에 향상시키고, 데이터 센터, 연구 개발, 콘텐츠 제작 등 다양한 분야에서 활용이 가능합니다.</p>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="sec features">
    <div class="sec-inner">
      <div class="sec-label">Features</div>
      <h2 class="sec-title">제품 특징</h2>
      <div class="feat-grid">

        <div class="feat-card">
          <div class="feat-tag">CPU</div>
          <div class="feat-title">고성능 프로세서</div>
          <div class="feat-list">
            <div class="feat-item">Single 또는 Dual CPU 사용 가능</div>
            <div class="feat-item">12코어 24쓰레드 최대 4.1GHz</div>
            <div class="feat-item">Intel Xeon Scalable 5th 프로세서 장착</div>
          </div>
        </div>

        <div class="feat-card">
          <div class="feat-tag">GPU</div>
          <div class="feat-title">그래픽 처리</div>
          <div class="feat-list">
            <div class="feat-item">26개의 2세대 RT 코어, 104개의 3세대 Tensor 코어</div>
            <div class="feat-item">3,328개의 차세대 CUDA코어와 12GB GDDR6 그래픽 메모리 GPU RTX A2000 탑재</div>
            <div class="feat-item">NVIDIA RTX 기술, 실시간 레이트레이싱, AI 기술 컴퓨팅 지원</div>
          </div>
        </div>

        <div class="feat-card">
          <div class="feat-tag">Memory</div>
          <div class="feat-title">DDR5 메모리</div>
          <div class="feat-list">
            <div class="feat-item">DDR5규격의 서버 및 워크스테이션용 메모리 모듈로 빠른 속도와 높은 대역폭 제공</div>
            <div class="feat-item">4800MHz의 작동 속도 및 ECC(오류 수정 코드) 기능으로 안정성 제공</div>
            <div class="feat-item">REG(Registered/버피링) DIMM으로 메모리 컨트롤러의 안정적인 작동들을 제공</div>
          </div>
        </div>

        <div class="feat-card">
          <div class="feat-tag">Storage</div>
          <div class="feat-title">스토리지</div>
          <div class="feat-list">
            <div class="feat-item">차세대 규격 NVMe SSD 또는 범용성 높은 SATA SSD 채택</div>
            <div class="feat-item">HDD 최대 80TB 옵션</div>
            <div class="feat-item">8BAY 핫스왑 베이 3.5인치, 2.5인치 드라이브 지원</div>
          </div>
        </div>

        <div class="feat-card">
          <div class="feat-tag">Network</div>
          <div class="feat-title">네트워크 & 확장</div>
          <div class="feat-list">
            <div class="feat-item">10Gbps 이더넷 포트 3개, IPMI 관리 포트 등 서버 환경에 필요한 네트워크 및 관리 기능 지원</div>
            <div class="feat-item">DDR5 메모리 슬롯 16개를 지원하며 PCIe 5.0 슬롯과 다양한 저장 장치 인터페이스를 지원하는 최신 기술을 활용 가능</div>
          </div>
        </div>

        <div class="feat-card">
          <div class="feat-tag">RAID</div>
          <div class="feat-title">RAID 및 안정성</div>
          <div class="feat-list">
            <div class="feat-item">컨트롤러당 최대 240개의 SAS/SATA 장치 또는 32개의 NVMe 장치 연결</div>
            <div class="feat-item">RAID 0, 1, 5, 6, 50, 60 및 SDS 환경을 위한 JBOD 모드 지원</div>
            <div class="feat-item">CacheVault 플래시 캐시 보호 기능</div>
            <div class="feat-item">고속 Backplane을 통한 안전적인 데이터 전송</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SPECS -->
  <section class="sec specs">
    <div class="sec-inner">
      <div class="sec-label">Specifications</div>
      <h2 class="sec-title">제품 사양</h2>
      <div class="specs-wrap">
        <table class="specs-table">
          <thead>
            <tr>
              <th>항목</th>
              <th>MSV-2000N</th>
              <th>MSV-2000</th>
              <th>MB-HD8000</th>
              <th>MB-HW3208</th>
              <th>MB-HW6408</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>물품식별번호</td>
              <td>25672214</td>
              <td>25672218</td>
              <td>25672217</td>
              <td>25672216</td>
              <td>25672215</td>
            </tr>
            <tr>
              <td>조달등록금액</td>
              <td>14,738,000</td>
              <td>13,378,000</td>
              <td>24,041,250</td>
              <td>12,779,000</td>
              <td>15,355,000</td>
            </tr>
            <tr>
              <td>Processor</td>
              <td colspan="2">Xeon Silver 4510 2.4G 12Core × 2</td>
              <td>Xeon Silver 4510 2.4G 12Core × 2</td>
              <td colspan="2">Xeon Silver 4510 2.4G 12Core</td>
            </tr>
            <tr>
              <td>GPU</td>
              <td>Nvidia RTX A2000 DDR6 12G</td>
              <td>ASPEED AST2600</td>
              <td>Nvidia GT1030 2G</td>
              <td>Nvidia GT1030 2G</td>
              <td>Nvidia GT1030 2G</td>
            </tr>
            <tr>
              <td>RAM</td>
              <td>64GB</td>
              <td>64GB</td>
              <td>64GB</td>
              <td>32GB</td>
              <td>32GB</td>
            </tr>
            <tr>
              <td>SSD</td>
              <td>500GB × 2</td>
              <td>500GB × 6</td>
              <td>500GB (NVMe)</td>
              <td>500GB (NVMe)</td>
              <td>500GB (NVMe)</td>
            </tr>
            <tr>
              <td>HDD</td>
              <td>—</td>
              <td>—</td>
              <td>80TB</td>
              <td>32TB</td>
              <td>64TB</td>
            </tr>
            <tr>
              <td>RAID</td>
              <td colspan="5">Broadcom LSI9560-8I</td>
            </tr>
            <tr>
              <td>PSU</td>
              <td colspan="5">800W Redundant</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="specs-note">※ 상기 스펙은 제품 모델별로 상이합니다.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-sec">
    <div class="cta-inner">
      <h2 class="cta-title">도입 문의를 환영합니다</h2>
      <p class="cta-sub">컴퓨터 서버는 조달청 나라장터를 통해 공공기관 직접 구매가 가능합니다.<br>자세한 사양 및 견적은 문의를 통해 확인하세요.</p>
      <div class="cta-btns">
        <a href="/#sec7" class="cta-btn cta-btn--primary">도입 문의하기 →</a>
        <a href="/works" class="cta-btn cta-btn--outline">구축사례 보기</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-logo"><img src="/images/logo.png" alt="EDS 이담에스티" /></div>
    <div class="footer-info">
      <span class="footer-contact">Tel. 02-857-7744 &nbsp;·&nbsp; 평일 09:00 – 18:00</span>
