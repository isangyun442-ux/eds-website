// src/pages/products/led.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Nanum+Square:wght@400;700;800&display=swap" rel="stylesheet" />
  <title>LED 디스플레이 — EDS 이담에스티</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Inter','Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:#fff;color:#0a0a0a;-webkit-font-smoothing:antialiased;}

    /* NAV */
    .nav{position:fixed;top:0;left:0;right:0;z-index:300;display:flex;align-items:center;justify-content:space-between;padding:18px 80px;background:rgba(255,255,255,0.97);box-shadow:0 1px 0 rgba(0,0,0,0.07);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);}
    .nav-logo{height:28px;display:flex;align-items:center;text-decoration:none;}
    .nav-logo img{height:28px;width:auto;object-fit:contain;}
    .nav-menu{display:flex;align-items:center;gap:48px;}
    .nav-item{position:relative;}
    .nav-link{display:block;font-family:'Nanum Square','Apple SD Gothic Neo',sans-serif;font-size:20px;font-weight:400;letter-spacing:0.05em;text-decoration:none;cursor:pointer;color:#1a1a1a;padding:8px 4px;border-radius:6px;transition:all 0.2s;white-space:nowrap;}
    .nav-link:hover{color:#1a2f8a;}
    .nav-link.active{color:#1a2f8a;}
    .nav-item.has-drop:hover .nav-link{color:#1a2f8a;}
    .nav-drop{position:absolute;top:calc(100% + 6px);left:0;min-width:160px;background:#fff;border-radius:10px;border:1px solid rgba(0,0,0,0.08);box-shadow:0 8px 40px rgba(0,0,0,0.12);padding:8px 0;opacity:0;visibility:hidden;transform:translateY(-6px);transition:opacity 0.2s,transform 0.2s,visibility 0.2s;}
    .nav-item.has-drop:hover .nav-drop{opacity:1;visibility:visible;transform:translateY(0);}
    .drop-link{display:block;font-size:14px;font-weight:500;color:#444;text-decoration:none;padding:10px 20px;transition:background 0.15s,color 0.15s;white-space:nowrap;}
    .drop-link:hover{background:rgba(26,47,138,0.05);color:#1a2f8a;}
    .nav-cta{font-size:13px;font-weight:700;padding:9px 20px;background:#1a2f8a;color:#fff;border:none;cursor:pointer;border-radius:6px;font-family:inherit;transition:background 0.2s;text-decoration:none;}
    .nav-cta:hover{background:#142580;}
    @media(max-width:768px){.nav{padding:12px 20px;}.nav-menu{display:none;}}
    .lang-switch { display:flex; gap:6px; margin-right:12px; }
    .lang-sw-btn { font-size:11px; font-weight:700; padding:4px 8px; border:1.5px solid #ddd; background:transparent; cursor:pointer; border-radius:4px; color:#666; font-family:inherit; transition:all 0.2s; }
    .lang-sw-btn.active { background:#1a2f8a; color:#fff; border-color:#1a2f8a; }

    /* HERO */
    .hero{padding:120px 60px 80px;background:linear-gradient(170deg,#f7f9ff 0%,#edf1fb 100%);}
    .hero-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
    .hero-badge{display:inline-flex;align-items:center;gap:8px;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#1a2f8a;margin-bottom:20px;}
    .hero-badge::before{content:'';width:20px;height:1.5px;background:#1a2f8a;}
    .hero-title{font-size:clamp(28px,3.5vw,48px);font-weight:900;letter-spacing:-0.04em;color:#0d1a3a;line-height:1.15;margin-bottom:12px;}
    .hero-title em{color:#1a2f8a;font-style:normal;}
    .hero-sub{font-size:15px;color:#6b7a8d;line-height:1.8;margin-bottom:32px;}
    .hero-img{width:100%;}
    .hero-img img{width:100%;height:auto;display:block;}
    @media(max-width:900px){.hero{padding:100px 24px 60px;}.hero-inner{grid-template-columns:1fr;gap:40px;}.hero-img{order:-1;}}

    /* SECTION 공통 */
    .sec{padding:80px 60px;}
    .sec-inner{max-width:1200px;margin:0 auto;}
    .sec-label{font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#1a2f8a;margin-bottom:8px;}
    .sec-title{font-size:clamp(22px,2.8vw,36px);font-weight:800;letter-spacing:-0.03em;color:#0d1a3a;margin-bottom:40px;}
    @media(max-width:768px){.sec{padding:60px 24px;}}

    /* 제품 카드 */
    .prod-card{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;margin-bottom:80px;padding-bottom:80px;border-bottom:1px solid #e8edf4;}
    .prod-card:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
    .prod-card.reverse .prod-img{order:2;}
    .prod-card.reverse .prod-info{order:1;}
    .prod-img{}
    .prod-img img{width:100%;height:auto;display:block;}
    .prod-series{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#1a2f8a;margin-bottom:12px;}
    .prod-series::before{content:'';width:20px;height:2px;background:#1a2f8a;display:block;}
    .prod-name{font-size:clamp(22px,2.5vw,34px);font-weight:900;letter-spacing:-0.03em;color:#0d1a3a;margin-bottom:8px;}
    .prod-desc{font-size:14px;color:#6b7a8d;line-height:1.8;margin-bottom:24px;}
    .feat-title{font-size:12px;font-weight:700;color:#0d1a3a;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:12px;}
    .feat-list{display:flex;flex-direction:column;gap:8px;margin-bottom:28px;}
    .feat-item{font-size:13px;color:#555;line-height:1.75;padding-left:14px;position:relative;}
    .feat-item::before{content:'·';position:absolute;left:0;color:#1a2f8a;font-weight:700;}

    /* 사양표 */
    .specs-wrap{overflow-x:auto;margin-top:16px;}
    .specs-table{width:100%;border-collapse:collapse;min-width:500px;}
    .specs-table thead{background:#0d1a3a;}
    .specs-table thead th{padding:12px 14px;font-size:11px;font-weight:700;color:#fff;text-align:center;letter-spacing:0.06em;white-space:nowrap;}
    .specs-table thead th:first-child{text-align:left;}
    .specs-table tbody tr{border-bottom:1px solid #f0f4fb;}
    .specs-table tbody tr:last-child{border-bottom:none;}
    .specs-table tbody tr:hover{background:#f7f9ff;}
    .specs-table td{padding:11px 14px;font-size:12px;color:#333;text-align:center;vertical-align:middle;}
    .specs-table td:first-child{font-weight:600;color:#1a2f8a;text-align:left;white-space:nowrap;}
    @media(max-width:768px){.prod-card{grid-template-columns:1fr;gap:32px;}.prod-card.reverse .prod-img,.prod-card.reverse .prod-info{order:0;}}

    /* CTA */
    .cta-sec{background:linear-gradient(135deg,#0d1a3a 0%,#1a2f8a 100%);padding:80px 60px;}
    .cta-inner{max-width:700px;margin:0 auto;text-align:center;}
    .cta-title{font-size:clamp(22px,3vw,36px);font-weight:900;color:#fff;letter-spacing:-0.03em;margin-bottom:16px;}
    .cta-sub{font-size:14px;color:rgba(255,255,255,0.65);line-height:1.8;margin-bottom:36px;}
    .cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
    .cta-btn{font-size:14px;font-weight:700;padding:14px 36px;border-radius:6px;cursor:pointer;font-family:inherit;text-decoration:none;transition:all 0.2s;}
    .cta-btn--primary{background:#fff;color:#1a2f8a;}
    .cta-btn--primary:hover{background:#e8edf8;}
    .cta-btn--outline{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,0.4);}
    .cta-btn--outline:hover{background:rgba(255,255,255,0.1);border-color:#fff;}
    @media(max-width:768px){.cta-sec{padding:60px 24px;}}

    /* FOOTER */
    .footer{background:#0d1a3a;padding:28px 60px;display:flex;justify-content:space-between;align-items:center;gap:16px;}
    .footer-logo img{height:20px;filter:brightness(0) invert(1);opacity:0.6;}
    .footer-info{display:flex;flex-direction:column;gap:4px;text-align:right;}
    .footer-copy{font-size:11px;color:rgba(255,255,255,0.3);}
    .footer-contact{font-size:12px;color:rgba(255,255,255,0.45);}
    @media(max-width:768px){.footer{padding:20px 24px;flex-direction:column;text-align:center;}.footer-info{text-align:center;}}
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <a href="/" class="nav-logo"><img src="/images/logo.png" alt="EDS 이담에스티" /></a>
    <div class="nav-menu">
      <div class="nav-item has-drop">
        <span class="nav-link">회사소개</span>
        <div class="nav-drop">
          <a href="/#sec2" class="drop-link">인사말</a>
          <a href="/#sec6" class="drop-link">연혁</a>
          <a href="/#sec-cert" class="drop-link">인증현황</a>
          <a href="/#sec7" class="drop-link">오시는 길</a>
        </div>
      </div>
      <div class="nav-item">
        <a href="/#sec3" class="nav-link">사업분야</a>
      </div>
