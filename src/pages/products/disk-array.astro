---
// src/pages/products/disk-array.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <title>디스크 어레이 — EDS 이담에스티</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Inter','Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:#fff;color:#0a0a0a;-webkit-font-smoothing:antialiased;}

    /* NAV */
    .nav{position:fixed;top:0;left:0;right:0;z-index:300;display:flex;align-items:center;justify-content:space-between;padding:14px 60px;background:rgba(255,255,255,0.97);box-shadow:0 1px 0 rgba(0,0,0,0.07);backdrop-filter:blur(12px);}
    .nav-logo{height:28px;display:flex;align-items:center;text-decoration:none;}
    .nav-logo img{height:26px;width:auto;}
    .nav-back{font-size:13px;font-weight:600;color:#1a2f8a;text-decoration:none;display:flex;align-items:center;gap:6px;transition:gap 0.2s;}
    .nav-back:hover{gap:10px;}
    .nav-cta{font-size:13px;font-weight:700;padding:9px 20px;background:#1a2f8a;color:#fff;border:none;cursor:pointer;border-radius:6px;font-family:inherit;transition:background 0.2s;text-decoration:none;}
    .nav-cta:hover{background:#142580;}
    @media(max-width:768px){.nav{padding:12px 20px;}}

    /* HERO */
    .hero{padding:120px 60px 80px;background:linear-gradient(170deg,#f7f9ff 0%,#edf1fb 100%);}
    .hero-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
    .hero-badge{display:inline-flex;align-items:center;gap:8px;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#1a2f8a;margin-bottom:20px;}
    .hero-badge::before{content:'';width:20px;height:1.5px;background:#1a2f8a;}
    .hero-title{font-size:clamp(28px,3.5vw,48px);font-weight:900;letter-spacing:-0.04em;color:#0d1a3a;line-height:1.15;margin-bottom:12px;}
    .hero-title em{color:#1a2f8a;font-style:normal;}
    .hero-sub{font-size:15px;color:#6b7a8d;line-height:1.8;margin-bottom:32px;}
    .hero-models{display:flex;flex-wrap:wrap;gap:8px;}
    .hero-model{display:inline-block;font-size:11px;font-weight:700;background:#1a2f8a;color:#fff;padding:4px 12px;border-radius:4px;letter-spacing:0.06em;}
    /* 이미지 2장 나란히 */
    .hero-imgs{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
    .hero-img-item{border-radius:10px;overflow:hidden;background:#111;box-shadow:0 16px 48px rgba(26,47,138,0.12);}
    .hero-img-item img{width:100%;height:auto;display:block;}
    .hero-img-label{font-size:10px;font-weight:700;letter-spacing:0.1em;color:#888;text-align:center;margin-top:8px;text-transform:uppercase;}
    @media(max-width:900px){.hero{padding:100px 24px 60px;}.hero-inner{grid-template-columns:1fr;gap:40px;}.hero-imgs{order:-1;}}

    /* SECTION 공통 */
    .sec{padding:80px 60px;}
    .sec-inner{max-width:1200px;margin:0 auto;}
    .sec-label{font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#1a2f8a;margin-bottom:12px;}
    .sec-title{font-size:clamp(22px,2.8vw,36px);font-weight:800;letter-spacing:-0.03em;color:#0d1a3a;margin-bottom:16px;}
    .sec-desc{font-size:14px;color:#6b7a8d;line-height:1.9;max-width:760px;}
    @media(max-width:768px){.sec{padding:60px 24px;}}

    /* OVERVIEW */
    .overview{background:#fff;}
    .overview-box{background:#f7f9ff;border-left:4px solid #1a2f8a;border-radius:0 10px 10px 0;padding:28px 32px;margin-top:24px;}
    .overview-box p{font-size:14px;color:#444;line-height:2;font-weight:500;}

    /* FEATURES 4박스 */
    .features{background:#f7f9ff;}
    .feat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:48px;}
    .feat-card{background:#fff;border:1px solid #e8edf4;border-radius:12px;padding:28px 28px 24px;transition:box-shadow 0.25s,transform 0.25s;}
    .feat-card:hover{box-shadow:0 10px 36px rgba(26,47,138,0.1);transform:translateY(-3px);}
    .feat-icon{width:36px;height:36px;background:rgba(26,47,138,0.08);border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;}
    .feat-title{font-size:16px;font-weight:800;color:#0d1a3a;margin-bottom:12px;}
    .feat-list{display:flex;flex-direction:column;gap:7px;}
    .feat-item{font-size:13px;color:#555;line-height:1.75;padding-left:14px;position:relative;}
    .feat-item::before{content:'·';position:absolute;left:0;color:#1a2f8a;font-weight:700;}
    @media(max-width:768px){.feat-grid{grid-template-columns:1fr;}}

    /* SPECS */
    .specs{background:#fff;}
    .specs-wrap{overflow-x:auto;margin-top:40px;}
    .specs-table{width:100%;border-collapse:collapse;min-width:660px;border-radius:12px;overflow:hidden;box-shadow:0 2px 20px rgba(26,47,138,0.06);}
    .specs-table thead{background:#0d1a3a;}
    .specs-table thead th{padding:14px 16px;font-size:11px;font-weight:700;color:#fff;text-align:center;letter-spacing:0.06em;text-transform:uppercase;white-space:nowrap;}
    .specs-table thead th:first-child{text-align:left;}
    .specs-table tbody tr{border-bottom:1px solid #f0f4fb;}
    .specs-table tbody tr:last-child{border-bottom:none;}
    .specs-table tbody tr:hover{background:#f7f9ff;}
    .specs-table td{padding:14px 16px;font-size:13px;color:#333;text-align:center;vertical-align:middle;}
    .specs-table td:first-child{font-weight:700;color:#1a2f8a;text-align:left;white-space:nowrap;}
    .specs-note{font-size:12px;color:#aaa;margin-top:14px;text-align:right;}

    /* CTA */
    .cta-sec{background:linear-gradient(135deg,#0d1a3a 0%,#1a2f8a 100%);padding:80px 60px;}
    .cta-inner{max-width:700px;margin:0 auto;text-align:center;}
    .cta-title{font-size:clamp(22px,3vw,36px);font-weight:900;color:#fff;letter-spacing:-0.03em;margin-bottom:16px;}
    .cta-sub{font-size:14px;color:rgba(255,255,255,0.65);line-height:1.8;margin-bottom:36px;}
    .cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
    .cta-btn{font-size:14px;font-weight:700;padding:14px 36px;border-radius:6px;cursor:pointer;font-family:inherit;text-decoration:none;transition:all 0.2s;}
    .cta-btn--primary{background:#fff;color:#1a2f8a;}
    .cta-btn--primary:hover{background:#e8edf8;}
    .cta-btn--outline{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,0.4);}
    .cta-btn--outline:hover{background:rgba(255,255,255,0.1);border-color:#fff;}
    @media(max-width:768px){.cta-sec{padding:60px 24px;}}

    /* FOOTER */
    .footer{background:#0d1a3a;padding:28px 60px;display:flex;justify-content:space-between;align-items:center;gap:16px;}
    .footer-logo img{height:20px;filter:brightness(0) invert(1);opacity:0.6;}
    .footer-info{display:flex;flex-direction:column;gap:4px;text-align:right;}
    .footer-copy{font-size:11px;color:rgba(255,255,255,0.3);}
    .footer-contact{font-size:12px;color:rgba(255,255,255,0.45);}
    @media(max-width:768px){.footer{padding:20px 24px;flex-direction:column;text-align:center;}.footer-info{text-align:center;}}
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <a href="/" class="nav-logo"><img src="/images/logo.png" alt="EDS 이담에스티" /></a>
    <a href="/#sec5" class="nav-back">← 조달청 등록제품으로</a>
    <a href="/#sec7" class="nav-cta">도입 문의</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div>
        <div class="hero-badge">조달청 등록제품</div>
        <h1 class="hero-title">디스크 <em>어레이</em></h1>
        <p class="hero-sub">안전성, 확장성, 사용자의 편의성을 고려한<br>고성능 네트워크 공유 스토리지</p>
        <div class="hero-models">
          <span class="hero-model">NS-NAS 2012</span>
          <span class="hero-model">NS-NAS 4036</span>
          <span class="hero-model">NS-J2000-96</span>
          <span class="hero-model">NS-J2000-192</span>
        </div>
      </div>
      <div>
        <div class="hero-imgs">
          <div>
            <div class="hero-img-item">
              <img src="/images/products/disk-array-nas2012.jpg" alt="NS-NAS 2012" />
            </div>
            <p class="hero-img-label">NS-NAS 2012</p>
          </div>
          <div>
            <div class="hero-img-item">
              <img src="/images/products/disk-array-nas4036.jpg" alt="NS-NAS 4036" />
            </div>
            <p class="hero-img-label">NS-NAS 4036</p>
          </div>
          <div>
            <div class="hero-img-item">
              <img src="/images/products/disk-array-j2000-96.jpg" alt="NS-J2000-96" />
            </div>
            <p class="hero-img-label">NS-J2000-96</p>
          </div>
          <div>
            <div class="hero-img-item">
              <img src="/images/products/disk-array-j2000-192.jpg" alt="NS-J2000-192" />
            </div>
            <p class="hero-img-label">NS-J2000-192</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="sec overview">
    <div class="sec-inner">
      <div class="sec-label">Overview</div>
      <h2 class="sec-title">NS-NAS란?</h2>
      <p class="sec-desc">NS-NAS 스토리지는 Xeon 최대 2개의 CPU 및 2TB까지 확장 가능한 메모리를 장착할 수 있는 고성능 시스템 기반으로 대용량의 데이터를 고속 전송에 적합한 파일시스템으로 설계되었습니다.</p>
      <div class="overview-box">
        <p>양방향 백업, 스케줄링, 원격지 압축백업, QoS 지원 등 다양한 설정이 가능한 백업을 지원하며 직관적인 GUI로 관련설정, 사용자, 네트워크 구성 등을 손 쉽게 추가, 변경할 수 있는 환경을 제공합니다. NS-NAS는 파일서버, 영상미디어, 학교, 관공서, 연구소, CCTV등 스토리지 공유가 필요한 다양한 업무에 적합한 합리적인 네트워크 스토리지입니다.</p>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="sec features">
    <div class="sec-inner">
      <div class="sec-label">Features</div>
      <h2 class="sec-title">제품 특징</h2>
      <div class="feat-grid">

        <div class="feat-card">
          <div class="feat-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1a2f8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div class="feat-title">최고의 성능</div>
          <div class="feat-list">
            <div class="feat-item">최대 2개의 Xeon 프로세서 확장</div>
            <div class="feat-item">2TB 메모리 증설 및 SSD 캐쉬 적용</div>
            <div class="feat-item">최대 4개의 100GbE 옵션 장착 가능</div>
            <div class="feat-item">대용량 데이터 처리에 최적화된 NAS 엔진</div>
          </div>
        </div>

        <div class="feat-card">
          <div class="feat-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1a2f8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          </div>
          <div class="feat-title">안정적 백업</div>
          <div class="feat-list">
            <div class="feat-item">다양한 외장형스토리지 연결 지원</div>
            <div class="feat-item">양방향 백업, 압축백업, QoS설정 기능 제공</div>
            <div class="feat-item">백업 스케줄링, 무한 License 제공</div>
          </div>
        </div>

        <div class="feat-card">
          <div class="feat-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1a2f8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
          </div>
          <div class="feat-title">넓은 확장성</div>
          <div class="feat-list">
            <div class="feat-item">최소 1TB부터 최대 8PB까지 확장</div>
            <div class="feat-item">최신의 고 용량 하드 디스크 지원</div>
            <div class="feat-item">스토리지 폴더단위 용량 증설, 감설 지원</div>
            <div class="feat-item">이기종 외장형 스토리지 지원</div>
          </div>
        </div>

        <div class="feat-card">
          <div class="feat-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1a2f8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <div class="feat-title">최상의 관리성</div>
          <div class="feat-list">
            <div class="feat-item">CPU, 메모리, 네트워크 사용 모니터링</div>
            <div class="feat-item">안전하고 직관적인 RAID 구성 관리</div>
            <div class="feat-item">시스템, 디스크, 네트워크 별도 로그 관리</div>
            <div class="feat-item">시간, 일자별 조회 선택 자원 사용 관리</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SPECS -->
  <section class="sec specs">
    <div class="sec-inner">
      <div class="sec-label">Specifications</div>
      <h2 class="sec-title">제품 사양</h2>
      <div class="specs-wrap">
        <table class="specs-table">
          <thead>
            <tr>
              <th>항목</th>
              <th>NS-NAS 2012</th>
              <th>NS-NAS 4036</th>
              <th>NS-J2000-96</th>
              <th>NS-J2000-192</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>물품식별번호</td>
              <td>25060019</td>
              <td>25499708</td>
              <td>25497586</td>
              <td>25497587</td>
            </tr>
            <tr>
              <td>조달등록금액</td>
              <td>20,257,000</td>
              <td>39,536,000</td>
              <td>16,097,000</td>
              <td>21,901,000</td>
            </tr>
            <tr>
              <td>형식</td>
              <td>2U Rack</td>
              <td>4U</td>
              <td>2U</td>
              <td>2U</td>
            </tr>
            <tr>
              <td>프로세서</td>
              <td>Intel Xeon Multi Core</td>
              <td>Intel Xeon Multi Core</td>
              <td>—</td>
              <td>—</td>
            </tr>
            <tr>
              <td>디스크베이</td>
              <td>12</td>
              <td>36</td>
              <td>12</td>
              <td>12</td>
            </tr>
            <tr>
              <td>디스크용량</td>
              <td>48TB (물리적용량)</td>
              <td>288TB (물리적용량)</td>
              <td>96TB (물리적용량)</td>
              <td>192TB (물리적용량)</td>
            </tr>
            <tr>
              <td>레이드</td>
              <td>0/1/5/6/10/50/60</td>
              <td>0/1/5/6/10/50/60</td>
              <td>—</td>
              <td>—</td>
            </tr>
            <tr>
              <td>PSU</td>
              <td>800W Redundant</td>
              <td>1300W Redundant</td>
              <td>800W Redundant</td>
              <td>800W Redundant</td>
            </tr>
            <tr>
              <td>기타</td>
              <td>NAS 스토리지 (메인)</td>
              <td>NAS 스토리지 (메인)</td>
              <td>JBOD 확장디스크 (부품)</td>
              <td>JBOD 확장디스크 (부품)</td>
            </tr>
            <tr>
              <td>크기</td>
              <td>436×650×90(H)</td>
              <td>437.5×650×176.5(H)</td>
              <td>436×650×90(H)</td>
              <td>436×650×90(H)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="specs-note">※ 본 카탈로그의 내용은 2025년 2월 기준으로 작성되었습니다.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-sec">
    <div class="cta-inner">
      <h2 class="cta-title">도입 문의를 환영합니다</h2>
      <p class="cta-sub">디스크 어레이는 조달청 나라장터를 통해 공공기관 직접 구매가 가능합니다.<br>자세한 사양 및 견적은 문의를 통해 확인하세요.</p>
      <div class="cta-btns">
        <a href="/#sec7" class="cta-btn cta-btn--primary">도입 문의하기 →</a>
        <a href="/works" class="cta-btn cta-btn--outline">구축사례 보기</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-logo"><img src="/images/logo.png" alt="EDS 이담에스티" /></div>
    <div class="footer-info">
      <span class="footer-contact">Tel. 02-857-7744 &nbsp;·&nbsp; 평일 09:00 – 18:00</span>
      <span class="footer-copy">© 2025 이담에스티 주식회사. All rights reserved.</span>
    </div>
  </footer>

</body>
</html>
