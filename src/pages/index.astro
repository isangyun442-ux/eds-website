  </div>

  <script is:inline>
  const nav = document.getElementById('nav');
  const hero = document.getElementById('sec0');
  window.addEventListener('scroll', function() {
    const heroHeight = hero ? hero.offsetHeight : 0;
    if (window.scrollY > heroHeight - 60) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
    const fb = document.getElementById('floatBtn');
    if (fb) {
      fb.style.opacity = window.scrollY > 200 ? '1' : '0';
      fb.style.pointerEvents = window.scrollY > 200 ? 'auto' : 'none';
    }
  });
  const fadeObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        fadeObs.unobserve(e.target); // 한 번 보이면 해제 — 위로 스크롤 시 깜빡임 방지
      }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.fade-up').forEach(function(el) { fadeObs.observe(el); });
  const sh = document.getElementById('sh');
  if (sh) {
    window.addEventListener('scroll', function() {
      if (window.scrollY > 80) sh.classList.add('hide');
    }, { passive: true });
  }

  // easing 스크롤 함수 (전역으로 먼저 선언)
  window.smoothScrollTo = function(target) {
    var start = window.scrollY;
    var distance = target - start;
    var duration = Math.min(800 + Math.abs(distance) * 0.3, 1400);
    var startTime = null;
    function easeOutQuart(t){ return 1 - Math.pow(1 - t, 4); }
    function step(ts){
      if(!startTime) startTime = ts;
      var elapsed = ts - startTime;
      var progress = Math.min(elapsed / duration, 1);
      window.scrollTo(0, start + distance * easeOutQuart(progress));
      if(progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  };

  window.qnGo = function(id){
    var el = document.getElementById(id);
    if(!el) return;
    var top = el.getBoundingClientRect().top + window.scrollY - 60;
    smoothScrollTo(top);
  };

  // ── 언어 드롭다운 ──
  var langNames = { ko:'KO', en:'EN', zh:'ZH', ja:'JA' };

  window.toggleLangDrop = function() {
    document.getElementById('langWrap').classList.toggle('open');
  };

  window.selectLang = function(lang) {
    // 언어 적용
    if (typeof window.__applyLang === 'function') window.__applyLang(lang);
    // 현재 코드 업데이트
    document.getElementById('langCurCode').textContent = langNames[lang] || lang.toUpperCase();
    // active 표시
    document.querySelectorAll('.lang-option').forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.lang === lang);
    });
    // 드롭다운 닫기
    document.getElementById('langWrap').classList.remove('open');
  };

  // 저장된 언어 초기 적용
  (function() {
    var saved = localStorage.getItem('eds-lang') || 'ko';
    document.getElementById('langCurCode').textContent = langNames[saved] || saved.toUpperCase();
    document.querySelectorAll('.lang-option').forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.lang === saved);
    });
  })();

  // 외부 클릭 시 드롭다운 닫기
  document.addEventListener('click', function(e) {
    var wrap = document.getElementById('langWrap');
    if (wrap && !wrap.contains(e.target)) wrap.classList.remove('open');
  });

  </script>

  <!-- 섹션 스냅 스크롤 -->
  <script is:inline>
  (function(){
    var SECTIONS = ['sec0','sec2','sec6','sec-cert','sec3','sec4','sec-strength','sec5','sec7'];
    // 뷰포트보다 길어서 자유 스크롤 허용할 섹션
    var FREE_SCROLL_SECTIONS = ['sec6', 'sec-strength'];
    var COOLDOWN = 1500;
    var THRESHOLD = 100;
    var EDGE_MARGIN = 80;
    var locked = false;
    var accDelta = 0;
    var accTimer = null;
    var currentIdx = 0; // 스크롤 위치 대신 타겟 인덱스 추적

    function getScrollIndex(){
      var scrollY = window.scrollY;
      var best = 0;
      for(var i = 0; i < SECTIONS.length; i++){
        var el = document.getElementById(SECTIONS[i]);
        if(!el) continue;
        var top = el.getBoundingClientRect().top + scrollY;
        if(scrollY >= top - 80) best = i;
      }
      return best;
    }

    function isTallSection(id){
      return FREE_SCROLL_SECTIONS.indexOf(id) !== -1;
    }

    // 현재 섹션 내에서 경계에 있는지 확인
    function isAtSectionEdge(idx, dir){
      var el = document.getElementById(SECTIONS[idx]);
      if(!el) return true;
      var scrollY = window.scrollY;
      var winH = window.innerHeight;
      var secTop = el.getBoundingClientRect().top + scrollY;
      var secBot = secTop + el.offsetHeight;

      if(dir > 0){
        // 아래 스크롤: 섹션 하단이 뷰포트 안에 들어왔는지
        return scrollY + winH >= secBot - EDGE_MARGIN;
      } else {
        // 위 스크롤: 섹션 상단에 가까운지
        return scrollY <= secTop + EDGE_MARGIN;
      }
    }

    function goToIndex(idx){
      if(idx < 0 || idx >= SECTIONS.length) return;
      var el = document.getElementById(SECTIONS[idx]);
      if(!el) return;
      locked = true;
      currentIdx = idx; // 애니메이션 완료 전에도 타겟 인덱스 확정
      var top = el.getBoundingClientRect().top + window.scrollY - 60;
      smoothScrollTo(Math.max(0, top));
      setTimeout(function(){ locked = false; }, COOLDOWN);
    }

    // 페이지 로드 시 현재 위치로 인덱스 초기화
    window.addEventListener('load', function(){
      currentIdx = getScrollIndex();
    });

    window.addEventListener('wheel', function(e){
      if(locked){
        accDelta = 0;
        clearTimeout(accTimer);
        return;
      }

      accDelta += e.deltaY;
      clearTimeout(accTimer);
      accTimer = setTimeout(function(){ accDelta = 0; }, 200);

      if(Math.abs(accDelta) < THRESHOLD) return;

      var dir = accDelta > 0 ? 1 : -1;
      accDelta = 0;

      var curId = SECTIONS[currentIdx];

      // 자유 스크롤 섹션이면 경계에 도달했을 때만 스냅
      if(isTallSection(curId) && !isAtSectionEdge(currentIdx, dir)) return;

      goToIndex(currentIdx + dir);
    }, { passive: true });

    // 키보드 지원
    window.addEventListener('keydown', function(e){
      if(locked) return;
      if(e.key === 'ArrowDown' || e.key === 'PageDown'){
        e.preventDefault();
        if(isTallSection(SECTIONS[currentIdx]) && !isAtSectionEdge(currentIdx, 1)) return;
        goToIndex(currentIdx + 1);
      } else if(e.key === 'ArrowUp' || e.key === 'PageUp'){
        e.preventDefault();
        if(isTallSection(SECTIONS[currentIdx]) && !isAtSectionEdge(currentIdx, -1)) return;
        goToIndex(currentIdx - 1);
      }
    });

    // 퀵메뉴/nav 클릭으로 이동 시 인덱스 동기화
    window.qnGo = function(id){
      var el = document.getElementById(id);
      if(!el) return;
      var idx = SECTIONS.indexOf(id);
      if(idx !== -1){ currentIdx = idx; locked = true; setTimeout(function(){ locked = false; }, COOLDOWN); }
      var top = el.getBoundingClientRect().top + window.scrollY - 60;
      smoothScrollTo(Math.max(0, top));
    };
  })();
  </script>

</body>
</html>

