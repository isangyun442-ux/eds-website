---
// src/pages/index.astro
import SecHero       from '../components/SecHero.astro';
import SecAbout      from '../components/SecAbout.astro';
import SecServices   from '../components/SecServices.astro';
import SecPortfolio  from '../components/SecPortfolio.astro';
import SecHistory    from '../components/SecHistory.astro';
import SecClients    from '../components/SecClients.astro';
import SecContact    from '../components/SecContact.astro';
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EDS 이담에스티 — Beyond The Future | 스마트 공간 솔루션</title>
  <meta name="description" content="방송 스튜디오부터 LED 디스플레이까지. 17년의 경험으로 최적의 스마트 공간을 설계합니다." />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <script is:inline src="/i18n/translations.js"></script>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      width: 100%;
      font-family: 'Inter', 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif;
      background: #fff;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* 공통 섹션 */
    .sec {
      width: 100%;
      position: relative;
    }

    /* ── 전역 페이드업 애니메이션 ── */
    .fade-up {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1);
    }
    .fade-up.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .fade-up-d1 { transition-delay: 0.1s; }
    .fade-up-d2 { transition-delay: 0.2s; }
    .fade-up-d3 { transition-delay: 0.3s; }
    .fade-up-d4 { transition-delay: 0.4s; }
    .fade-up-d5 { transition-delay: 0.5s; }

    /* NAV */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 300;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 60px;
      transition: background 0.4s, box-shadow 0.4s, padding 0.3s;
    }
    .nav.scrolled {
      background: rgba(255,255,255,0.97);
      box-shadow: 0 1px 0 rgba(0,0,0,0.06);
      padding: 14px 60px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    /* 로고 */
    .nav-logo {
      height: 28px; position: relative; width: 140px;
      flex-shrink: 0; text-decoration: none;
    }
    .logo-color { position: absolute; top: 0; left: 0; height: 28px; width: auto; object-fit: contain; opacity: 0; transition: opacity 0.4s; }
    .logo-white { position: absolute; top: 0; left: 0; height: 28px; width: auto; object-fit: contain; filter: brightness(0) invert(1); opacity: 1; transition: opacity 0.4s; }
    .nav.scrolled .logo-color { opacity: 1; }
    .nav.scrolled .logo-white { opacity: 0; }

    /* 메뉴 */
    .nav-menu { display: flex; align-items: center; gap: 4px; }

    .nav-item {
      position: relative;
    }
    .nav-link {
      display: block;
      font-size: 17px; font-weight: 600;
      letter-spacing: -0.01em;
      text-decoration: none; cursor: pointer;
      padding: 8px 16px;
      border-radius: 6px;
      transition: all 0.2s;
      white-space: nowrap;
    }
    .nav.scrolled .nav-link { color: #1a1a1a; }
    .nav:not(.scrolled) .nav-link { color: rgba(255,255,255,0.9); }
    .nav-item:hover .nav-link {
      background: rgba(255,255,255,0.12);
    }
    .nav.scrolled .nav-item:hover .nav-link {
      background: rgba(13,58,74,0.06);
      color: #0D3A4A;
    }

    /* 드롭다운 */
    .nav-drop {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      background: rgba(10, 20, 30, 0.75);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: 0 8px 40px rgba(0,0,0,0.3);
      padding: 8px;
      min-width: 160px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-6px);
      transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
      z-index: 100;
    }
    .nav-item.has-drop:hover .nav-drop {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .drop-link {
      display: block;
      font-size: 14px; font-weight: 500;
      color: rgba(255,255,255,0.8); text-decoration: none;
      padding: 9px 14px;
      border-radius: 6px;
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .drop-link:hover {
      background: rgba(255,255,255,0.1);
      color: #fff;
    }

    /* 언어 버튼 */
    .lang-wrap { display: flex; gap: 4px; flex-shrink: 0; }
    .lang-btn {
      font-size: 11px; font-weight: 700; padding: 5px 9px;
      background: transparent; border: 1px solid rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.5); cursor: pointer; letter-spacing: 0.06em;
      transition: all 0.2s; border-radius: 4px;
    }
    .nav.scrolled .lang-btn { border-color: rgba(0,0,0,0.12); color: #999; }
    .lang-btn:hover { color: #fff; border-color: rgba(255,255,255,0.5); }
    .nav.scrolled .lang-btn:hover { color: #0D3A4A; border-color: #0D3A4A; }
    .lang-btn.active { color: #fff; border-color: #00B8D9; background: rgba(0,184,217,0.12); }
    .nav.scrolled .lang-btn.active { color: #0D3A4A; border-color: #0D3A4A; background: rgba(13,58,74,0.07); }

    @media (max-width: 768px) {
      .nav { display: none !important; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <a href="/" class="nav-logo">
      <img class="logo-color" src="/images/logo.png" alt="EDS 이담에스티" />
      <img class="logo-white" src="/images/logo.png" alt="EDS 이담에스티" />
    </a>

    <div class="nav-menu">

      <!-- 회사소개 -->
      <div class="nav-item has-drop">
        <span class="nav-link">회사소개</span>
        <div class="nav-drop">
          <a href="#sec2" class="drop-link" onclick="event.preventDefault();document.getElementById('sec2').scrollIntoView({behavior:'smooth'})">인사말</a>
          <a href="#sec5" class="drop-link" onclick="event.preventDefault();document.getElementById('sec5').scrollIntoView({behavior:'smooth'})">연혁</a>
          <a href="#sec2" class="drop-link" onclick="event.preventDefault();document.getElementById('sec2').scrollIntoView({behavior:'smooth'})">인증현황</a>
          <a href="#sec7" class="drop-link" onclick="event.preventDefault();document.getElementById('sec7').scrollIntoView({behavior:'smooth'})">오시는 길</a>
        </div>
      </div>

      <!-- 사업분야 -->
      <div class="nav-item has-drop">
        <span class="nav-link">사업분야</span>
        <div class="nav-drop">
          <a href="#sec3" class="drop-link" onclick="event.preventDefault();document.getElementById('sec3').scrollIntoView({behavior:'smooth'})">공공기관</a>
          <a href="#sec3" class="drop-link" onclick="event.preventDefault();document.getElementById('sec3').scrollIntoView({behavior:'smooth'})">교육기관</a>
          <a href="#sec3" class="drop-link" onclick="event.preventDefault();document.getElementById('sec3').scrollIntoView({behavior:'smooth'})">기업</a>
          <a href="#sec3" class="drop-link" onclick="event.preventDefault();document.getElementById('sec3').scrollIntoView({behavior:'smooth'})">미디어센터</a>
          <a href="#sec3" class="drop-link" onclick="event.preventDefault();document.getElementById('sec3').scrollIntoView({behavior:'smooth'})">종교</a>
        </div>
      </div>

      <!-- 조달청 등록제품 -->
      <div class="nav-item has-drop">
        <span class="nav-link">조달청 등록제품</span>
        <div class="nav-drop">
          <a href="#" class="drop-link">미디어박스</a>
          <a href="#" class="drop-link">컴퓨터 서버</a>
          <a href="#" class="drop-link">디스크 어레이</a>
          <a href="#" class="drop-link">LED 전광판</a>
        </div>
      </div>

      <!-- 구축사례 -->
      <div class="nav-item">
        <a href="#sec4" class="nav-link" onclick="event.preventDefault();document.getElementById('sec4').scrollIntoView({behavior:'smooth'})">구축사례</a>
      </div>

      <!-- 문의 -->
      <div class="nav-item">
        <a href="#sec7" class="nav-link" onclick="event.preventDefault();document.getElementById('sec7').scrollIntoView({behavior:'smooth'})">문의</a>
      </div>

    </div>

    <div class="lang-wrap">
      <button class="lang-btn active" data-lang="ko" onclick="__applyLang('ko')">KO</button>
      <button class="lang-btn" data-lang="en" onclick="__applyLang('en')">EN</button>
      <button class="lang-btn" data-lang="zh" onclick="__applyLang('zh')">ZH</button>
      <button class="lang-btn" data-lang="ja" onclick="__applyLang('ja')">JA</button>
    </div>
  </nav>

  <!-- 섹션들 -->
  <SecHero />
  <SecAbout />
  <SecServices />
  <SecPortfolio />
  <SecHistory />
  <SecClients />
  <SecContact />

<script is:inline>
  const nav = document.getElementById('nav');

  window.addEventListener('scroll', function() {
    const hero = document.getElementById('sec0');
    const heroHeight = hero ? hero.offsetHeight : 0;
    if (window.scrollY > heroHeight - 60) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  });

  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.querySelector(a.getAttribute('href'));
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    });
  });

  // 전역 fade-up IntersectionObserver
  const fadeObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        fadeObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.fade-up').forEach(function(el) { fadeObs.observe(el); });
</script>

<!-- ── 플로팅 문의 버튼 + 팝업 ── -->
<div class="float-btn" id="floatBtn" onclick="document.getElementById('inquiryModal').classList.add('open')">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <span>문의하기</span>
</div>

<!-- 팝업 모달 -->
<div class="inq-modal" id="inquiryModal">
  <div class="inq-overlay" onclick="document.getElementById('inquiryModal').classList.remove('open')"></div>
  <div class="inq-box">
    <div class="inq-head">
      <div>
        <div class="inq-title">도입 문의</div>
        <div class="inq-sub">전문 상담팀이 빠르게 답변드립니다</div>
      </div>
      <button class="inq-close" onclick="document.getElementById('inquiryModal').classList.remove('open')">✕</button>
    </div>

    <div class="inq-body">
      <div class="inq-field">
        <label class="inq-label">회사명 <span class="req">*</span></label>
        <input class="inq-input" type="text" placeholder="회사명을 입력해주세요" />
      </div>
      <div class="inq-field">
        <label class="inq-label">담당자 이름 <span class="req">*</span></label>
        <input class="inq-input" type="text" placeholder="홍길동" />
      </div>
      <div class="inq-field">
        <label class="inq-label">연락처 <span class="req">*</span></label>
        <div class="inq-tel">
          <input class="inq-input" type="tel" placeholder="010" maxlength="4"/>
          <span>-</span>
          <input class="inq-input" type="tel" placeholder="0000" maxlength="4"/>
          <span>-</span>
          <input class="inq-input" type="tel" placeholder="0000" maxlength="4"/>
        </div>
      </div>
      <div class="inq-field">
        <label class="inq-label">이메일</label>
        <input class="inq-input" type="email" placeholder="example@company.com" />
      </div>
      <div class="inq-field">
        <label class="inq-label">상담 분야 <span class="req">*</span></label>
        <div class="inq-checks">
          <label class="inq-check"><input type="checkbox" /><span>방송 SI</span></label>
          <label class="inq-check"><input type="checkbox" /><span>스튜디오 구축</span></label>
          <label class="inq-check"><input type="checkbox" /><span>LED 디스플레이</span></label>
          <label class="inq-check"><input type="checkbox" /><span>스마트 강의실</span></label>
          <label class="inq-check"><input type="checkbox" /><span>아카이브 시스템</span></label>
          <label class="inq-check"><input type="checkbox" /><span>화상회의 시스템</span></label>
          <label class="inq-check"><input type="checkbox" /><span>유지보수</span></label>
          <label class="inq-check"><input type="checkbox" /><span>기타</span></label>
        </div>
      </div>
      <div class="inq-field">
        <label class="inq-label">문의 내용</label>
        <textarea class="inq-input inq-textarea" placeholder="문의하실 내용을 자유롭게 입력해주세요"></textarea>
      </div>
    </div>

    <div class="inq-foot">
      <button class="inq-submit">문의 보내기 →</button>
      <p class="inq-privacy">평일 09:00 – 18:00 운영 · Tel. 02-857-7744</p>
    </div>
  </div>
</div>

<style>
  /* 플로팅 버튼 */
  .float-btn {
    position: fixed; bottom: 32px; right: 32px;
    z-index: 400;
    display: flex; align-items: center; gap: 8px;
    background: #0D3A4A; color: #fff;
    padding: 14px 22px; border-radius: 50px;
    cursor: pointer; font-size: 14px; font-weight: 700;
    box-shadow: 0 4px 24px rgba(13,58,74,0.35);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    letter-spacing: 0.02em;
  }
  .float-btn:hover {
    background: #00B8D9;
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(0,184,217,0.4);
  }

  /* 오버레이 */
  .inq-modal {
    position: fixed; inset: 0; z-index: 500;
    display: flex; align-items: flex-end; justify-content: flex-end;
    padding: 0 32px 100px;
    pointer-events: none; opacity: 0;
    transition: opacity 0.25s;
  }
  .inq-modal.open { pointer-events: all; opacity: 1; }
  .inq-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(4px);
  }
  .inq-box {
    position: relative; z-index: 1;
    background: #fff; border-radius: 16px;
    width: 440px; max-height: 80vh;
    display: flex; flex-direction: column;
    box-shadow: 0 24px 80px rgba(0,0,0,0.2);
    transform: translateY(20px);
    transition: transform 0.3s cubic-bezier(0.16,1,0.3,1);
    overflow: hidden;
  }
  .inq-modal.open .inq-box { transform: translateY(0); }

  /* 헤더 */
  .inq-head {
    display: flex; align-items: flex-start; justify-content: space-between;
    padding: 24px 28px 20px;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
  }
  .inq-title { font-size: 20px; font-weight: 800; color: #0a0a0a; letter-spacing: -0.03em; margin-bottom: 4px; }
  .inq-sub { font-size: 12px; color: #999; }
  .inq-close {
    background: none; border: none; cursor: pointer;
    font-size: 16px; color: #aaa; padding: 4px; line-height: 1;
    transition: color 0.2s;
  }
  .inq-close:hover { color: #0a0a0a; }

  /* 바디 스크롤 */
  .inq-body {
    overflow-y: auto; padding: 20px 28px;
    display: flex; flex-direction: column; gap: 18px;
    flex: 1; min-height: 0;
  }
  .inq-body::-webkit-scrollbar { width: 4px; }
  .inq-body::-webkit-scrollbar-thumb { background: #e0e0e0; border-radius: 2px; }

  /* 필드 */
  .inq-field { display: flex; flex-direction: column; gap: 7px; }
  .inq-label { font-size: 12px; font-weight: 700; color: #333; letter-spacing: 0.02em; }
  .req { color: #e53e3e; }
  .inq-input {
    width: 100%; padding: 10px 14px;
    border: 1px solid #e0e0e0; border-radius: 8px;
    font-size: 14px; color: #0a0a0a; font-family: inherit;
    outline: none; transition: border-color 0.2s;
    background: #fafafa;
  }
  .inq-input:focus { border-color: #00B8D9; background: #fff; }
  .inq-input::placeholder { color: #bbb; }

  /* 전화번호 */
  .inq-tel { display: flex; align-items: center; gap: 6px; }
  .inq-tel span { color: #aaa; font-weight: 500; }
  .inq-tel .inq-input { text-align: center; }

  /* 텍스트에리어 */
  .inq-textarea { resize: none; height: 90px; }

  /* 체크박스 */
  .inq-checks { display: flex; flex-wrap: wrap; gap: 8px; }
  .inq-check {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: #555; cursor: pointer;
    padding: 7px 14px;
    border: 1px solid #e0e0e0; border-radius: 20px;
    transition: all 0.15s;
  }
  .inq-check:hover { border-color: #00B8D9; color: #00B8D9; }
  .inq-check input { display: none; }
  .inq-check input:checked + span { color: #0D3A4A; font-weight: 700; }
  .inq-check:has(input:checked) { border-color: #0D3A4A; background: rgba(13,58,74,0.05); }

  /* 푸터 */
  .inq-foot {
    padding: 16px 28px 24px;
    border-top: 1px solid #f0f0f0;
    flex-shrink: 0;
  }
  .inq-submit {
    width: 100%; padding: 14px;
    background: #0D3A4A; color: #fff;
    border: none; border-radius: 8px;
    font-size: 14px; font-weight: 700;
    cursor: pointer; letter-spacing: 0.06em;
    font-family: inherit;
    transition: background 0.2s;
    margin-bottom: 10px;
  }
  .inq-submit:hover { background: #00B8D9; }
  .inq-privacy { font-size: 11px; color: #bbb; text-align: center; }

  @media (max-width: 480px) {
    .float-btn span { display: none; }
    .float-btn { padding: 14px; border-radius: 50%; }
    .inq-modal { padding: 0 0 90px; align-items: flex-end; justify-content: center; }
    .inq-box { width: 100%; border-radius: 16px 16px 0 0; max-height: 90vh; }
  }
</style>
</body>
</html>
