---
// 메인 페이지
// 컴포넌트를 import해서 조립하는 곳이에요
// 순서 바꾸거나 섹션 추가/제거할 때 여기만 수정하면 돼요
import Layout    from '../layouts/Layout.astro';
import Nav       from '../components/Nav.astro';
import Hero      from '../components/Hero.astro';
import Services  from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import History from '../components/History.astro';
import Clients   from '../components/Clients.astro';
import Contact   from '../components/Contact.astro';
---

<Layout title="EDS — Beyond The Future | 스마트 공간 솔루션">

  <Nav />
  <Hero />

  <!-- 통계 배너 -->
  <div class="stats-band">
    <div class="stat-item reveal"><div class="sn">200<span class="sc">+</span></div><div class="sl">구축 완료 공간</div></div>
    <div class="stat-item reveal"><div class="sn">15<span class="sc">년</span></div><div class="sl">업력 및 전문성</div></div>
    <div class="stat-item reveal"><div class="sn">98<span class="sc">%</span></div><div class="sl">고객 만족도</div></div>
    <div class="stat-item reveal"><div class="sn">24<span class="sc">/7</span></div><div class="sl">기술 지원</div></div>
  </div>

  <Services />
  <Portfolio />
  <History />
  <Clients />
  <Contact />

  <!-- 푸터 -->
  <footer>
    <div class="ft-logo">
      <img src="/images/logo.png" alt="EDS" />
    </div>
    <div class="ft-tagline">Beyond The Future — 이담에스티 주식회사</div>
    <div class="ft-copy">© 2025 EDS. All rights reserved.</div>
  </footer>

</Layout>

<style>
  /* 통계 배너 */
  .stats-band {
    background: var(--navy);
    display: grid; grid-template-columns: repeat(4,1fr);
    position: relative; overflow: hidden;
  }
  .stats-band::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--navy2) 0%, var(--red) 33%, var(--cyan) 66%, var(--navy2) 100%);
  }
  .stat-item {
    padding: 44px 32px; text-align: center;
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .stat-item:last-child { border-right: none; }
  .sn {
    font-family: var(--sans); font-size: 52px; font-weight: 800; font-style: italic;
    color: #fff; line-height: 1; margin-bottom: 8px; letter-spacing: -0.03em;
  }
  .sc { color: var(--cyan); font-size: 32px; }
  .sl { font-size: 11px; font-weight: 600; letter-spacing: .15em; text-transform: uppercase; color: var(--gray); }

  /* 푸터 */
  footer {
    background: var(--navy3);
    border-top: 3px solid var(--red);
    padding: 36px 60px;
    display: grid; grid-template-columns: auto 1fr auto;
    align-items: center; gap: 40px;
  }
  .ft-logo img { height: 28px; width: auto; object-fit: contain; filter: brightness(0) invert(1); opacity: .85; }
  .ft-tagline  { font-size: 11px; font-weight: 600; letter-spacing: .15em; text-transform: uppercase; color: rgba(255,255,255,0.25); }
  .ft-copy     { font-size: 11px; color: rgba(255,255,255,0.2); }

  @media (max-width: 768px) {
    .stats-band { grid-template-columns: repeat(2,1fr); }
    .stat-item  { padding: 32px 20px; }
    footer { grid-template-columns: 1fr; gap: 12px; padding: 28px 24px; text-align: center; }
  }
</style>
