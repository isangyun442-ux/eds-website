<script is:inline>
// 퀵메뉴 표시/숨김 + 활성 섹션 + 슬라이딩 인디케이터 + 플로팅 lag
(function(){
  var nav       = document.getElementById('quickNav');
  var items     = document.querySelectorAll('.qn-item');
  var indicator = document.getElementById('qnIndicator');
  var list      = document.getElementById('qnList');
  var sections  = ['sec2','sec6','sec-cert','sec3','sec4','sec-strength','sec5','sec7'];

  // ── 플로팅 lag (scroll velocity → offset) ──
  var navH       = 0;
  var offset     = 0;
  var velocity   = 0;
  var lastScroll = window.scrollY;

  function lerp(a, b, t){ return a + (b - a) * t; }

  function raf(){
    navH = nav.offsetHeight || navH;
    var scrollY = window.scrollY;
    var delta   = scrollY - lastScroll;
    lastScroll  = scrollY;

    velocity += delta * 0.10;   // 스크롤 방향으로 밀림
    velocity *= 0.84;            // 마찰 (낮을수록 오래 남음)
    offset = lerp(offset, velocity, 0.12);

    var baseY = window.innerHeight / 2 - navH / 2;
    nav.style.transform = 'translateY(' + Math.round(baseY + offset) + 'px)';
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  function moveIndicator(activeItem){
    if(!activeItem || !indicator) return;
    indicator.style.top    = activeItem.offsetTop + 'px';
    indicator.style.height = activeItem.offsetHeight + 'px';
    indicator.classList.add('on');
  }

  function update(){
    var scrollY = window.scrollY;
    var winH    = window.innerHeight;
    var docH    = document.body.scrollHeight;

    if(scrollY > 200) nav.classList.add('visible');
    else nav.classList.remove('visible');

    // sec2 구간 dim 처리
    var sec2El = document.getElementById('sec2');
    var sec6El = document.getElementById('sec6');
    if(sec2El && sec6El){
      var sec2Top = sec2El.getBoundingClientRect().top + scrollY;
      var sec6Top = sec6El.getBoundingClientRect().top + scrollY;
      if(scrollY >= sec2Top - 100 && scrollY < sec6Top - 100){
        nav.classList.add('dim');
      } else {
        nav.classList.remove('dim');
      }
    }

    // 활성 섹션
    var cur = '';
    if(scrollY + winH >= docH - 50){
      cur = sections[sections.length - 1];
    } else {
      sections.forEach(function(id){
        var el = document.getElementById(id);
        if(!el) return;
        if(scrollY >= el.getBoundingClientRect().top + scrollY - 80) cur = id;
      });
    }

    var activeItem = null;
    items.forEach(function(item){
      var isActive = item.dataset.sec === cur;
      item.classList.toggle('active', isActive);
      if(isActive) activeItem = item;
    });
    if(activeItem) moveIndicator(activeItem);
    else indicator.classList.remove('on');
  }

  window.addEventListener('scroll', update, { passive: true });
  requestAnimationFrame(function(){ requestAnimationFrame(update); });
})();
</script>
