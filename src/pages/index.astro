    <button class="dot" onclick="goTo(2)"></button>
    <button class="dot" onclick="goTo(3)"></button>
    <button class="dot" onclick="goTo(4)"></button>
    <button class="dot" onclick="goTo(5)"></button>
  </div>

</div>

<script>
  const DARK_SECS = [0, 5];
  let cur = 0, busy = false;
  const N = 6;
  const secs   = Array.from({length:N}, (_,i) => document.getElementById('sec'+i));
  const dots   = document.querySelectorAll('.dot');
  const nav    = document.getElementById('nav');
  const dotsEl = document.getElementById('dots');
  const sh     = document.getElementById('sh');
  const s4sc   = document.getElementById('s4scroll');

  function goTo(n) {
    if (busy || n === cur || n < 0 || n >= N) return;
    busy = true;
    secs[cur].classList.remove('active');
    secs[cur].classList.add('exit-up');
    dots[cur].classList.remove('active');
    setTimeout(() => secs[cur].classList.remove('exit-up'), 900);
    cur = n;
    secs[cur].classList.add('active');
    dots[cur].classList.add('active');
    const isDark = DARK_SECS.includes(cur);
    nav.classList.toggle('scrolled', !isDark);
    dotsEl.classList.toggle('dark', isDark);
    if (sh) sh.classList.toggle('hide', cur > 0);
    if (cur !== 4 && s4sc) s4sc.scrollTop = 0;
    setTimeout(() => { busy = false; }, 900);
  }

  window.goTo = goTo;

  // 초기 상태 — 첫 화면은 어두운 배경
  nav.classList.remove('scrolled');

  document.getElementById('fp').addEventListener('wheel', e => {
    if (cur === 4 && s4sc) {
      const atTop = s4sc.scrollTop <= 1;
      const atBot = s4sc.scrollTop + s4sc.clientHeight >= s4sc.scrollHeight - 4;
      if (e.deltaY > 0 && !atBot) return;
      if (e.deltaY < 0 && !atTop) return;
    }
    e.preventDefault();
    goTo(e.deltaY > 0 ? cur + 1 : cur - 1);
  }, { passive: false });

  let ts = 0;
  document.getElementById('fp').addEventListener('touchstart', e => {
    ts = e.touches[0].clientY;
  }, { passive: true });
  document.getElementById('fp').addEventListener('touchend', e => {
    const d = ts - e.changedTouches[0].clientY;
    if (Math.abs(d) > 50) goTo(d > 0 ? cur + 1 : cur - 1);
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowDown' || e.key === 'PageDown') { e.preventDefault(); goTo(cur + 1); }
    if (e.key === 'ArrowUp'   || e.key === 'PageUp')   { e.preventDefault(); goTo(cur - 1); }
  });
</script>
