---
// src/pages/index.astro
import SecHero       from '../components/SecHero.astro';
import SecAbout      from '../components/SecAbout.astro';
import SecHistory    from '../components/SecHistory.astro';
import SecCert       from '../components/SecCert.astro';
import SecServices   from '../components/SecServices.astro';
import SecPortfolio  from '../components/SecPortfolio.astro';
import SecStrength   from '../components/SecStrength.astro';
import SecClients    from '../components/SecClients.astro';
import SecContact    from '../components/SecContact.astro';
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <script>
    // 모바일 기기 감지 → /mobile로 리다이렉트
    (function() {
      var ua = navigator.userAgent || navigator.vendor || window.opera;
      var isMobile = /android|webos|iphone|ipad|ipod|blackberry|iemobile|opera mini/i.test(ua.toLowerCase());
      var isSmall = window.innerWidth <= 768;
      if (isMobile || isSmall) {
        window.location.replace('/mobile');
      }
    })();
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EDS (주)이담에스티</title>
  <meta name="description" content="방송 스튜디오부터 LED 디스플레이까지. 17년의 경험으로 최적의 스마트 공간을 설계합니다." />
  <link rel="icon" type="image/png" href="/images/EDAM_ICON.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Nanum+Square:wght@400;700;800&display=swap" rel="stylesheet" />
  <script is:inline src="/i18n/translations.js"></script>
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      width: 100%;
      font-family: 'Inter', 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif;
      background: #fff;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    .sec { width: 100%; position: relative; }
    .fade-up {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.85s cubic-bezier(0.16,1,0.3,1), transform 0.85s cubic-bezier(0.16,1,0.3,1);
      transition-delay: 0.15s;
    }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .fade-up-d1 { transition-delay: 0.25s; }
    .fade-up-d2 { transition-delay: 0.35s; }
    .fade-up-d3 { transition-delay: 0.45s; }
    .fade-up-d4 { transition-delay: 0.55s; }
    .fade-up-d5 { transition-delay: 0.65s; }
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 300;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 80px;
      background: rgba(0, 0, 0, 0.22);
      transition: background 0.4s, box-shadow 0.4s, padding 0.3s;
    }
    .nav.scrolled {
      background: rgba(255,255,255,0.97);
      box-shadow: 0 1px 0 rgba(0,0,0,0.06);
      padding: 18px 80px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .nav-logo { height: 28px; position: relative; width: 140px; flex-shrink: 0; text-decoration: none; }
    .logo-color { position: absolute; top: 0; left: 0; height: 28px; width: auto; object-fit: contain; opacity: 0; transition: opacity 0.4s; }
    .logo-white { position: absolute; top: 0; left: 0; height: 28px; width: auto; object-fit: contain; filter: brightness(0) invert(1); opacity: 1; transition: opacity 0.4s; }
    .nav.scrolled .logo-color { opacity: 1; }
    .nav.scrolled .logo-white { opacity: 0; }
    .nav-menu { display: flex; align-items: center; gap: 48px; }
    .nav-item { position: relative; }
    .nav-link {
      display: block;
      font-family: 'Nanum Square', 'Apple SD Gothic Neo', sans-serif;
      font-size: 20px; font-weight: 400;
      letter-spacing: 0.05em; text-decoration: none; cursor: pointer;
      padding: 8px 4px; border-radius: 6px; transition: all 0.2s; white-space: nowrap;
    }
    .nav.scrolled .nav-link { color: #1a1a1a; }
    .nav:not(.scrolled) .nav-link { color: rgba(255,255,255,0.9); }
    .nav:not(.scrolled):hover { background: rgba(0, 0, 0, 0.32); }
    .nav-item.has-drop:hover .nav-link { background: rgba(255,255,255,0.1); }
    .nav.scrolled .nav-item.has-drop:hover .nav-link { background: rgba(13,58,74,0.06); }
    .nav-drop {
      position: absolute; top: 100%; left: 0; min-width: 160px;
      background: rgba(10, 20, 30, 0.75); backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px); border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 8px 40px rgba(0,0,0,0.3);
      padding: 8px 0; opacity: 0; visibility: hidden; transform: translateY(-6px);
      transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
    }
    .nav-item.has-drop:hover .nav-drop { opacity: 1; visibility: visible; transform: translateY(0); }
    .drop-link {
      display: block; font-size: 14px; font-weight: 500;
      color: rgba(255,255,255,0.8); text-decoration: none;
      padding: 10px 20px; border-radius: 6px; transition: background 0.15s, color 0.15s; white-space: nowrap;
    }
    .drop-link:hover { background: rgba(255,255,255,0.1); }
    /* 언어 드롭다운 */
    .lang-wrap { position: relative; flex-shrink: 0; }

    .lang-trigger {
      display: flex; align-items: center; gap: 6px;
      background: none;
      border: none;
      border-radius: 8px;
      padding: 8px 13px;
      cursor: pointer; font-family: inherit;
      color: #fff; font-size: 12px; font-weight: 700; letter-spacing: 0.06em;
      transition: color 0.3s, background 0.2s;
    }
    .lang-trigger:hover { background: rgba(255,255,255,0.12); }
    .nav.scrolled .lang-trigger { color: #0d1a3a; }
    .nav.scrolled .lang-trigger:hover { background: rgba(13,26,58,0.06); }

    .lang-globe { flex-shrink: 0; color: currentColor; }
    .lang-cur-code { font-size: 13px; font-weight: 800; }
    .lang-caret { font-size: 11px; transition: transform 0.25s; display: inline-block; }
    .lang-wrap.open .lang-caret { transform: rotate(180deg); }

    /* 드롭다운 목록 */
    .lang-drop {
      position: absolute; top: calc(100% + 8px); right: 0;
      background: #fff;
      border: 1px solid rgba(26,47,138,0.12);
      border-radius: 12px;
      padding: 6px;
      min-width: 148px;
      box-shadow: 0 8px 32px rgba(26,47,138,0.14), 0 2px 8px rgba(0,0,0,0.08);
      opacity: 0; pointer-events: none;
      transform: translateY(-6px) scale(0.97);
      transform-origin: top right;
      transition: opacity 0.2s, transform 0.2s;
      z-index: 999;
    }
    .lang-wrap.open .lang-drop {
      opacity: 1; pointer-events: all;
      transform: translateY(0) scale(1);
    }

    .lang-option {
      display: flex; align-items: center; gap: 10px;
      width: 100%; padding: 9px 12px;
      background: none; border: none; cursor: pointer;
      font-family: inherit; font-size: 13px; font-weight: 600;
      color: #333; border-radius: 8px;
      transition: background 0.15s, color 0.15s;
      text-align: left;
    }
    .lang-option:hover { background: #f0f4ff; color: #1a2f8a; }
    .lang-option.active { background: #eef2ff; color: #1a2f8a; font-weight: 700; }
    .lang-flag { font-size: 18px; line-height: 1; flex-shrink: 0; }
    .lang-name { font-size: 13px; }
    @media (max-width: 768px) { .nav { display: none !important; } }
  </style>
</head>
<body>

  <nav class="nav" id="nav">
    <a href="/" class="nav-logo">
      <img class="logo-color" src="/images/logo.png" alt="EDS 이담에스티" />
      <img class="logo-white" src="/images/logo.png" alt="EDS 이담에스티" />
    </a>
    <div class="nav-menu">
      <div class="nav-item has-drop">
        <a class="nav-link" href="#sec2" onclick="event.preventDefault();qnGo('sec2')" data-i18n="nav.about">회사소개</a>
        <div class="nav-drop">
          <a href="#sec2" class="drop-link" onclick="event.preventDefault();qnGo('sec2')">인사말</a>
          <a href="#sec6" class="drop-link" onclick="event.preventDefault();qnGo('sec6')">연혁</a>
          <a href="#sec-cert" class="drop-link" onclick="event.preventDefault();qnGo('sec-cert')">인증현황</a>
          <a href="#sec7" class="drop-link" onclick="event.preventDefault();qnGo('sec7')">오시는 길</a>
        </div>
      </div>
      <div class="nav-item">
        <a href="#sec3" class="nav-link" onclick="event.preventDefault();qnGo('sec3')" data-i18n="nav.services">사업분야</a>
      </div>
      <div class="nav-item">
        <a href="#sec4" class="nav-link" onclick="event.preventDefault();qnGo('sec4')" data-i18n="nav.portfolio">구축사례</a>
      </div>
      <div class="nav-item has-drop">
        <a class="nav-link" href="#sec5" onclick="event.preventDefault();qnGo('sec5')" data-i18n="nav.procurement">조달청 등록제품</a>
        <div class="nav-drop">
          <a href="/products/mediabox" class="drop-link">미디어박스</a>
          <a href="/products/server" class="drop-link">컴퓨터 서버</a>
          <a href="/products/disk-array" class="drop-link">디스크 어레이</a>
          <a href="/products/led" class="drop-link">LED 전광판</a>
        </div>
      </div>
      <div class="nav-item">
        <a href="#sec7" class="nav-link" onclick="event.preventDefault();qnGo('sec7')" data-i18n="nav.contact">문의</a>
      </div>
    </div>
    <div class="lang-wrap" id="langWrap">
      <button class="lang-trigger" id="langTrigger" onclick="toggleLangDrop()">
        <svg class="lang-globe" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        <span class="lang-cur-code" id="langCurCode">KO</span>
        <span class="lang-caret" id="langCaret">︿</span>
      </button>
      <div class="lang-drop" id="langDrop">
        <button class="lang-option" data-lang="ko" onclick="selectLang('ko')">
          <span class="lang-flag">🇰🇷</span><span class="lang-name">한국어</span>
        </button>
        <button class="lang-option" data-lang="en" onclick="selectLang('en')">
          <span class="lang-flag">🇺🇸</span><span class="lang-name">영어</span>
        </button>
        <button class="lang-option" data-lang="zh" onclick="selectLang('zh')">
          <span class="lang-flag">🇨🇳</span><span class="lang-name">중국어</span>
        </button>
        <button class="lang-option" data-lang="ja" onclick="selectLang('ja')">
          <span class="lang-flag">🇯🇵</span><span class="lang-name">일본어</span>
        </button>
      </div>
    </div>
  </nav>

  <SecHero />
  <SecAbout />
  <SecHistory />
  <SecCert />
  <SecServices />
  <SecPortfolio />
  <SecStrength />
  <SecClients />
  <SecContact />

  <!-- 퀵 네비게이션 -->
  <div class="quick-nav" id="quickNav">
    <button class="qn-top" onclick="smoothScrollTo(0)" aria-label="맨 위로">
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M6.5 10V3M3 6l3.5-3.5L10 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      TOP
    </button>
    <div class="qn-divider"></div>
    <div class="qn-list" id="qnList">
      <div class="qn-indicator" id="qnIndicator"></div>
      <a class="qn-item" data-sec="sec2" onclick="qnGo('sec2')" data-i18n="nav.about">회사소개</a>
      <a class="qn-item" data-sec="sec6" onclick="qnGo('sec6')" data-i18n="nav.history">회사연혁</a>
      <a class="qn-item" data-sec="sec-cert" onclick="qnGo('sec-cert')" data-i18n="nav.cert">인증현황</a>
      <a class="qn-item" data-sec="sec3" onclick="qnGo('sec3')" data-i18n="nav.services">사업분야</a>
      <a class="qn-item" data-sec="sec4" onclick="qnGo('sec4')" data-i18n="nav.portfolio">구축사례</a>
      <a class="qn-item" data-sec="sec-strength" onclick="qnGo('sec-strength')" data-i18n="nav.strength">회사강점</a>
      <a class="qn-item" data-sec="sec5" onclick="qnGo('sec5')" data-i18n="nav.procurement">등록제품</a>
      <a class="qn-item" data-sec="sec7" onclick="qnGo('sec7')" data-i18n="nav.contact">문의</a>
    </div>
  </div>

  <div class="float-btn" id="floatBtn" onclick="document.getElementById('inquiryModal').classList.add('open')">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span data-i18n="nav.float">문의하기</span>
  </div>

  <div class="inq-modal" id="inquiryModal">
    <div class="inq-overlay" onclick="document.getElementById('inquiryModal').classList.remove('open')"></div>
    <div class="inq-box">
      <div class="inq-head">
        <div>
          <div class="inq-title">도입 문의</div>
          <div class="inq-sub">스마트 공간 구축에 관하여 문의 바랍니다.</div>
        </div>
        <button class="inq-close" onclick="document.getElementById('inquiryModal').classList.remove('open')">&#x2715;</button>
