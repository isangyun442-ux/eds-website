<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Serif+KR:wght@400;700&display=swap" rel="stylesheet" />
  <title>전체 구축사례 — EDS 이담에스티</title>
  <style is:global>
    /* ── 리셋 & 기본 ── */
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Inter','Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:#f7f8fc;color:#0A0A0A;-webkit-font-smoothing:antialiased;}

    /* ── NAV (index.astro 동일 구조) ── */
    .nav{
      position:fixed;top:0;left:0;right:0;z-index:300;
      display:flex;align-items:center;justify-content:space-between;
      padding:14px 60px;
      background:rgba(255,255,255,0.97);
      box-shadow:0 1px 0 rgba(0,0,0,0.07);
      backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
    }
    .nav-logo{height:28px;display:flex;align-items:center;text-decoration:none;}
    .nav-logo img{height:26px;width:auto;}
    .nav-menu{display:flex;align-items:center;gap:4px;}
    .nav-item{position:relative;}
    .nav-link{
      display:block;font-size:15px;font-weight:600;letter-spacing:-0.01em;
      text-decoration:none;color:#1a1a1a;cursor:pointer;
      padding:8px 14px;border-radius:6px;transition:all 0.2s;white-space:nowrap;
    }
    .nav-link:hover{background:rgba(26,47,138,0.06);color:#1a2f8a;}
    .nav-item.has-drop:hover .nav-link{background:rgba(26,47,138,0.06);color:#1a2f8a;}
    .nav-drop{
      position:absolute;top:calc(100% + 6px);left:0;min-width:160px;
      background:#fff;border-radius:10px;
      border:1px solid rgba(0,0,0,0.08);box-shadow:0 8px 40px rgba(0,0,0,0.12);
      padding:8px 0;opacity:0;visibility:hidden;transform:translateY(-6px);
      transition:opacity 0.2s,transform 0.2s,visibility 0.2s;
    }
    .nav-item.has-drop:hover .nav-drop{opacity:1;visibility:visible;transform:translateY(0);}
    .drop-link{
      display:block;font-size:14px;font-weight:500;color:#444;
      text-decoration:none;padding:10px 20px;transition:background 0.15s,color 0.15s;white-space:nowrap;
    }
    .drop-link:hover{background:rgba(26,47,138,0.05);color:#1a2f8a;}
    .nav-link.active{color:#1a2f8a;}
    .nav-cta{
      font-size:13px;font-weight:700;padding:9px 20px;
      background:#1a2f8a;color:#fff;border:none;cursor:pointer;
      border-radius:6px;letter-spacing:0.03em;font-family:inherit;
      transition:background 0.2s;
    }
    .nav-cta:hover{background:#142580;}
    @media(max-width:768px){
      .nav{padding:12px 20px;}
      .nav-menu{display:none;}
      .nav-cta{font-size:12px;padding:8px 14px;}
    }

    /* ── 래퍼 ── */
    .wrap{max-width:1400px;margin:0 auto;padding:96px 40px 80px;}

    /* ── 페이지 헤더 ── */
    .page-header{text-align:center;margin-bottom:44px;}
    .ph-eye{
      display:inline-flex;align-items:center;gap:12px;
      font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;
      color:#1a2f8a;margin-bottom:14px;
    }
    .ph-eye::before,.ph-eye::after{content:"";display:block;width:28px;height:1px;background:#1a2f8a;opacity:0.4;}
    .ph-title{font-size:clamp(26px,4vw,46px);font-weight:800;letter-spacing:-0.03em;color:#0d1a3a;margin-bottom:10px;}
    .ph-sub{font-size:13px;color:#999;} .ph-sub strong{color:#1a2f8a;font-weight:700;}

    /* ── 필터바 ── */
    .filter-bar{
      background:#fff;border:1px solid #e8ecf4;border-radius:12px;
      padding:18px 22px;margin-bottom:16px;
      display:flex;flex-direction:column;gap:12px;
      box-shadow:0 2px 12px rgba(26,47,138,0.04);
    }
    .filter-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
    .fl{font-size:9px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#bbb;min-width:44px;flex-shrink:0;}
    .fb{
      font-size:11px;font-weight:600;padding:5px 14px;
      background:#f5f7fc;color:#555;border:1.5px solid transparent;
      cursor:pointer;border-radius:5px;transition:all 0.15s;font-family:inherit;
    }
    .fb:hover{border-color:#1a2f8a;color:#1a2f8a;}
    .fb.on{background:#1a2f8a;color:#fff;border-color:#1a2f8a;}
    .si{
      padding:7px 14px;border:1.5px solid #e8ecf4;border-radius:6px;
      font-family:inherit;font-size:13px;color:#0A0A0A;outline:none;
      background:#f9faff;min-width:200px;transition:border-color 0.2s;
    }
    .si:focus{border-color:#1a2f8a;background:#fff;}

    /* ── 결과 바 ── */
    .rbar{display:flex;justify-content:flex-end;margin-bottom:12px;}
    .rc{font-size:12px;color:#aaa;} .rc strong{color:#1a2f8a;}

    /* ── 카드 그리드 ── */
    .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;background:#e2e8f0;border-radius:10px;overflow:hidden;}
    .wc{cursor:pointer;position:relative;overflow:hidden;height:220px;background:#0D2030;}
    .wc-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform 0.5s,opacity 0.3s;opacity:0.82;}
    .wc:hover .wc-bg{transform:scale(1.06);opacity:1;}
    .wc-ph{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0d1f3a,#1a3460);}
    .wc-ph span{font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.25);}
    .wc-ov{position:absolute;inset:0;background:linear-gradient(transparent 30%,rgba(10,15,40,0.82));}
    .wc-info{position:absolute;bottom:0;left:0;right:0;padding:14px 16px;}
    .wc-cat{font-size:9px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#00B8D9;display:block;margin-bottom:4px;}
    .wc-name{font-size:13px;font-weight:700;color:#fff;line-height:1.35;margin-bottom:6px;}
    .wc-meta{display:flex;align-items:center;justify-content:space-between;}
    .wc-date{font-size:10px;color:rgba(255,255,255,0.4);}
    .wc-cli{font-size:9px;font-weight:600;background:rgba(255,255,255,0.12);color:rgba(255,255,255,0.65);padding:2px 8px;border-radius:3px;}

    /* ── 빈 상태 ── */
    .empty{text-align:center;padding:80px 20px;display:none;}
    .empty-btn{background:#1a2f8a;color:#fff;border:none;font-size:12px;font-weight:700;padding:10px 24px;cursor:pointer;margin-top:16px;font-family:inherit;border-radius:6px;}

    /* ── 모달 오버레이 ── */
    .mbg{display:none;position:fixed;inset:0;background:rgba(10,15,40,0.55);z-index:500;align-items:center;justify-content:center;padding:24px;backdrop-filter:blur(4px);}
    .mbg.on{display:flex;}

    /* ── 모달 박스 ── */
    .modal{
      background:#fff;width:100%;max-width:1080px;max-height:92vh;
      overflow-y:auto;border-radius:16px;
      box-shadow:0 32px 80px rgba(10,15,40,0.25);
      display:flex;flex-direction:column;
    }

    /* 모달 헤더 (카테고리 + 제목 + 닫기) */
    .mhead{
      display:flex;align-items:flex-start;justify-content:space-between;
      padding:24px 32px 20px;border-bottom:1px solid #f0f0f5;flex-shrink:0;
    }
    .mhead-left{flex:1;min-width:0;}
    .mcat{
      font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;
      color:#1a2f8a;margin-bottom:8px;display:block;
    }
    .mtitle{
      font-size:22px;font-weight:800;color:#0d1a3a;
      letter-spacing:-0.02em;line-height:1.3;
      font-family:'Inter',sans-serif;
    }
    .mclose{
      width:36px;height:36px;background:none;border:1.5px solid #e8ecf4;
      cursor:pointer;color:#999;font-size:16px;display:flex;align-items:center;
      justify-content:center;font-family:inherit;border-radius:8px;
      transition:all 0.2s;flex-shrink:0;margin-left:20px;margin-top:2px;
    }
    .mclose:hover{background:#f5f7fc;color:#1a2f8a;border-color:#1a2f8a;}

    /* 모달 바디 2컬럼 */
    .modal-body{display:grid;grid-template-columns:1fr 300px;}

    /* 왼쪽: 이미지 */
    .mleft{padding:0 0 28px 32px;}
    .mmain{
      width:100%;aspect-ratio:16/10;overflow:hidden;
      position:relative;background:#f0f3fa;border-radius:10px;
    }
    .mmain-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:opacity 0.25s;}
    .mmain-ph{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
    .mmain-ph span{font-size:13px;color:#bbb;}
    .mthumbs{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;}
    .mthumbs.hidden{display:none;}
    .mthumb{
      width:76px;height:54px;cursor:pointer;position:relative;overflow:hidden;
      border:2px solid #e8ecf4;border-radius:6px;transition:all 0.2s;flex-shrink:0;background:#e8ecf4;
    }
    .mthumb:hover{border-color:#1a2f8a;}
    .mthumb.on{border-color:#1a2f8a;box-shadow:0 0 0 3px rgba(26,47,138,0.12);}
    .mthumb-bg{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(0.85);}
    .mthumb.on .mthumb-bg{filter:brightness(1);}

    /* 오른쪽: 정보 */
    .mright{padding:0 32px 28px 28px;border-left:1px solid #f0f0f5;}
    .minfo-block{margin-bottom:20px;}
    .minfo-label{font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#bbb;margin-bottom:6px;}
    .minfo-val{font-size:14px;color:#333;line-height:1.6;font-weight:500;}
    .mdesc{font-size:13px;line-height:1.9;color:#666;}
    .mtags{display:flex;flex-wrap:wrap;gap:6px;margin-top:4px;}
    .mtag{
      font-size:10px;font-weight:600;
      background:rgba(26,47,138,0.07);color:#1a2f8a;
      padding:4px 12px;border-radius:4px;
    }
    .mstat-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;}
    .mstat{background:#f7f8fc;border-radius:8px;padding:12px 14px;}
    .mstat-n{font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#bbb;margin-bottom:4px;}
    .mstat-v{font-size:13px;font-weight:600;color:#0d1a3a;}
    .mcta{
      display:block;width:100%;background:#1a2f8a;color:#fff;border:none;
      font-size:13px;font-weight:700;padding:14px;cursor:pointer;font-family:inherit;
      letter-spacing:0.05em;margin-top:auto;text-align:center;
      transition:background 0.2s;border-radius:8px;
    }
    .mcta:hover{background:#142580;}
    .mcta-sub{
      display:block;width:100%;background:transparent;color:#1a2f8a;
      border:1.5px solid #e0e6f5;font-size:12px;font-weight:600;
      padding:10px;cursor:pointer;font-family:inherit;letter-spacing:0.04em;
      text-align:center;transition:all 0.2s;border-radius:8px;margin-top:8px;
    }
    .mcta-sub:hover{border-color:#1a2f8a;background:rgba(26,47,138,0.04);}

    /* ── 반응형 ── */
    @media(max-width:1024px){.grid{grid-template-columns:repeat(3,1fr);}}
    @media(max-width:768px){
      .wrap{padding:72px 16px 48px;}
      .grid{grid-template-columns:repeat(2,1fr);} .wc{height:180px;}
      .modal-body{grid-template-columns:1fr;}
      .mright{border-left:none;border-top:1px solid #f0f0f5;padding:20px 20px 24px;}
      .mleft{padding:0 0 20px 20px;}
      .mhead{padding:18px 20px 14px;}
      .mthumb{width:60px;height:42px;}
      .mstat-grid{grid-template-columns:1fr 1fr;}
    }
    @media(max-width:480px){.wc{height:150px;}.grid{grid-template-columns:repeat(2,1fr);}}

    /* ── 푸터 ── */
    .footer{
      background:#0d1a3a;
      padding:32px 60px;
      display:flex;justify-content:space-between;align-items:center;
      margin-top:60px;gap:16px;
    }
    .footer-logo img{height:22px;filter:brightness(0) invert(1);opacity:0.7;}
    .footer-info{display:flex;flex-direction:column;gap:4px;text-align:right;}
    .footer-copy{font-size:11px;color:rgba(255,255,255,0.35);}
    .footer-contact{font-size:12px;color:rgba(255,255,255,0.5);}
    @media(max-width:768px){
      .footer{padding:20px 24px;flex-direction:column;text-align:center;}
      .footer-info{text-align:center;}
    }
  </style>
</head>
