        <div class="mtags" id="mtags"></div>
      </div>
      <div class="mfoot">
        <button class="mback" onclick="closeModal()">← 목록으로</button>
        <button class="mcta" onclick="location.href='/#s5'">도입 문의하기 →</button>
      </div>
    </div>
  </div>

  <footer class="footer">
    <img src="/images/logo.png" alt="EDS" />
    <span class="footer-copy">© 2025 이담에스티 주식회사. All rights reserved.</span>
  </footer>

