---
// 전체 구축사례 페이지 — src/pages/works.astro 에 저장하세요
// URL: /works
import Layout from '../layouts/Layout.astro';
import Nav   from '../components/Nav.astro';
---

<Layout title="구축사례 전체 — EDS 이담에스티">
  <Nav />

  <div class="works-wrap">
    <div class="works-header">
      <div class="wh-eyebrow">All Portfolio</div>
      <h1 class="wh-title">전체 구축사례</h1>
      <p class="wh-sub">2007년부터 현재까지 <strong id="total-count">170</strong>개의 프로젝트를 완수했습니다</p>
    </div>

    <!-- 필터 -->
    <div class="filter-bar">
      <div class="filter-group">
        <span class="filter-label">서비스</span>
        <div class="filter-btns" id="filter-service">
          <button class="fb active" data-filter="service" data-val="all">전체</button>
          <button class="fb" data-filter="service" data-val="방송제작 스튜디오">방송제작 스튜디오</button>
          <button class="fb" data-filter="service" data-val="이러닝 스튜디오">이러닝 스튜디오</button>
          <button class="fb" data-filter="service" data-val="LED 디스플레이">LED 디스플레이</button>
          <button class="fb" data-filter="service" data-val="스마트 강의실">스마트 강의실</button>
          <button class="fb" data-filter="service" data-val="아카이브 시스템">아카이브 시스템</button>
          <button class="fb" data-filter="service" data-val="방송 인프라">방송 인프라</button>
          <button class="fb" data-filter="service" data-val="전시체험">전시체험</button>
          <button class="fb" data-filter="service" data-val="화상회의">화상회의</button>
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label">고객유형</span>
        <div class="filter-btns" id="filter-client">
          <button class="fb active" data-filter="client" data-val="all">전체</button>
          <button class="fb" data-filter="client" data-val="공공기관">공공기관</button>
          <button class="fb" data-filter="client" data-val="교육기관">교육기관</button>
          <button class="fb" data-filter="client" data-val="기업">기업</button>
          <button class="fb" data-filter="client" data-val="종교">종교</button>
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label">검색</span>
        <input class="search-input" id="search-input" type="text" placeholder="프로젝트명 검색..." />
      </div>
    </div>

    <!-- 결과 카운트 -->
    <div class="result-bar">
      <span class="result-count"><span id="result-num">170</span>개의 프로젝트</span>
    </div>

    <!-- 그리드 -->
    <div class="works-grid" id="works-grid"></div>

    <!-- 빈 상태 -->
    <div class="empty-state" id="empty-state" style="display:none">
      <div class="es-icon">🔍</div>
      <div class="es-text">검색 결과가 없습니다</div>
      <button class="es-reset" onclick="resetFilters()">필터 초기화</button>
    </div>
  </div>

  <footer class="works-footer">
    <div class="ft-logo"><img src="/images/logo.png" alt="EDS" /></div>
    <div class="ft-tagline">Beyond The Future — 이담에스티 주식회사</div>
    <div class="ft-copy">© 2025 EDS. All rights reserved.</div>
  </footer>
</Layout>

<style>
  :root {
    --navy:  #0D3A4A; --navy2: #0A2D3A; --navy3: #061E28;
    --red:   #D42B2B; --red2:  #B82222;
    --cyan:  #00B8D9; --gray:  #8C9BA5;
    --light: #E8EFF2; --bg:    #F4F7F9; --white: #FFFFFF;
    --line:  rgba(13,58,74,0.10);
    --sans: 'Barlow','Noto Sans KR',sans-serif;
    --kr:   'Noto Sans KR',sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); font-family: var(--sans); }

  .works-wrap { max-width: 1200px; margin: 0 auto; padding: 100px 40px 80px; }

  .works-header { text-align: center; margin-bottom: 48px; }
  .wh-eyebrow {
    display: inline-flex; align-items: center; gap: 12px;
    font-size: 11px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase;
    color: var(--red); margin-bottom: 14px;
  }
  .wh-eyebrow::before, .wh-eyebrow::after { content: ''; display: block; width: 28px; height: 2px; background: var(--red); }
  .wh-title {
    font-family: var(--sans); font-size: clamp(32px,5vw,52px);
    font-weight: 800; font-style: italic; color: var(--navy3);
    letter-spacing: -0.02em; margin-bottom: 12px;
  }
  .wh-sub { font-family: var(--kr); font-size: 15px; color: var(--gray); }
  .wh-sub strong { color: var(--red); }

  /* 필터 */
  .filter-bar {
    background: var(--white); border: 1px solid var(--line);
    padding: 20px 24px; margin-bottom: 20px;
    display: flex; flex-direction: column; gap: 14px;
  }
  .filter-group { display: flex; align-items: flex-start; gap: 12px; flex-wrap: wrap; }
  .filter-label {
    font-size: 10px; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; color: var(--gray);
    padding-top: 7px; min-width: 52px; flex-shrink: 0;
  }
  .filter-btns { display: flex; flex-wrap: wrap; gap: 6px; }
  .fb {
    font-family: var(--sans); font-size: 11px; font-weight: 600;
    letter-spacing: .04em; padding: 5px 12px;
    background: var(--light); color: var(--navy);
    border: 1.5px solid transparent; cursor: pointer;
    clip-path: polygon(5px 0,100% 0,calc(100% - 5px) 100%,0 100%);
    transition: all .15s;
  }
  .fb:hover { border-color: var(--cyan); color: var(--cyan); }
  .fb.active { background: var(--navy); color: #fff; border-color: var(--navy); }

  .search-input {
    padding: 6px 14px; border: 1.5px solid var(--light);
    font-family: var(--kr); font-size: 13px; color: var(--navy3);
    outline: none; background: var(--light); min-width: 220px;
    transition: border-color .2s;
  }
  .search-input:focus { border-color: var(--cyan); background: #fff; }

  /* 결과 */
  .result-bar {
    display: flex; justify-content: flex-end;
    margin-bottom: 16px;
  }
  .result-count { font-size: 12px; color: var(--gray); font-family: var(--kr); }
  #result-num { color: var(--red); font-weight: 700; }

  /* 그리드 */
  .works-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px; background: var(--line);
  }
  .wc {
    background: var(--white); padding: 20px;
    cursor: pointer; position: relative; overflow: hidden;
    transition: transform .2s, box-shadow .2s;
    border-left: 3px solid transparent;
  }
  .wc::before {
    content: '/'; position: absolute; bottom: -10px; right: 8px;
    font-size: 80px; font-weight: 900; font-style: italic;
    color: rgba(13,58,74,0.04); line-height: 1;
    transition: color .2s;
  }
  .wc:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(13,58,74,0.10); z-index: 1; border-left-color: var(--red); }
  .wc:hover::before { color: rgba(212,43,43,0.06); }

  .wc-cat {
    font-size: 9px; font-weight: 700; letter-spacing: .14em;
    text-transform: uppercase; color: var(--cyan); margin-bottom: 8px;
  }
  .wc-title {
    font-family: var(--sans); font-size: 13px; font-weight: 700;
    color: var(--navy); line-height: 1.4; margin-bottom: 8px;
  }
  .wc-overview {
    font-family: var(--kr); font-size: 11px; line-height: 1.7;
    color: var(--gray); margin-bottom: 12px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .wc-meta {
    display: flex; align-items: center; justify-content: space-between;
    border-top: 1px solid var(--light); padding-top: 8px; margin-top: auto;
  }
  .wc-date { font-size: 10px; color: var(--gray); letter-spacing: .04em; }
  .wc-client {
    font-size: 9px; font-weight: 700; letter-spacing: .08em;
    background: var(--light); color: var(--navy); padding: 2px 7px;
  }

  /* 빈 상태 */
  .empty-state { text-align: center; padding: 80px 20px; }
  .es-icon { font-size: 48px; margin-bottom: 16px; }
  .es-text { font-family: var(--kr); font-size: 16px; color: var(--gray); margin-bottom: 20px; }
  .es-reset {
    background: var(--red); color: #fff; border: none; cursor: pointer;
    font-family: var(--sans); font-size: 12px; font-weight: 700;
    letter-spacing: .12em; text-transform: uppercase; padding: 10px 28px;
    clip-path: polygon(8px 0,100% 0,calc(100% - 8px) 100%,0 100%);
  }

  /* 푸터 */
  .works-footer {
    background: var(--navy3); border-top: 3px solid var(--red);
    padding: 32px 60px;
    display: grid; grid-template-columns: auto 1fr auto;
    align-items: center; gap: 32px;
  }
  .works-footer .ft-logo img { height: 26px; width: auto; filter: brightness(0) invert(1); opacity: .8; }
  .works-footer .ft-tagline { font-size: 11px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,0.25); }
  .works-footer .ft-copy { font-size: 11px; color: rgba(255,255,255,0.2); }

  @media (max-width: 960px) {
    .works-wrap { padding: 90px 20px 60px; }
    .works-grid { grid-template-columns: repeat(2,1fr); }
    .works-footer { grid-template-columns: 1fr; gap: 10px; padding: 24px 20px; text-align: center; }
  }
  @media (max-width: 480px) {
    .works-grid { grid-template-columns: 1fr; }
  }
</style>

