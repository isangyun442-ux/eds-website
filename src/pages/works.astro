<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>전체 구축사례 — EDS 이담에스티</title>
  <style is:global>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:"Apple SD Gothic Neo","Noto Sans KR",sans-serif;background:#f5f5f5;color:#0A0A0A;}
    .nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(255,255,255,0.97);box-shadow:0 1px 0 rgba(0,0,0,0.07);display:flex;align-items:center;justify-content:space-between;padding:14px 52px;}
    .nav-logo{height:26px;} .nav-logo img{height:26px;width:auto;}
    .nav-menu{display:flex;gap:28px;} .nav-menu a{font-size:12px;font-weight:500;color:#444;text-decoration:none;}
    .nav-cta{font-size:11px;font-weight:700;padding:8px 18px;background:#0D3A4A;color:#fff;border:none;cursor:pointer;}
    .wrap{max-width:1400px;margin:0 auto;padding:90px 32px 80px;}
    .page-header{text-align:center;margin-bottom:40px;}
    .ph-eye{display:inline-flex;align-items:center;gap:12px;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#D42B2B;margin-bottom:12px;}
    .ph-eye::before,.ph-eye::after{content:"";display:block;width:24px;height:1px;background:#D42B2B;}
    .ph-title{font-size:clamp(28px,4vw,48px);font-weight:800;letter-spacing:-0.03em;color:#0A0A0A;margin-bottom:8px;}
    .ph-sub{font-size:13px;color:#aaa;} .ph-sub strong{color:#D42B2B;}
    .filter-bar{background:#fff;border:1px solid #efefef;padding:16px 20px;margin-bottom:16px;display:flex;flex-direction:column;gap:10px;}
    .filter-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
    .fl{font-size:9px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#bbb;min-width:44px;flex-shrink:0;}
    .fb{font-size:11px;font-weight:600;padding:5px 12px;background:#f5f5f5;color:#555;border:1.5px solid transparent;cursor:pointer;transition:all 0.15s;font-family:inherit;}
    .fb:hover{border-color:#00B8D9;color:#00B8D9;} .fb.on{background:#0D3A4A;color:#fff;border-color:#0D3A4A;}
    .si{padding:6px 14px;border:1.5px solid #efefef;font-family:inherit;font-size:13px;color:#0A0A0A;outline:none;background:#f9f9f9;min-width:200px;}
    .si:focus{border-color:#00B8D9;background:#fff;}
    .rbar{display:flex;justify-content:flex-end;margin-bottom:10px;}
    .rc{font-size:12px;color:#aaa;} .rc strong{color:#D42B2B;}
    .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;background:#ddd;}
    .wc{cursor:pointer;position:relative;overflow:hidden;height:220px;background:#0D2030;}
    .wc-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform 0.5s,opacity 0.3s;opacity:0.82;}
    .wc:hover .wc-bg{transform:scale(1.06);opacity:1;}
    .wc-ph{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0D2A3A,#1A3A4A);}
    .wc-ph span{font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.25);}
    .wc-ov{position:absolute;inset:0;background:linear-gradient(transparent 25%,rgba(0,0,0,0.78));}
    .wc-info{position:absolute;bottom:0;left:0;right:0;padding:12px 14px;}
    .wc-cat{font-size:9px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#00B8D9;display:block;margin-bottom:3px;}
    .wc-name{font-size:13px;font-weight:700;color:#fff;line-height:1.3;margin-bottom:5px;}
    .wc-meta{display:flex;align-items:center;justify-content:space-between;}
    .wc-date{font-size:10px;color:rgba(255,255,255,0.4);}
    .wc-cli{font-size:9px;font-weight:600;background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);padding:2px 7px;}
    .empty{text-align:center;padding:80px 20px;display:none;}
    .empty-btn{background:#0D3A4A;color:#fff;border:none;font-size:12px;font-weight:700;padding:10px 24px;cursor:pointer;margin-top:16px;font-family:inherit;}
    .mbg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.78);z-index:500;align-items:center;justify-content:center;}
    .mbg.on{display:flex;}
    .modal{background:#fff;width:90%;max-width:840px;max-height:90vh;overflow-y:auto;}
    .mhead{background:#0D3A4A;padding:16px 22px;display:flex;align-items:flex-start;justify-content:space-between;position:sticky;top:0;z-index:10;border-bottom:3px solid #D42B2B;}
    .mcat{font-size:9px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#00B8D9;margin-bottom:3px;}
    .mtitle{font-size:19px;font-weight:800;color:#fff;letter-spacing:-0.02em;line-height:1.2;}
    .mdate{font-size:11px;color:rgba(255,255,255,0.4);margin-top:2px;}
    .mclose{width:30px;height:30px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);cursor:pointer;color:rgba(255,255,255,0.7);font-size:15px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:inherit;}
    .mclose:hover{background:rgba(212,43,43,0.5);color:#fff;}
    .mgallery{display:grid;grid-template-columns:1fr 84px;}
    .mmain{height:340px;overflow:hidden;position:relative;background:#0D2030;}
    .mmain-bg{position:absolute;inset:0;background-size:cover;background-position:center;}
    .mmain-ph{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
    .mmain-ph span{font-size:11px;color:rgba(255,255,255,0.2);letter-spacing:0.1em;text-transform:uppercase;}
    .mthumbs{display:flex;flex-direction:column;gap:2px;background:#0A2030;padding:2px;}
    .mthumb{flex:1;min-height:0;cursor:pointer;position:relative;overflow:hidden;border:2px solid transparent;transition:border-color 0.2s;}
    .mthumb.on{border-color:#00B8D9;}
    .mthumb-bg{position:absolute;inset:0;background-size:cover;background-position:center;background-color:#0D2030;}
    .mthumb-n{position:absolute;bottom:2px;right:3px;font-size:8px;color:rgba(255,255,255,0.4);font-weight:700;}
    .mbody{padding:18px 22px;border-top:1px solid #f0f0f0;}
    .mdesc{font-size:13px;line-height:1.9;color:#666;margin-bottom:12px;}
    .mtags{display:flex;flex-wrap:wrap;gap:5px;}
    .mtag{font-size:10px;font-weight:600;background:#f0f0f0;color:#0D3A4A;padding:3px 10px;}
    .mfoot{padding:12px 22px;background:#f9f9f9;border-top:1px solid #f0f0f0;display:flex;justify-content:space-between;align-items:center;}
    .mback{font-size:11px;font-weight:700;color:#bbb;cursor:pointer;background:none;border:none;font-family:inherit;letter-spacing:0.08em;text-transform:uppercase;}
    .mback:hover{color:#0D3A4A;}
    .mcta{background:#D42B2B;color:#fff;border:none;font-size:11px;font-weight:700;padding:10px 22px;cursor:pointer;font-family:inherit;letter-spacing:0.08em;text-transform:uppercase;}
    .footer{background:#0A0A0A;border-top:3px solid #D42B2B;padding:24px 52px;display:flex;justify-content:space-between;align-items:center;margin-top:60px;}
    .footer img{height:20px;filter:brightness(0) invert(1);opacity:0.55;}
    .footer-copy{font-size:11px;color:#444;}
    @media(max-width:1024px){.grid{grid-template-columns:repeat(3,1fr);}}
    @media(max-width:768px){
      .nav{padding:12px 20px;} .nav-menu{display:none;} .wrap{padding:72px 16px 48px;}
      .grid{grid-template-columns:repeat(2,1fr);} .wc{height:180px;}
      .mgallery{grid-template-columns:1fr 64px;} .mmain{height:220px;}
      .footer{padding:18px 24px;flex-direction:column;gap:8px;text-align:center;}
    }
    @media(max-width:480px){.wc{height:150px;}}
  </style>
</head>
