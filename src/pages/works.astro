// API에서 관리자 추가 프로젝트 불러와서 합치기
let allProjects = [...hardcodedProjects];
let sv='all',cl='all',q='',cp=null;

async function loadAdminProjects() {
  try {
    const res = await fetch('/api/admin/projects');
    if (!res.ok) return;
    const adminProjects = await res.json();
    const hardcodedIds = new Set(hardcodedProjects.map(p => p.id));
    const newOnes = adminProjects.filter(p => !hardcodedIds.has(p.id));
    if (newOnes.length > 0) {
      allProjects = [...newOnes, ...hardcodedProjects];
      render();
    }
  } catch(e) {}
}

function render(){
  const fl=allProjects.filter(p=>(sv==='all'||p.service===sv)&&(cl==='all'||p.client===cl)&&(!q||p.title.includes(q)||(p.overview||'').includes(q)));
  const g=document.getElementById('grid'),e=document.getElementById('empty');
  document.getElementById('rn').textContent=fl.length;
  if(!fl.length){g.style.display='none';e.style.display='block';return;}
  g.style.display='grid';e.style.display='none';
  g.innerHTML=fl.map(p=>{
    const hi=p.images&&p.images.length>0;
    const bg=hi?'<div class="wc-bg" style="background-image:url('+p.images[0]+')"></div>':'<div class="wc-ph"><span>'+p.service+'</span></div>';
    return '<div class="wc" onclick="openModal('+p.id+')">'
      +bg
      +'<div class="wc-ov"></div>'
      +'<div class="wc-info">'
        +'<span class="wc-cat">'+p.service+'</span>'
        +'<p class="wc-name">'+p.title+'</p>'
        +'<div class="wc-meta"><span class="wc-date">'+p.date+'</span><span class="wc-cli">'+p.client+'</span></div>'
      +'</div>'
      +'</div>';
  }).join('');
}

function openModal(id){
  const p=allProjects.find(x=>x.id===id);
  if(!p) return;
  cp=p;
  document.getElementById('mcat').textContent=p.service;
  document.getElementById('mtitle').textContent=p.title;
  document.getElementById('mdate').textContent=p.date+' · '+p.client;
  document.getElementById('mdesc').textContent=p.overview||'';
  document.getElementById('mtags').innerHTML=[p.service,p.client].map(t=>'<span class="mtag">'+t+'</span>').join('');
  const th=document.getElementById('mth');
  if(p.images&&p.images.length>0){
    th.innerHTML=p.images.slice(0,4).map((img,i)=>'<div class="mthumb '+(i===0?'on':'')+'" onclick="selImg('+i+')">'+'<div class="mthumb-bg" style="background-image:url('+img+')"></div>'+'<span class="mthumb-n">'+(i+1)+'</span></div>').join('');
    setMain(p.images[0],true);
  }else{
    th.innerHTML=[1,2,3,4].map(i=>'<div class="mthumb '+(i===1?'on':'')+'"><div class="mthumb-bg"></div><span class="mthumb-n">'+i+'</span></div>').join('');
    setMain(null,false);
  }
  document.getElementById('mbg').classList.add('on');
  document.body.style.overflow='hidden';
}

function setMain(url,has){
  const bg=document.getElementById('mbg2'),ph=document.getElementById('mph');
  if(has&&url){bg.style.backgroundImage='url('+url+')';bg.style.display='block';ph.style.display='none';}
  else{bg.style.display='none';ph.style.display='flex';}
}

function selImg(i){
  if(!cp||!cp.images||i>=cp.images.length) return;
  document.querySelectorAll('.mthumb').forEach((t,j)=>t.classList.toggle('on',j===i));
  setMain(cp.images[i],true);
}

function closeModal(){
  document.getElementById('mbg').classList.remove('on');
  document.body.style.overflow='';
  cp=null;
}

document.getElementById('mbg').addEventListener('click',e=>{if(e.target===document.getElementById('mbg')) closeModal();});
document.querySelectorAll('.fb').forEach(b=>b.addEventListener('click',()=>{
  const f=b.dataset.f,v=b.dataset.v;
  document.querySelectorAll('.fb[data-f="'+f+'"]').forEach(x=>x.classList.remove('on'));
  b.classList.add('on');
  if(f==='s') sv=v; else cl=v;
  render();
}));
document.getElementById('si').addEventListener('input',e=>{q=e.target.value.trim();render();});
function reset(){sv='all';cl='all';q='';document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));document.querySelectorAll('.fb[data-v="all"]').forEach(b=>b.classList.add('on'));document.getElementById('si').value='';render();}
document.addEventListener('keydown',e=>{if(e.key==='Escape') closeModal();});
render();
loadAdminProjects();
</script>
</body>
