---
// 전체 구축사례 페이지
// src/pages/works.astro 에 저장하세요
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>전체 구축사례 — EDS 이담에스티</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:#f5f5f5;color:#0A0A0A;}

    /* NAV */
    .nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(255,255,255,0.97);box-shadow:0 1px 0 rgba(0,0,0,0.07);display:flex;align-items:center;justify-content:space-between;padding:14px 52px;}
    .nav-logo{height:26px;}
    .nav-logo img{height:26px;width:auto;}
    .nav-menu{display:flex;gap:28px;}
    .nav-menu a{font-size:12px;font-weight:500;color:#444;text-decoration:none;}
    .nav-cta{font-size:11px;font-weight:700;padding:8px 18px;background:#0D3A4A;color:#fff;border:none;cursor:pointer;letter-spacing:0.05em;}

    /* WRAP */
    .wrap{max-width:1280px;margin:0 auto;padding:100px 40px 80px;}

    /* HEADER */
    .page-header{text-align:center;margin-bottom:48px;}
    .ph-eyebrow{display:inline-flex;align-items:center;gap:12px;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#D42B2B;margin-bottom:14px;}
    .ph-eyebrow::before,.ph-eyebrow::after{content:'';display:block;width:28px;height:1px;background:#D42B2B;}
    .ph-title{font-size:clamp(32px,5vw,52px);font-weight:800;letter-spacing:-0.03em;color:#0A0A0A;margin-bottom:10px;}
    .ph-sub{font-size:14px;color:#aaa;}
    .ph-sub strong{color:#D42B2B;font-weight:700;}

    /* FILTER */
    .filter-bar{background:#fff;border:1px solid #efefef;padding:18px 24px;margin-bottom:20px;display:flex;flex-direction:column;gap:12px;}
    .filter-row{display:flex;align-items:flex-start;gap:12px;flex-wrap:wrap;}
    .filter-label{font-size:9px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#bbb;padding-top:7px;min-width:48px;flex-shrink:0;}
    .filter-btns{display:flex;flex-wrap:wrap;gap:6px;}
    .fb{font-size:11px;font-weight:600;padding:5px 13px;background:#f5f5f5;color:#555;border:1.5px solid transparent;cursor:pointer;transition:all 0.15s;font-family:inherit;}
    .fb:hover{border-color:#00B8D9;color:#00B8D9;}
    .fb.on{background:#0D3A4A;color:#fff;border-color:#0D3A4A;}
    .search-input{padding:6px 14px;border:1.5px solid #efefef;font-family:inherit;font-size:13px;color:#0A0A0A;outline:none;background:#f9f9f9;min-width:220px;transition:border-color 0.2s;}
    .search-input:focus{border-color:#00B8D9;background:#fff;}

    /* RESULT */
    .result-bar{display:flex;justify-content:flex-end;margin-bottom:14px;}
    .result-count{font-size:12px;color:#aaa;}
    .result-count strong{color:#D42B2B;font-weight:700;}

    /* GRID */
    .works-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;background:#e8e8e8;}
    .wc{background:#fff;cursor:pointer;position:relative;overflow:hidden;transition:box-shadow 0.2s;display:flex;flex-direction:column;}
    .wc:hover{box-shadow:0 4px 20px rgba(0,0,0,0.1);z-index:1;}
    .wc-img{height:160px;overflow:hidden;position:relative;background:#C8D8E0;}
    .wc-img-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform 0.4s;}
    .wc:hover .wc-img-bg{transform:scale(1.04);}
    .wc-img-placeholder{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#D8E8EE,#C0D4DC);}
    .wc-img-placeholder span{font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#8CAAB4;}
    .wc-body{padding:14px 16px;flex:1;display:flex;flex-direction:column;}
    .wc-cat{font-size:9px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#00B8D9;margin-bottom:5px;}
    .wc-title{font-size:13px;font-weight:700;color:#0A0A0A;line-height:1.4;margin-bottom:6px;flex:1;}
    .wc-overview{font-size:11px;color:#999;line-height:1.65;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:8px;}
    .wc-meta{display:flex;align-items:center;justify-content:space-between;border-top:1px solid #f5f5f5;padding-top:8px;margin-top:auto;}
    .wc-date{font-size:10px;color:#bbb;}
    .wc-client{font-size:9px;font-weight:700;background:#f0f0f0;color:#555;padding:2px 8px;}

    /* EMPTY */
    .empty{text-align:center;padding:80px 20px;display:none;}
    .empty-icon{font-size:40px;margin-bottom:16px;}
    .empty-text{font-size:15px;color:#bbb;margin-bottom:20px;}
    .empty-btn{background:#0D3A4A;color:#fff;border:none;font-size:12px;font-weight:700;padding:10px 24px;cursor:pointer;font-family:inherit;}

    /* MODAL */
    .modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:500;}
    .modal-bg.on{display:flex;align-items:center;justify-content:center;}
    .modal{background:#fff;width:90%;max-width:860px;max-height:90vh;overflow-y:auto;position:relative;}
    .modal-head{background:#0D3A4A;padding:18px 24px;display:flex;align-items:flex-start;justify-content:space-between;position:sticky;top:0;z-index:10;border-bottom:3px solid #D42B2B;}
    .modal-cat{font-size:9px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#00B8D9;margin-bottom:4px;}
    .modal-title{font-size:20px;font-weight:800;color:#fff;letter-spacing:-0.02em;line-height:1.2;}
    .modal-meta-text{font-size:11px;color:rgba(255,255,255,0.4);margin-top:3px;}
    .modal-close{width:32px;height:32px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);cursor:pointer;color:rgba(255,255,255,0.7);font-size:16px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background 0.2s;font-family:inherit;}
    .modal-close:hover{background:rgba(212,43,43,0.5);color:#fff;}

    /* 모달 갤러리 */
    .modal-gallery{display:grid;grid-template-columns:1fr 88px;}
    .modal-main{height:360px;overflow:hidden;position:relative;background:#0D2030;}
    .modal-main-img{position:absolute;inset:0;background-size:cover;background-position:center;}
    .modal-main-placeholder{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
    .modal-main-placeholder span{font-size:11px;color:rgba(255,255,255,0.2);letter-spacing:0.1em;text-transform:uppercase;}
    .modal-thumbs{display:flex;flex-direction:column;gap:2px;background:#0A2030;padding:2px;}
    .modal-thumb{flex:1;min-height:0;cursor:pointer;position:relative;overflow:hidden;border:2px solid transparent;transition:border-color 0.2s;}
    .modal-thumb.on{border-color:#00B8D9;}
    .modal-thumb-bg{position:absolute;inset:0;background-size:cover;background-position:center;background-color:#0D2030;}
    .modal-thumb-num{position:absolute;bottom:2px;right:4px;font-size:8px;color:rgba(255,255,255,0.4);font-weight:700;}

    .modal-body{padding:20px 24px;border-top:1px solid #f0f0f0;}
    .modal-overview{font-size:13px;line-height:1.9;color:#666;margin-bottom:14px;}
    .modal-tags{display:flex;flex-wrap:wrap;gap:6px;}
    .modal-tag{font-size:10px;font-weight:600;background:#f0f0f0;color:#0D3A4A;padding:3px 10px;}
    .modal-foot{padding:12px 24px;background:#f9f9f9;border-top:1px solid #f0f0f0;display:flex;justify-content:space-between;align-items:center;}
    .modal-back{font-size:11px;font-weight:700;color:#bbb;cursor:pointer;background:none;border:none;font-family:inherit;letter-spacing:0.08em;text-transform:uppercase;}
    .modal-back:hover{color:#0D3A4A;}
    .modal-cta{background:#D42B2B;color:#fff;border:none;font-size:11px;font-weight:700;padding:10px 24px;cursor:pointer;font-family:inherit;letter-spacing:0.08em;text-transform:uppercase;}

    /* FOOTER */
    .footer{background:#0A0A0A;border-top:3px solid #D42B2B;padding:28px 52px;display:flex;justify-content:space-between;align-items:center;margin-top:60px;}
    .footer img{height:22px;filter:brightness(0) invert(1);opacity:0.6;}
    .footer-copy{font-size:11px;color:#444;}

    @media(max-width:960px){.works-grid{grid-template-columns:repeat(3,1fr);}}
    @media(max-width:768px){
      .nav{padding:12px 20px;}
      .nav-menu{display:none;}
      .wrap{padding:80px 16px 60px;}
      .works-grid{grid-template-columns:repeat(2,1fr);}
      .modal-gallery{grid-template-columns:1fr 70px;}
      .modal-main{height:240px;}
      .footer{padding:20px 24px;flex-direction:column;gap:10px;text-align:center;}
    }
    @media(max-width:480px){.works-grid{grid-template-columns:1fr;}}
  </style>
</head>
