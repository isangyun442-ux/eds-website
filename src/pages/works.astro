let svc='all', cli='all', q='';
let curProj = null;

function render() {
  const filtered = allProjects.filter(p => {
    const s = svc==='all' || p.service===svc;
    const c = cli==='all' || p.client===cli;
    const sq = !q || p.title.includes(q) || (p.overview||'').includes(q);
    return s && c && sq;
  });
  const grid = document.getElementById('grid');
  const empty = document.getElementById('empty');
  document.getElementById('result-num').textContent = filtered.length;
  if (!filtered.length) { grid.style.display='none'; empty.style.display='block'; return; }
  grid.style.display='grid'; empty.style.display='none';
  grid.innerHTML = filtered.map(p => {
    const hasImg = p.images && p.images.length > 0;
    const imgHtml = hasImg
      ? `<div class="wc-img-bg" style="background-image:url('${p.images[0]}')"></div>`
      : `<div class="wc-img-placeholder"><span>${p.service}</span></div>`;
    return `<div class="wc" onclick="openModal(${p.id})">
      <div class="wc-img">${imgHtml}</div>
      <div class="wc-body">
        <span class="wc-cat">${p.service}</span>
        <p class="wc-title">${p.title}</p>
        ${p.overview ? `<p class="wc-overview">${p.overview}</p>` : ''}
        <div class="wc-meta">
          <span class="wc-date">${p.date}</span>
          <span class="wc-client">${p.client}</span>
        </div>
      </div>
    </div>`;
  }).join('');
}

function openModal(id) {
  const p = allProjects.find(x => x.id===id);
  if (!p) return;
  curProj = p;
  document.getElementById('m-cat').textContent = p.service;
  document.getElementById('m-title').textContent = p.title;
  document.getElementById('m-meta').textContent = p.date + ' · ' + p.client;
  document.getElementById('m-overview').textContent = p.overview || '';
  document.getElementById('m-tags').innerHTML = [p.service, p.client].map(t => `<span class="modal-tag">${t}</span>`).join('');
  const thumbsEl = document.getElementById('m-thumbs');
  if (p.images && p.images.length > 0) {
    thumbsEl.innerHTML = p.images.slice(0,4).map((img,i) =>
      `<div class="modal-thumb ${i===0?'on':''}" onclick="selectImg(${i})">
        <div class="modal-thumb-bg" style="background-image:url('${img}')"></div>
        <span class="modal-thumb-num">${i+1}</span>
      </div>`).join('');
    setMainImg(p.images[0], true);
  } else {
    thumbsEl.innerHTML = [1,2,3,4].map(i => `<div class="modal-thumb ${i===1?'on':''}"><div class="modal-thumb-bg"></div><span class="modal-thumb-num">${i}</span></div>`).join('');
    setMainImg(null, false);
  }
  document.getElementById('modal-bg').classList.add('on');
  document.body.style.overflow='hidden';
}

function setMainImg(url, hasImg) {
  const mainImg=document.getElementById('m-main-img');
  const ph=document.getElementById('m-placeholder');
  if (hasImg&&url) { mainImg.style.backgroundImage=`url('${url}')`;mainImg.style.display='block';ph.style.display='none'; }
  else { mainImg.style.display='none';ph.style.display='flex'; }
}

function selectImg(idx) {
  if (!curProj||!curProj.images||idx>=curProj.images.length) return;
  document.querySelectorAll('.modal-thumb').forEach((t,i)=>t.classList.toggle('on',i===idx));
  setMainImg(curProj.images[idx],true);
}

window.closeModal=()=>{ document.getElementById('modal-bg').classList.remove('on');document.body.style.overflow='';curProj=null; };
document.getElementById('modal-bg').addEventListener('click',e=>{ if(e.target===document.getElementById('modal-bg')) window.closeModal(); });
document.querySelectorAll('.fb').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const f=btn.dataset.f,v=btn.dataset.v;
    document.querySelectorAll(`.fb[data-f="${f}"]`).forEach(b=>b.classList.remove('on'));
    btn.classList.add('on');
    if(f==='service') svc=v; else cli=v;
    render();
  });
});
document.getElementById('search').addEventListener('input',e=>{q=e.target.value.trim();render();});
function resetFilters(){svc='all';cli='all';q='';document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));document.querySelectorAll('.fb[data-v="all"]').forEach(b=>b.classList.add('on'));document.getElementById('search').value='';render();}
document.addEventListener('keydown',e=>{if(e.key==='Escape') window.closeModal();});
render();
</script>
