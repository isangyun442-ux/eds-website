let activeService = 'all';
let activeClient  = 'all';
let searchQuery   = '';

function render() {
  const filtered = allProjects.filter(p => {
    const svcOk    = activeService === 'all' || p.service === activeService;
    const clientOk = activeClient  === 'all' || p.client  === activeClient;
    const searchOk = !searchQuery  || p.title.includes(searchQuery) || p.overview.includes(searchQuery);
    return svcOk && clientOk && searchOk;
  });

  const grid  = document.getElementById('works-grid');
  const empty = document.getElementById('empty-state');
  document.getElementById('result-num').textContent = filtered.length;

  if (filtered.length === 0) {
    grid.style.display  = 'none';
    empty.style.display = 'block';
    return;
  }
  grid.style.display  = 'grid';
  empty.style.display = 'none';

  grid.innerHTML = filtered.map(p => `
    <div class="wc" onclick="alert('사진이 추가되면 모달이 열립니다!\n\n프로젝트: ${p.title}')">
      <div class="wc-cat">${p.service}</div>
      <div class="wc-title">${p.title}</div>
      ${p.overview ? `<div class="wc-overview">${p.overview}</div>` : ''}
      <div class="wc-meta">
        <span class="wc-date">${p.date}</span>
        <span class="wc-client">${p.client}</span>
      </div>
    </div>
  `).join('');
}

document.querySelectorAll('.fb').forEach(btn => {
  btn.addEventListener('click', () => {
    const type = btn.dataset.filter;
    const val  = btn.dataset.val;
    document.querySelectorAll(`.fb[data-filter="${type}"]`).forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    if (type === 'service') activeService = val;
    else                    activeClient  = val;
    render();
  });
});

document.getElementById('search-input').addEventListener('input', e => {
  searchQuery = e.target.value.trim();
  render();
});

function resetFilters() {
  activeService = 'all'; activeClient = 'all'; searchQuery = '';
  document.querySelectorAll('.fb').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.fb[data-val="all"]').forEach(b => b.classList.add('active'));
  document.getElementById('search-input').value = '';
  render();
}

render();
</script>
