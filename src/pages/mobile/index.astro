<script is:inline>
// ── Hero 영상 자동재생 보장 ──
(function() {
  var v = document.getElementById('heroVideo');
  if (!v) return;
  v.muted = true;
  var p = v.play();
  if (p !== undefined) {
    p.catch(function() {
      v.muted = true;
      v.play();
    });
  }
  document.addEventListener('touchstart', function() {
    if (v.paused) { v.muted = true; v.play(); }
  }, { once: true });
})();

// ── NAV 드로어 ──
const menuBtn = document.getElementById('menuBtn');
const drawer = document.getElementById('drawer');
const drawerBg = document.getElementById('drawerBg');

function openDrawer() { menuBtn.classList.add('open'); drawer.classList.add('open'); document.body.style.overflow='hidden'; }
function closeDrawer() { menuBtn.classList.remove('open'); drawer.classList.remove('open'); document.body.style.overflow=''; }
menuBtn.addEventListener('click', () => drawer.classList.contains('open') ? closeDrawer() : openDrawer());
drawerBg.addEventListener('click', closeDrawer);

// ── SERVICES 탭 ──
document.querySelectorAll('.m-svc-tab').forEach(function(tab) {
  tab.addEventListener('click', function() {
    const idx = tab.dataset.idx;
    document.querySelectorAll('.m-svc-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.m-svc-panel').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.querySelector('.m-svc-panel[data-idx="'+idx+'"]').classList.add('active');
  });
});

// ── PORTFOLIO 슬라이더 ──
const projects = [
  { title:'한국외국어대학교 스튜디오 첨단화', cat:'LED 디스플레이', date:'2025.02', desc:'신규 LED 설치 및 유튜브 부스 설치를 통한 이러닝 컨텐츠 및 미디어 컨텐츠 제작 첨단 방송시스템', imgs:['/images/portfolio/HUFS_ST_01.jpg','/images/portfolio/HUFS_ST_02.jpg','/images/portfolio/HUFS_ST_03.jpg'] },
  { title:'서울사이버대학교 스튜디오 장비 고도화', cat:'스마트 강의실', date:'2024.12', desc:'기존 방송시스템 고도화를 통한 스마트 스튜디오 구축', imgs:['/images/portfolio/SC_ST_01.jpg','/images/portfolio/SC_ST_02.jpg','/images/portfolio/SC_ST_03.jpg'] },
  { title:'KTV 방송시스템 장비구매 설치', cat:'아카이브 시스템', date:'2024.12', desc:'기존 방송시스템 연계, 호환 및 방송 제작환경 개선 조정실', imgs:['/images/portfolio/KTV_BS_01.jpg','/images/portfolio/KTV_BS_02.jpg'] },
  { title:'경동나비엔 동암기념관 LED디스플레이', cat:'LED 디스플레이', date:'2024.09', desc:'경동나비엔 동암기념관 전시실 내 사각기둥형태 LED 디스플레이 작품 전시', imgs:['/images/portfolio/GD_LED_01.jpg','/images/portfolio/GD_LED_02.jpg'] },
  { title:'LG유플러스 XR스튜디오', cat:'LED 디스플레이', date:'2023.05', desc:'LED 디스플레이를 활용한 실감형 XR 스튜디오 구축', imgs:['/images/portfolio/LGU_XR_01.jpg','/images/portfolio/LGU_XR_02.jpg'] },
];
let cur = 0;
let curImg = 0;
const slidesWrap = document.getElementById('mPortSlides');
const portMainImg = document.createElement('img');
const portThumbsWrap = document.createElement('div');
const portCat = document.createElement('div');
const portName = document.createElement('div');
const portSub = document.createElement('div');
const portDesc = document.createElement('div');

portMainImg.style.cssText = 'width:100%;height:100%;object-fit:cover;';
portThumbsWrap.className = 'm-port-thumbs';
portCat.className = 'm-port-cat';
portName.className = 'm-port-name';
portSub.className = 'm-port-sub';
portDesc.className = 'm-port-desc';

const imgWrap = document.createElement('div');
imgWrap.className = 'm-port-img';
const imgOv = document.createElement('div');
imgOv.className = 'm-port-img-ov';
imgWrap.appendChild(portMainImg);
imgWrap.appendChild(imgOv);

const portInfo = document.createElement('div');
portInfo.className = 'm-port-info';

slidesWrap.appendChild(imgWrap);
slidesWrap.appendChild(portThumbsWrap);
slidesWrap.appendChild(portCat);
slidesWrap.appendChild(portName);
slidesWrap.appendChild(portSub);
slidesWrap.appendChild(portDesc);

function renderPort() {
  const p = projects[cur];
  curImg = 0;
  portMainImg.src = p.imgs[0] || '';
  portMainImg.alt = p.title;
  portCat.textContent = p.cat;
  portName.textContent = p.title;
  portSub.textContent = p.date;
  portDesc.textContent = p.desc;
  document.getElementById('mPortCur').textContent = String(cur+1).padStart(2,'0');

  // 썸네일
  portThumbsWrap.innerHTML = p.imgs.slice(0,4).map(function(img,i){
    return '<div class="m-port-thumb'+(i===0?' on':'')+'" data-i="'+i+'" style="cursor:pointer;">'
      +'<img src="'+img+'" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;" />'
      +'</div>';
  }).join('');
  portThumbsWrap.querySelectorAll('.m-port-thumb').forEach(function(t) {
    t.addEventListener('click', function() {
      const i = parseInt(t.dataset.i);
      portMainImg.src = p.imgs[i];
      portThumbsWrap.querySelectorAll('.m-port-thumb').forEach(function(x,j){ x.classList.toggle('on', j===i); });
    });
  });
}

function goPort(n) {
  cur = (n + projects.length) % projects.length;
  renderPort();
}
document.getElementById('mPortPrev').addEventListener('click', function(){ goPort(cur-1); });
document.getElementById('mPortNext').addEventListener('click', function(){ goPort(cur+1); });
renderPort();
</script>
