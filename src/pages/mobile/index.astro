// projects 데이터를 모바일용 형식으로 변환
const mProjects = projects.map(function(p) {
  return {
    title: p.title,
    cat: p.service,
    date: p.date,
    desc: p.overview || '',
    imgs: p.images || []
  };
});
let cur = 0;
let curImg = 0;
const slidesWrap = document.getElementById('mPortSlides');
const portMainImg = document.createElement('img');
const portThumbsWrap = document.createElement('div');
const portCat = document.createElement('div');
const portName = document.createElement('div');
const portSub = document.createElement('div');
const portDesc = document.createElement('div');

portMainImg.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
portThumbsWrap.className = 'm-port-thumbs';
portThumbsWrap.style.cssText = 'display:flex !important;flex-direction:row !important;flex-wrap:nowrap !important;gap:8px;margin:12px 0 16px;overflow-x:auto;-webkit-overflow-scrolling:touch;';
portCat.className = 'm-port-cat';
portName.className = 'm-port-name';
portSub.className = 'm-port-sub';
portDesc.className = 'm-port-desc';
portCat.style.cssText = 'display:block;font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#00B8D9;margin-bottom:6px;';
portName.style.cssText = 'display:block;font-size:18px;font-weight:800;color:#fff;margin-bottom:8px;line-height:1.3;';
portSub.style.cssText = 'display:block;font-size:12px;color:rgba(255,255,255,0.6);margin-bottom:10px;';
portDesc.style.cssText = 'display:block;font-size:13px;color:rgba(255,255,255,0.65);line-height:1.8;';

const imgWrap = document.createElement('div');
imgWrap.className = 'm-port-img';
const imgOv = document.createElement('div');
imgOv.className = 'm-port-img-ov';
imgWrap.appendChild(portMainImg);
imgWrap.appendChild(imgOv);

const portInfo = document.createElement('div');
portInfo.className = 'm-port-info';

slidesWrap.appendChild(imgWrap);
slidesWrap.appendChild(portThumbsWrap);
slidesWrap.appendChild(portCat);
slidesWrap.appendChild(portName);
slidesWrap.appendChild(portSub);
slidesWrap.appendChild(portDesc);

function renderPort() {
  const p = mProjects[cur];
  curImg = 0;
  portMainImg.src = p.imgs[0] || '';
  portMainImg.alt = p.title;
  portCat.textContent = p.cat;
  portName.textContent = p.title;
  portSub.textContent = p.date;
  portDesc.textContent = p.desc;
  document.getElementById('mPortCur').textContent = String(cur+1).padStart(2,'0');
  document.getElementById('mPortTotal') && (document.getElementById('mPortTotal').textContent = mProjects.length);

  // 썸네일
  portThumbsWrap.innerHTML = p.imgs.slice(0,4).map(function(img,i){
    return '<div class="m-port-thumb'+(i===0?' on':'')+'" data-i="'+i+'" style="cursor:pointer;flex-shrink:0;width:68px;height:50px;border-radius:6px;overflow:hidden;border:2px solid '+(i===0?'#fff':'rgba(255,255,255,0.2)')+';background:#0d2030;">'
      +'<img src="'+img+'" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />'
      +'</div>';
  }).join('');
  portThumbsWrap.querySelectorAll('.m-port-thumb').forEach(function(t) {
    t.addEventListener('click', function() {
      const i = parseInt(t.dataset.i);
      portMainImg.src = p.imgs[i];
      portThumbsWrap.querySelectorAll('.m-port-thumb').forEach(function(x,j){
        x.classList.toggle('on', j===i);
        x.style.border = j===i ? '2px solid #fff' : '2px solid rgba(255,255,255,0.2)';
      });
    });
  });
}

function goPort(n) {
  cur = (n + mProjects.length) % mProjects.length;
  renderPort();
}
document.getElementById('mPortPrev').addEventListener('click', function(){ goPort(cur-1); });
document.getElementById('mPortNext').addEventListener('click', function(){ goPort(cur+1); });
renderPort();
</script>
