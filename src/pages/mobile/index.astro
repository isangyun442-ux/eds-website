---
// src/pages/mobile/index.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <title>EDS 이담에스티</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{font-family:'Inter','Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:#fff;color:#0a0a0a;-webkit-font-smoothing:antialiased;overflow-x:hidden;}

    /* ── NAV ── */
    .nav{position:fixed;top:0;left:0;right:0;z-index:300;display:flex;align-items:center;justify-content:space-between;padding:14px 20px;background:rgba(255,255,255,0.97);box-shadow:0 1px 0 rgba(0,0,0,0.07);backdrop-filter:blur(12px);}
    .nav-logo img{height:24px;width:auto;}
    .nav-menu-btn{width:36px;height:36px;background:none;border:none;cursor:pointer;display:flex;flex-direction:column;justify-content:center;gap:5px;padding:4px;}
    .nav-menu-btn span{display:block;width:24px;height:2px;background:#1a1a1a;border-radius:2px;transition:all 0.3s;}
    .nav-menu-btn.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .nav-menu-btn.open span:nth-child(2){opacity:0;}
    .nav-menu-btn.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}

    /* 드로어 */
    .drawer{position:fixed;inset:0;z-index:200;pointer-events:none;}
    .drawer-bg{position:absolute;inset:0;background:rgba(0,0,0,0.4);opacity:0;transition:opacity 0.3s;}
    .drawer-panel{position:absolute;top:0;right:0;width:75vw;max-width:280px;height:100%;background:#fff;transform:translateX(100%);transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);padding:72px 28px 40px;display:flex;flex-direction:column;gap:4px;}
    .drawer.open{pointer-events:auto;}
    .drawer.open .drawer-bg{opacity:1;}
    .drawer.open .drawer-panel{transform:translateX(0);}
    .drawer-link{font-size:18px;font-weight:600;color:#0d1a3a;text-decoration:none;padding:14px 0;border-bottom:1px solid #f0f4fb;display:block;}
    .drawer-link:last-child{border-bottom:none;}
    .drawer-cta{margin-top:24px;background:#1a2f8a;color:#fff;border:none;font-size:15px;font-weight:700;padding:14px;border-radius:8px;width:100%;cursor:pointer;font-family:inherit;}

    /* ── HERO ── */
    .m-hero{position:relative;height:56.25vw;min-height:200px;overflow:hidden;background:#060e18;margin-top:52px;}
    .m-hero video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
    .m-hero-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.15);}

    /* ── 공통 섹션 ── */
    .m-sec{padding:64px 24px;}
    .m-label{font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#1a2f8a;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
    .m-label::before{content:'';width:20px;height:2px;background:#1a2f8a;display:block;}
    .m-title{font-size:clamp(24px,6vw,36px);font-weight:800;letter-spacing:-0.03em;color:#0d1a3a;margin-bottom:16px;line-height:1.2;}
    .m-title em{color:#1a2f8a;font-style:normal;}
    .m-desc{font-size:14px;color:#666;line-height:1.9;}

    /* ── ABOUT ── */
    .m-about{background:#0d1a3a;}
    .m-about .m-label{color:rgba(255,255,255,0.5);}
    .m-about .m-label::before{background:rgba(255,255,255,0.5);}
    .m-about-title{font-size:clamp(22px,5vw,32px);font-weight:900;color:#fff;letter-spacing:-0.02em;margin:12px 0 16px;line-height:1.2;}
    .m-about-title2{font-size:clamp(18px,4vw,26px);font-weight:800;color:#fff;letter-spacing:-0.02em;margin:0 0 16px;line-height:1.3;}
    .m-about-sub{font-size:14px;color:rgba(255,255,255,0.65);line-height:1.9;}
    .m-about-divider{height:1px;background:rgba(255,255,255,0.12);margin:28px 0;}
    .m-about-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:28px;}
    .m-stat{text-align:center;background:rgba(255,255,255,0.06);border-radius:10px;padding:20px 12px;}
    .m-stat-num{font-size:28px;font-weight:900;color:#00B8D9;line-height:1;}
    .m-stat-label{font-size:11px;color:rgba(255,255,255,0.5);margin-top:6px;line-height:1.4;}

    /* ── SERVICES ── */
    .m-services{background:#f7f9ff;}
    .m-svc-tabs{display:flex;gap:0;overflow-x:auto;border-bottom:2px solid #e8edf4;margin:24px 0 0;scrollbar-width:none;}
    .m-svc-tabs::-webkit-scrollbar{display:none;}
    .m-svc-tab{flex-shrink:0;padding:12px 18px;background:none;border:none;border-bottom:2px solid transparent;margin-bottom:-2px;font-size:13px;font-weight:600;color:#999;cursor:pointer;font-family:inherit;white-space:nowrap;transition:all 0.2s;}
    .m-svc-tab.active{color:#0d1a3a;border-bottom-color:#1a2f8a;}
    .m-svc-panel{display:none;padding-top:24px;}
    .m-svc-panel.active{display:block;}
    .m-svc-img{width:100%;aspect-ratio:16/9;border-radius:10px;overflow:hidden;background:#e8ecf4;margin-bottom:20px;}
    .m-svc-img img{width:100%;height:100%;object-fit:cover;}
    .m-svc-name{font-size:20px;font-weight:800;color:#0d1a3a;margin-bottom:12px;}
    .m-svc-desc{font-size:14px;color:#555;line-height:1.9;margin-bottom:16px;}
    .m-svc-chips{display:flex;flex-wrap:wrap;gap:6px;}
    .m-svc-chip{font-size:11px;font-weight:600;padding:5px 12px;border:1.5px solid #dde3ef;color:#666;border-radius:4px;}

    /* ── PORTFOLIO ── */
    .m-portfolio{background:linear-gradient(180deg,#060e18 0%,#0a1628 100%) !important;}
    .m-portfolio .m-label{color:rgba(255,255,255,0.5);}
    .m-portfolio .m-label::before{background:rgba(255,255,255,0.3);}
    .m-portfolio .m-title{color:#fff;}
    .m-port-slides{position:relative;margin-top:24px;}
    /* 큰 메인 이미지 */
    .m-port-img{width:100%;aspect-ratio:16/9;border-radius:10px;overflow:hidden;background:#0d2030;margin-bottom:12px;position:relative;}
    .m-port-img img{width:100%;height:100%;object-fit:cover;display:block;}
    .m-port-img-ov{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 30%,rgba(6,14,24,0.85) 100%);}
    .m-port-thumbs{display:flex;flex-direction:row;flex-wrap:nowrap;gap:8px;margin:12px 0 16px;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;}
    .m-port-thumbs::-webkit-scrollbar{display:none;}
    .m-port-thumb{flex-shrink:0;width:72px;height:52px;border-radius:6px;overflow:hidden;border:2px solid rgba(255,255,255,0.2);cursor:pointer;background:#0d2030;transition:border-color 0.2s;}
    .m-port-thumb.on{border-color:#fff;}
    .m-port-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
    .m-port-info{padding:0;}
    .m-port-cat{font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#00B8D9 !important;margin-bottom:6px;display:block !important;visibility:visible !important;}
    .m-port-name{font-size:18px;font-weight:800;color:#fff !important;margin-bottom:8px;line-height:1.3;display:block !important;visibility:visible !important;}
    .m-port-sub{font-size:12px;color:rgba(255,255,255,0.6) !important;margin-bottom:10px;display:block !important;}
    .m-port-desc{font-size:13px;color:rgba(255,255,255,0.65) !important;line-height:1.8;display:block !important;}
    .m-port-nav{display:flex;align-items:center;gap:12px;margin-top:24px;flex-wrap:wrap;}
    .m-port-btn{width:44px;height:44px;background:rgba(255,255,255,0.08);border:1.5px solid rgba(255,255,255,0.2);color:#fff;font-size:18px;cursor:pointer;border-radius:6px;display:flex;align-items:center;justify-content:center;transition:all 0.2s;}
    .m-port-btn:disabled{opacity:0.25;}
    .m-port-counter{font-size:13px;color:rgba(255,255,255,0.4);}
    .m-port-counter strong{color:#fff;font-size:18px;font-weight:900;}
    .m-port-all{margin-left:auto;font-size:12px;font-weight:700;color:#fff;text-decoration:none;border:1.5px solid rgba(255,255,255,0.3);padding:10px 20px;border-radius:6px;white-space:nowrap;}

    /* ── STRENGTH ── */
    .m-strength{background:#fff;}
    .m-str-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:28px;}
    .m-str-card{background:#f7f9ff;border:1px solid #e8edf4;border-radius:12px;padding:20px 16px;}
    .m-str-icon{font-size:24px;margin-bottom:10px;}
    .m-str-name{font-size:14px;font-weight:800;color:#0d1a3a;margin-bottom:8px;}
    .m-str-desc{font-size:12px;color:#666;line-height:1.7;}
    .m-str-quote{background:linear-gradient(135deg,rgba(13,26,58,0.88),rgba(26,47,138,0.84));border-radius:14px;padding:40px 24px;margin-top:28px;text-align:center;position:relative;overflow:hidden;}
    .m-str-q-text{font-size:15px;color:rgba(255,255,255,0.9);line-height:1.9;font-weight:500;word-break:keep-all;}
    .m-str-q-text strong{color:#fff;font-weight:800;}
    .m-str-q-sig{font-size:12px;color:rgba(255,255,255,0.4);margin-top:16px;letter-spacing:0.06em;}

    /* ── CLIENTS ── */
    .m-clients{background:#f4f6f9;}
    .m-clients-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:28px;}
    .m-client-card{background:#fff;border:1px solid #eaecef;border-radius:14px;overflow:hidden;cursor:pointer;text-decoration:none;color:inherit;display:block;}
    .m-client-thumb{width:100%;aspect-ratio:4/3;background:#e8ecf4;overflow:hidden;}
    .m-client-thumb img{width:100%;height:100%;object-fit:cover;}
    .m-client-info{padding:12px 14px 14px;}
    .m-client-name{font-size:13px;font-weight:800;color:#0d1a3a;margin-bottom:4px;}
    .m-client-desc{font-size:11px;color:#999;line-height:1.5;}

    /* ── CONTACT ── */
    .m-contact{background:#fff;}
    .m-contact-info{display:flex;flex-direction:column;gap:20px;margin-top:28px;}
    .m-contact-item{display:flex;align-items:flex-start;gap:14px;}
    .m-contact-icon{width:40px;height:40px;background:rgba(26,47,138,0.08);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#1a2f8a;flex-shrink:0;}
    .m-contact-label{font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#bbb;margin-bottom:4px;}
    .m-contact-value{font-size:14px;color:#333;font-weight:500;line-height:1.6;}
    .m-contact-map{width:100%;height:240px;border-radius:12px;overflow:hidden;border:1px solid #e8edf4;margin-top:28px;}
    .m-contact-map iframe{width:100%;height:100%;border:none;}
    .m-contact-btn{display:block;width:100%;background:#1a2f8a;color:#fff;border:none;font-size:15px;font-weight:700;padding:16px;border-radius:8px;margin-top:24px;cursor:pointer;font-family:inherit;text-align:center;text-decoration:none;}
    .m-inquiry-form{background:#f7f9ff;border-radius:14px;padding:28px 24px;margin-top:28px;text-align:center;}
    .m-inquiry-title{font-size:20px;font-weight:800;color:#0d1a3a;margin-bottom:8px;}
    .m-inquiry-sub{font-size:13px;color:#888;margin-bottom:20px;}
    .m-inquiry-tel{display:block;background:#1a2f8a;color:#fff;font-size:16px;font-weight:700;padding:16px;border-radius:8px;text-decoration:none;margin-bottom:10px;}
    .m-inquiry-email{display:block;background:#fff;color:#1a2f8a;font-size:14px;font-weight:600;padding:14px;border-radius:8px;text-decoration:none;border:1.5px solid #1a2f8a;margin-bottom:16px;}
    .m-inquiry-hours{font-size:12px;color:#aaa;}

    /* ── 도입문의 모달 (PC 동일) ── */
    .inq-modal{position:fixed;inset:0;z-index:500;display:flex;align-items:center;justify-content:center;pointer-events:none;opacity:0;transition:opacity 0.25s;}
    .inq-modal.open{pointer-events:all;opacity:1;}
    .inq-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.4);}
    .inq-box{position:relative;z-index:1;background:#fff;border-radius:16px;width:92%;max-width:520px;max-height:88vh;overflow-y:auto;box-shadow:0 24px 80px rgba(0,0,0,0.25);display:flex;flex-direction:column;transform:translateY(20px);transition:transform 0.25s;}
    .inq-modal.open .inq-box{transform:translateY(0);}
    .inq-head{display:flex;align-items:flex-start;justify-content:space-between;padding:24px 24px 20px;border-bottom:1px solid #f0f0f0;flex-shrink:0;}
    .inq-title{font-size:20px;font-weight:800;color:#0a0a0a;letter-spacing:-0.03em;margin-bottom:4px;}
    .inq-sub{font-size:13px;color:#999;}
    .inq-close{background:none;border:none;cursor:pointer;font-size:18px;color:#bbb;line-height:1;padding:4px;transition:color 0.2s;}
    .inq-close:hover{color:#333;}
    .inq-body{padding:20px 24px;overflow-y:auto;flex:1;}
    .inq-field{margin-bottom:16px;}
    .inq-label{display:block;font-size:12px;font-weight:700;color:#555;margin-bottom:8px;}
    .req{color:#e53e3e;}
    .inq-input{width:100%;border:1.5px solid #e8e8e8;border-radius:8px;padding:11px 14px;font-size:14px;color:#1a1a1a;outline:none;font-family:inherit;transition:border-color 0.2s;}
    .inq-input:focus{border-color:#1a2f8a;}
    .inq-textarea{min-height:80px;resize:none;}
    .inq-tel{display:flex;align-items:center;gap:6px;}
    .inq-tel .inq-input{text-align:center;}
    .inq-tel span{color:#bbb;font-weight:700;}
    .inq-checks{display:flex;flex-wrap:wrap;gap:8px;}
    .inq-check{display:flex;align-items:center;gap:6px;font-size:13px;color:#555;cursor:pointer;padding:7px 14px;border:1.5px solid #e8e8e8;border-radius:6px;transition:all 0.15s;}
    .inq-check:hover{border-color:#1a2f8a;color:#1a2f8a;}
    .inq-check input{display:none;}
    .inq-foot{padding:16px 24px 24px;border-top:1px solid #f0f0f0;flex-shrink:0;}
    .inq-submit{width:100%;padding:14px;background:#1a2f8a;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit;}
    .inq-submit:hover{background:#142580;}
    .inq-privacy{font-size:11px;color:#bbb;text-align:center;margin-top:10px;}

    /* ── FOOTER ── */
    .m-footer{background:#0d1a3a;padding:28px 24px;text-align:center;}
    .m-footer-logo img{height:22px;filter:brightness(0) invert(1);opacity:0.7;margin-bottom:16px;}
    .m-footer-info{font-size:11px;color:rgba(255,255,255,0.35);line-height:1.9;}
    .m-footer-copy{font-size:11px;color:rgba(255,255,255,0.25);margin-top:12px;}

    /* 문의 플로팅 버튼 */
    .m-fab{position:fixed;bottom:24px;right:20px;z-index:100;background:#1a2f8a;color:#fff;border:none;border-radius:50px;padding:12px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;box-shadow:0 4px 20px rgba(26,47,138,0.4);display:flex;align-items:center;gap:8px;}
  </style>
</head>
<body>

  <!-- 도입문의 모달 (PC 버전 동일) -->
  <div class="inq-modal" id="inquiryModal">
    <div class="inq-overlay" onclick="document.getElementById('inquiryModal').classList.remove('open')"></div>
    <div class="inq-box">
      <div class="inq-head">
        <div>
          <div class="inq-title">도입 문의</div>
          <div class="inq-sub">스마트 공간 구축에 관하여 문의 바랍니다.</div>
        </div>
        <button class="inq-close" onclick="document.getElementById('inquiryModal').classList.remove('open')">&#x2715;</button>
      </div>
      <div class="inq-body">
        <div class="inq-field">
          <label class="inq-label">회사명 <span class="req">*</span></label>
          <input class="inq-input" type="text" placeholder="회사명 또는 기관명을 입력해 주세요" />
        </div>
        <div class="inq-field">
          <label class="inq-label">담당자 이름 <span class="req">*</span></label>
          <input class="inq-input" type="text" placeholder="이름" />
        </div>
        <div class="inq-field">
          <label class="inq-label">연락처 <span class="req">*</span></label>
          <div class="inq-tel">
            <input class="inq-input" type="tel" placeholder="010" maxlength="4"/>
            <span>-</span>
            <input class="inq-input" type="tel" placeholder="0000" maxlength="4"/>
            <span>-</span>
            <input class="inq-input" type="tel" placeholder="0000" maxlength="4"/>
          </div>
        </div>
        <div class="inq-field">
          <label class="inq-label">이메일</label>
          <input class="inq-input" type="email" placeholder="example@company.com" />
        </div>
        <div class="inq-field">
          <label class="inq-label">상담 분야 <span class="req">*</span></label>
          <div class="inq-checks">
            <label class="inq-check"><input type="checkbox" /><span>방송 SI</span></label>
            <label class="inq-check"><input type="checkbox" /><span>이러닝 스튜디오</span></label>
            <label class="inq-check"><input type="checkbox" /><span>LED 디스플레이</span></label>
            <label class="inq-check"><input type="checkbox" /><span>스마트 강의실</span></label>
            <label class="inq-check"><input type="checkbox" /><span>화상회의 시스템</span></label>
            <label class="inq-check"><input type="checkbox" /><span>미디어 아카이브</span></label>
            <label class="inq-check"><input type="checkbox" /><span>조달청 등록제품</span></label>
            <label class="inq-check"><input type="checkbox" /><span>기타</span></label>
          </div>
        </div>
        <div class="inq-field">
          <label class="inq-label">문의내용</label>
          <textarea class="inq-input inq-textarea" placeholder="구체적인 내용을 입력해 주시면 빠르게 도움드리겠습니다."></textarea>
        </div>
      </div>
      <div class="inq-foot">
        <button class="inq-submit">상담 신청하기</button>
        <p class="inq-privacy">운영시간 09:00 ~ 18:00 (평일) &nbsp;Tel. 02-857-7744</p>
      </div>
    </div>
  </div>

  <!-- NAV -->
  <nav class="nav">
    <a href="/mobile"><img src="/images/logo.png" alt="EDS 이담에스티" style="height:24px;" /></a>
    <button class="nav-menu-btn" id="menuBtn" aria-label="메뉴">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- 드로어 -->
  <div class="drawer" id="drawer">
    <div class="drawer-bg" id="drawerBg"></div>
    <div class="drawer-panel">
      <a href="#m-about" class="drawer-link" onclick="closeDrawer()">회사소개</a>
      <a href="#m-services" class="drawer-link" onclick="closeDrawer()">사업분야</a>
      <a href="#m-portfolio" class="drawer-link" onclick="closeDrawer()">구축사례</a>
      <a href="#m-clients" class="drawer-link" onclick="closeDrawer()">조달청 등록제품</a>
      <a href="#m-contact" class="drawer-link" onclick="closeDrawer()">문의</a>
      <button class="drawer-cta" onclick="closeDrawer();document.getElementById('m-contact').scrollIntoView({behavior:'smooth'})">도입 문의하기</button>
    </div>
  </div>

  <!-- HERO -->
  <section class="m-hero" id="m-hero">
    <video
      id="heroVideo"
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline
      preload="auto"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
    >
      <source src="https://res.cloudinary.com/dlaty4qsq/video/upload/v1778474387/2025_%ED%99%8D%EB%B3%B4%EC%98%81%EC%83%81_%EB%A9%94%EC%9D%B8_olhpma.mp4" type="video/mp4" />
    </video>
    <div class="m-hero-overlay"></div>
  </section>

  <!-- ABOUT -->
  <section class="m-sec m-about" id="m-about">
    <div class="m-label">About Us</div>
    <h2 class="m-about-title">"1만 시간의 법칙"</h2>
