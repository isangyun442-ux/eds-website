---
// src/pages/admin/editor.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>EDS 에디터</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Pretendard','Noto Sans KR',sans-serif;background:#0f1117;color:#fff;height:100vh;overflow:hidden;display:flex;flex-direction:column;}
.nav{height:52px;background:#1a1d2e;border-bottom:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:space-between;padding:0 16px;flex-shrink:0;}
.nav-l{display:flex;align-items:center;gap:12px;}
.logo{display:flex;align-items:center;gap:8px;}
.logo img{height:20px;}
.logo span{font-size:11px;color:rgba(255,255,255,0.3);font-weight:600;}
.sep{width:1px;height:18px;background:rgba(255,255,255,0.1);}
.tabs{display:flex;gap:2px;}
.tab{padding:5px 11px;border-radius:5px;font-size:12px;font-weight:600;cursor:pointer;border:none;background:transparent;color:rgba(255,255,255,0.3);font-family:inherit;}
.tab:hover{color:#fff;}
.tab.on{background:rgba(99,102,241,0.18);color:#818cf8;}
.nav-r{display:flex;gap:6px;}
.btn{padding:6px 13px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;border:none;}
.btn-ghost{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);text-decoration:none;display:flex;align-items:center;gap:4px;}
.btn-save{background:#4f46e5;color:#fff;}
.btn-deploy{background:#059669;color:#fff;}
.main{display:flex;flex:1;overflow:hidden;}
.panel{width:272px;flex-shrink:0;background:#13151f;border-right:1px solid rgba(255,255,255,0.07);overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.06) transparent;}
.ps{padding:13px;border-bottom:1px solid rgba(255,255,255,0.05);}
.pt{font-size:10px;font-weight:700;letter-spacing:.1em;color:rgba(255,255,255,0.22);text-transform:uppercase;margin-bottom:10px;}
.ctrl{margin-bottom:11px;}
.ctrl:last-child{margin-bottom:0;}
.cl{font-size:11px;font-weight:600;color:rgba(255,255,255,0.4);margin-bottom:5px;display:flex;justify-content:space-between;}
.cv{color:#818cf8;font-weight:700;}
.cr{display:flex;align-items:center;gap:7px;}
.sw{width:28px;height:28px;border-radius:5px;border:1.5px solid rgba(255,255,255,0.1);cursor:pointer;overflow:hidden;position:relative;flex-shrink:0;}
.sw input[type=color]{position:absolute;inset:-4px;width:calc(100% + 8px);height:calc(100% + 8px);border:none;opacity:0;cursor:pointer;}
.hx{flex:1;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:#fff;padding:5px 7px;border-radius:5px;font-size:12px;font-family:monospace;outline:none;}
.hx:focus{border-color:#4f46e5;}
.sl{width:100%;height:3px;background:rgba(255,255,255,0.08);border-radius:2px;outline:none;-webkit-appearance:none;cursor:pointer;margin-top:4px;}
.sl::-webkit-slider-thumb{-webkit-appearance:none;width:13px;height:13px;border-radius:50%;background:#4f46e5;cursor:pointer;}
.fg{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-top:2px;}
.fb{padding:7px 4px;border-radius:5px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.03);color:rgba(255,255,255,0.4);font-family:inherit;text-align:center;}
.fb:hover{background:rgba(255,255,255,0.07);color:#fff;}
.fb.on{background:rgba(99,102,241,0.2);border-color:#818cf8;color:#818cf8;}
.fup{border:1.5px dashed rgba(255,255,255,0.1);border-radius:6px;padding:10px;text-align:center;cursor:pointer;}
.fup:hover{border-color:#4f46e5;}
.fup p{font-size:11px;color:rgba(255,255,255,0.25);line-height:1.6;}
.fup span{color:#818cf8;}
.ftag{margin-top:5px;background:rgba(99,102,241,0.12);border:1px solid rgba(99,102,241,0.25);color:#818cf8;padding:4px 8px;border-radius:4px;font-size:11px;cursor:pointer;display:block;}
.ftag.on{background:rgba(99,102,241,0.28);}
.tip{background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.18);border-radius:6px;padding:9px;font-size:11px;color:rgba(255,255,255,0.4);line-height:1.7;}
.tip strong{color:#a5b4fc;}
.pv-wrap{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.pv-bar{height:38px;background:#13151f;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;padding:0 13px;gap:8px;flex-shrink:0;}
.pv-lbl{font-size:10px;color:rgba(255,255,255,0.2);font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
.pv-body{flex:1;overflow:hidden;display:flex;}
.fw{flex:1;height:100%;}
iframe{width:100%;height:100%;border:none;display:block;}
.toast{position:fixed;bottom:18px;right:18px;background:#1e2030;border:1px solid rgba(255,255,255,0.1);color:#fff;padding:9px 15px;border-radius:8px;font-size:13px;font-weight:600;z-index:9999;opacity:0;transition:opacity .25s;pointer-events:none;}
.toast.on{opacity:1;}
.toast.ok{border-color:rgba(5,150,105,.5);background:rgba(5,150,105,.12);}
.toast.err{border-color:rgba(239,68,68,.5);background:rgba(239,68,68,.12);}
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-l">
    <div class="logo"><img src="/images/logo.png" alt="EDS"><span>디자인 에디터</span></div>
    <div class="sep"></div>
    <div class="tabs" id="tabs">
      <button class="tab on" data-s="about">회사소개</button>
      <button class="tab" data-s="history">회사연혁</button>
      <button class="tab" data-s="services">사업분야</button>
      <button class="tab" data-s="portfolio">구축사례</button>
    </div>
  </div>
  <div class="nav-r">
    <a href="/admin/dashboard" class="btn btn-ghost">← 대시보드</a>
    <button class="btn btn-ghost" onclick="doReset()">초기화</button>
    <button class="btn btn-save" onclick="doSave()">💾 저장</button>
    <button class="btn btn-deploy" onclick="doDeploy()">🚀 배포</button>
  </div>
</nav>

<div class="main">
<div class="panel">

<div id="pa-about">
  <div class="ps">
    <div class="pt">왼쪽 배경</div>
    <div class="ctrl"><div class="cl">상단 색상</div><div class="cr"><div class="sw" id="sw-leftBg1"><input type="color" id="c-leftBg1" value="#2a45c8" oninput="oC('leftBg1',this.value)"></div><input class="hx" id="h-leftBg1" value="#2a45c8" oninput="oH('leftBg1',this.value)"></div></div>
    <div class="ctrl"><div class="cl">하단 색상</div><div class="cr"><div class="sw" id="sw-leftBg2"><input type="color" id="c-leftBg2" value="#0f1f6a" oninput="oC('leftBg2',this.value)"></div><input class="hx" id="h-leftBg2" value="#0f1f6a" oninput="oH('leftBg2',this.value)"></div></div>
  </div>
  <div class="ps">
    <div class="pt">오른쪽 배경</div>
    <div class="ctrl"><div class="cl">상단 색상</div><div class="cr"><div class="sw" id="sw-rightBg1"><input type="color" id="c-rightBg1" value="#1a1f2e" oninput="oC('rightBg1',this.value)"></div><input class="hx" id="h-rightBg1" value="#1a1f2e" oninput="oH('rightBg1',this.value)"></div></div>
    <div class="ctrl"><div class="cl">하단 색상</div><div class="cr"><div class="sw" id="sw-rightBg2"><input type="color" id="c-rightBg2" value="#0e1220" oninput="oC('rightBg2',this.value)"></div><input class="hx" id="h-rightBg2" value="#0e1220" oninput="oH('rightBg2',this.value)"></div></div>
  </div>
  <div class="ps">
    <div class="pt">텍스트 색상</div>
    <div class="ctrl"><div class="cl">제목</div><div class="cr"><div class="sw" id="sw-titleColor"><input type="color" id="c-titleColor" value="#ffffff" oninput="oC('titleColor',this.value)"></div><input class="hx" id="h-titleColor" value="#ffffff" oninput="oH('titleColor',this.value)"></div></div>
    <div class="ctrl"><div class="cl">본문</div><div class="cr"><div class="sw" id="sw-bodyColor"><input type="color" id="c-bodyColor" value="#a5b4fc" oninput="oC('bodyColor',this.value)"></div><input class="hx" id="h-bodyColor" value="#a5b4fc" oninput="oH('bodyColor',this.value)"></div></div>
    <div class="ctrl"><div class="cl">강조(bold)</div><div class="cr"><div class="sw" id="sw-accentColor"><input type="color" id="c-accentColor" value="#ffffff" oninput="oC('accentColor',this.value)"></div><input class="hx" id="h-accentColor" value="#ffffff" oninput="oH('accentColor',this.value)"></div></div>
  </div>
  <div class="ps">
    <div class="pt">크기 & 간격</div>
    <div class="ctrl"><div class="cl">제목 크기 <span class="cv" id="v-titleSize">42px</span></div><input type="range" class="sl" id="s-titleSize" min="20" max="72" value="42" oninput="oS('titleSize',this.value,'px')"></div>
    <div class="ctrl"><div class="cl">본문 크기 <span class="cv" id="v-bodySize">15px</span></div><input type="range" class="sl" id="s-bodySize" min="10" max="22" value="15" oninput="oS('bodySize',this.value,'px')"></div>
    <div class="ctrl"><div class="cl">줄간격 <span class="cv" id="v-lineHeight">2.0</span></div><input type="range" class="sl" id="s-lineHeight" min="1.2" max="3.0" step="0.1" value="2.0" oninput="oS('lineHeight',this.value,'')"></div>
    <div class="ctrl"><div class="cl">자간 <span class="cv" id="v-letterSpacing">-0.03em</span></div><input type="range" class="sl" id="s-letterSpacing" min="-0.08" max="0.1" step="0.01" value="-0.03" oninput="oS('letterSpacing',this.value,'em')"></div>
    <div class="ctrl"><div class="cl">패딩 <span class="cv" id="v-padding">100px</span></div><input type="range" class="sl" id="s-padding" min="30" max="180" value="100" oninput="oS('padding',this.value,'px')"></div>
    <div class="ctrl"><div class="cl">섹션 높이 <span class="cv" id="v-minHeight">700px</span></div><input type="range" class="sl" id="s-minHeight" min="300" max="1200" value="700" oninput="oS('minHeight',this.value,'px')"></div>
  </div>
  <div class="ps">
    <div class="pt">전체 폰트</div>
    <div class="fg" id="fg">
      <button class="fb on" data-f="'Noto Sans KR',sans-serif" onclick="oF(this)">Noto Sans</button>
      <button class="fb" data-f="'Pretendard',sans-serif" onclick="oF(this)">Pretendard</button>
      <button class="fb" data-f="'Nanum Gothic',sans-serif" onclick="oF(this)">나눔고딕</button>
      <button class="fb" data-f="'Nanum Myeongjo',serif" onclick="oF(this)">나눔명조</button>
      <button class="fb" data-f="'Black Han Sans',sans-serif" onclick="oF(this)">블랙한산</button>
      <button class="fb" data-f="'Gowun Dodum',sans-serif" onclick="oF(this)">고운돋움</button>
    </div>
    <div style="margin-top:10px;">
      <div class="fup" onclick="document.getElementById('ffile').click()">
        <input type="file" id="ffile" accept=".ttf,.otf,.woff,.woff2" style="display:none" onchange="oFU(this)">
        <p>커스텀 폰트 업로드<br><span>.ttf .otf .woff .woff2</span></p>
      </div>
      <div id="ftags"></div>
    </div>
  </div>
  <div class="ps">
    <div class="pt">💡 편집 방법</div>
    <div class="tip">미리보기에서 텍스트를 <strong>클릭</strong>하면 바로 편집 가능해요.<br>드래그로 선택 후 툴바에서 <strong>폰트·크기·색상</strong>을 적용하세요.</div>
  </div>
</div>

<div id="pa-history" style="display:none">
  <div class="ps">
    <div class="pt">배경</div>
    <div class="ctrl"><div class="cl">상단 색상</div><div class="cr"><div class="sw" id="sw-hBg1"><input type="color" id="c-hBg1" value="#060e18" oninput="oC2('hBg1',this.value)"></div><input class="hx" id="h-hBg1" value="#060e18" oninput="oH2('hBg1',this.value)"></div></div>
    <div class="ctrl"><div class="cl">하단 색상</div><div class="cr"><div class="sw" id="sw-hBg2"><input type="color" id="c-hBg2" value="#0d1c38" oninput="oC2('hBg2',this.value)"></div><input class="hx" id="h-hBg2" value="#0d1c38" oninput="oH2('hBg2',this.value)"></div></div>
  </div>
  <div class="ps">
    <div class="pt">텍스트 색상</div>
    <div class="ctrl"><div class="cl">제목</div><div class="cr"><div class="sw" id="sw-hTitleColor"><input type="color" id="c-hTitleColor" value="#ffffff" oninput="oC2('hTitleColor',this.value)"></div><input class="hx" id="h-hTitleColor" value="#ffffff" oninput="oH2('hTitleColor',this.value)"></div></div>
    <div class="ctrl"><div class="cl">서브타이틀</div><div class="cr"><div class="sw" id="sw-hSubColor"><input type="color" id="c-hSubColor" value="#8899bb" oninput="oC2('hSubColor',this.value)"></div><input class="hx" id="h-hSubColor" value="#8899bb" oninput="oH2('hSubColor',this.value)"></div></div>
    <div class="ctrl"><div class="cl">연도</div><div class="cr"><div class="sw" id="sw-hYearColor"><input type="color" id="c-hYearColor" value="#ffffff" oninput="oC2('hYearColor',this.value)"></div><input class="hx" id="h-hYearColor" value="#ffffff" oninput="oH2('hYearColor',this.value)"></div></div>
    <div class="ctrl"><div class="cl">내용 텍스트</div><div class="cr"><div class="sw" id="sw-hDescColor"><input type="color" id="c-hDescColor" value="#ccddee" oninput="oC2('hDescColor',this.value)"></div><input class="hx" id="h-hDescColor" value="#ccddee" oninput="oH2('hDescColor',this.value)"></div></div>
  </div>
  <div class="ps">
    <div class="pt">크기 & 간격</div>
    <div class="ctrl"><div class="cl">제목 크기 <span class="cv" id="v-hTitleSize">48px</span></div><input type="range" class="sl" id="s-hTitleSize" min="20" max="72" value="48" oninput="oS2('hTitleSize',this.value,'px')"></div>
    <div class="ctrl"><div class="cl">내용 크기 <span class="cv" id="v-hDescSize">14px</span></div><input type="range" class="sl" id="s-hDescSize" min="10" max="22" value="14" oninput="oS2('hDescSize',this.value,'px')"></div>
    <div class="ctrl"><div class="cl">줄간격 <span class="cv" id="v-hLineHeight">1.9</span></div><input type="range" class="sl" id="s-hLineHeight" min="1.2" max="3.0" step="0.1" value="1.9" oninput="oS2('hLineHeight',this.value,'')"></div>
  </div>
  <div class="ps">
    <div class="pt">타임라인 스타일</div>
    <div class="ctrl"><div class="cl">라인 색상</div><div class="cr"><div class="sw" id="sw-hLineColor"><input type="color" id="c-hLineColor" value="#334466" oninput="oC2('hLineColor',this.value)"></div><input class="hx" id="h-hLineColor" value="#334466" oninput="oH2('hLineColor',this.value)"></div></div>
    <div class="ctrl"><div class="cl">닷 테두리 색상</div><div class="cr"><div class="sw" id="sw-hDotColor"><input type="color" id="c-hDotColor" value="#ffffff" oninput="oC2('hDotColor',this.value)"></div><input class="hx" id="h-hDotColor" value="#ffffff" oninput="oH2('hDotColor',this.value)"></div></div>
  </div>
  <div class="ps">
    <div class="pt">💡 편집 방법</div>
    <div class="tip">미리보기에서 텍스트를 <strong>클릭</strong>하면 바로 편집 가능해요.</div>
  </div>
</div>

<div id="pa-services" style="display:none"><div class="ps"><div class="pt">준비 중</div><p style="font-size:11px;color:rgba(255,255,255,0.25)">곧 추가돼요</p></div></div>
<div id="pa-portfolio" style="display:none"><div class="ps"><div class="pt">준비 중</div><p style="font-size:11px;color:rgba(255,255,255,0.25)">곧 추가돼요</p></div></div>

</div>

<div class="pv-wrap">
  <div class="pv-bar">
    <span class="pv-lbl">미리보기</span>
  </div>
  <div class="pv-body">
    <div class="fw" id="fw"><iframe id="pf" src="/"></iframe></div>
  </div>
</div>
</div>

<div class="toast" id="toast"></div>

<script>
const tok = sessionStorage.getItem('eds-admin-token')||'';
if(!tok){ alert('로그인이 필요해요'); location.href='/admin'; }

// ── 상태 ──
let fonts = {};
let curSec = 'about';

let S = {
  leftBg1:'#2a45c8', leftBg2:'#0f1f6a',
  rightBg1:'#1a1f2e', rightBg2:'#0e1220',
  titleColor:'#ffffff', bodyColor:'#a5b4fc', accentColor:'#ffffff',
  titleSize:42, bodySize:15, lineHeight:2.0,
  letterSpacing:-0.03, padding:100, minHeight:700,
  fontFamily:"'Noto Sans KR',sans-serif"
};
let T = {
  leftTitle:'"1만 시간의\n법칙"',
  leftBody:'어떤 분야에서 전문성을 갖기 위해 투자해야 하는 시간을 의미합니다.',
  rightTitle:'전문가 집단\n이담에스티',
  rightBody:'이담에스티는 방송기술, 컴퓨터그래픽, 오디오, IT 분야의 20년 이상의 외길을 다져온 전문가들로 구성된 회사입니다.'
};
let H = {
  hBg1:'#ffffff', hBg2:'#dce6f8',
  hTitleColor:'#0d1a3a', hSubColor:'#6b7a99',
  hYearColor:'#0d1a3a', hDescColor:'#444e6a',
  hTitleSize:48, hDescSize:14, hLineHeight:1.9,
  hLineColor:'#c5d0ed', hDotColor:'#1a2f8a'
};
let lastSaved = {S:null, T:null, H:null};

const pf = document.getElementById('pf');

// ── iframe 로드 ──
pf.addEventListener('load', function(){
  setTimeout(function(){
    doInject();
    doText();
    startEdit();
  }, 1500);
});

// ── About 스타일 주입 ──
// __ei__ 를 항상 head 맨 끝에 재삽입 → 페이지 자체 스타일보다 항상 우선
function doInject(){
  try{
    const doc = pf.contentDocument;
    if(!doc || !doc.head) return;

    // 기존 제거 후 맨 끝에 재삽입
    const old = doc.getElementById('__ei__');
    if(old) old.remove();
    const el = doc.createElement('style');
    el.id = '__ei__';
    doc.head.appendChild(el);

    let ff = '';
    Object.values(fonts).forEach(function(f){ ff += f; });

    const gm = {
      'Noto Sans KR':'Noto+Sans+KR:wght@400;700;900',
      'Nanum Gothic':'Nanum+Gothic:wght@400;700',
      'Nanum Myeongjo':'Nanum+Myeongjo',
      'Black Han Sans':'Black+Han+Sans',
      'Gowun Dodum':'Gowun+Dodum'
    };
    const fn = S.fontFamily.replace(/'/g,'').split(',')[0].trim();
    const oldgf = doc.getElementById('__gf__');
    if(oldgf) oldgf.remove();
    if(gm[fn]){
      const lk = doc.createElement('link');
      lk.id = '__gf__'; lk.rel = 'stylesheet';
      lk.href = 'https://fonts.googleapis.com/css2?family='+gm[fn]+'&display=swap';
      doc.head.appendChild(lk);
    }

    el.textContent = ff + `
      #sec2 .ab-left{background:linear-gradient(135deg,${S.leftBg1} 0%,${S.leftBg2} 100%)!important;}
      #sec2 .ab-right{background:linear-gradient(135deg,${S.rightBg1} 0%,${S.rightBg2} 100%)!important;}
      #sec2 .ab-title{color:${S.titleColor}!important;font-size:${S.titleSize}px!important;letter-spacing:${S.letterSpacing}em!important;font-family:${S.fontFamily}!important;}
      #sec2 .ab-body{color:${S.bodyColor}!important;font-size:${S.bodySize}px!important;line-height:${S.lineHeight}!important;font-family:${S.fontFamily}!important;}
      #sec2 .ab-label{color:${S.titleColor}!important;font-family:${S.fontFamily}!important;}
      #sec2 .ab-sig{font-family:${S.fontFamily}!important;}
      #sec2 .ab-body strong{color:${S.accentColor}!important;}
      #sec2 .ab-left-content,#sec2 .ab-right-content{padding:${S.padding}px!important;}
      #sec2 .ab-wrap{min-height:${S.minHeight}px!important;}
      .eds-e{outline:2px dashed rgba(99,102,241,0.6)!important;cursor:text!important;min-height:1.5em!important;display:block;}
      .eds-e:focus{outline:2px solid #818cf8!important;background:rgba(99,102,241,0.05)!important;}
    `;
  }catch(e){ console.warn('doInject:',e); }
}

// ── History 스타일 주입 ──
function doInjectH(){
  try{
    const doc = pf.contentDocument;
    if(!doc || !doc.head) return;
    const old = doc.getElementById('__ei_h__');
    if(old) old.remove();
    const el = doc.createElement('style');
    el.id = '__ei_h__';
    doc.head.appendChild(el);
    el.textContent = `
      #sec6 .s5{background:linear-gradient(170deg,${H.hBg1} 0%,${H.hBg2} 100%)!important;}
      #sec6 .h-title{color:${H.hTitleColor}!important;font-size:${H.hTitleSize}px!important;}
      #sec6 .h-sub{color:${H.hSubColor}!important;line-height:${H.hLineHeight}!important;}
      #sec6 .h-eyebrow{color:${H.hSubColor}!important;}
      #sec6 .tl-year{color:${H.hYearColor}!important;}
      #sec6 .tl-desc{color:${H.hDescColor}!important;font-size:${H.hDescSize}px!important;line-height:${H.hLineHeight}!important;}
      #sec6 .tl-month{color:${H.hSubColor}!important;}
      #sec6 .tl-line{background:${H.hLineColor}!important;}
      #sec6 .tl-dot{border-color:${H.hDotColor}!important;}
      #sec6 .tl-end-dot{background:${H.hDotColor}!important;}
    `;
  }catch(e){}
}

// ── 텍스트 주입 ──
function doText(){
  try{
    const doc = pf.contentDocument;
    const sec = doc.getElementById('sec2');
    if(!sec) return;
    if(T.leftContent){
      const lc = sec.querySelector('.ab-left-content');
      if(lc) lc.innerHTML = T.leftContent;
    } else {
      const a = sec.querySelector('.ab-left-content .ab-title');
      const b = sec.querySelector('.ab-left-content .ab-body');
      if(a) a.innerHTML = T.leftTitle.replace(/\n/g,'<br>');
      if(b) b.innerHTML = T.leftBody.replace(/\n/g,'<br>');
    }
    if(T.rightContent){
      const rc = sec.querySelector('.ab-right-content');
      if(rc) rc.innerHTML = T.rightContent;
    } else {
      const c = sec.querySelector('.ab-right-content .ab-title');
      const d = sec.querySelector('.ab-right-content .ab-body');
      if(c) c.innerHTML = T.rightTitle.replace(/\n/g,'<br>');
      if(d) d.innerHTML = T.rightBody.replace(/\n/g,'<br>');
    }
  }catch(e){}
}

// ── 편집 모드 ──
function startEdit(){
  try{
    const doc = pf.contentDocument;
    const secId = curSec === 'history' ? 'sec6' : 'sec2';
    const sec = doc.getElementById(secId);
    if(!sec) return;

    // 기존 편집 요소 초기화
    doc.querySelectorAll('.eds-e').forEach(function(el){
      el.contentEditable = 'false';
      el.classList.remove('eds-e');
    });

    // 섹션별 편집 대상
    const sel = curSec === 'history'
      ? '.h-title,.h-sub,.h-eyebrow,.tl-year,.tl-desc,.tl-month,.tl-end-label'
      : '.ab-title,.ab-body,.ab-label,.ab-sig';

    sec.querySelectorAll(sel).forEach(function(el){
      el.contentEditable = 'true';
      el.classList.add('eds-e');
      el.addEventListener('input', syncFromFrame);
    });

    // 기존 툴바 제거
    const oldTb = doc.getElementById('__tb__');
    if(oldTb) oldTb.remove();

    // 구글폰트 로드
    if(!doc.getElementById('__gfall__')){
      const lk = doc.createElement('link');
      lk.id = '__gfall__'; lk.rel = 'stylesheet';
      lk.href = 'https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700;900&family=Nanum+Gothic:wght@400;700&family=Nanum+Myeongjo&family=Black+Han+Sans&family=Gowun+Dodum&display=swap';
      doc.head.appendChild(lk);
    }

    // 플로팅 툴바 생성
    const tb = doc.createElement('div');
    tb.id = '__tb__';
    tb.style.cssText = 'position:fixed;top:-200px;left:0;z-index:99999;background:#1a1d2e;border:1px solid rgba(255,255,255,0.15);border-radius:9px;padding:5px 7px;display:flex;align-items:center;gap:3px;box-shadow:0 4px 24px rgba(0,0,0,0.7);font-family:system-ui,sans-serif;opacity:0;transition:opacity .15s;pointer-events:none;';

    function sep(){ const d=doc.createElement('div'); d.style.cssText='width:1px;height:16px;background:rgba(255,255,255,0.1);margin:0 2px;'; return d; }

    // 폰트 드롭다운
    const fontList = [
      {n:'Noto Sans', f:"'Noto Sans KR',sans-serif"},
      {n:'Pretendard', f:"'Pretendard',sans-serif"},
      {n:'나눔고딕', f:"'Nanum Gothic',sans-serif"},
      {n:'나눔명조', f:"'Nanum Myeongjo',serif"},
      {n:'블랙한산', f:"'Black Han Sans',sans-serif"},
      {n:'고운돋움', f:"'Gowun Dodum',sans-serif"},
    ];
    const fd = doc.createElement('div');
    fd.style.cssText = 'position:relative;';
    const fdBtn = doc.createElement('button');
    fdBtn.textContent = '폰트 ▾';
    fdBtn.style.cssText = 'background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:#fff;padding:3px 8px;border-radius:4px;font-size:11px;cursor:pointer;white-space:nowrap;';
    const fdList = doc.createElement('div');
    fdList.style.cssText = 'display:none;position:absolute;top:100%;left:0;background:#1a1d2e;border:1px solid rgba(255,255,255,0.15);border-radius:6px;overflow:hidden;min-width:110px;box-shadow:0 4px 16px rgba(0,0,0,0.6);margin-top:3px;z-index:99;';
    fontList.forEach(function(fm){
      const item = doc.createElement('div');
      item.textContent = fm.n;
      item.style.cssText = 'padding:7px 12px;font-size:12px;color:#fff;cursor:pointer;font-family:'+fm.f+';';
      item.addEventListener('mouseover', function(){ this.style.background='rgba(99,102,241,0.2)'; });
      item.addEventListener('mouseout', function(){ this.style.background=''; });
      item.addEventListener('mousedown', function(e){
        e.preventDefault();
        restoreSel();
        wrapSel({fontFamily: fm.f});
        fdList.style.display = 'none';
      });
      fdList.appendChild(item);
    });
    fdBtn.addEventListener('mousedown', function(e){ e.preventDefault(); saveSel(); fdList.style.display = fdList.style.display==='none'?'block':'none'; });
    fd.appendChild(fdBtn); fd.appendChild(fdList);
    tb.appendChild(fd);
    tb.appendChild(sep());

    // 크기
    const sz = doc.createElement('input');
    sz.type='number'; sz.min='8'; sz.max='120'; sz.value='15';
    sz.style.cssText = 'background:#0f1117;border:1px solid rgba(255,255,255,0.1);color:#fff;padding:3px 4px;border-radius:4px;font-size:11px;outline:none;width:44px;';
    sz.addEventListener('mousedown', function(e){ e.preventDefault(); saveSel(); });
    sz.addEventListener('change', function(){ restoreSel(); wrapSel({fontSize: this.value+'px'}); });
    tb.appendChild(sz);
    tb.appendChild(sep());

    // B I U
    function mkBtn(html, cmd){
      const b = doc.createElement('button');
      b.innerHTML = html;
      b.style.cssText = 'background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:#fff;padding:3px 7px;border-radius:4px;font-size:12px;cursor:pointer;';
      b.addEventListener('mousedown', function(e){ e.preventDefault(); saveSel(); });
      b.addEventListener('click', function(){ restoreSel(); doc.execCommand(cmd); syncFromFrame(); });
      return b;
    }
    tb.appendChild(mkBtn('<b>B</b>', 'bold'));
    tb.appendChild(mkBtn('<i>I</i>', 'italic'));
    tb.appendChild(mkBtn('<u>U</u>', 'underline'));
    tb.appendChild(sep());

    // 색상
    const col = doc.createElement('input');
    col.type = 'color'; col.value = '#ffffff';
    col.style.cssText = 'width:26px;height:26px;border:none;border-radius:4px;cursor:pointer;padding:1px;background:transparent;';
    col.addEventListener('mousedown', function(){ saveSel(); });
    col.addEventListener('input', function(){ restoreSel(); doc.execCommand('foreColor', false, this.value); syncFromFrame(); });
    tb.appendChild(col);
    tb.appendChild(sep());

    // 서식제거
    const clr = doc.createElement('button');
    clr.textContent = '✕';
    clr.style.cssText = 'background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);padding:3px 7px;border-radius:4px;font-size:11px;cursor:pointer;';
    clr.addEventListener('mousedown', function(e){ e.preventDefault(); saveSel(); });
    clr.addEventListener('click', function(){ restoreSel(); doc.execCommand('removeFormat'); syncFromFrame(); });
    tb.appendChild(clr);

    doc.body.appendChild(tb);

    // selection 관리
    let savedRange = null;
    function saveSel(){
      const sel = doc.getSelection();
      if(sel && !sel.isCollapsed && sel.toString()){
        try{ savedRange = sel.getRangeAt(0).cloneRange(); }catch(e){}
      }
    }
    function restoreSel(){
      if(!savedRange) return;
      try{ const sel=doc.getSelection(); sel.removeAllRanges(); sel.addRange(savedRange); }catch(e){}
    }
    function wrapSel(style){
      const sel = doc.getSelection();
      if(!sel || sel.isCollapsed) return;
      const range = sel.getRangeAt(0);
      const span = doc.createElement('span');
      const css = Object.entries(style).map(function(e){
        return e[0].replace(/([A-Z])/g,'-$1').toLowerCase()+':'+e[1]+'!important';
      }).join(';');
      span.setAttribute('style', css);
      try{ range.surroundContents(span); }
      catch(e2){ span.appendChild(range.extractContents()); range.insertNode(span); }
      syncFromFrame();
    }

    // 툴바 위치
    doc.addEventListener('selectionchange', function(){
      const sel = doc.getSelection();
      if(!sel || sel.isCollapsed || !sel.toString().trim()){
        setTimeout(function(){
          if(fdList.style.display === 'block') return;
          const s2 = doc.getSelection();
          if(!s2 || s2.isCollapsed){ tb.style.opacity='0'; tb.style.pointerEvents='none'; }
        }, 200);
        return;
      }
      saveSel();
      const r = sel.getRangeAt(0).getBoundingClientRect();
      if(!r.width) return;
      const x = Math.max(4, Math.min(r.left+r.width/2-160, doc.documentElement.clientWidth-340));
      const y = Math.max(4, r.top - 52 + pf.contentWindow.scrollY);
      tb.style.left = x+'px'; tb.style.top = y+'px';
      tb.style.opacity = '1'; tb.style.pointerEvents = 'all';
      const node = sel.anchorNode;
      if(node){
        const el = node.nodeType===3 ? node.parentElement : node;
        sz.value = parseInt(doc.defaultView.getComputedStyle(el).fontSize)||15;
      }
    });

    doc.addEventListener('click', function(e){ if(!fd.contains(e.target)) fdList.style.display='none'; });

  }catch(e){ console.warn('startEdit:', e); }
}

// ── syncFromFrame ──
function syncFromFrame(){
  try{
    const doc = pf.contentDocument;
    // About 텍스트
    const sec2 = doc.getElementById('sec2');
    if(sec2){
      const lc = sec2.querySelector('.ab-left-content');
      const rc = sec2.querySelector('.ab-right-content');
      if(lc) T.leftContent = cleanForSave(lc);
      if(rc) T.rightContent = cleanForSave(rc);
    }
    // History 텍스트 (제목/서브만 - 연혁항목 제외)
    const sec6 = doc.getElementById('sec6');
    if(sec6){
      const ht = sec6.querySelector('.h-title');
      const hs = sec6.querySelector('.h-sub');
      if(ht) H.histTitle = ht.innerText;
      if(hs) H.histSub = hs.innerText;
    }
  }catch(e){}
}

function cleanForSave(el){
  const clone = el.cloneNode(true);
  clone.querySelectorAll('[contenteditable]').forEach(function(n){
    n.removeAttribute('contenteditable');
    n.classList.remove('eds-e');
    if(!n.getAttribute('class')) n.removeAttribute('class');
  });
  clone.querySelectorAll('[style*="outline"]').forEach(function(n){
    n.style.outline='';
    if(!n.getAttribute('style')) n.removeAttribute('style');
  });
  const tb = clone.querySelector('#__tb__');
  if(tb) tb.remove();
  return clone.innerHTML;
}

// ── 컨트롤 핸들러 ──
window.oC = function(k,v){
  S[k]=v;
  const h=document.getElementById('h-'+k), sw=document.getElementById('sw-'+k);
  if(h)h.value=v; if(sw)sw.style.background=v;
  doInject();
};
window.oH = function(k,v){
  if(!/^#[0-9a-fA-F]{6}$/.test(v)) return;
  S[k]=v;
  const c=document.getElementById('c-'+k), sw=document.getElementById('sw-'+k);
  if(c)c.value=v; if(sw)sw.style.background=v;
  doInject();
};
window.oS = function(k,v,u){
  S[k]=parseFloat(v);
  const el=document.getElementById('v-'+k);
  if(el) el.textContent=v+u;
  doInject();
};
window.oF = function(btn){
  document.querySelectorAll('.fb,.ftag').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  S.fontFamily = btn.dataset.f;
  doInject();
};

// History 컨트롤
window.oC2 = function(k,v){ H[k]=v; const h=document.getElementById('h-'+k),sw=document.getElementById('sw-'+k); if(h)h.value=v; if(sw)sw.style.background=v; doInjectH(); };
window.oH2 = function(k,v){ if(!/^#[0-9a-fA-F]{6}$/.test(v))return; H[k]=v; const c=document.getElementById('c-'+k),sw=document.getElementById('sw-'+k); if(c)c.value=v; if(sw)sw.style.background=v; doInjectH(); };
window.oS2 = function(k,v,u){ H[k]=parseFloat(v); const el=document.getElementById('v-'+k); if(el)el.textContent=v+u; doInjectH(); };

// 폰트 업로드
window.oFU = function(input){
  const file=input.files[0]; if(!file)return;
  const reader=new FileReader();
  reader.onload=function(e){
    const name=file.name.replace(/\.[^.]+$/,'').replace(/\s+/g,'_');
    const ext=file.name.split('.').pop().toLowerCase();
    const fmt=ext==='ttf'?'truetype':ext==='otf'?'opentype':ext;
    fonts[name]="@font-face{font-family:'"+name+"';src:url('"+e.target.result+"') format('"+fmt+"');font-display:swap;}";
    S.fontFamily="'"+name+"',sans-serif";
    const wrap=document.getElementById('ftags');
    const tag=document.createElement('div');
    tag.className='ftag on'; tag.textContent=name; tag.dataset.f="'"+name+"',sans-serif";
    tag.onclick=function(){ document.querySelectorAll('.fb,.ftag').forEach(b=>b.classList.remove('on')); tag.classList.add('on'); S.fontFamily=tag.dataset.f; doInject(); };
    wrap.appendChild(tag);
    document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));
    doInject();
    showToast('폰트 적용: '+name, 'ok');
  };
  reader.readAsDataURL(file);
  input.value='';
};

// ── 탭 전환 ──
document.getElementById('tabs').addEventListener('click', function(e){
  const tab = e.target.closest('.tab');
  if(!tab) return;
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  tab.classList.add('on');
  curSec = tab.dataset.s;
  document.querySelectorAll('[id^="pa-"]').forEach(p=>p.style.display='none');
  document.getElementById('pa-'+curSec).style.display='block';
  const map = {about:'sec2', history:'sec6', services:'sec3', portfolio:'sec4'};
  try{
    const el = pf.contentDocument.getElementById(map[curSec]);
    if(el) pf.contentWindow.scrollTo(0, el.offsetTop - 60);
  }catch(e){}
  if(curSec==='about'){ doInject(); }
  else if(curSec==='history'){ doInjectH(); }
  setTimeout(startEdit, 300);
});

// ── 초기화 ──
window.doReset = async function(){
  if(!confirm('마지막 저장 시점으로 되돌릴까요?')) return;
  if(lastSaved.S){
    Object.assign(S, lastSaved.S);
    Object.assign(T, lastSaved.T||{});
    Object.assign(H, lastSaved.H||{});
    syncControls();
    doInject(); doText(); doInjectH();
    showToast('마지막 저장 시점으로 복원됐어요', 'ok');
  } else {
    try{
      const [a,h] = await Promise.all([
        fetch('/api/admin/design-styles?section=about',{headers:{'x-admin-token':tok}}).then(r=>r.ok?r.json():null),
        fetch('/api/admin/design-styles?section=history',{headers:{'x-admin-token':tok}}).then(r=>r.ok?r.json():null),
      ]);
      if(a){ if(a.styles)Object.assign(S,a.styles); if(a.texts)Object.assign(T,a.texts); }
      if(h && h.styles) Object.assign(H, h.styles);
      syncControls(); doInject(); doText(); doInjectH();
      showToast('저장된 값으로 복원됐어요', 'ok');
    }catch(e){ showToast('복원 실패', 'err'); }
  }
};

// ── 저장 ──
window.doSave = async function(){
  syncFromFrame();
  if(!tok){ showToast('로그인이 필요해요', 'err'); return; }
  try{
    const r1 = await fetch('/api/admin/design-styles',{
      method:'POST',
      headers:{'x-admin-token':tok,'Content-Type':'application/json'},
      body: JSON.stringify({section:'about', styles:S, texts:T})
    });
    const r2 = await fetch('/api/admin/design-styles',{
      method:'POST',
      headers:{'x-admin-token':tok,'Content-Type':'application/json'},
      body: JSON.stringify({section:'history', styles:H, texts:{histTitle:H.histTitle||'', histSub:H.histSub||''}})
    });
    if(r1.ok && r2.ok){
      lastSaved = {S:{...S}, T:{...T}, H:{...H}};
      showToast('💾 저장 완료!', 'ok');
    } else {
      showToast('저장 실패 ('+r1.status+')', 'err');
    }
  }catch(e){ showToast('오류: '+e.message, 'err'); }
};

// ── 배포 ──
window.doDeploy = async function(){
  if(!confirm('배포할까요?')) return;
  await doSave();
  try{
    const r = await fetch('/api/admin/deploy',{method:'POST',headers:{'x-admin-token':tok}});
    if(r.ok) showToast('🚀 배포 시작!', 'ok');
    else showToast('배포 실패', 'err');
  }catch(e){ showToast('오류', 'err'); }
};

// ── 컨트롤 동기화 ──
function syncControls(){
  Object.entries(S).forEach(function([k,v]){
    const h=document.getElementById('h-'+k), c=document.getElementById('c-'+k), sw=document.getElementById('sw-'+k), sl=document.getElementById('s-'+k);
    if(h)h.value=v; if(c)c.value=v; if(sw)sw.style.background=v; if(sl)sl.value=v;
  });
  Object.entries(H).forEach(function([k,v]){
    const h=document.getElementById('h-'+k), c=document.getElementById('c-'+k), sw=document.getElementById('sw-'+k), sl=document.getElementById('s-'+k);
    if(h)h.value=v; if(c)c.value=v; if(sw)sw.style.background=v; if(sl)sl.value=v;
  });
}

// ── 초기 스워치 ──
Object.keys(S).forEach(function(k){
  const sw=document.getElementById('sw-'+k); if(sw) sw.style.background=S[k];
});
Object.keys(H).forEach(function(k){
  const sw=document.getElementById('sw-'+k); if(sw) sw.style.background=H[k];
});

// ── KV에서 불러오기 ──
Promise.all([
  fetch('/api/admin/design-styles?section=about',{headers:{'x-admin-token':tok}}).then(r=>r.ok?r.json():null).catch(()=>null),
  fetch('/api/admin/design-styles?section=history',{headers:{'x-admin-token':tok}}).then(r=>r.ok?r.json():null).catch(()=>null),
]).then(function([aboutData, histData]){
  if(aboutData){ if(aboutData.styles)Object.assign(S,aboutData.styles); if(aboutData.texts)Object.assign(T,aboutData.texts); }
  if(histData && histData.styles) Object.assign(H, histData.styles);
  lastSaved = {S:{...S}, T:{...T}, H:{...H}};
  syncControls();
  try{
    if(pf.contentDocument && pf.contentDocument.getElementById('sec2')){
      doInject(); doText();
    }
  }catch(e){}
});

// ── 토스트 ──
function showToast(msg, type){
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast on '+(type||'');
  clearTimeout(window._tt);
  window._tt = setTimeout(()=>t.className='toast', 2500);
}
</script>
