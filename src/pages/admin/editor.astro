// ── 폰트 업로드 ──
window.oFU=function(input){
  const file=input.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=function(e){
    const name=file.name.replace(/\.[^.]+$/,'').replace(/\s+/g,'_');
    const ext=file.name.split('.').pop().toLowerCase();
    const fmt=ext==='ttf'?'truetype':ext==='otf'?'opentype':ext;
    fonts[name]="@font-face{font-family:'"+name+"';src:url('"+e.target.result+"') format('"+fmt+"');font-display:swap;}";
    S.fontFamily="'"+name+"',sans-serif";
    const wrap=document.getElementById('ftags');
    const tag=document.createElement('div');
    tag.className='ftag on';tag.textContent=name;tag.dataset.f="'"+name+"',sans-serif";
    tag.onclick=function(){
      document.querySelectorAll('.fb,.ftag').forEach(b=>b.classList.remove('on'));
      tag.classList.add('on');S.fontFamily=tag.dataset.f;doInject();
    };
    wrap.appendChild(tag);
    document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));
    doInject();
    showToast('폰트 적용: '+name,'ok');
  };
  reader.readAsDataURL(file);
  input.value='';
};

// ── 탭 ──
document.getElementById('tabs').addEventListener('click',function(e){
  const tab=e.target.closest('.tab');if(!tab)return;
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  tab.classList.add('on');
  currentSec=tab.dataset.s;
  document.querySelectorAll('[id^="pa-"]').forEach(p=>p.style.display='none');
  document.getElementById('pa-'+currentSec).style.display='block';
  const map={about:'sec2',history:'sec6',services:'sec3',portfolio:'sec4'};
  try{
    const el=pf.contentDocument.getElementById(map[currentSec]);
    if(el)pf.contentWindow.scrollTo(0,el.offsetTop-60);
  }catch(e){}
  if(currentSec==='history') doInjectH();
  // 탭 전환 시 편집모드 재적용
  if(editOn){
    stopEdit();
    setTimeout(startEdit, 300);
  }
});

// ── 미리보기 zoom 조정 ──
function resizePreview(){
  try{
    const wrap=document.querySelector('.pv-body');
    const iframe=document.getElementById('pf');
    if(!wrap||!iframe)return;
    const W=wrap.offsetWidth;
    const H=wrap.offsetHeight;
    const scale=W/1440;
    iframe.style.width='1440px';
    iframe.style.height=Math.round(H/scale)+'px';
    iframe.style.transform='scale('+scale+')';
    iframe.style.transformOrigin='0 0';
  }catch(e){}
}
window.addEventListener('resize',resizePreview);
setTimeout(resizePreview,500);

// ── 초기화 ──
// 마지막 저장값 (초기화용)
let lastSaved = {S:null, T:null, H:null};

window.doReset=async function(){
  if(!confirm('마지막 저장 시점으로 되돌릴까요?'))return;
  // 마지막 저장값이 있으면 복원, 없으면 KV에서 다시 불러오기
  if(lastSaved.S){
    Object.assign(S, lastSaved.S);
    Object.assign(T, lastSaved.T);
    Object.assign(H, lastSaved.H||{});
    syncControls();syncHistControls();
    doInject();doText();
    if(currentSec==='history') doInjectH();
    showToast('마지막 저장 시점으로 복원됐어요','ok');
  } else {
    // KV에서 다시 불러오기
    try{
      const [a,h]=await Promise.all([
        fetch('/api/admin/design-styles?section=about',{headers:{'x-admin-token':tok}}).then(r=>r.ok?r.json():null),
        fetch('/api/admin/design-styles?section=history',{headers:{'x-admin-token':tok}}).then(r=>r.ok?r.json():null),
      ]);
      if(a){if(a.styles)Object.assign(S,a.styles);if(a.texts)Object.assign(T,a.texts);}
      if(h&&h.styles)Object.assign(H,h.styles);
      syncControls();syncHistControls();
      doInject();doText();
      if(currentSec==='history') doInjectH();
      showToast('저장된 값으로 복원됐어요','ok');
    }catch(e){showToast('복원 실패','err');}
  }
};

// ── 저장 ──
window.doSave=async function(){
  syncFromFrame();
  // 토큰 확인
  if(!tok){
    showToast('로그인이 필요해요','err');
    setTimeout(()=>location.href='/admin',1500);
    return;
  }
  try{
    const r1=await fetch('/api/admin/design-styles',{
      method:'POST',
      headers:{'x-admin-token':tok,'Content-Type':'application/json'},
      body:JSON.stringify({section:'about',styles:S,texts:T})
    });
    const r2=await fetch('/api/admin/design-styles',{
      method:'POST',
      headers:{'x-admin-token':tok,'Content-Type':'application/json'},
      body:JSON.stringify({section:'history',styles:H})
    });
    if(r1.status===401||r2.status===401){
      showToast('인증 실패 - 다시 로그인해주세요','err');
      setTimeout(()=>location.href='/admin',1500);
      return;
    }
    if(r1.ok&&r2.ok){
      lastSaved={S:{...S},T:{...T},H:{...H}};
      showToast('💾 저장 완료!','ok');
    } else {
      const e1=await r1.json().catch(()=>({}));
      showToast('저장 실패: '+(e1.error||r1.status),'err');
    }
  }catch(e){
    showToast('네트워크 오류: '+e.message,'err');
  }
};

// ── 배포 ──
window.doDeploy=async function(){
  if(!confirm('배포할까요?'))return;
  await doSave();
  try{
    const r=await fetch('/api/admin/deploy',{method:'POST',headers:{'x-admin-token':tok}});
    if(r.ok)showToast('🚀 배포 시작!','ok');
    else showToast('배포 실패','err');
  }catch(e){showToast('오류','err');}
};

// ── 컨트롤 동기화 ──
function syncControls(){
  Object.entries(S).forEach(function([k,v]){
    const h=document.getElementById('h-'+k),c=document.getElementById('c-'+k),sw=document.getElementById('sw-'+k),sl=document.getElementById('s-'+k),vl=document.getElementById('v-'+k);
    if(h)h.value=v;if(c)c.value=v;if(sw)sw.style.background=v;if(sl)sl.value=v;
  });
  ['leftTitle','leftBody','rightTitle','rightBody'].forEach(function(k){
    const el=document.getElementById('t-'+k);if(el&&T[k])el.value=typeof T[k]==='string'?T[k].replace(/<br>/g,'\n').replace(/<[^>]+>/g,''):'';
  });
}

// 초기 스워치 적용
['leftBg1','leftBg2','rightBg1','rightBg2','titleColor','bodyColor','accentColor'].forEach(function(k){
  const sw=document.getElementById('sw-'+k);if(sw)sw.style.background=S[k];
});
['hBg1','hBg2','hTitleColor','hSubColor','hYearColor','hDescColor','hLineColor','hDotColor'].forEach(function(k){
  const sw=document.getElementById('sw-'+k);if(sw)sw.style.background=H[k];
});

function syncHistControls(){
  Object.entries(H).forEach(function([k,v]){
    const h=document.getElementById('h-'+k),c=document.getElementById('c-'+k),sw=document.getElementById('sw-'+k),sl=document.getElementById('s-'+k),vl=document.getElementById('v-'+k);
    if(h)h.value=v;if(c)c.value=v;if(sw)sw.style.background=v;if(sl)sl.value=v;
  });
}

// ── 저장값 불러오기 ──
Promise.all([
  fetch('/api/admin/design-styles?section=about',{headers:{'x-admin-token':tok}}).then(r=>r.ok?r.json():null),
  fetch('/api/admin/design-styles?section=history',{headers:{'x-admin-token':tok}}).then(r=>r.ok?r.json():null),
]).then(function([aboutData,histData]){
  if(aboutData){
    if(aboutData.styles)Object.assign(S,aboutData.styles);
    if(aboutData.texts)Object.assign(T,aboutData.texts);
    syncControls();
  }
  if(histData&&histData.styles){
    Object.assign(H,histData.styles);
    syncHistControls();
  }
  // 불러온 값을 lastSaved로 기록
  lastSaved={S:{...S},T:{...T},H:{...H}};
  try{
    if(pf.contentDocument&&pf.contentDocument.getElementById('sec2')){
      doInject();doText();
    }
  }catch(e){}
}).catch(function(){});

// ── 토스트 ──
function showToast(msg,type){
  const t=document.getElementById('toast');
  t.textContent=msg;t.className='toast on '+(type||'');
  clearTimeout(window._tt);window._tt=setTimeout(()=>t.className='toast',2500);
}
</script>
</body>
</html>
