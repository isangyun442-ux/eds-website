---
// src/pages/admin/index.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EDS 관리자 로그인</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Pretendard','Noto Sans KR',sans-serif;background:#0d1a3a;min-height:100vh;display:flex;align-items:center;justify-content:center;}
    .box{background:#fff;border-radius:16px;padding:48px 40px;width:100%;max-width:400px;box-shadow:0 20px 60px rgba(0,0,0,0.3);}
    .logo{text-align:center;margin-bottom:32px;}
    .logo img{height:32px;}
    .logo p{font-size:13px;color:#888;margin-top:8px;}
    h1{font-size:22px;font-weight:800;color:#0d1a3a;text-align:center;margin-bottom:28px;}
    label{display:block;font-size:12px;font-weight:700;color:#666;margin-bottom:6px;letter-spacing:0.05em;}
    input{width:100%;padding:12px 16px;border:1.5px solid #e0e5f0;border-radius:8px;font-size:15px;outline:none;transition:border 0.2s;font-family:inherit;}
    input:focus{border-color:#1a2f8a;}
    .field{margin-bottom:20px;}
    .btn{width:100%;padding:14px;background:#1a2f8a;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit;transition:background 0.2s;}
    .btn:hover{background:#0d1a3a;}
    .err{background:#fff0f0;color:#d00;font-size:13px;padding:10px 14px;border-radius:8px;margin-bottom:16px;display:none;text-align:center;}
    .err.on{display:block;}
  </style>
</head>
<body>
  <div class="box">
    <div class="logo">
      <img src="/images/logo.png" alt="EDS">
      <p>관리자 페이지</p>
    </div>
    <h1>로그인</h1>
    <div class="err" id="err">비밀번호가 올바르지 않습니다.</div>
    <div class="field">
      <label>비밀번호</label>
      <input type="password" id="pw" placeholder="비밀번호 입력" onkeydown="if(event.key==='Enter')login()">
    </div>
    <button class="btn" onclick="login()">로그인</button>
  </div>
  <script>
    if(sessionStorage.getItem('eds-admin-token')){
      location.href='/admin/dashboard';
    }
    window.login = function(){
      const pw=document.getElementById('pw').value.trim();
      if(!pw){ document.getElementById('err').classList.add('on'); return; }
      // GET으로 인증 확인 (프로젝트 생성 없이)
      fetch('/api/admin/auth',{
        headers:{'x-admin-token':pw}
      }).then(r=>{
        if(r.ok){
          sessionStorage.setItem('eds-admin-token', pw);
          location.href='/admin/dashboard';
        } else {
          document.getElementById('err').classList.add('on');
        }
      }).catch(()=>{
        document.getElementById('err').classList.add('on');
      });
    }
  </script>
</body>
</html>
